}
@if (!templateAktivitasList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(templateAktivitasList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { TemplateAktivitas: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(templateAktivitasList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(templateAktivitasList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(templateAktivitasList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(templateAktivitasList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "IdTemplateProses": @Html.Raw(templateAktivitasList.IdTemplateProses.ToClientList(templateAktivitasList)),
            "UrutanAktivitas": @Html.Raw(templateAktivitasList.UrutanAktivitas.ToClientList(templateAktivitasList)),
            "NamaAktivitas": @Html.Raw(templateAktivitasList.NamaAktivitas.ToClientList(templateAktivitasList)),
            "IdPIC": @Html.Raw(templateAktivitasList.IdPIC.ToClientList(templateAktivitasList)),
            "Keterangan": @Html.Raw(templateAktivitasList.Keterangan.ToClientList(templateAktivitasList)),
            "DibuatOleh": @Html.Raw(templateAktivitasList.DibuatOleh.ToClientList(templateAktivitasList)),
            "TanggalDibuat": @Html.Raw(templateAktivitasList.TanggalDibuat.ToClientList(templateAktivitasList)),
            "DiperbaruiOleh": @Html.Raw(templateAktivitasList.DiperbaruiOleh.ToClientList(templateAktivitasList)),
            "TanggalDiperbarui": @Html.Raw(templateAktivitasList.TanggalDiperbarui.ToClientList(templateAktivitasList)),
            "TipeAktivitas": @Html.Raw(templateAktivitasList.TipeAktivitas.ToClientList(templateAktivitasList)),
            "_URL": @Html.Raw(templateAktivitasList._URL.ToClientList(templateAktivitasList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
