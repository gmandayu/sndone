<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("FormInputProofOfVisit");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    /* === Set otomatis Tanggal (yyyy/mm/dd hh:mm:ss) === */
    function setTanggal() {
      const today = new Date();
      const formattedDate =
        today.getFullYear() + "/" +
        String(today.getMonth() + 1).padStart(2, "0") + "/" +
        String(today.getDate()).padStart(2, "0") + " " +
        String(today.getHours()).padStart(2, "0") + ":" +
        String(today.getMinutes()).padStart(2, "0") + ":" +
        String(today.getSeconds()).padStart(2, "0");
      const el = document.getElementById("x_Tanggal");
      if (el) el.value = formattedDate;
    }
    window.onload = function () { setTanggal(); };
    const parent_url = ew.PATH_BASE;

    /* ==== Ambil NoReferensi dari URL / form ==== */
    function resolveNoRef() {
      const qs = new URLSearchParams(location.search);
      let v = (qs.getAll("NoReferensi")[0] || qs.getAll("x_NoReferensi[]")[0] || "").trim();
      if (!v) v = (qs.get("x_NoReferensi") || "").trim();
      if (!v) v = ($('input[name="x_NoReferensi[]"]').val() || $('input[name="x_NoReferensi"]').val() || "").trim();
      return v;
    }
    const NoReferensi = resolveNoRef();

    /* ==== Guard akses: OH (Rule 10) bebas; lainnya harus MOD (API GetMODForPOV) ==== */
    (function () {
      const role = parseInt('@CurrentUserInfo("Rule")') || 0; // jaga agar null tidak auto-lolos
      if (role === 0 || role === 10) return;
      const noRef = NoReferensi;
      if (!noRef) return; // tanpa NoRef, biarkan default

      // KUNCI UI jika ditolak + AKTIFKAN CANCEL + ALERT container
      const denyAccess = (msg) => {
        const $form = $("#fFormInputProofOfVisitadd");
        const backUrl = `${parent_url}FormInputProofOfVisitList?cmd=search&x_NoReferensi%5B%5D=${encodeURIComponent(noRef)}`;

        // Kandidat tombol cancel (termasuk custom)
        const $cancelCandidates = $(
          '#btn-cancel-custom, a[data-ew-action="cancel"], button[name="btn-cancel"], a.btn-secondary, a.btn-default'
        );
        if ($form.length) {
          // 1) Disable semua kontrol KECUALI kandidat cancel
          $form
            .find("input,select,textarea,button")
            .not($cancelCandidates) // <-- jangan matikan tombol cancel
            .prop("disabled", true);

          // 2) Sembunyikan tombol aksi utama (save/submit)
          $form.find('button[name="btn-action"], button[name="btn-submit"], .ew-btn[data-ew-action]').hide();

          // 3) AKTIFKAN tombol Cancel & pasang handler ke List
          const enableCancel = ($el) => {
            if (!$el || !$el.length) return;

            // Jika anchor set href; jika button pasang click handler
            if ($el.is("a")) {
              $el.attr("href", backUrl);
            } else {
              $el.off("click").on("click", function (e) {
                e.preventDefault();
                window.location.href = backUrl;
              });
            }
            $el
              .prop("disabled", false)
              .removeAttr("disabled")
              .removeClass("disabled")
              .css("pointer-events", "auto")
              .show();
          };

          // Aktifkan semua kandidat cancel
          $cancelCandidates.each(function () { enableCancel($(this)); });

          // 4) Jika tak ada tombol cancel sama sekali buat fallback
          if (!$cancelCandidates.length && !$("#btn-cancel-fallback").length) {
            const $fallback = $(`
              <a class="btn btn-secondary ms-2" id="btn-cancel-fallback" href="${backUrl}">
                <i class="fa-solid fa-xmark"></i> Cancel
              </a>
            `);
            const $btnWrap = $form.find('button[name="btn-submit"]').first().parent();
            ($btnWrap.length ? $btnWrap : $(".ew-toolbar").first()).append($fallback);
          }
        }

        // 5) Tampilkan ALERT container (seperti SetUserMOD)
        const $container = $(".content .container-fluid").first();
        const $alert = $(`
          <div class="alert alert-warning d-flex align-items-start mt-3" role="alert" id="no-access-alert">
            <i class="fa-solid fa-triangle-exclamation me-2 mt-1"></i>
            <div>
              <div class="fw-bold">Tidak ada akses untuk mengisi Form Input Proof of Visit.</div>
              <div class="small">
                ${msg || "Akses dibatasi: hanya User MOD / OH / Admin yang dapat menambah data."}
                <br>Solusi: <em>Ganti Akun</em> atau <em>minta diberikan akses oleh OH</em>.
              </div>
              <div class="mt-2">
                <a href="${parent_url}logout" class="btn btn-outline-secondary btn-sm me-2">
                  <i class="fa-solid fa-right-from-bracket"></i> Ganti Akun
                </a>
                <a href="${backUrl}" class="btn btn-primary btn-sm">
                  <i class="fa-solid fa-list"></i> Kembali ke List
                </a>
              </div>
            </div>
          </div>
        `);
        if ($container.length) $container.prepend($alert); else $("body").prepend($alert);

        // 6) Pastikan tombol Cancel custom tetap aktif meski ada script lain yang disable ulang
        setTimeout(() => {
          $("#btn-cancel-custom").prop("disabled", false).removeAttr("disabled").removeClass("disabled");
        }, 0);

        // 7) Scroll ke atas agar alert terlihat
        window.scrollTo({ top: 0, behavior: "smooth" });
      };

      // Panggil API checker MOD
      $.get(ew.PATH_BASE + "api/LookUpList/GetMODForPOV", { noRef })
        .done(function (res) {
          if (!res || res.success !== true || res.isCurrentUserMOD !== true) {
            denyAccess("Anda bukan User MOD untuk plant & tanggal ini. Minta akses ke OH atau gunakan akun yang tepat.");
          }
        })
        .fail(function () {
          denyAccess("Gagal memverifikasi MOD. Hubungi Administrator / OH.");
        });
    })();
});
</script>
