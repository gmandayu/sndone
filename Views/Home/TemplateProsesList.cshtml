}
</div>
}
@if (!templateProsesList.IsExport() || Config.ExportMasterRecord && templateProsesList.IsExport("print")) {
if (!Empty(templateProsesList.DbMasterFilter) && templateProsesList.CurrentMasterTable == "MasterTemplate") {
    if (templateProsesList.MasterRecordExists) {
        @await Html.PartialAsync("MasterTemplateMaster.cshtml")
    }
