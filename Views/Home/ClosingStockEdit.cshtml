@if (IsJsonResponse()) {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-bs-dismiss="modal">@Html.Raw(Language.Phrase("CancelBtn"))</button>
} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fClosingStockedit" data-href="@AppPath(closingStockEdit.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
}
    </div><!-- /buttons offset -->
@Html.Raw(closingStockEdit.IsModal ? "</template>" : "</div>")<!-- /buttons .row -->
</form>
</main>
@closingStockEdit.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("ClosingStock");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    $('#r_PlantForLookup').hide();
    $('#r_NomorClosingStock').hide();
    $('#r_LookupJenisPlant').hide();
    if ($('#x_TipeProdukSTS') != '') {
        $('#r_TipeProdukSTS').show();
    } else {
        $('#r_TipeProdukSTS').hide();
    }
});
</script>
