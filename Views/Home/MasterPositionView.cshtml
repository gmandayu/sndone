@{
    // View
    View = this;

    // Check action result
    if (masterPositionView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterPositionView.UseLayout ? "_Layout" : "";
}
@if (!masterPositionView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @masterPositionView.ExportOptions.RenderBody()
    @masterPositionView.OtherOptions.RenderBody()
</div>
}
@masterPositionView.ShowPageHeader()
@masterPositionView.ShowMessages()
<main class="view">
<form name="fMasterPositionview" id="fMasterPositionview" class="ew-form ew-view-form overlay-wrapper" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (!masterPositionView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterPositionView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterPosition: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fMasterPositionview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterPositionview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="modal" value="@ConvertToInt(masterPositionView.IsModal)">
<table class="@(masterPositionView.TableClass)">
@if (masterPositionView.IdPosition.Visible) { // masterPositionView.IdPosition.Visible (begin)
    <tr id="r_IdPosition" @Html.Raw(masterPositionView.IdPosition.RowAttributes)>
        <td class="@(masterPositionView.TableLeftColumnClass)"><span id="elh_MasterPosition_IdPosition">@Html.Raw(masterPositionView.IdPosition.Caption)</span></td>
        <td data-name="IdPosition" @Html.Raw(masterPositionView.IdPosition.CellAttributes)>
<span id="el_MasterPosition_IdPosition">
<span @Html.Raw(masterPositionView.IdPosition.ViewAttributes)>
@Html.Raw(masterPositionView.IdPosition.GetViewValue())</span>
</span></td>
    </tr>
} @* masterPositionView.IdPosition.Visible (end) *@
@if (masterPositionView.NamaPosition.Visible) { // masterPositionView.NamaPosition.Visible (begin)
    <tr id="r_NamaPosition" @Html.Raw(masterPositionView.NamaPosition.RowAttributes)>
        <td class="@(masterPositionView.TableLeftColumnClass)"><span id="elh_MasterPosition_NamaPosition">@Html.Raw(masterPositionView.NamaPosition.Caption)</span></td>
        <td data-name="NamaPosition" @Html.Raw(masterPositionView.NamaPosition.CellAttributes)>
<span id="el_MasterPosition_NamaPosition">
<span @Html.Raw(masterPositionView.NamaPosition.ViewAttributes)>
@Html.Raw(masterPositionView.NamaPosition.GetViewValue())</span>
</span></td>
    </tr>
} @* masterPositionView.NamaPosition.Visible (end) *@
@if (masterPositionView.Location.Visible) { // masterPositionView.Location.Visible (begin)
    <tr id="r_Location" @Html.Raw(masterPositionView.Location.RowAttributes)>
        <td class="@(masterPositionView.TableLeftColumnClass)"><span id="elh_MasterPosition_Location">@Html.Raw(masterPositionView.Location.Caption)</span></td>
        <td data-name="Location" @Html.Raw(masterPositionView.Location.CellAttributes)>
<span id="el_MasterPosition_Location">
<span @Html.Raw(masterPositionView.Location.ViewAttributes)>
@Html.Raw(masterPositionView.Location.GetViewValue())</span>
</span></td>
    </tr>
} @* masterPositionView.Location.Visible (end) *@
@if (masterPositionView._UserLevel.Visible) { // masterPositionView._UserLevel.Visible (begin)
    <tr id="r__UserLevel" @Html.Raw(masterPositionView._UserLevel.RowAttributes)>
        <td class="@(masterPositionView.TableLeftColumnClass)"><span id="elh_MasterPosition__UserLevel">@Html.Raw(masterPositionView._UserLevel.Caption)</span></td>
        <td data-name="_UserLevel" @Html.Raw(masterPositionView._UserLevel.CellAttributes)>
<span id="el_MasterPosition__UserLevel">
<span @Html.Raw(masterPositionView._UserLevel.ViewAttributes)>
@Html.Raw(masterPositionView._UserLevel.GetViewValue())</span>
</span></td>
    </tr>
} @* masterPositionView._UserLevel.Visible (end) *@
@if (masterPositionView.Role.Visible) { // masterPositionView.Role.Visible (begin)
    <tr id="r_Role" @Html.Raw(masterPositionView.Role.RowAttributes)>
        <td class="@(masterPositionView.TableLeftColumnClass)"><span id="elh_MasterPosition_Role">@Html.Raw(masterPositionView.Role.Caption)</span></td>
        <td data-name="Role" @Html.Raw(masterPositionView.Role.CellAttributes)>
<span id="el_MasterPosition_Role">
<span @Html.Raw(masterPositionView.Role.ViewAttributes)>
@Html.Raw(masterPositionView.Role.GetViewValue())</span>
</span></td>
    </tr>
} @* masterPositionView.Role.Visible (end) *@
</table>
@{ masterPositionView.CloseRecordset(); }
</form>
</main>
@masterPositionView.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!masterPositionView.IsExport()) {
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
}
