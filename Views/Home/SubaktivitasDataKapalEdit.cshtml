<script>
var currentTable = @Html.Raw(ConvertToJson(subaktivitasDataKapalEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { SubaktivitasDataKapal: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fSubaktivitasDataKapaledit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
