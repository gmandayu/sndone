    @if (generalList.ContainsKey("NamaKapal") && !string.IsNullOrEmpty(generalList["NamaKapal"].ToString()))
    {
        <div class="row py-3 border-bottom">
            <div class="col-2 fw-bold d-flex align-items-center">
                Nama Kapal
            </div>
            <div class="col-10 d-flex gap-3">
                @(generalList["NamaKapal"])
            </div>
        </div>
    }
    else if (generalList.ContainsKey("NomorPolisi") && !string.IsNullOrEmpty(generalList["NomorPolisi"].ToString()))
    {
        <div class="row py-3 border-bottom">
            <div class="col-2 fw-bold d-flex align-items-center">
                Nomor Polisi
            </div>
            <div class="col-10 d-flex gap-3">
                @(generalList["NomorPolisi"])
            </div>
        </div>
    }

    @if (IdTemplateAktivitas == "13" || IdTemplateAktivitas == "89" || IdTemplateAktivitas == "140" ||
        IdTemplateAktivitas == "170" || IdTemplateAktivitas == "199" || IdTemplateAktivitas == "236" ||
        IdTemplateAktivitas == "273" || IdTemplateAktivitas == "320" || IdTemplateAktivitas == "325" ||
        IdTemplateAktivitas == "348" || IdTemplateAktivitas == "356" || IdTemplateAktivitas == "378" ||
        IdTemplateAktivitas == "361" || IdTemplateAktivitas == "394" || IdTemplateAktivitas == "426" ||
        IdTemplateAktivitas == "476")
    {
        <div class="row py-3 border-bottom">
            <div class="col-2 fw-bold d-flex align-items-center">
                Produk
            </div>
            <div class="col-10 d-flex gap-3">
                @(produkView)
            </div>
        </div>
    }

    @if (IdTemplateAktivitas == "320" || IdTemplateAktivitas == "356" || IdTemplateAktivitas == "479")
    {
        <div class="row py-3 border-bottom">
            <div class="col-2 fw-bold d-flex align-items-center">
                ETC
            </div>
            <div class="col-10 d-flex gap-3">
                @(ETCval)
            </div>
        </div>

        @for (int i = 0; i < etaList.Count; i++)
        {
            var idx = i + 1;
            var row = etaList[i];

            var etaStatis = row.ContainsKey("ETA") ? row["ETA"]?.ToString() : "";
            var etaDinamis = row.ContainsKey("ETA_Dinamis") ? row["ETA_Dinamis"]?.ToString() : "";
            var tujuanPipa = row.ContainsKey("Tujuan") ? row["Tujuan"]?.ToString() : "";

            var etaShow = !string.IsNullOrWhiteSpace(etaDinamis) ? etaDinamis : etaStatis;

            <div class="row py-3 border-bottom align-items-center">
                <div class="col-2 fw-bold">
                    <p class="caption-tujuan">
                        ETA @idx
                    </p>
                    <p class="caption-tujuan">
                        @tujuanPipa
                    </p>
                </div>
                <div class="col-10 d-flex gap-3">
                    @(etaShow)
                </div>
            </div>
        }
