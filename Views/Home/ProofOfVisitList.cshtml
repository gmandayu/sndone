<script>
var currentTable = @Html.Raw(ConvertToJson(proofOfVisitList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { ProofOfVisit: currentTable } });
var currentForm;
var fProofOfVisitsrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fProofOfVisitsrch")
        .setPageId("list")
@if (proofOfVisitList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([

            ["TanggalDibuat", [], fields.TanggalDibuat.isInvalid],
            ["y_TanggalDibuat", [ew.Validators.between], false]
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LinkRedirect": @Html.Raw(proofOfVisitList.LinkRedirect.ToClientList(proofOfVisitList)),
            "Plant": @Html.Raw(proofOfVisitList.Plant.ToClientList(proofOfVisitList)),
            "TotalPengisian": @Html.Raw(proofOfVisitList.TotalPengisian.ToClientList(proofOfVisitList)),
            "Catatan": @Html.Raw(proofOfVisitList.Catatan.ToClientList(proofOfVisitList)),
            "DibuatOleh": @Html.Raw(proofOfVisitList.DibuatOleh.ToClientList(proofOfVisitList)),
            "DiperbaruiOleh": @Html.Raw(proofOfVisitList.DiperbaruiOleh.ToClientList(proofOfVisitList)),
            "TanggalDiperbarui": @Html.Raw(proofOfVisitList.TanggalDiperbarui.ToClientList(proofOfVisitList)),
        })

        // Filters
        .setFilterList(@Html.Raw(proofOfVisitList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
