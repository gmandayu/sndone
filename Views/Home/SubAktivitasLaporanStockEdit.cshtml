        <label id="elh_SubAktivitasLaporanStock_WorkingLoss" for="x_WorkingLoss" class="@(subAktivitasLaporanStockEdit.LeftColumnClass)">@Html.Raw(subAktivitasLaporanStockEdit.WorkingLoss.Caption)@Html.Raw(subAktivitasLaporanStockEdit.WorkingLoss.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(subAktivitasLaporanStockEdit.RightColumnClass)"><div @Html.Raw(subAktivitasLaporanStockEdit.WorkingLoss.CellAttributes)>
<span id="el_SubAktivitasLaporanStock_WorkingLoss">
<span @Html.Raw(subAktivitasLaporanStockEdit.WorkingLoss.ViewAttributes)>
