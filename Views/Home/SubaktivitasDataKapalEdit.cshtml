    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-bs-dismiss="modal">@Html.Raw(Language.Phrase("CancelBtn"))</button>
} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fSubaktivitasDataKapaledit" data-href="@AppPath(subaktivitasDataKapalEdit.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
