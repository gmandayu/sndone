@if (closingStockEdit.Produk.Visible) { // closingStockEdit.Produk.Visible (begin)
    <div id="r_Produk" @Html.Raw(closingStockEdit.Produk.RowAttributes)>
        <label id="elh_ClosingStock_Produk" for="x_Produk" class="@(closingStockEdit.LeftColumnClass)">@Html.Raw(closingStockEdit.Produk.Caption)@Html.Raw(closingStockEdit.Produk.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(closingStockEdit.RightColumnClass)"><div @Html.Raw(closingStockEdit.Produk.CellAttributes)>
<span id="el_ClosingStock_Produk">
    <select
        id="x_Produk"
        name="x_Produk"
        class="form-select ew-select@(closingStockEdit.Produk.IsInvalidClass)"
        data-select2-id="fClosingStockedit_x_Produk"
        data-table="ClosingStock"
        data-field="x_Produk"
        data-value-separator="@(closingStockEdit.Produk.DisplayValueSeparatorAttribute)"
        data-placeholder="@(HtmlEncode(closingStockEdit.Produk.PlaceHolder))"
        @Html.Raw(closingStockEdit.Produk.EditAttributes)>
        @(closingStockEdit.Produk.SelectOptionListHtml("x_Produk"))
    </select>
    @Html.Raw(closingStockEdit.Produk.GetCustomMessage)
    <div class="invalid-feedback">@Html.Raw(closingStockEdit.Produk.GetErrorMessage())</div>
<script>
loadjs.ready("fClosingStockedit", function() {
    var options = { name: "x_Produk", selectId: "fClosingStockedit_x_Produk" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fClosingStockedit.lists.Produk?.lookupOptions.length) {
        options.data = { id: "x_Produk", form: "fClosingStockedit" };
    } else {
        options.ajax = { id: "x_Produk", form: "fClosingStockedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.ClosingStock.fields.Produk.selectOptions);
    ew.createSelect(options);
});
</script>
</span>
</div></div>
    </div>
} @* closingStockEdit.Produk.Visible (end) *@
@if (closingStockEdit.Catatan.Visible) { // closingStockEdit.Catatan.Visible (begin)
