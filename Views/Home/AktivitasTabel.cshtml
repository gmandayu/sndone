            Proses
        </div>
        <div class="col-10 d-flex gap-3">
            @(NamaProses)
        </div>
    </div>

    <div class="row py-3 border-bottom">
        <div class="col-2 fw-bold d-flex align-items-center">
            Aktivitas
        </div>
        <div class="col-10 d-flex gap-3">
            @(NamaAktivitas)
        </div>
