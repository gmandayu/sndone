<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    const NoReferensi = "@HttpContext.Request.Query["NoReferensi"]";
    if (!NoReferensi) {
        ew.alert('URL Tidak Valid');
        setTimeout(function() {
            history.back();
        }, 1000);
    }
    let filesArr = [];
    $("#fileName").on("click", function () {
        $("#fileInput").trigger("click");
    });
    $("#fileInput").on("change", function(e) {
        let newFiles = Array.from(e.target.files);
        filesArr = filesArr.concat(newFiles);
        $(this).val('');
        renderTable();
    });
    function renderTable(){
        let $table = $("#fileTable");
        let $tbody = $table.find("tbody");
        $tbody.empty();
        if(filesArr.length === 0){
            $('#row-table').hide();
            return;
        }
        $('#row-table').show();
        filesArr.forEach((file, index) => {
            let sizeKB = (file.size / 1024).toFixed(2);
            let row = `
                <tr>
                    <td>${index+1}</td>
                    <td>${file.name}</td>
                    <td>
                        <button class="btn text-danger btn-delete" type="button" data-index="${index}"><i class="fa-solid fa-times"></i></button>
                    </td>
                </tr>
            `;
            $tbody.append(row);
        });
    }
    $(document).on("click", ".btn-delete", function(){
        let index = $(this).data("index");
        filesArr.splice(index, 1);
        renderTable();
    });
    $(document).on("click", "#btn-cancel-custom", function(){
        window.location.href = `${parent_url}FormInputGoodHouseKeepingList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
    });
    $("#btn-submit-custom").off("click.__ghk").on("click.__ghk", function () {
        // ---- Validasi wajib ----
        if (filesArr.length === 0) {
            ew.alert("File tidak boleh kosong!");
            return;
        }
        const $noRefEl = $("#NoReferensi-custom");
        const $tglEl   = $("#x_tgltiba");
        const $lokEl   = $("#x_Lokasi");
        if (($noRefEl.val() || "").trim() === "") {
            ew.alert("Nomor Good House Keeping tidak boleh kosong!");
            return;
        }
        if (($tglEl.val() || "").trim() === "") {
            ew.alert("Tanggal tidak boleh kosong!");
            return;
        }
        if (($lokEl.val() || "").trim() === "") {
            ew.alert("Lokasi tidak boleh kosong!");
            return;
        }

        // ---- Helpers ----
        const noRef = ($noRefEl.val() || "").trim();

        // Normalisasi ke "YYYY-MM-DD"
        const toIsoDateOnly = (val) => {
            if (!val) return "";
            let d = String(val).trim();
            d = d.split("T")[0].split(" ")[0]; // buang waktu
            d = d.replace(/[./]/g, "-").replace(/\//g, "-"); // samakan pemisah

            // yyyy-mm-dd
            let m = d.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
            if (m) {
                const mm = m[2].padStart(2, "0");
                const dd = m[3].padStart(2, "0");
                return `${m[1]}-${mm}-${dd}`;
            }
            // dd-mm-yyyy
            m = d.match(/^(\d{1,2})-(\d{1,2})-(\d{4})$/);
            if (m) {
                const dd = m[1].padStart(2, "0");
                const mm = m[2].padStart(2, "0");
                return `${m[3]}-${mm}-${dd}`;
            }
            return d; // fallback
        };
        const tglTibaIso = toIsoDateOnly(($tglEl.val() || "").trim());

        // ---- Cek ke API GoodHouseKeeping ----
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/goodhousekeeping/get_tanggal_dibuat",
            method: "GET",
            data: { noReferensi: noRef },
            success: function (res) {
                hideLoading();
                console.log("[GHK modal check]", {
                    noRef,
                    tglTibaIso,
                    api: res
                });
                if (!res || !res.success || !res.found) {
                    ew.alert("Referensi GoodHouseKeeping tidak ditemukan.").then(() => {
                        doUpload(); 
                    });
                    return;
                }
                const tglDibuatIso = (res.tanggalDibuatIso || "").trim(); 
                if (tglTibaIso !== tglDibuatIso) {
                    ew.alert({
                        html:
                            "<div>Tanggal yang diinput berbeda dengan Tanggal Dibuat di GoodHouseKeeping.</div>",
                        showCancelButton: true,
                        confirmButtonText: "Lanjutkan",
                        cancelButtonText: "Periksa Lagi"
                    }).then((result) => {
                        if (result.isConfirmed) {
                            doUpload();
                        } else {
                            $tglEl.focus();
                        }
                    });
                } else {
                    doUpload();
                }
            },
            error: function (xhr) {
                hideLoading();
                console.error("[GHK modal check] API error", xhr);
                ew.alert("Gagal memanggil API. Melanjutkan simpan.").then(() => {
                    doUpload();
                });
            }
        });
    });

    // Fungsi unggah file (formData) setelah semua pengecekan selesai
    function doUpload() {
        showLoading();
        let formData = new FormData();
        formData.append("NoReferensi", $('#NoReferensi-custom').val());
        formData.append("Tanggal", $('#x_tgltiba').val());
        formData.append("Lokasi", $('#x_Lokasi').val());
        formData.append("Keterangan", $('#x_Keterangan').val());
        formData.append("Menu", "GHK");
        filesArr.forEach(file => formData.append("files", file)); 
        $.ajax({
            url: parent_url + "api/LookUpList/UploadDocumentGHKandPOV",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = 
                            `${parent_url}FormInputGoodHouseKeepingList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Upload gagal: " + xhr.responseText);
            }
        });
    }
});
</script>
