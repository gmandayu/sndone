@Html.Raw(templateProsesEdit.IdTemplate.Lookup.GetParamTag(templateProsesEdit, "p_x_IdTemplate"))
<script>
loadjs.ready("fTemplateProsesedit", function() {
    var options = { name: "x_IdTemplate", selectId: "fTemplateProsesedit_x_IdTemplate" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fTemplateProsesedit.lists.IdTemplate?.lookupOptions.length) {
        options.data = { id: "x_IdTemplate", form: "fTemplateProsesedit" };
