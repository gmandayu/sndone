@{
    // View
    View = this;

    // Check action result
    if (masterDokumenList.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterDokumenList.UseLayout ? "_Layout" : "";
}
@if (!masterDokumenList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterDokumenList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterDokumen: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(masterDokumenList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(masterDokumenList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(masterDokumenList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(masterDokumenList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "IdDokumen": @Html.Raw(masterDokumenList.IdDokumen.ToClientList(masterDokumenList)),
            "NamaDokumen": @Html.Raw(masterDokumenList.NamaDokumen.ToClientList(masterDokumenList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (!masterDokumenList.IsExport()) {
<div class="btn-toolbar ew-toolbar">
@if (masterDokumenList.TotalRecords > 0 && masterDokumenList.ExportOptions.Visible) {
    masterDokumenList.ExportOptions.Render("body");
}
@if (masterDokumenList.ImportOptions.Visible) {
    masterDokumenList.ImportOptions.Render("body");
