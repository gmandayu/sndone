@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("PenimbunanPenyaluran");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    var parent_url = ew.PATH_BASE;
    $('#r_PlantForLookup').hide();
    $('#r_NomorPenimbunanPenyaluran').hide();
    $('#r_NoPenyaluran').hide();
    $('#r_LookupTipeProduk').hide();
    $('#r_LookupJenisPlant').hide();
    $('#r_TipeProdukSTS').hide();
    $('#r_JenisProduk').hide();
    $('#r_Plant').hide();
    $('#r_IdModa').hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant?Menu=PenimbunanPenyaluran',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty();
                $.each(data, function (index, item) {
                    ddl.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
                if (Array.isArray(data) && data.length > 0) {
                    ddl.val(data[0].Value).trigger('change');
                }
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Proses Penyaluran.');
            setTimeout(() => {
                window.location.href = parent_url+'PenimbunanPenyaluranList';
            }, 1000);
        }
    });
    // Ensure Plant is set before opening dependent lookups
    const ensurePlantBeforeOpen = function(e) {
        const plantVal = $('#x_Plant').val();
        if (!plantVal) {
            const lpVal = $('#x_LookupPlant').val();
            const lpText = $('#x_LookupPlant').find('option:selected').text();
            if (lpVal) {
                $('#x_Plant').val(lpVal).trigger('change');
                $('#sv_x_Plant').val(lpText || '');
            } else {
                ew.alert('Silakan pilih Plant terlebih dahulu');
                e.preventDefault();
            }
        }
    };
    // Ensure Plant and Moda is set before opening dependent lookups
    const ensurePlantAndModaBeforeOpen = function(e) {
        const plantVal = $('#x_Plant').val();
        if (!plantVal) {
            const lpVal = $('#x_LookupPlant').val();
            const lpText = $('#x_LookupPlant').find('option:selected').text();
            if (lpVal) {
                $('#x_Plant').val(lpVal).trigger('change');
                $('#sv_x_Plant').val(lpText || '');
            } else {
                ew.alert('Silakan pilih Plant terlebih dahulu');
                e.preventDefault();
            }
        }
        const modaVal = $('#x_IdModa').val();
        if (!modaVal) {
            ew.alert('Silakan pilih Moda terlebih dahulu');
            e.preventDefault();
        }
    };
    $('#x_IdTangki').on('select2:opening', ensurePlantBeforeOpen);
    // $('#x_NoPenyaluran').on('select2:opening', ensurePlantBeforeOpen);
    $('#x_LookupNoPenyaluranSelect').on('select2:opening', ensurePlantAndModaBeforeOpen);
    $("#x_Plant").prop("readonly", true);
    const action = "@HttpContext.Request.Query["action"].ToString()";
    if (action === 'addproduct') {
        $('#x_KodeProduk').val('').trigger('change');
        $('#x_IdPlant').trigger('change');
    }
});
</script>
