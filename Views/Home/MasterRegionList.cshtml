<form name="@(masterRegionList.FormName)" id="@(masterRegionList.FormName)" class="ew-form ew-list-form" action="@AppPath(masterRegionList.PageName)" method="post" novalidate autocomplete="off">
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
@if (masterRegionList.IsModal) {
<input type="hidden" name="modal" value="1">
}
<div id="gmp_MasterRegion" class="card-body ew-grid-middle-panel @(masterRegionList.TableContainerClass)" style="@(masterRegionList.TableContainerStyle)">
@if (masterRegionList.TotalRecords > 0 || masterRegionList.IsGridEdit || masterRegionList.IsMultiEdit) {
<table id="tbl_MasterRegionlist" class="@(masterRegionList.TableClass)"><!-- .ew-table -->
<thead>
    <tr class="ew-table-header">
@{
    // Header row
    masterRegionList.RowType = RowType.Header;

    // Render list options
    await masterRegionList.RenderListOptions();
}
@* Render list options (header, left) *@
@masterRegionList.ListOptions.RenderHeader("left")
@if (masterRegionList.IdRegion.Visible) { // masterRegionList.IdRegion.Visible (begin)
        <th data-name="IdRegion" class="@(masterRegionList.IdRegion.HeaderCellClass)"><div id="elh_MasterRegion_IdRegion" class="MasterRegion_IdRegion">@Html.Raw(masterRegionList.RenderFieldHeader(masterRegionList.IdRegion))</div></th>
} @* masterRegionList.IdRegion.Visible (end) *@
@if (masterRegionList.Region.Visible) { // masterRegionList.Region.Visible (begin)
        <th data-name="Region" class="@(masterRegionList.Region.HeaderCellClass)"><div id="elh_MasterRegion_Region" class="MasterRegion_Region">@Html.Raw(masterRegionList.RenderFieldHeader(masterRegionList.Region))</div></th>
} @* masterRegionList.Region.Visible (end) *@
@if (masterRegionList.RegionCode.Visible) { // masterRegionList.RegionCode.Visible (begin)
        <th data-name="RegionCode" class="@(masterRegionList.RegionCode.HeaderCellClass)"><div id="elh_MasterRegion_RegionCode" class="MasterRegion_RegionCode">@Html.Raw(masterRegionList.RenderFieldHeader(masterRegionList.RegionCode))</div></th>
} @* masterRegionList.RegionCode.Visible (end) *@
@* Render list options (header, right) *@
@masterRegionList.ListOptions.RenderHeader("right")
    </tr>
</thead>
<tbody data-page="@(masterRegionList.PageNumber)">
@{
    await masterRegionList.SetupGrid();
    bool eof = masterRegionList.Recordset == null; // DN
}
@while (masterRegionList.RecordCount < masterRegionList.StopRecord || SameString(masterRegionList.RowIndex, "$rowindex$")) { // Begin While
    if (!eof && !SameString(masterRegionList.RowIndex, "$rowindex$") &&
        (!masterRegionList.IsGridAdd || masterRegionList.CurrentMode == "copy") &&
        (!((masterRegionList.IsCopy || masterRegionList.IsAdd) && masterRegionList.RowIndex is int rowIndex && rowIndex == 0))) // DN
        eof = !await masterRegionList.Recordset.ReadAsync();
    masterRegionList.RecordCount++;
    if (masterRegionList.RecordCount >= masterRegionList.StartRecord) {
        await masterRegionList.SetupRow();
    <tr @Html.Raw(masterRegionList.RowAttributes)>
    @* Render list options (body, left) *@
    @masterRegionList.ListOptions.RenderBody("left", masterRegionList.RowCount)
    @if (masterRegionList.IdRegion.Visible) { // masterRegionList.IdRegion.Visible (begin)
        <td data-name="IdRegion" @Html.Raw(masterRegionList.IdRegion.CellAttributes)>
<span id="el@(SameString(masterRegionList.RowIndex, "$rowindex$") ? "$rowindex$" : masterRegionList.RowCount)_MasterRegion_IdRegion" class="el_MasterRegion_IdRegion">
<span @Html.Raw(masterRegionList.IdRegion.ViewAttributes)>
@Html.Raw(masterRegionList.IdRegion.GetViewValue())</span>
</span>
</td>
    } @* masterRegionList.IdRegion.Visible (end) *@
    @if (masterRegionList.Region.Visible) { // masterRegionList.Region.Visible (begin)
        <td data-name="Region" @Html.Raw(masterRegionList.Region.CellAttributes)>
<span id="el@(SameString(masterRegionList.RowIndex, "$rowindex$") ? "$rowindex$" : masterRegionList.RowCount)_MasterRegion_Region" class="el_MasterRegion_Region">
<span @Html.Raw(masterRegionList.Region.ViewAttributes)>
@Html.Raw(masterRegionList.Region.GetViewValue())</span>
</span>
</td>
    } @* masterRegionList.Region.Visible (end) *@
    @if (masterRegionList.RegionCode.Visible) { // masterRegionList.RegionCode.Visible (begin)
        <td data-name="RegionCode" @Html.Raw(masterRegionList.RegionCode.CellAttributes)>
<span id="el@(SameString(masterRegionList.RowIndex, "$rowindex$") ? "$rowindex$" : masterRegionList.RowCount)_MasterRegion_RegionCode" class="el_MasterRegion_RegionCode">
<span @Html.Raw(masterRegionList.RegionCode.ViewAttributes)>
@Html.Raw(masterRegionList.RegionCode.GetViewValue())</span>
</span>
</td>
    } @* masterRegionList.RegionCode.Visible (end) *@
    @* Render list options (body, right) *@
    @masterRegionList.ListOptions.RenderBody("right", masterRegionList.RowCount)
    </tr>
    } @* End if *@

    // Reset for template row
    if (SameString(masterRegionList.RowIndex, "$rowindex$"))
        masterRegionList.RowIndex = 0;

    // Reset inline add/copy row
    if ((masterRegionList.IsCopy || masterRegionList.IsAdd) && masterRegionList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        masterRegionList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(masterRegionList.CurrentAction) && !masterRegionList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
@{ masterRegionList.CloseRecordset(); }
