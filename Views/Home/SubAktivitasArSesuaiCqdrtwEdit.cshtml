                        <td class="text-break body-table fw-bold" id="R4"></td>
                    </tr>
                </tbody>
            </table>
                `;
            $("#r_lastUpdatedDate").after(tableHtml);
            const moveField = (fieldId, targetTdId) => {
                const fieldRow = $("#" + fieldId).closest(".row");
                $("#" + fieldId).appendTo("#" + targetTdId); // move field to table
                fieldRow.hide(); // hide original
            };
            moveField("el_SubAktivitasARSesuaiCQDRTW_KL_Obs", "td_AR_KlObs");
            moveField("el_SubAktivitasARSesuaiCQDRTW_KL_15", "td_AR_Kl15");
            moveField("el_SubAktivitasARSesuaiCQDRTW_Barrels", "td_AR_Barrels");
            moveField("el_SubAktivitasARSesuaiCQDRTW_LT", "td_AR_Lt");
            moveField("el_SubAktivitasARSesuaiCQDRTW_MT", "td_AR_Mt");
    $.ajax({
            url: parent_url + `api/LookUpList/GetNomorPenerimaanFromPenimbunan?NomorPenimbunan=${IdReferensi}`,
            method: "GET",
            success: function (res) {
                if (res.success) {
                    const noReferensi = res.nomorPenerimaan;

                    // Panggil API SFBD
                    $.get(parent_url + `api/LookUpList/GetSFBDValue?NoReferensi=${noReferensi}&Jenis=RTW`, function (data) {
                        if (data.success) {
                            $("#td_SFBD_KlObs").text(data.klobs);
                            $("#td_SFBD_Kl15").text(data.kl15);
                            $("#td_SFBD_Barrels").text(data.barrels);
                            $("#td_SFBD_Mt").text(data.mt);
                            $("#td_SFBD_Lt").text(data.lt);
                        }
                    });

                    // Panggil API BLSFAL
                    $.get(parent_url + `api/LookUpList/GetBLSFALValue?NoReferensi=${noReferensi}&Jenis=RTW`, function (data) {
                        if (data.success) {
                            // BL
                            $("#td_BL_KlObs").text(data.bl_klobs);
                            $("#td_BL_Kl15").text(data.bl_kl15);
                            $("#td_BL_Barrels").text(data.bl_barrels);
                            $("#td_BL_Mt").text(data.bl_mt);
                            $("#td_BL_Lt").text(data.bl_lt);
                            // SFAL
                            $("#td_SFAL_KlObs").text(data.sfal_klobs);
                            $("#td_SFAL_Kl15").text(data.sfal_kl15);
                            $("#td_SFAL_Barrels").text(data.sfal_barrels);
                            $("#td_SFAL_Mt").text(data.sfal_mt);
                            $("#td_SFAL_Lt").text(data.sfal_lt);
                        }
                    });
                } else {
                    alert("Gagal mendapatkan nomor referensi: " + res.message);
                }
            }
        });
    $.ajax({
        url: parent_url + "api/LookUpList/GetRValue",
        type: "GET",
        data: {
            NoReferensi: IdReferensi,
            Menu: "AR",
            Jenis: "RTW"
        },
        success: function(rs){
            if (rs.success) {

                ["R1", "R2", "R3", "R4"].forEach(key => {
                    let val = parseFloat(rs[key]);
                    const el = document.getElementById(key);
                    if (!isNaN(val)) {
                        let color = "";
                        val = val * 100;
                        if (key === "R2") {
                            if (val < -0.07) {
                                color = "#ba313b";
                            } else if (val >= -0.07 && val <= 0) {
                                color = "#3c6dbd";
                            } else {
                                color = "#198754";
                            }
                        } else {
                            if (val < -0.125) {
                                color = "#ba313b";
                            } else if (val >= -0.125 && val <= 0) {
                                color = "#3c6dbd";
                            } else {
                                color = "#198754";
                            }
                        }
                        el.textContent = val.toFixed(3) + "%";
                        el.style.color = color;
                    }
                });
            }
        },
        error: function (xhr, status, error) {
            console.log("Error: " + xhr.responseText);
        }
    });    
    let uploadModal = `<div class="modal fade" id="warningValueModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="warningValueModalTitle">Konfirmasi Simpan Data</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id='warningValueText'>
            Konfirmasi 
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="btn-cancel-modal">Batal</button>
            <button type="button" class="btn btn-primary" id="btn-confirm-modal">Lanjutkan</button>
          </div>
        </div>
      </div>
    </div>`
    $("body").append(uploadModal);
    $("#btn-cancel-modal").click(function (event) {
        event.preventDefault();
        $("#warningValueModal").modal("hide");
    });
    $('#x_KL_Obs, #x_KL_15, #x_Barrels, #x_MT, #x_LT')
        .attr('inputmode', 'numeric')
        .on('input', function () {
            let val = $(this).val();
            let isNegative = val.startsWith('-');
            val = val.replace(',', '.');
            val = val.replace(/[^0-9.]/g, '');
            const parts = val.split('.');
            if (parts.length > 2) {
                val = parts[0] + '.' + parts.slice(1).join('');
            }
            if (isNegative) {
                val = '-' + val;
            }
            $(this).val(val);
        });
     let reverseStatusModal = `<div class="modal fade" id="confirmReverseStatusEditingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header bg-primary">
                        <h1 class="modal-title fs-5" id="confirmReverseStatusEditingModalTitle">Konfirmasi Kembalikan Status</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <form id="reverseStatusEditingModalForm">
                        <div class="modal-body px-2 py-1">
                            <div class="mb-3">
                                <label for="message-text" class="col-form-label">Catatan:</label>
                                <textarea class="form-control" id="catatanReverseStatusEditing" required rows="4"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="btnReverseStatusEditingModalCancel">Batal</button>
                            <button type="submit" class="btn btn-primary" id="btnReverseStatusEditingModalSubmit">Lanjutkan</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>`
    $("body").append(reverseStatusModal);
    $("#btnReverseStatusEditingModalCancel").click(function (event) {
        event.preventDefault();
        $("#confirmReverseStatusEditingModal").modal("hide");
    });
    $(document).on("click", "#btn-reverse-status", function () {
        $("#confirmReverseStatusEditingModal").modal("show");
    });
});
</script>
