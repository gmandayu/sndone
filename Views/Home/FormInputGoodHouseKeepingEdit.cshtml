<script>
    $(document).ready(function() {
        const parent_url = ew.PATH_BASE;
        const NoReferensi = "@NoReferensi";
        const id = "@id";
        const dataDokumen = @Html.Raw(jsonDokumen);
        let filesArr = [];
        let deleteIds = [];
        if (!NoReferensi || !id) {
            ew.alert('URL Tidak Valid');
            setTimeout(function() {
                history.back();
            }, 1000);
        }
        dataDokumen.forEach(item => {
            if (item.FileName) {
                filesArr.push({
                    id: item.id,
                    FileName: item.FileName
                });
            }
        });
        renderTable();
        $("#fileName").on("click", function () {
            $("#fileInput").trigger("click");
        });
        $("#fileInput").on("change", function (e) {
            let newFiles = Array.from(e.target.files);
            let mapped = [];
            for (let f of newFiles) {
                if (f.size > 20 * 1024 * 1024) {
                    ew.alert(`File "${f.name}" melebihi 20 MB dan tidak dapat diupload.`);
                    continue;
                }
                mapped.push({
                    file: f,
                    FileName: f.name
                });
            }
            if (mapped.length > 0) {
                filesArr = filesArr.concat(mapped);
                renderTable();
            }
            $(this).val('');
        });
        function renderTable() {
            let $table = $("#fileTable");
            let $tbody = $table.find("tbody");
            $tbody.empty();
            if (filesArr.length === 0) {
                $('#row-table').hide();
                return;
            }
            $('#row-table').show();
            filesArr.forEach((item, index) => {
                let FileEl = item.id ? `<button class="btn text-primary btn-download p-0" type="button" data-id="${item.id}">${item.FileName}</button>` : item.FileName;
                let row = `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${FileEl}</td>
                        <td>
                            <button class="btn text-danger btn-delete" 
                                    type="button" 
                                    data-index="${index}" 
                                    data-id="${item.id || ''}">
                                <i class="fa-solid fa-times"></i>
                            </button>
                        </td>
                    </tr>
                `;
                $tbody.append(row);
            });
        }
        $(document).on("click", ".btn-delete", function () {
            let index = $(this).data("index");
            let id = $(this).data("id");
            if (id) {
                deleteIds.push(id);
            }
            filesArr.splice(index, 1);
            renderTable();
        });
        $(document).on("click", "#btn-cancel-custom", function () {
            window.location.href = `${parent_url}FormInputGoodHouseKeepingList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
        });
        $("#btn-submit-custom").on("click", function () {
            if (filesArr.length === 0 && deleteIds.length === 0) {
                ew.alert("Tidak ada perubahan file!");
                return;
            }
            if($('#NoReferensi-custom').val() === ''){
                ew.alert("Nomor Good House Keeping tidak boleh kosong!");
                return;
            }
            if($('#x_tgltiba').val() === ''){
                ew.alert("Tanggal Tiba tidak boleh kosong!");
                return;
            }
            if($('#x_Lokasi').val() === ''){
                ew.alert("Lokasi tidak boleh kosong!");
                return;
            }
            showLoading();
            let formData = new FormData();
            formData.append("idRef", id);
            formData.append("NoReferensi", $('#NoReferensi-custom').val());
            formData.append("Tanggal", $('#x_tgltiba').val());
            formData.append("Lokasi", $('#x_Lokasi').val());
            formData.append("Keterangan", $('#x_Keterangan').val());
            filesArr.forEach(item => {
                if (item.file) {
                    formData.append("files", item.file);
                }
            });
            formData.append("Menu", "GHK");
            deleteIds.forEach(id => {
                formData.append("DeletedIds", id);
            });
            $.ajax({
                url: parent_url + "api/LookUpList/UpdateDocumentGHKandPOV",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (rs) {
                    hideLoading();
                    if (rs.success) {
                        ew.alert(rs.message);
                        setTimeout(function () {
                            window.location.href = `${parent_url}FormInputGoodHouseKeepingList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
                        }, 2000);
                    } else {
                        ew.alert(rs.message);
                    }
                },
                error: function (xhr) {
                    hideLoading();
                    ew.alert("Upload gagal: " + xhr.responseText);
                }
            });
        });
        $(document).on('click', '.btn-download', function (e) {
            e.preventDefault();
            const id = $(this).data('id');
            if (!id) {
                ew.alert("ID dokumen tidak ditemukan.");
                return;
            }
            $.ajax({
                url: parent_url + 'api/LookUpList/DownloadSingleDocument',
                type: 'GET',
                data: { 
                    id: id,
                    menu: 'GHK'
                },
                xhrFields: {
                    responseType: 'blob'
                },
                beforeSend: function () {
                    showLoading();
                },
                success: function (response, status, xhr) {
                    const disposition = xhr.getResponseHeader('Content-Disposition');
                    let fileName = "download_file";
                    if (disposition) {
                        const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                        if (fileNameMatch && fileNameMatch[1]) {
                            fileName = decodeURIComponent(fileNameMatch[1]);
                        }
                        const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                        if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                            fileName = decodeURIComponent(utf8FileNameMatch[1]);
                        }
                    }
                    const blobUrl = window.URL.createObjectURL(response);
                    const a = document.createElement('a');
                    a.href = blobUrl;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(blobUrl);
                    ew.alert("Download berhasil!");
                },
                error: function (xhr, status, error) {
                    if (xhr.status === 404) {
                        ew.alert("File tidak ditemukan di server.");
                    } else if (xhr.status === 500) {
                        ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                    } else {
                        ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                    }
                },
                complete: function () {
                    hideLoading();
                }
            });
        });
    });
</script></div>
</template>
