                    var ETAraw = row.ContainsKey("ETA") ? row["ETA"]?.ToString() : "";
                    string ETAFormatted = "";
                    if (!string.IsNullOrWhiteSpace(ETAraw))
                    {
                        if (DateTime.TryParse(ETAraw, out DateTime dt))
                        {
                            ETAFormatted = dt.ToString("yyyy/MM/dd HH:mm:ss");
