    templateProsesList.ShowFilterList();
}
@if (!templateProsesList.IsModal) {
<form name="fTemplateProsessrch" id="fTemplateProsessrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fTemplateProsessrch_search_panel" class="mb-2 mb-sm-0 @(templateProsesList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(templateProsesList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { TemplateProses: currentTable } });
var currentForm;
var fTemplateProsessrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fTemplateProsessrch")
        .setPageId("list")
@if (templateProsesList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "IdTemplate": @Html.Raw(templateProsesList.IdTemplate.ToClientList(templateProsesList)),
            "UrutanProses": @Html.Raw(templateProsesList.UrutanProses.ToClientList(templateProsesList)),
            "NamaProses": @Html.Raw(templateProsesList.NamaProses.ToClientList(templateProsesList)),
            "IdPIC": @Html.Raw(templateProsesList.IdPIC.ToClientList(templateProsesList)),
            "IdTools": @Html.Raw(templateProsesList.IdTools.ToClientList(templateProsesList)),
            "Keterangan": @Html.Raw(templateProsesList.Keterangan.ToClientList(templateProsesList)),
            "DibuatOleh": @Html.Raw(templateProsesList.DibuatOleh.ToClientList(templateProsesList)),
            "TanggalDibuat": @Html.Raw(templateProsesList.TanggalDibuat.ToClientList(templateProsesList)),
            "DiperbaruiOleh": @Html.Raw(templateProsesList.DiperbaruiOleh.ToClientList(templateProsesList)),
            "TanggalDiperbarui": @Html.Raw(templateProsesList.TanggalDiperbarui.ToClientList(templateProsesList)),
            "TipeProses": @Html.Raw(templateProsesList.TipeProses.ToClientList(templateProsesList)),
        })

        // Filters
        .setFilterList(@Html.Raw(templateProsesList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
