            "IdPosition": @Html.Raw(masterPositionList.IdPosition.ToClientList(masterPositionList)),
            "NamaPosition": @Html.Raw(masterPositionList.NamaPosition.ToClientList(masterPositionList)),
            "Location": @Html.Raw(masterPositionList.Location.ToClientList(masterPositionList)),
            "_UserLevel": @Html.Raw(masterPositionList._UserLevel.ToClientList(masterPositionList)),
            "Role": @Html.Raw(masterPositionList.Role.ToClientList(masterPositionList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
