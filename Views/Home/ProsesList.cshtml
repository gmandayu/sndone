                                  </span>` ;

                // Sisipkan setelah tombol export
                $(".ew-filter-option").after(resultHtml);
            },
            error: function (xhr, status, error) {
                console.error('Gagal update status aktivitas:', status, error);
            }
        })
    }
    function getURLParameter(param) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.has(param) ? urlParams.getAll(param) : null;
    }

    // $(document).ready(function () {
    //         var foundCompleted = false; // Flag to track if "Completed" has been found
    //         var processedNextRow = false; // Flag to track if the next row after "Completed" has been processed

    //         $rows.each(function (i) {
    //             if (i === 0 && statusText !== "Completed") {
