    ew.templateData = { rows: @Html.Raw(ConvertToJson(setPjsEdit.Rows)) };
    ew.applyTemplate("tpd_SetPjsedit", "tpm_SetPjsedit", "SetPjsedit", "@(setPjsEdit.Export)", "SetPjs", ew.templateData.rows[0], @(setPjsEdit.IsModal ? "true" : "false"));
    loadjs.done("customtemplate");
});
</script>
</main>
