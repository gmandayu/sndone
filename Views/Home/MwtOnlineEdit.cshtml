@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MWTOnline");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    var steps = [
        { number: 1, label: "MWT Online", url: '', icon: "fa-comment-dots" },
    ];
    var currentStep = 1;
    var $stepperWrapper = $('<div id="bread-crumb-nav" class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    var $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        var isActive = step.number === currentStep;
        var isCompleted = step.number < currentStep;
        var stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        var icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #3c6dbd;">${step.number}</div>`;
            labelContent = `<div><a href="${step.url}" class="step-label"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    if ($('#bread-crumb-nav').length == 0) {
        $(".content-header .container-fluid .row").append($stepperWrapper);
    }

    // ============================================================================
    // SignalR Real-time Connection
    // ============================================================================
    (function() {
        'use strict';
        console.log('🚀 MWT Chat - Initializing SignalR...');

        // Prevent multiple initialization
        if (window.MwtChatSignalR) {
            console.log('⛔ SignalR already initialized');
            return;
        }
        const MwtChat = {
            connection: null,
            isInitialized: false,
            isConnecting: false,
            retryCount: 0,
            maxRetries: 3,
            getBaseUrl: function() {
                return parent_url;
            },
            init: function() {
                if (this.isInitialized) {
                    console.log('⛔ Already initialized');
                    return Promise.resolve(this.connection);
                }
                console.log('🔌 Starting initialization...');
                this.isInitialized = true;
                if (typeof signalR === 'undefined') {
                    console.log('📦 Loading SignalR library...');
                    return this.loadSignalRLibrary()
                        .then(() => this.createConnection());
                }
                return this.createConnection();
            },
            loadSignalRLibrary: function() {
                return new Promise((resolve, reject) => {
                    const script = document.createElement('script');
                    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js';
                    script.async = true;
                    script.onload = () => {
                        console.log('✅ SignalR library loaded');
                        resolve();
                    };
                    script.onerror = () => {
                        console.error('❌ Failed to load SignalR');
                        this.isInitialized = false;
                        reject(new Error('Failed to load SignalR'));
                    };
                    document.head.appendChild(script);
                });
            },
            createConnection: function() {
                if (this.isConnecting) {
                    console.log('⏳ Connection in progress...');
                    return Promise.resolve(this.connection);
                }
                if (this.connection && this.connection.state === signalR.HubConnectionState.Connected) {
                    console.log('✅ Already connected');
                    return Promise.resolve(this.connection);
                }
                this.isConnecting = true;
                try {
                    const hubUrl = `${this.getBaseUrl()}mwtChatHub`;
                    console.log('🔌 Connecting to:', hubUrl);
                    this.connection = new signalR.HubConnectionBuilder()
                        .withUrl(hubUrl)
                        .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                        .configureLogging(signalR.LogLevel.Warning)
                        .build();
                    this.setupEventHandlers();
                    return this.connection.start()
                        .then(() => {
                            console.log('✅ Connected! ID:', this.connection.connectionId);
                            this.isConnecting = false;
                            this.retryCount = 0;
                            this.updateBadge();
                            return this.connection;
                        })
                        .catch(err => {
                            console.error('❌ Connection failed:', err);
                            this.isConnecting = false;
                            this.handleConnectionError(err);
                            throw err;
                        });
                } catch (err) {
                    console.error('❌ Error creating connection:', err);
                    this.isConnecting = false;
                    return Promise.reject(err);
                }
            },
            setupEventHandlers: function() {
                if (!this.connection) return;
                this.connection.onclose((error) => {
                    console.log('🔴 Connection closed', error);
                    this.isConnecting = false;
                });
                this.connection.onreconnecting((error) => {
                    console.log('🔄 Reconnecting...', error);
                });
                this.connection.onreconnected((connectionId) => {
                    console.log('✅ Reconnected! ID:', connectionId);
                    this.updateBadge();
                });

                // Badge update notification
                this.connection.on('UpdateMwtBadge', () => {
                    console.log('📢 Badge update received');
                    this.updateBadge();
                });

                // Chat message notification
                this.connection.on('ReceiveMessage', (user, message) => {
                    console.log('💬 Message from', user);
                    this.handleMessage(user, message);
                });

                // Chat updated notification
                this.connection.on('ChatUpdated', (data) => {
                    console.log('📝 Chat updated:', data);
                    this.handleChatUpdate(data);
                });
            },
            handleConnectionError: function(error) {
                this.retryCount++;
                if (this.retryCount <= this.maxRetries) {
                    const delay = Math.min(5000 * Math.pow(2, this.retryCount - 1), 30000);
                    console.log(`🔄 Retry ${this.retryCount}/${this.maxRetries} in ${delay}ms`);
                    setTimeout(() => {
                        this.isInitialized = false;
                        this.init();
                    }, delay);
                } else {
                    console.error('❌ Max retries reached');
                }
            },
            updateBadge: function() {
                $.ajax({
                    url: `${parent_url}api/LookUpList/GetMwtOnProgressCount`,
                    method: 'GET',
                    cache: false,
                    timeout: 5000,
                    success: (data) => {
                        if (data && data.success) {
                            console.log('✅ Badge count:', data.count);
                            this.renderBadge(data.count);
                        }
                    },
                    error: (err) => {
                        console.warn('⚠️ Failed to get badge:', err);
                    }
                });
            },
            renderBadge: function(count) {
                const $menuLink = $('li[data-name="mi_MWTOnline"] > a > p');
                if (!$menuLink.length) return;
                $menuLink.find('.badge-mwt').remove();
                if (count > 0) {
                    const $badge = $('<span class="right badge badge-mwt">')
                        .text(count)
                        .css({
                            'background-color': '#ff0000',
                            'color': '#ffffff',
                            'font-weight': 'bold',
                            'margin-left': '5px',
                            'padding': '2px 6px',
                            'border-radius': '10px',
                            'font-size': '11px'
                        });
                    $menuLink.append($badge);
                }
            },
            handleMessage: function(user, message) {
                console.log('Processing message from', user);
                // Reload page untuk refresh chat list
                setTimeout(() => location.reload(), 1000);
            },
            handleChatUpdate: function(data) {
                console.log('Handling chat update:', data);
                // Reload page untuk refresh
                setTimeout(() => location.reload(), 1000);
            },
            sendMessage: function(message) {
                if (!this.connection || this.connection.state !== signalR.HubConnectionState.Connected) {
                    console.error('❌ Not connected');
                    return Promise.reject(new Error('Not connected'));
                }
                return this.connection.invoke('SendMessage', message)
                    .catch(err => {
                        console.error('❌ Send failed:', err);
                        throw err;
                    });
            },
            broadcastUpdate: function(eventName, data) {
                if (!this.connection || this.connection.state !== signalR.HubConnectionState.Connected) {
                    return Promise.reject(new Error('Not connected'));
                }
                return this.connection.invoke(eventName, data);
            },
            disconnect: function() {
                if (this.connection) {
                    console.log('🔌 Disconnecting...');
                    return this.connection.stop()
                        .then(() => {
                            console.log('✅ Disconnected');
                            this.connection = null;
                            this.isInitialized = false;
                            this.isConnecting = false;
                        });
                }
                return Promise.resolve();
            },
            getStatus: function() {
                if (!this.connection) {
                    return { state: 'Disconnected', connectionId: null };
                }
                return {
                    state: this.connection.state,
                    connectionId: this.connection.connectionId,
                    isInitialized: this.isInitialized
                };
            }
        };

        // Expose globally
        window.MwtChatSignalR = MwtChat;

        // Auto-initialize when DOM ready
        $(document).ready(function() {
            MwtChat.init()
                .then(() => console.log('✅ SignalR ready'))
                .catch(err => console.error('❌ SignalR init failed:', err));
        });

        // Cleanup on unload
        $(window).on('beforeunload', function() {
            MwtChat.disconnect();
        });
    })();
});
</script>
