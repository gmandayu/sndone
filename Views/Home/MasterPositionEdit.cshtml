@if (masterPositionEdit._UserLevel.Visible) { // masterPositionEdit._UserLevel.Visible (begin)
    <div id="r__UserLevel" @Html.Raw(masterPositionEdit._UserLevel.RowAttributes)>
        <label id="elh_MasterPosition__UserLevel" for="x__UserLevel" class="@(masterPositionEdit.LeftColumnClass)">@Html.Raw(masterPositionEdit._UserLevel.Caption)@Html.Raw(masterPositionEdit._UserLevel.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(masterPositionEdit.RightColumnClass)"><div @Html.Raw(masterPositionEdit._UserLevel.CellAttributes)>
<span id="el_MasterPosition__UserLevel">
    <select
        id="x__UserLevel"
        name="x__UserLevel"
        class="form-select ew-select@(masterPositionEdit._UserLevel.IsInvalidClass)"
        data-select2-id="fMasterPositionedit_x__UserLevel"
        data-table="MasterPosition"
        data-field="x__UserLevel"
        data-value-separator="@(masterPositionEdit._UserLevel.DisplayValueSeparatorAttribute)"
        data-placeholder="@(HtmlEncode(masterPositionEdit._UserLevel.PlaceHolder))"
        @Html.Raw(masterPositionEdit._UserLevel.EditAttributes)>
        @(masterPositionEdit._UserLevel.SelectOptionListHtml("x__UserLevel"))
    </select>
    @Html.Raw(masterPositionEdit._UserLevel.GetCustomMessage)
    <div class="invalid-feedback">@Html.Raw(masterPositionEdit._UserLevel.GetErrorMessage())</div>
@Html.Raw(masterPositionEdit._UserLevel.Lookup.GetParamTag(masterPositionEdit, "p_x__UserLevel"))
<script>
loadjs.ready("fMasterPositionedit", function() {
    var options = { name: "x__UserLevel", selectId: "fMasterPositionedit_x__UserLevel" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fMasterPositionedit.lists._UserLevel?.lookupOptions.length) {
        options.data = { id: "x__UserLevel", form: "fMasterPositionedit" };
    } else {
        options.ajax = { id: "x__UserLevel", form: "fMasterPositionedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.MasterPosition.fields._UserLevel.selectOptions);
    ew.createSelect(options);
});
</script>
</span>
</div></div>
    </div>
} @* masterPositionEdit._UserLevel.Visible (end) *@
