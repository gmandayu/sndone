            ["PosisiPJS", [fields.PosisiPJS.visible && fields.PosisiPJS.required ? ew.Validators.required(fields.PosisiPJS.caption) : null], fields.PosisiPJS.isInvalid],
            ["LookupPosition", [fields.LookupPosition.visible && fields.LookupPosition.required ? ew.Validators.required(fields.LookupPosition.caption) : null], fields.LookupPosition.isInvalid],
            ["TanggalMulai", [fields.TanggalMulai.visible && fields.TanggalMulai.required ? ew.Validators.required(fields.TanggalMulai.caption) : null, ew.Validators.datetime(fields.TanggalMulai.clientFormatPattern)], fields.TanggalMulai.isInvalid],
            ["TanggalSelesai", [fields.TanggalSelesai.visible && fields.TanggalSelesai.required ? ew.Validators.required(fields.TanggalSelesai.caption) : null, ew.Validators.datetime(fields.TanggalSelesai.clientFormatPattern)], fields.TanggalSelesai.isInvalid],
            ["Keterangan", [fields.Keterangan.visible && fields.Keterangan.required ? ew.Validators.required(fields.Keterangan.caption) : null], fields.Keterangan.isInvalid],
            ["Remaks", [fields.Remaks.visible && fields.Remaks.required ? ew.Validators.required(fields.Remaks.caption) : null], fields.Remaks.isInvalid],
            ["DiperbaharuiOleh", [fields.DiperbaharuiOleh.visible && fields.DiperbaharuiOleh.required ? ew.Validators.required(fields.DiperbaharuiOleh.caption) : null], fields.DiperbaharuiOleh.isInvalid],
            ["DiperbaharuiTanggal", [fields.DiperbaharuiTanggal.visible && fields.DiperbaharuiTanggal.required ? ew.Validators.required(fields.DiperbaharuiTanggal.caption) : null, ew.Validators.datetime(fields.DiperbaharuiTanggal.clientFormatPattern)], fields.DiperbaharuiTanggal.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
