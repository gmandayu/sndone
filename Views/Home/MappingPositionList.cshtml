            "IdPlant": @Html.Raw(mappingPositionList.IdPlant.ToClientList(mappingPositionList)),
            "NamaPlant": @Html.Raw(mappingPositionList.NamaPlant.ToClientList(mappingPositionList)),
        })

        // Filters
        .setFilterList(@Html.Raw(mappingPositionList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
