@if (!masterRegionList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterRegionList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterRegion: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(masterRegionList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(masterRegionList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(masterRegionList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(masterRegionList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "IdRegion": @Html.Raw(masterRegionList.IdRegion.ToClientList(masterRegionList)),
            "Region": @Html.Raw(masterRegionList.Region.ToClientList(masterRegionList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
