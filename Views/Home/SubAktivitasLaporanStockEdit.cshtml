<div class="invalid-feedback">@Html.Raw(subAktivitasLaporanStockEdit.StockAkhir.GetErrorMessage())</div>
</span>
</div></div>
    </div>
} @* subAktivitasLaporanStockEdit.StockAkhir.Visible (end) *@
@if (subAktivitasLaporanStockEdit.WorkingLoss.Visible) { // subAktivitasLaporanStockEdit.WorkingLoss.Visible (begin)
