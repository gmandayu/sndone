<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("ClosingStock");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    var parent_url = ew.PATH_BASE;$('#r_PlantForLookup').hide();
    $('#r_NomorClosingStock').hide();
    $('#r_LookupJenisPlant').hide();
    $('#r_TipeProdukSTS').hide();
    $('#r_Plant').hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant?Menu=ClosingStock',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                $.each(data, function (index, item) {
                    const selected = index === 0 ? 'selected' : '';
                    ddl.append(`<option value="${item.Value}" ${selected}>${item.Label}</option>`);
                    if (selected){
                        $('#sv_x_Plant').val(item.Label);
                        $('#x_Plant').val(item.Value).trigger('change');
                        setTimeout(function() {
                            $("#x_LookupPlant").val(item.Value).trigger('change');
                        }, 100);
                    }
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Closing Stock.');
            setTimeout(() => {
                window.location.href = parent_url+'ClosingStockList';
            }, 1000);
        }
    });
});
</script>
