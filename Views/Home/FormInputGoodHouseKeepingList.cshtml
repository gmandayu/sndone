<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("FormInputGoodHouseKeeping");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    const parent_url = ew.PATH_BASE;
    const NoReferensi = "@HttpContext.Request.Query["x_NoReferensi[]"]";
    (function() {
        const steps = [
            { number: 1, label: "Good House Keeping", url: parent_url + 'GoodHouseKeepingList', icon: "fa-clipboard-list" },
            { number: 2, label: "Input Data", url: "",                               icon: "fa-pen-to-square" }
        ];
        const currentStep = 2;
        if (!document.querySelector("style[data-hsse-stepper]")) {
            $("<style data-hsse-stepper>")
              .prop("type", "text/css")
              .html(`
                .stepper{display:flex;counter-reset:step}
                .step{width:150px;text-align:center;position:relative}
                .step:not(:last-child)::after{content:'';position:absolute;top:20px;right:-50%;width:100%;height:4px;background-color:#ccc;z-index:0}
                .step.completed:not(:last-child)::after{background-color:#3c6dbd}
                .step-icon{width:36px;height:36px;line-height:36px;border-radius:50%;background:#ccc;display:inline-block;z-index:1;position:relative;color:#fff;font-weight:bold}
                .step.active .step-icon{background:#28a745} /* hijau utk step aktif */
                .step-label{margin-top:8px;font-size:14px;display:flex;justify-content:center;align-items:center;gap:6px;color:#3c6dbd;text-decoration:none}
                .step-label-not-active{color:#CCC!important}
            `).appendTo("head");
        }
        const $wrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
        const $stepper = $wrapper.find(".stepper");
        steps.forEach(step => {
            const isActive = step.number === currentStep;
            const isCompleted = step.number < currentStep;
            let icon, label, html;
            if (isActive) {
                // step aktif = hijau
                icon = `<div class="step-icon bg-success">${step.number}</div>`;
                label = `<div class="step-label text-success"><i class="fa-solid ${step.icon} me-1 text-success"></i>${step.label}</div>`;
                html = `<div class="step active text-success">${icon}${label}</div>`;
            } else if (isCompleted) {
                // step selesai = biru (sama dgn garis)
                icon = `<div class="step-icon" style="background:#3c6dbd">${step.number}</div>`;
                label = `<div class="step-label"><a href="${step.url}" class="text-primary"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
                html = `<div class="step completed text-primary">${icon}${label}</div>`;
            } else {
                // step belum mulai
                icon = `<div class="step-icon">${step.number}</div>`;
                label = `<div class="step-label-not-active"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</div>`;
                html = `<div class="step text-secondary">${icon}${label}</div>`;
            }
            $stepper.append(html);
        });
        $(".content-header .container-fluid .row").append($wrapper);
    })();

    // text judul samping fillter
    (function () {
      let info = {};
      $("table.ew-master-table tr").each(function () {
        const tds = $(this).find("td");
        const label = (tds[0] && $(tds[0]).text().trim()) || "";
        const value = (tds[1] && $(tds[1]).text().trim()) || "";
        if (label) info[label] = value;
      });
      const nomor = info["Nomor Good House Keeping"] || "";
      const plant = info["Plant"] || "";
      const tiba  = info["Tanggal Tiba"] || "";
      const nomorHtml = nomor ? `<span style="color: red">${nomor}</span>` : "";
      const plantHtml = plant ? `<span style="color: red">${plant}</span>` : "";
      const tibaHtml  = tiba  ? `<span style="color: red">${tiba}</span>`  : "";
      const deskripsi =
        `GOOD HOUSE KEEPING ${nomorHtml}, ` +
        `Plant: ${plantHtml}` +
        (tiba ? `, Tanggal Tiba: ${tibaHtml}` : "");
      const $anchor = $(".ew-filter-option").first();
      if ($anchor.length && nomor) {
        $anchor.after(`<span class="ms-3 fw-bold fst-italic">${deskripsi}</span>`);
      }
    })();
    let $btn = $(`a.btn.btn-default.ew-add-edit.ew-add[href="${parent_url}FormInputGoodHouseKeepingAdd"]`);
    if ($btn.length) {
        $btn.remove();
        let oldButton = $('button.btn-primary[name="btn-submit"]');
        let addButton = $(`
            <button class="btn btn-success ms-2" id="btn-add-ghk">
                <i class="fas fa-plus"></i> Add New
            </button>
        `);
        addButton.on('click', function (e) {
            e.preventDefault();
            window.location.href = `${parent_url}FormInputGoodHouseKeepingAdd?NoReferensi=${NoReferensi}`;
        });
        oldButton.parent().append(addButton);
    }

    // === Judul "Plant & Tanggal" via API ===
    (function () {
      const parent_url = ew.PATH_BASE;

      // Cegah judul ganda saat partial reload
      if (document.getElementById("title-ghk-plant-date")) return;

      // Ambil Nomor Good House Keeping dari QS (detail list)
      const qs = new URLSearchParams(window.location.search);
      let noRef = (qs.getAll("x_NoReferensi[]")[0] || "").trim();

      // Fallback: baca dari master DOM jika ada
      if (!noRef) {
        const info = {};
        $("table.ew-master-table tr").each(function () {
          const tds = $(this).find("td");
          const label = (tds[0] && $(tds[0]).text().trim()) || "";
          const value = (tds[1] && $(tds[1]).text().trim()) || "";
          if (label) info[label] = value;
        });
        noRef = (info["Nomor Good House Keeping"] || "").trim();
      }
      if (!noRef) return;
      $.ajax({
        url: parent_url + "api/LookUpList/get_ghk_header",
        type: "GET",
        data: { nomorReferensi: noRef }
      })
      .done(function (res) {
        let label = "Plant: -, Tanggal: -";
        if (res && res.success) {
          // contoh: res.plant = "1106 - Fuel Terminal Gunung Sitoli", res.tanggal = "16/09/2025"
          label = `Plant: <span style="color:red">${res.plant || "-"}</span>, ` +
                  `Tanggal: <span style="color:red">${res.tanggal || "-"}</span>`;
        }
        const html = `<span id="title-ghk-plant-date" class="ms-3 fw-bold fst-italic">${label}</span>`;
        $(".ew-filter-option").first().after(html);
      })
      .fail(function () {
        const html = `<span id="title-ghk-plant-date" class="ms-3 fw-bold fst-italic">Plant: -, Tanggal: -</span>`;
        $(".ew-filter-option").first().after(html);
      });
    })();
});
</script>
}
