<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("ProofOfVisit");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    const parentURL = ew.PATH_BASE;
    renderStepper({
       	steps: [{ number: 1, label: 'Proof of Visit', icon: 'fa-clipboard-list' }],
       	currentStep: 1,
       	mountSelector: '.content-header .container-fluid .row',
    });
    const roleStr = '@CurrentUserInfo("Rule")';
    const allowedRoles = [0, 10];
    setupAddButtonWithPermission({
       	parentURL,
       	addPath: 'ProofOfVisitAdd',
       	roleStr,
       	allowedRoles,
       	searchPanelSelector: '.ew-search-panel',
    });
    setupTanggalDibuatFilter({
       	formId: 'fProofOfVisitsrch',
       	awalEditValue: '@proofOfVisitList.TanggalDibuat.EditValue',
       	akhirEditValue: '@proofOfVisitList.TanggalDibuat.EditValue2',
       	customContainerSelector: 'div#xs_custom_TanggalDibuat',
       	displayAwalId: 'x_TanggalDibuat',
       	displayAkhirId: 'y_TanggalDibuat',
       	awalFeedbackWrapSelector: '#el_custom_ProofOfVisit_TanggalDibuat',
       	akhirFeedbackWrapSelector: '#el2_custom_ProofOfVisit_TanggalDibuat',
    });
    function hasAllowedRole(roleStr, allowedRoles) {
       	const role = parseInt(roleStr, 10);
       	return Number.isFinite(role) && allowedRoles.includes(role);
    }
    function fetchPovPermission(parentURL) {
       	return $.ajax({
       		url: `${parentURL}api/pov/permission/valid`,
       		method: 'GET',
       		dataType: 'json',
       	})
       		.then((res) => !!(res && res.success && res.data?.valid))
       		.catch(() => false);
    }
    function hideDefaultAddButtons(addPath) {
       	const needle = (addPath || '').toLowerCase();
       	$('.ew-grid-lower-panel a, .ew-grid-upper-panel a')
       		.filter(function () {
       			return (this.href || '').toLowerCase().includes(needle);
       		})
       		.hide();
       	$('.ew-grid-lower-panel .btn, .ew-grid-lower-panel a, .ew-grid-upper-panel .btn, .ew-grid-upper-panel a')
       		.filter(function () {
       			return $(this).find('.fa-plus, .fa-solid.fa-plus').length > 0;
       		})
       		.hide();
    }
    function setupAddButtonWithPermission({ parentURL, addPath, roleStr, allowedRoles, searchPanelSelector }) {
       	const role = parseInt(roleStr, 10);
       	const roleAllowed = Number.isFinite(role) && allowedRoles.includes(role);
       	if (roleAllowed) {
       		moveAddButtonNearSearch({
       			parentURL,
       			addPath,
       			roleStr,
       			allowedRoles,
       			searchPanelSelector,
       		});
       		return;
       	}
       	fetchPovPermission(parentURL).then((isValid) => {
       		if (!isValid) {
       			hideDefaultAddButtons(addPath);
       			return;
       		}
       		moveAddButtonNearSearch({
       			parentURL,
       			addPath,
       			roleStr: 10, // sementara paksa agar allowed
       			allowedRoles,
       			searchPanelSelector,
       		});
       	});
    }
    function ensureStepperCssOnce() {
       	if (document.querySelector('style[data-hsse-stepper]')) return;
       	$('<style data-hsse-stepper>')
       		.prop('type', 'text/css')
       		.html(`
                .stepper{display:flex;counter-reset:step;gap:0}
                .step{width:150px;text-align:center;position:relative}
                .step:not(:last-child)::after{content:'';position:absolute;top:20px;right:-50%;width:100%;height:4px;background-color:#ccc;z-index:0}
                .step.completed:not(:last-child)::after{background-color:#3c6dbd}
                .step-icon{width:36px;height:36px;line-height:36px;border-radius:50%;background:#ccc;display:inline-block;z-index:1;position:relative;color:#fff;font-weight:bold}
                .step.active .step-icon{background:#3c6dbd}
                .step-label{margin-top:8px;font-size:14px;display:flex;justify-content:center;align-items:center;gap:6px;color:#3c6dbd;text-decoration:none}
                .step-label-not-active{color:#CCC!important}
            `).appendTo('head');
    }
    function renderStepper({ steps, currentStep, mountSelector }) {
       	ensureStepperCssOnce();
       	const $wrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
       	const $stepper = $wrapper.find('.stepper');
       	steps.forEach((step) => {
       		const isActive = step.number === currentStep;
       		const iconHtml = `<div class="step-icon ${isActive ? 'bg-success' : ''}">${step.number}</div>`;
       		const labelHtml = isActive
       			? `<div class="step-label text-success"><i class="fa-solid ${step.icon} me-1 text-success"></i>${step.label}</div>`
       			: `<div class="step-label-not-active"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</div>`;
       		$stepper.append(`<div class="step ${isActive ? 'active text-success' : 'text-secondary'}">${iconHtml}${labelHtml}</div>`);
       	});
       	$(mountSelector).append($wrapper);
    }
    function moveAddButtonNearSearch({ parentURL, addPath, roleStr, allowedRoles, searchPanelSelector }) {
       	const role = parseInt(roleStr, 10) || 0;
       	if (!allowedRoles.includes(role)) return;
       	const addUrl = `${parentURL}${addPath}`;
       	const $addBtn = $(`
            <a href="${addUrl}" class="btn btn-success ms-2" id="btn-add-pov">
                <i class="fa-solid fa-plus"></i> Add New
            </a>
        `);
       	let $searchBtn = $(`${searchPanelSelector} button[type="submit"].btn-primary`).first();
       	if (!$searchBtn.length) $searchBtn = $('#btn-search').first();
       	if ($searchBtn.length) {
       		$searchBtn.after($addBtn);
       	} else {
       		$(searchPanelSelector).first().append($('<div class="mt-2"></div>').append($addBtn));
       	}

       	// hide add bawaan
       	hideDefaultAddButtons(addPath);
    }
    function parseYmd(dateStr) {
       	const m = (dateStr || '').match(/^(\d{4})\/(\d{2})\/(\d{2})$/);
       	if (!m) return null;
       	const y = parseInt(m[1], 10);
       	const mo = parseInt(m[2], 10) - 1;
       	const d = parseInt(m[3], 10);
       	return new Date(y, mo, d);
    }
    function isValidYmd(dateStr) {
       	const m = (dateStr || '').match(/^(\d{4})\/(\d{2})\/(\d{2})$/);
       	if (!m) return false;
       	const year = parseInt(m[1], 10);
       	const month = parseInt(m[2], 10);
       	const day = parseInt(m[3], 10);
       	if (month < 1 || month > 12) return false;
       	const maxDay = new Date(year, month, 0).getDate();
       	return day >= 1 && day <= maxDay;
    }
    function isDateLessOrEqual(a, b) {
       	const dA = parseYmd(a);
       	const dB = parseYmd(b);
       	if (!dA || !dB) return false;
       	return dA.getTime() <= dB.getTime();
    }
    function setInvalid($input, feedbackWrapSelector, msg) {
       	$input.addClass('is-invalid');
       	const $wrap = $(feedbackWrapSelector);
       	const $fb = $wrap.find('.invalid-feedback').first().length ? $wrap.find('.invalid-feedback').first() : $wrap.next('.invalid-feedback');
       	if ($fb.length) $fb.text(msg);
    }
    function clearInvalid($input, feedbackWrapSelector) {
       	$input.removeClass('is-invalid');
       	const $wrap = $(feedbackWrapSelector);
       	const $fb = $wrap.find('.invalid-feedback').first().length ? $wrap.find('.invalid-feedback').first() : $wrap.next('.invalid-feedback');
       	if ($fb.length) $fb.text('');
    }
    function setupTanggalDibuatFilter({ formId, awalEditValue, akhirEditValue, customContainerSelector, displayAwalId, displayAkhirId, awalFeedbackWrapSelector, akhirFeedbackWrapSelector }) {
       	const $form = $('#' + formId);
       	if (!$form.length) return;
       	const $container = $(customContainerSelector);
       	if (!$container.length) return;
       	const $hiddenAwal = $('<input>', {
       		type: 'hidden',
       		name: 'x_TanggalDibuat',
       		id: 'x_TanggalDibuat_hidden',
       		value: awalEditValue ? `${awalEditValue}:00` : '',
       	});
       	const $hiddenAkhir = $('<input>', {
       		type: 'hidden',
       		name: 'y_TanggalDibuat',
       		id: 'y_TanggalDibuat_hidden',
       		value: akhirEditValue ? `${akhirEditValue}:59` : '',
       	});
       	$container.append($hiddenAwal, $hiddenAkhir);
       	const $displayAwal = $('#' + displayAwalId);
       	const $displayAkhir = $('#' + displayAkhirId);
       	if (!$displayAwal.length || !$displayAkhir.length) return;
       	const rawAwal = $hiddenAwal.val();
       	if (typeof rawAwal === 'string' && rawAwal.length >= 10) $displayAwal.val(rawAwal.substring(0, 10));
       	const rawAkhir = $hiddenAkhir.val();
       	if (typeof rawAkhir === 'string' && rawAkhir.length >= 10) $displayAkhir.val(rawAkhir.substring(0, 10));
       	const format = 'yyyy/MM/dd';
       	const options = {
       		localization: {
       			locale: ew.LANGUAGE_ID + '-u-nu-' + ew.getNumberingSystem(),
       			hourCycle: 'h24',
       			format,
       			...ew.language.phrase('datetimepicker'),
       		},
       		display: {
       			icons: {
       				previous: ew.IS_RTL ? 'fa-solid fa-chevron-right' : 'fa-solid fa-chevron-left',
       				next: ew.IS_RTL ? 'fa-solid fa-chevron-left' : 'fa-solid fa-chevron-right',
       			},
       			components: { hours: false, minutes: false, seconds: false },
       			theme: ew.isDark() ? 'dark' : 'auto',
       			sideBySide: false,
       		},
       	};
       	const pickerAwal = ew.createDateTimePicker(formId, displayAwalId, ew.deepAssign({ useCurrent: true }, options));
       	const pickerAkhir = ew.createDateTimePicker(formId, displayAkhirId, ew.deepAssign({ useCurrent: true }, options));
       	pickerAwal.subscribe('change.td', function () {
       		clearInvalid($displayAwal, awalFeedbackWrapSelector);
       		const v = $displayAwal.val();
       		if (v) $hiddenAwal.val(v + ' 00:00:00');
       	});
       	pickerAkhir.subscribe('change.td', function () {
       		clearInvalid($displayAkhir, akhirFeedbackWrapSelector);
       		const v = $displayAkhir.val();
       		if (v) $hiddenAkhir.val(v + ' 23:59:59');
       	});
       	$displayAwal.on('input keyup paste', function () {
       		const v = $(this).val();
       		if (!v) {
       			clearInvalid($displayAwal, awalFeedbackWrapSelector);
       			$hiddenAwal.val('');
       			return;
       		}
       		if (isValidYmd(v)) {
       			clearInvalid($displayAwal, awalFeedbackWrapSelector);
       			$hiddenAwal.val(v + ' 00:00:00');
       		} else {
       			$hiddenAwal.val('');
       		}
       	});
       	$displayAkhir.on('input keyup paste', function () {
       		const v = $(this).val();
       		if (!v) {
       			clearInvalid($displayAkhir, akhirFeedbackWrapSelector);
       			$hiddenAkhir.val('');
       			return;
       		}
       		if (isValidYmd(v)) {
       			clearInvalid($displayAkhir, akhirFeedbackWrapSelector);
       			$hiddenAkhir.val(v + ' 23:59:59');
       		} else {
       			$hiddenAkhir.val('');
       		}
       	});
       	$form.on('submit', function (e) {
       		e.preventDefault();
       		clearInvalid($displayAwal, awalFeedbackWrapSelector);
       		clearInvalid($displayAkhir, akhirFeedbackWrapSelector);
       		const a = ($displayAwal.val() || '').toString().trim();
       		const b = ($displayAkhir.val() || '').toString().trim();
       		if (!a && !b) {
       			this.submit();
       			return;
       		}
       		if (!a && b) {
       			setInvalid($displayAwal, awalFeedbackWrapSelector, 'Wajib diisi jika Tanggal Dibuat Sampai sudah terisi');
       			if (!isValidYmd(b)) setInvalid($displayAkhir, akhirFeedbackWrapSelector, 'Tanggal invalid');
       			return;
       		}
       		if (a && !b) {
       			setInvalid($displayAkhir, akhirFeedbackWrapSelector, 'Wajib diisi jika Tanggal Dibuat Dari sudah terisi');
       			if (!isValidYmd(a)) setInvalid($displayAwal, awalFeedbackWrapSelector, 'Tanggal invalid');
       			return;
       		}
       		if (!isValidYmd(a)) setInvalid($displayAwal, awalFeedbackWrapSelector, 'Tanggal invalid');
       		if (!isValidYmd(b)) setInvalid($displayAkhir, akhirFeedbackWrapSelector, 'Tanggal invalid');
       		if (!isValidYmd(a) || !isValidYmd(b)) return;
       		if (!isDateLessOrEqual(a, b)) {
       			setInvalid($displayAwal, awalFeedbackWrapSelector, 'Tanggal Dibuat Dari harus lebih awal atau sama dengan Tanggal Dibuat Sampai');
       			return;
       		}
       		$hiddenAwal.val(a + ' 00:00:00');
       		$hiddenAkhir.val(b + ' 23:59:59');
       		this.submit();
       	});
    }
});
</script>
}
