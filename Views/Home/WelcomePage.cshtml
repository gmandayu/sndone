@{
    // View
    View = this;

    // Check action result
    if (welcomePage.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = welcomePage.UseLayout ? "_Layout" : "";
}
@welcomePage.ShowMessages()
@{
    var userLevel = CurrentUserLevel();
    var userIdPosition = CurrentUserInfo("IdPosition") ?? "0";
    var plantId = "";
    var whereFilter = "";
    var whereFilterPlant = "";
    var whereFilterPoV = ""; 
    var whereFilterPlantGHK = ""; 
    var whereFilterPlantBukuTamu = ""; 
    List<string> plantFilters = new();
    var result = new List<object>();
    var penyaluranProcessSalesList = new List<object>();
    var penyaluranProcessKonsinyasiList = new List<object>();
    var startDate = Request.Query.TryGetValue("startDate", out var sd) && !string.IsNullOrEmpty(sd) ? sd.ToString() : DateTime.Now.ToString("yyyy-MM-dd");
    var endDate = Request.Query.TryGetValue("endDate", out var ed) && !string.IsNullOrEmpty(ed) ? ed.ToString() : DateTime.Now.ToString("yyyy-MM-dd");
    var regionIdParam = Request.Query.TryGetValue("region", out var rp) && !string.IsNullOrEmpty(rp) ? rp.ToString() : "";
    var plantIdParam = Request.Query.TryGetValue("plant", out var pp) && !string.IsNullOrEmpty(pp) ? pp.ToString() : "";
    var regions = new List<object>();
    var plants = new List<object>();
    
    var filterBetweenDate = $"WHERE CAST(TanggalDibuat AS date) BETWEEN '{startDate}' AND '{endDate}'";

    if (userLevel != "-1" && userLevel != "3" && userLevel != "4")
    {
        plantId = CurrentUserInfo("Plant")?.ToString();
    }

    if (userLevel == "4")
    {
        var regionsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT DISTINCT MR.IdRegion, MR.Region FROM MappingPosition MP JOIN MasterRegion MR ON MP.IdRegion = MR.IdRegion WHERE MP.IdRegion IN (SELECT IdRegion FROM MappingPosition WHERE IdPosition = @IdPosition)",
            reader => new
            {
                IdRegion = reader.GetInt32("IdRegion").ToString(),
                Region = reader.IsDBNull("Region") ? null : reader.GetString("Region")
            },
            new Dictionary<string, object> {{"@IdPosition", userIdPosition}});
        
        var plantsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT DISTINCT IdPlant, NamaPlant as Terminal, IdRegion as Region FROM MappingPosition WHERE IdRegion IN (SELECT IdRegion FROM MappingPosition WHERE IdPosition = @IdPosition)",
            reader => new
            {
                IdPlant = reader.GetInt32("IdPlant").ToString(),
                Terminal = reader.IsDBNull("Terminal") ? null : reader.GetString("Terminal"),
                Region = reader.GetInt32("Region").ToString()
            },
            new Dictionary<string, object> {{"@IdPosition", userIdPosition}});
        
        await Task.WhenAll(regionsTask, plantsTask);
        regions = regionsTask.Result;
        plants = plantsTask.Result;
        
        if (!string.IsNullOrEmpty(plantIdParam) && plantIdParam != "All")
        {
            plantFilters.Add(plantIdParam);
        }
        else if (!string.IsNullOrEmpty(regionIdParam) && regionIdParam != "All")
        {   
            plantFilters = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<string>(
                "SELECT IdPlant FROM MasterPlant WHERE Region = @Region",
                reader => reader.GetInt32("IdPlant").ToString(), 
                new Dictionary<string, object>{{ "@Region", regionIdParam }});
        }
        else 
        {
            plantFilters = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<string>(
                "SELECT IdPlant FROM MasterPlant WHERE Region IN (SELECT IdRegion FROM MappingPosition WHERE IdPosition = @userIdPosition)",
                reader => reader.GetInt32("IdPlant").ToString(),
                new Dictionary<string, object>{{ "@userIdPosition", userIdPosition }});
        }
    } else if (userLevel == "-1" || userLevel == "3")
    {
        var regionsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT IdRegion, Region FROM MasterRegion",
            reader => new
            {
                IdRegion = reader.GetInt32("IdRegion").ToString(),
                Region = reader.IsDBNull("Region") ? null : reader.GetString("Region")
            });
        
        var plantsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT IdPlant, Nama_Terminal as Terminal, Region FROM MasterPlant",
            reader => new
            {
                IdPlant = reader.GetInt32("IdPlant").ToString(),
                Terminal = reader.IsDBNull("Terminal") ? null : reader.GetString("Terminal"),
                Region = reader.IsDBNull("Region") ? null : reader.GetString("Region")
            });
        
        await Task.WhenAll(regionsTask, plantsTask);
        regions = regionsTask.Result;
        plants = plantsTask.Result;
        
        if (!string.IsNullOrEmpty(plantIdParam) && plantIdParam != "All")
        {
            plantFilters.Add(plantIdParam);
        }
        else if (!string.IsNullOrEmpty(regionIdParam) && regionIdParam != "All")
        {
            plantFilters = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<string>(
                "SELECT IdPlant FROM MasterPlant WHERE Region = @Region",
                reader => reader.GetInt32("IdPlant").ToString(), 
                new Dictionary<string, object>{{ "@Region", regionIdParam }});
        }
        else 
        {
            plantFilters = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<string>(
                "SELECT IdPlant FROM MasterPlant",
                reader => reader.GetInt32("IdPlant").ToString());
        }
    } else 
    {
        var regionsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT IdRegion, Region FROM MasterRegion WHERE IdRegion in (SELECT MR.IdRegion as Region FROM MappingPosition MP JOIN MasterRegion MR ON MR.IdRegion = MP.IdRegion WHERE IdPosition = @IdPosition)",
            reader => new
            {
                IdRegion = reader.GetInt32("IdRegion").ToString(),
                Region = reader.IsDBNull("Region") ? null : reader.GetString("Region")
            }, 
            new Dictionary<string, object>{{ "@IdPosition", userIdPosition }});

        var plantsTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT MP.IdPlant, MP.NamaPlant as Terminal, MR.IdRegion as Region FROM MappingPosition MP JOIN MasterRegion MR ON MR.IdRegion = MP.IdRegion WHERE IdPosition = @IdPosition",
            reader => new
            {
                IdPlant = reader.GetInt32("IdPlant").ToString(),
                Terminal = reader.IsDBNull("Terminal") ? null : reader.GetString("Terminal"),
                Region = reader.GetInt32("Region").ToString()
            }, 
            new Dictionary<string, object>{{ "@IdPosition", userIdPosition }});
        
        await Task.WhenAll(regionsTask, plantsTask);
        regions = regionsTask.Result;
        plants = plantsTask.Result;

        if (!string.IsNullOrEmpty(plantIdParam) && plantIdParam != "All")
        {
            plantFilters.Add(plantIdParam);
        }
        else 
        {
            plantFilters = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<string>(
                "SELECT DISTINCT IdPlant FROM MappingPosition WHERE IdPosition = @userIdPosition",
                reader => reader.GetInt32("IdPlant").ToString(),
                new Dictionary<string, object>{{"@userIdPosition", userIdPosition}});
        }
    }
        
    if (plantFilters.Count > 0)
    {
        var filterCondition = string.Join(" OR ", plantFilters.Select(p => $"IdPlant = {p}"));
        whereFilter = $" AND ({filterCondition})";
        whereFilterPlant = $" AND ({string.Join(" OR ", plantFilters.Select(p => $"Plant = {p}"))})";
        whereFilterPlantGHK = $" AND ({string.Join(" OR ", plantFilters.Select(p => $"GHK.Plant = {p}"))})";
        whereFilterPlantBukuTamu = $" AND ({string.Join(" OR ", plantFilters.Select(p => $"BT.Plant = {p}"))})";
        whereFilterPoV = $" AND ({string.Join(" OR ", plantFilters.Select(p => $"p.LookupPlant = {p}"))})";
    }
    else if (userLevel != "-1" && userLevel != "3")
    {
        whereFilter = " AND IdPlant = 0";
        whereFilterPlant = " AND Plant = 0";
        whereFilterPlantGHK = " AND GHK.Plant = 0";
        whereFilterPlantBukuTamu = " AND BT.Plant = 0";
        whereFilterPoV = " AND p.LookupPlant = 0";
    }
    
    string query = $@"
        SELECT 
            'Penerimaan'                                                  AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM Penerimaan {filterBetweenDate} {whereFilter}

        UNION ALL

        SELECT
            'Penerimaan Penyimpanan'                                      AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM Penimbunan {filterBetweenDate} {whereFilterPlant}

        UNION ALL

        SELECT
            'Penyaluran Penyimpanan'                                      AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM PenimbunanPenyaluran {filterBetweenDate} {whereFilterPlant}

        UNION ALL

        SELECT
            'Closing Stock Penyimpanan'                                   AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM ClosingStock {filterBetweenDate} {whereFilterPlant}

        UNION ALL

        SELECT
            'Rencana & Realisasi Penyaluran'                              AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM RencanaPenyaluran {filterBetweenDate} {whereFilter}

        UNION ALL

        SELECT
            'Proses Penyaluran'                                           AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM Penyaluran {filterBetweenDate} {whereFilter}

        UNION ALL

        SELECT
            'Sampling Lab Test Penyaluran'                                AS PlanName,
            COUNT(*)                                                      AS Total,
            ISNULL(SUM(IIF(StatusProses = 'Waiting', 1, 0)), 0)           AS Waiting,
            ISNULL(SUM(IIF(StatusProses = 'In Progress', 1, 0)), 0)       AS InProgress,
            ISNULL(SUM(IIF(StatusProses = 'Complete', 1, 0)), 0)          AS Complete
        FROM SamplingLabTest {filterBetweenDate} {whereFilter}

        UNION ALL
        SELECT
            'Proof of Visit' AS PlanName,
            COUNT(*) AS Total,          
            COUNT(*) AS Waiting,        
            ISNULL(SUM(CASE WHEN UPPER(LTRIM(RTRIM(ISNULL(f.Ketidaksesuaiaan,'')))) = 'YA' THEN 1 ELSE 0 END),0) AS Complete, -- Baris 2: Tidak Sesuai
            ISNULL(SUM(CASE WHEN UPPER(LTRIM(RTRIM(ISNULL(f.Ketidaksesuaiaan,'')))) = 'TIDAK'    THEN 1 ELSE 0 END),0) AS InProgress   -- Baris 3: Sesuai
        FROM FormInputProofOfVisit f
        LEFT JOIN ProofOfVisit p
            ON p.NomorProofOfVisit = f.NoReferensi
        LEFT JOIN MasterPlant mp         
            ON mp.IdPlant = p.LookupPlant
        WHERE
            CAST(f.Tanggal AS date) BETWEEN '{startDate}' AND '{endDate}'
            {whereFilterPoV}

        UNION ALL
        SELECT
            'Buku Tamu' AS PlanName,
            (SELECT COUNT(*) FROM BukuTamu WHERE CAST(Tanggal AS date) BETWEEN '{startDate}' AND '{endDate}' {whereFilterPlant}) AS Total,
            ISNULL(SUM(IIF(BTD.Area = 'Pintu Utama In', 1, 0)), 0) AS Waiting,
            ISNULL(SUM(IIF(BTD.Area = 'Lobby Utama In', 1, 0)), 0) AS InProgress,
            ISNULL(SUM(IIF(BTD.Area = 'Area Terlarang In', 1, 0)), 0) AS Complete
        FROM BukuTamu BT
        JOIN BukuTamuDetail BTD ON BT.NomorBukuTamu = BTD.NoReferensi
        WHERE 
            CAST(BT.Tanggal AS date) BETWEEN '{startDate}' AND '{endDate}'
            {whereFilterPlantBukuTamu}
        
        UNION ALL
        SELECT
            'MWT Online'                                      AS PlanName,
            COUNT(*)                                          AS Total,
            ISNULL(SUM(IIF(Status = 'On Progress', 1, 0)), 0) AS Waiting,
            ISNULL(SUM(IIF(Status = 'Back Log', 1, 0)), 0)    AS InProgress,
            ISNULL(SUM(IIF(Status = 'Completed', 1, 0)), 0)   AS Complete
        FROM MWTOnline 
        WHERE CAST(CreatedDate AS date) BETWEEN '{startDate}' AND '{endDate}'
            {whereFilter}

        UNION ALL
        SELECT
            'Good House Keeping'             AS PlanName,
            COUNT(GHK.NomorGoodHouseKeeping) AS Total,
            COUNT(FGHK.NoReferensi)          AS Waiting,
            0                                AS InProgress,
            0                                AS Complete
        FROM 
            GoodHouseKeeping GHK LEFT JOIN FormInputGoodHouseKeeping FGHK
            ON GHK.NomorGoodHouseKeeping = FGHK.NoReferensi
        WHERE
            CAST(GHK.TanggalDibuat AS date) BETWEEN '{startDate}' AND '{endDate}'
            {whereFilterPlantGHK}
        ";

    var dashboardQueryTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
        query,
        rider => new
        {
            PlanName = rider.GetString("PlanName"),
            Total = rider.GetInt32("Total"),
            Waiting = rider.GetInt32("Waiting"),
            InProgress = rider.GetInt32("InProgress"),
            Complete = rider.GetInt32("Complete")
        });
        
    string prosesPenyaluranSalesQuery = $@"
            SELECT
                MP.NamaProduk AS ProductName,
                SUM(TRY_CAST(SP.Volume as decimal(18,2))) AS TotalVolume,
                'Sales' AS TipePenyaluran
            from Penyaluran P
            JOIN SubAktivitasLogbookPenerimaanPenyaluran SP ON P.NomorPenyaluran = SP.NoReferensi
            JOIN MasterProduk MP ON SP.Produk = MP.NoProduk
            {filterBetweenDate} {whereFilter} AND TipePenyaluran = 'Sales'
            group by
                SP.Produk,
                MP.NamaProduk

                UNION ALL

            SELECT
                MP.NamaProduk AS ProductName,
                SUM(TRY_CAST(SB.BL_KLObs AS decimal(18,2))) AS TotalVolume,
                'Konsinyasi' AS TipePenyaluran
            FROM Penyaluran P
            JOIN SubAktivitasInputDataKapal SK
                ON P.NomorPenyaluran = SK.NoReferensi
            JOIN SubAktivitasNilaiBLSFALPenyaluran SB
                ON P.NomorPenyaluran = SB.NoReferensi
            JOIN MasterProduk MP
                ON SK.JenisProduk = MP.NoProduk
            {filterBetweenDate} {whereFilter} AND TipePenyaluran = 'Konsinyasi'
            GROUP BY
                SK.JenisProduk,
                MP.NamaProduk
            HAVING
                SUM(TRY_CAST(SB.BL_KLObs AS decimal(18,2))) IS NOT NULL
        ";

    var penyaluranQueryTask = DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
        prosesPenyaluranSalesQuery,
        rider => new
        {
            ProductName = rider.GetString("ProductName"),
            TotalVolume = rider.GetDecimal("TotalVolume"),
            TipePenyaluran = rider.GetString("TipePenyaluran")
        });

    await Task.WhenAll(dashboardQueryTask, penyaluranQueryTask);
    
    result = dashboardQueryTask.Result;
    var prosesPenyaluranSalesResult = penyaluranQueryTask.Result;

    penyaluranProcessKonsinyasiList = prosesPenyaluranSalesResult
        .Where(x => ((dynamic)x).TipePenyaluran == "Konsinyasi")
        .Select(x => new { Name = ((dynamic)x).ProductName, Value = ((dynamic)x).TotalVolume })
        .ToList<object>();

    penyaluranProcessSalesList = prosesPenyaluranSalesResult
        .Where(x => ((dynamic)x).TipePenyaluran == "Sales")
        .Select(x => new { Name = ((dynamic)x).ProductName, Value = ((dynamic)x).TotalVolume })
        .ToList<object>();
}

