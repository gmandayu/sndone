} @* closingStockEdit.IdTangki.Visible (end) *@
@if (closingStockEdit.TanggalClosingStock.Visible) { // closingStockEdit.TanggalClosingStock.Visible (begin)
    <div id="r_TanggalClosingStock" @Html.Raw(closingStockEdit.TanggalClosingStock.RowAttributes)>
        <label id="elh_ClosingStock_TanggalClosingStock" for="x_TanggalClosingStock" class="@(closingStockEdit.LeftColumnClass)">@Html.Raw(closingStockEdit.TanggalClosingStock.Caption)@Html.Raw(closingStockEdit.TanggalClosingStock.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(closingStockEdit.RightColumnClass)"><div @Html.Raw(closingStockEdit.TanggalClosingStock.CellAttributes)>
<span id="el_ClosingStock_TanggalClosingStock">
<span @Html.Raw(closingStockEdit.TanggalClosingStock.ViewAttributes)>
<input type="text" readonly class="form-control-plaintext" value="@Html.Raw(RemoveHtml(ConvertToString(closingStockEdit.TanggalClosingStock.EditValue)))"></span>
<input type="hidden" data-table="ClosingStock" data-field="x_TanggalClosingStock" data-hidden="1" name="x_TanggalClosingStock" id="x_TanggalClosingStock" value="@Html.Raw(HtmlEncode(closingStockEdit.TanggalClosingStock.CurrentValue))">
