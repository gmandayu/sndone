<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("SamplingLabTest");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    var parent_url = ew.PATH_BASE;
    $("#r_NomorSamplingLabTest").hide();
    $('#r_LookupTipeProduk').hide();
    $('#r_LookupJenisPlant').hide();
    $('#r_TipeProdukSTS').hide();
    $('#r_IdPlant').hide();
    $('#r_IdReferensi').hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                var targetPlantId = "@Html.Raw(samplingLabTestAdd.IdPlant.CurrentValue)";
                $.each(data, function (index, item) {
                    let isSelected = false;
                    if (targetPlantId && (item.Value == targetPlantId || item.Value.toString() == targetPlantId.toString())) {
                        isSelected = true;
                    } else if (!targetPlantId && index === 0) {
                        isSelected = true;
                    }
                    const selectedAttr = isSelected ? 'selected' : '';
                    ddl.append(`<option value="${item.Value}" ${selectedAttr}>${item.Label}</option>`);
                    if (isSelected){
                        $('#x_IdPlant').val(item.Value).trigger('change');
                        $('#x_LookupPlant').trigger('change');
                        const $sv = $('#sv_x_IdPlant');
                        if ($sv.length) {
                            $sv.val(item.Label);
                        }
                        $('#x_LookupIdReferensi').val(null).trigger('change');
                    }
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && idRole != '3') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Sampling Lab Test.');
            setTimeout(() => {
                window.location.href = parent_url+'SamplingLabTestList';
            }, 1000);
        }
    });
    const action = "@HttpContext.Request.Query["action"].ToString()";
    if (action === 'addproduct') {
        $('#x_KodeProduk').val('').trigger('change');
        $('#x_IdPlant').trigger('change');
    }
    $('#sv_x_IdPlant').prop('readonly', true);
});
</script>
