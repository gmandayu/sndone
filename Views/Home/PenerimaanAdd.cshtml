    var parent_url = ew.PATH_BASE;
    $("#x_NomorPenerimaan").prop("readonly", true);
    $("#r_LookupTipeProduk").hide();
    $("#r_LookupJenisPlant").hide();
    $("#r_TipeProdukSTS").hide();
    $("#r_IdPlant").hide();
    $("#r_IdPenyaluran").hide();
    $("#r_Refinery").hide();
    const action = '@HttpContext.Request.Query["action"].ToString()';
    if (action === "addproduct") {
    	$("#x_KodeProduk").val("").trigger("change");
    	let TipeProdukSTS = $("#x_TipeProdukSTS").val();
    	if (TipeProdukSTS) {
    		$("#x_TipeProdukSTS").trigger("change");
    		$("#r_TipeProdukSTS").show();
    	} else {
    		$("#x_IdPlant").trigger("change");
    	}
    	let plantId = $("#x_IdPlant").val();
    	let modaId = $("#x_ModaTransportasi").val();
    	const penyaluranId = $("#x_IdPenyaluran").val();
    	if (["1", "2"].includes(modaId)) {
    		// do what?
    	} else if (modaId === "3") {
    		fillIdPenyaluranList(plantId, modaId);
    		$("#r_NamaKapal").hide();
    		$("#r_IdDermaga").hide();
    		$("#r_NomorVoyage").hide();
    		$("#r_Refinery").hide();
    		$("#x_NamaKapal").val("");
    		$("#x_IdDermaga").val("");
    		$("#x_NomorVoyage").val("");
    		$("#x_Refinery").prop("checked", false);
    		$("#elh_Penerimaan_TanggalSandar").contents().first()[0].textContent = "Tanggal";
    		$("#x_TanggalSandar").attr("placeholder", "Tanggal");
    	} else if (modaId === "4") {
    		fillIdPenyaluranList(plantId, modaId);
    		$("#r_NamaKapal").hide();
    		$("#r_IdDermaga").hide();
    		$("#r_NomorVoyage").hide();
    		$("#r_Refinery").hide();
    		$("#x_NamaKapal").val("");
    		$("#x_IdDermaga").val("");
    		$("#x_NomorVoyage").val("");
    		$("#x_Refinery").prop("checked", false);
    		$("#elh_Penerimaan_TanggalSandar").contents().first()[0].textContent = "Tanggal";
    		$("#x_TanggalSandar").attr("placeholder", "Tanggal");
    	} else if (modaId == "5" || modaId == "6") {
    		const penyaluranSelection = $("#x_IdPenyaluran");
    		penyaluranSelection.empty();
    		penyaluranSelection.append('<option value="">Loading...</option>');
    		$.ajax({
    			url: parent_url + "api/LookUpList/get-dropdown/penyaluran-to-penerimaan",
    			method: "GET",
    			dataType: "json",
    			data: {
    				plantId: plantId,
    				modaId: modaId,
    			},
    			success: function (data) {
    				penyaluranSelection.empty();
    				$.each(data, function (index, item) {
    					let isSelected = penyaluranId == item.Value;
    					penyaluranSelection.append(`<option value="${item.Value}" selected="${isSelected}">${item.Label}</option>`);
    				});
    			},
    			error: function (xhr, status, error) {
    				console.error("Gagal ambil data dropdown:", error);
    				penyaluranSelection.empty();
    			},
    		});
    		$("#r_IdPenyaluran").show();
    		$("#r_NamaKapal").hide();
    		$("#r_IdDermaga").hide();
    		$("#r_NomorVoyage").hide();
    		$("#elh_Penerimaan_TanggalSandar").contents().first()[0].textContent = "Tanggal";
    		$("#x_TanggalSandar").attr("placeholder", "Tanggal");
    		$("#r_Refinery").show();
    		if ($("#x_Refinery").prop("checked")) {
    			$("#r_IdPenyaluran").hide();
    		}
    	} else {
    		$("#elh_Penerimaan_TanggalSandar").contents().first()[0].textContent = "Tanggal Sandar";
    		$("#x_TanggalSandar").attr("placeholder", "Tanggal Sandar");
    		$("#r_NamaKapal").show();
    		$("#r_IdDermaga").show();
    		$("#r_NomorVoyage").show();
    		$("#r_IdPenyaluran").hide();
    		$("#r_Refinery").hide();
    		$("#x_IdPenyaluran").val("");
    		$("#x_Refinery").prop("checked", false);
    	}
    }
    $(document).ready(function () {
    	const ddl = $("#x_LookupPlant");
    	ddl.empty();
    	ddl.append('<option value="">Loading...</option>');
    	$.ajax({
    		url: parent_url + "api/LookUpList/get-dropdown/plant?Menu=Penerimaan",
    		method: "GET",
    		dataType: "json",
    		success: function (data) {
    			ddl.empty();
    			var targetPlantId = "@Html.Raw(penerimaanAdd.IdPlant.CurrentValue)";
    			$.each(data, function (index, item) {
    				let isSelected = false;
    				if (targetPlantId && (item.Value == targetPlantId || item.Value.toString() == targetPlantId.toString())) {
    					isSelected = true;
    				} else if (!targetPlantId && index === 0) {
    					isSelected = true;
    				}
    				const selectedAttr = isSelected ? "selected" : "";
    				ddl.append(`<option value="${item.Value}" ${selectedAttr}>${item.Label}</option>`);
    				if (isSelected) {
    					$("#x_IdPlant").val(item.Value).trigger("change");
    				}
    			});
    		},
    		error: function (xhr, status, error) {
    			console.error("Gagal ambil data dropdown:", error);
    			ddl.empty();
    		},
    	});
    	const UserLevel = "@CurrentUserLevel()";
    	const idRole = '@CurrentUserInfo("Rule")?.ToString()';
    	if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && idRole != "1" && idRole != "12" && idRole != "13") {
    		ew.alert("Anda tidak memiliki akses untuk menambah data Penerimaan.");
    		setTimeout(() => {
    			window.location.href = parent_url + "PenerimaanList";
    		}, 1000);
    	}
    });
    function fillIdPenyaluranList(idPlant, idModa) {
    	const penyaluranSelection = $("#x_IdPenyaluran");
    	penyaluranSelection.empty();
    	penyaluranSelection.append('<option value="">Loading...</option>');
    	$.ajax({
    		url: parent_url + "api/LookUpList/get-dropdown/penyaluran-to-penerimaan",
    		method: "GET",
    		dataType: "json",
    		data: {
    			plantId: idPlant,
    			modaId: idModa,
    		},
    		success: function (data) {
    			penyaluranSelection.empty();
    			$.each(data, function (index, item) {
    				penyaluranSelection.append(`<option value="${item.Value}">${item.Label}</option>`);
    			});
    		},
    		error: function (xhr, status, error) {
    			console.error("Gagal ambil data dropdown:", error);
    			penyaluranSelection.empty();
    		},
    		complete: function () {
    			$("#r_IdPenyaluran").show();
    		},
    	});
    }
});
</script>
