<script>
    $(document).ready(function() {
        $(".input-numeric")
            .attr('inputmode', 'numeric')
            .on('input', function () {
                let val = $(this).val();
                let isNegative = val.startsWith('-');
                val = val.replace(',', '.');
                val = val.replace(/[^0-9.]/g, '');
                const parts = val.split('.');
                if (parts.length > 2) {
                    val = parts[0] + '.' + parts.slice(1).join('');
                }
                if (isNegative) {
                    val = '-' + val;
                }
                $(this).val(val);
            });
    });
    $('#btnAddGerbong').on('click', function () {
        var tbody = $('#gerbongBody');
        var idx = tbody.children('tr').length;
        var rowHtml = `
            <tr>
                <td class="text-center">
                    <button type="button"
                            class="btn btn-sm btn-danger btn-remove-row">
                        ✕
                    </button>
                </td>
                <td>
                    <input type="text"
                        class="form-control isi-detail-gerbong"
                        name="anak[${idx}].DetailGerbong"
                        data-idx="${idx}"
                        placeholder="Gerbong ${idx}">
                </td>
                <td>
                    <input type="text"
                        class="form-control input-numeric isi-detail-quantity"
                        name="anak[${idx}].DetailQuantity"
                        data-idx="${idx}"
                        placeholder="0">
                </td>
            </tr>
        `;
        tbody.append(rowHtml);
    });
    $(document).on('click', '.btn-remove-row', function () {
        $(this).closest('tr').remove();
        reindexRows();
    });
    function reindexRows() {
        $('#gerbongBody tr').each(function (i) {
            $(this).find('.isi-detail-gerbong')
                .attr('name', `anak[${i}].DetailGerbong`)
                .attr('data-idx', i)
                .attr('placeholder', `Gerbong ${i + 1}`);
            $(this).find('.isi-detail-quantity')
                .attr('name', `anak[${i}].DetailQuantity`)
                .attr('data-idx', i);
        });
    }
    $(document).on('input', '.isi-detail-gerbong', function () {
        const forb = /[;|<>\"'\\\/]/g;
        let val = $(this).val();
        if (forb.test(val)) {
            $(this).val(val.replace(forb, ''));
        }
    });
</script> *@
