@{
    // View
    View = this;

    // Check action result
    if (closingStockList.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = closingStockList.UseLayout ? "_Layout" : "";
}
@if (!closingStockList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(closingStockList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { ClosingStock: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(closingStockList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(closingStockList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(closingStockList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(closingStockList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "Proses2": @Html.Raw(closingStockList.Proses2.ToClientList(closingStockList)),
            "Plant": @Html.Raw(closingStockList.Plant.ToClientList(closingStockList)),
            "TipeProdukSTS": @Html.Raw(closingStockList.TipeProdukSTS.ToClientList(closingStockList)),
            "IdTangki": @Html.Raw(closingStockList.IdTangki.ToClientList(closingStockList)),
            "Produk": @Html.Raw(closingStockList.Produk.ToClientList(closingStockList)),
            "StatusProses": @Html.Raw(closingStockList.StatusProses.ToClientList(closingStockList)),
            "PersentaseProgress": @Html.Raw(closingStockList.PersentaseProgress.ToClientList(closingStockList)),
            "DibuatOleh": @Html.Raw(closingStockList.DibuatOleh.ToClientList(closingStockList)),
            "TanggalDibuat": @Html.Raw(closingStockList.TanggalDibuat.ToClientList(closingStockList)),
            "DiperbaruiOleh": @Html.Raw(closingStockList.DiperbaruiOleh.ToClientList(closingStockList)),
            "TanggalDiperbarui": @Html.Raw(closingStockList.TanggalDiperbarui.ToClientList(closingStockList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
