@{
    // View
    View = this;

    // Check action result
    if (masterAreaDelete.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterAreaDelete.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(masterAreaDelete.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterArea: currentTable } });
var currentPageID = ew.PAGE_ID = "delete";
var currentForm;
var fMasterAreadelete;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterAreadelete")
        .setPageId("delete")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
@masterAreaDelete.ShowPageHeader()
@masterAreaDelete.ShowMessages()
<form name="fMasterAreadelete" id="fMasterAreadelete" class="ew-form ew-delete-form" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="action" id="action" value="delete">
@foreach (string key in masterAreaDelete.RecordKeys) {
<input type="hidden" name="key_m[]" value="@key">
}
<div class="card ew-card ew-grid @(masterAreaDelete.TableGridClass)">
<div class="card-body ew-grid-middle-panel @(masterAreaDelete.TableContainerClass)" style="@(masterAreaDelete.TableContainerStyle)">
<table class="@(masterAreaDelete.TableClass)">
    <thead>
    <tr class="ew-table-header">
@if (masterAreaDelete.ID.Visible) { // masterAreaDelete.ID.Visible (begin)
        <th class="@Html.Raw(masterAreaDelete.ID.HeaderCellClass)"><span id="elh_MasterArea_ID" class="MasterArea_ID">@Html.Raw(masterAreaDelete.ID.Caption)</span></th>
} @* masterAreaDelete.ID.Visible (end) *@
@if (masterAreaDelete.Area.Visible) { // masterAreaDelete.Area.Visible (begin)
        <th class="@Html.Raw(masterAreaDelete.Area.HeaderCellClass)"><span id="elh_MasterArea_Area" class="MasterArea_Area">@Html.Raw(masterAreaDelete.Area.Caption)</span></th>
} @* masterAreaDelete.Area.Visible (end) *@
    </tr>
    </thead>
    <tbody>
@{ masterAreaDelete.RecordCount = 0; }
@while (masterAreaDelete.Recordset != null && await masterAreaDelete.Recordset.ReadAsync()) { // DN
    masterAreaDelete.RecordCount++;
    masterAreaDelete.RowCount++;

    // Set row properties
    masterAreaDelete.ResetAttributes();
    masterAreaDelete.RowType = RowType.View; // View

    // Get the field contents
    await masterAreaDelete.LoadRowValues(masterAreaDelete.Recordset);

    // Render row
    await masterAreaDelete.RenderRow();
    <tr @Html.Raw(masterAreaDelete.RowAttributes)>
@if (masterAreaDelete.ID.Visible) { // masterAreaDelete.ID.Visible (begin)
        <td @Html.Raw(masterAreaDelete.ID.CellAttributes)>
<span id="">
<span @Html.Raw(masterAreaDelete.ID.ViewAttributes)>
@Html.Raw(masterAreaDelete.ID.GetViewValue())</span>
</span></td>
} @* masterAreaDelete.ID.Visible (end) *@
@if (masterAreaDelete.Area.Visible) { // masterAreaDelete.Area.Visible (begin)
        <td @Html.Raw(masterAreaDelete.Area.CellAttributes)>
<span id="">
<span @Html.Raw(masterAreaDelete.Area.ViewAttributes)>
@Html.Raw(masterAreaDelete.Area.GetViewValue())</span>
</span></td>
} @* masterAreaDelete.Area.Visible (end) *@
    </tr>
}
@{ masterAreaDelete.CloseRecordset(); }
</tbody>
</table>
</div>
</div>
<div class="ew-buttons ew-desktop-buttons">
<button class="btn btn-primary ew-btn" name="btn-action" id="btn-action" type="submit">@Html.Raw(Language.Phrase("DeleteBtn"))</button>
<button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-href="@AppPath(masterAreaDelete.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
</div>
</form>
@masterAreaDelete.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
