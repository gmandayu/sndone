<span id="el@(prosesList.RowIndex == "$rowindex$" ? "$rowindex$" : prosesList.RowCount)_Proses_TanggalDiperbarui" class="el_Proses_TanggalDiperbarui">
<span @Html.Raw(prosesList.TanggalDiperbarui.ViewAttributes)>
@Html.Raw(prosesList.TanggalDiperbarui.GetViewValue())</span>
</span>
</td>
    } @* prosesList.TanggalDiperbarui.Visible (end) *@
    @* Render list options (body, right) *@
    @prosesList.ListOptions.RenderBody("right", prosesList.RowCount)
    </tr>
    } @* End if *@

    // Reset for template row
    if (SameString(prosesList.RowIndex, "$rowindex$"))
        prosesList.RowIndex = 0;

    // Reset inline add/copy row
    if ((prosesList.IsCopy || prosesList.IsAdd) && prosesList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        prosesList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(prosesList.CurrentAction) && !prosesList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
@{ prosesList.CloseRecordset(); }
@if (!prosesList.IsExport()) {
<div class="card-footer ew-grid-lower-panel">
@if (!prosesList.IsGridAdd && !(prosesList.IsGridEdit && prosesList.ModalGridEdit) && !prosesList.IsMultiEdit) {
@Html.Raw(prosesList.Pager.Render())
}
<div class="ew-list-other-options">
@prosesList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@prosesList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @prosesList.FooterOptions.RenderBody()
</div>
</main>
@prosesList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
