<script>
loadjs.ready("load", function() {
    // Startup script
    $('.ew-search-operator').hide();
    $('.ew-search-and').hide();
    $('.ew-search-field2').addClass('ew-search-field').removeClass('ew-search-field2');
    $('.ew-search-field').addClass('align-items-center');
    $('.modal-header').addClass('bg-primary');
    const fromEl = '<p class="p-0 m-0 fw-bold me-2" style="width: 80px;">Start Date</p>';
    const toEl = '<p class="p-0 m-0 fw-bold mx-2" style="width: 70px;">End Date</p>';
    $('#datetimepicker_fPenerimaansearch_x_TanggalSandar').before(fromEl);
    $('#datetimepicker_fPenerimaansearch_y_TanggalSandar').before(toEl);
    $('#datetimepicker_fPenerimaansearch_x_TanggalDibuat').before(fromEl);
    $('#datetimepicker_fPenerimaansearch_y_TanggalDibuat').before(toEl);
    $('#datetimepicker_fPenerimaansearch_x_TanggalDiperbarui').before(fromEl);
    $('#datetimepicker_fPenerimaansearch_y_TanggalDiperbarui').before(toEl);
});
</script>
