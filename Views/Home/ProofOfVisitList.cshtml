@if (!proofOfVisitList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(proofOfVisitList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { ProofOfVisit: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(proofOfVisitList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(proofOfVisitList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(proofOfVisitList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(proofOfVisitList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "LinkRedirect": @Html.Raw(proofOfVisitList.LinkRedirect.ToClientList(proofOfVisitList)),
            "Plant": @Html.Raw(proofOfVisitList.Plant.ToClientList(proofOfVisitList)),
            "TotalPengisian": @Html.Raw(proofOfVisitList.TotalPengisian.ToClientList(proofOfVisitList)),
            "Catatan": @Html.Raw(proofOfVisitList.Catatan.ToClientList(proofOfVisitList)),
            "DibuatOleh": @Html.Raw(proofOfVisitList.DibuatOleh.ToClientList(proofOfVisitList)),
            "DiperbaruiOleh": @Html.Raw(proofOfVisitList.DiperbaruiOleh.ToClientList(proofOfVisitList)),
            "TanggalDiperbarui": @Html.Raw(proofOfVisitList.TanggalDiperbarui.ToClientList(proofOfVisitList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
