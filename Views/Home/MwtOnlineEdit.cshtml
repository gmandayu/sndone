    loadjs.ready("head", function() {
        $('#btnDownloadAll').on('click', function() {
            const noMwt = "@mwtOnlineEdit.NoMWTOnline.CurrentValue";
            ew.alert("Preparing download...", "info");
            $.ajax({
                url: parent_url + 'api/LookUpList/DownloadMwtZip',
                type: 'GET',
                data: { noMwt: noMwt },
                xhrFields: { responseType: 'blob' },
                success: function(blob, status, xhr) {
                    if (blob.type === "application/json") {
                        const reader = new FileReader();
                        reader.onload = function() {
                            const result = JSON.parse(this.result);
                            ew.alert(result.message || "Download failed.");
                        };
                        reader.readAsText(blob);
                        return;
                    }
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `MWT_Files_${noMwt}.zip`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                    Swal.close();
                },
                error: function(xhr) {
                    if (xhr.status === 404) {
                        ew.alert("No files found to download.");
                    } else {
                        ew.alert("Failed to download files.");
                    }
                }
            });
        });
    });
    function getChatIcon(fileType) {
    if (!fileType) return "fa-file";
        const mime = fileType.toLowerCase();
        if (mime.startsWith("image/")) {
            return "fa-file-image";
        }
        if (mime === "application/pdf") {
            return "fa-file-pdf";
        }
        if ([
            "application/msword",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
        ].includes(mime)) {
            return "fa-file-word";
        }
        if ([
            "application/vnd.ms-excel",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        ].includes(mime)) {
            return "fa-file-excel";
        }
        if ([
            "application/zip",
            "application/x-zip-compressed",
            "application/x-rar-compressed"
        ].includes(mime)) {
            return "fa-file-archive";
        }
        return "fa-file";
    }
    function initMwtChat() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/mwtChatHub')
            .withAutomaticReconnect()
            .build();
        console.log(connection);
        if (!connection) {
            console.log("Global SignalR not found, retrying in 500ms...");
            setTimeout(initMwtChat, 500);
            return;
        }
        const currentNoMwt = "@mwtOnlineEdit.NoMWTOnline.CurrentValue";
        const currentUser = "@CurrentUserName()";
        connection.off("ReceiveMwtMessage");
        connection.on("ReceiveMwtMessage", function (sender, message, fileUrl, fileType, originalName, date, newId) {
            const isMe = sender.toLowerCase() === currentUser.toLowerCase();
            let fileHtml = '', chatIcon = '';
            if (fileUrl) {
                chatIcon = getChatIcon(fileType);
                if (chatIcon == 'fa-file-image') {
                    fileHtml = `
                    <div class="${message ? 'mt-1' : ''}">
                        <button type="button" class="img-wrapper position-relative btn-download btn p-0" style="height: 200px;" data-id="${newId}">
                            <div class="img-skeleton w-100 h-100 position-absolute top-0 start-0 d-flex align-items-center justify-content-center">
                                <div class="spinner-border ${isMe ? 'text-white' : 'text-primary'}" style="width: 3rem; height: 3rem;"></div>
                            </div>
                            <img class="preview-image w-100 opacity-0" style="max-height: 200px;" src="" alt="${originalName}" data-id="${newId}" loading="lazy">
                            <div class="img-overlay">
                                <i class="fa fa-download text-primary"></i>
                            </div>
                        </button>
                    </div>`;
                } else {
                    fileHtml = `
                    <div class="${message ? 'border-top border-white-50 mt-1 pt-2' : ''}">
                        <button type="button" data-id="${newId}" class="btn d-flex align-items-center text-decoration-none p-2 rounded btn-download ${isMe ? 'bg-white bg-opacity-10 text-white' : 'bg-light text-dark'}">
                            <i class="fas ${chatIcon} fa-lg me-2"></i>
                            <span class="text-truncate" style="max-width: 200px;">${originalName || 'Download File'}</span>
                            <i class="fas fa-download ms-2 small"></i>
                        </button>
                    </div>`;
                }
            }
            let bubbleHtml = `
                <div class="message-wrapper ${isMe ? 'right' : 'left'}">
                    <div class="bubble ${isMe ? 'right' : 'left'}">
                        ${message ? message.replace(/\n/g, '<br>') : ''}
                        ${fileHtml}
                    </div>
                    <div class="message-info">
                        <span>${sender}</span> • ${date}
                    </div>
                </div>
            `;
            $('#chatBody').append(bubbleHtml);
            const cb = document.getElementById('chatBody');
            if(cb) cb.scrollTop = cb.scrollHeight;
            if (fileUrl && chatIcon == 'fa-file-image') {
                const img = $(`img.preview-image[data-id="${newId}"]`);
                const wrapper = img.closest('.img-wrapper');
                const skeleton = wrapper.find('.img-skeleton');
                const overlay = wrapper.find('.img-overlay');
                $.ajax({
                    url: parent_url + `api/LookUpList/GetPreviewDocument?id=${newId}`,
                    type: "GET",
                    xhrFields: { responseType: 'blob', withCredentials: true },
                    success: function (blob) {
                        const url = URL.createObjectURL(blob);
                        img.attr('src', url);
                        img.removeClass('opacity-0').addClass('opacity-100');
                        skeleton.removeClass('opacity-100').addClass('opacity-0');
                    }
                });
            }
        });
        if (connection.state === "Connected") {
            connection.invoke("JoinMwtGroup", currentNoMwt).catch(err => console.error(err));
        } else {
            connection.start().then(() => {
                connection.invoke("JoinMwtGroup", currentNoMwt).catch(err => console.error(err));
            });
        }
        $('#chatFileInput').off('change').on('change', function() {
            const newFiles = Array.from(this.files);
            if (newFiles.length === 0) return;
            let currentTotalSize = 0;
            selectedFiles.forEach(f => currentTotalSize += f.size);
            let newBatchSize = 0;
            newFiles.forEach(f => newBatchSize += f.size);
            if (currentTotalSize + newBatchSize > 50 * 1024 * 1024) {
                ew.alert("Total file size is too large (Max 50MB).");
                $(this).val('');
                return;
            }
            selectedFiles = selectedFiles.concat(newFiles);
            updateFileChipUI();
            $(this).val('');
        });
        function updateFileChipUI() {
            if (selectedFiles.length === 0) {
                $('#filePreviewChip').hide();
                $('#fileNamePreview').text('');
                return;
            }
            $('#filePreviewChip').css('display', 'flex');
            $('#fileNamePreview').css('color', 'green');
            if (selectedFiles.length === 1) {
                $('#fileNamePreview').text(selectedFiles[0].name);
            } else {
                // Show total count of accumulated files
                $('#fileNamePreview').text(selectedFiles.length + " files selected");
            }
        }
        $('#btnSendChat').off('click').on('click', function() {
            sendMessage(connection, currentNoMwt, currentUser);
        });
        $('#chatMessageInput').off('keypress').on('keypress', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage(connection, currentNoMwt, currentUser);
            }
        });
        $('#btnCompleteTask').on('click', function() {
            ew.prompt("Are you sure you want to mark this task as Completed?", function(result) {
                if (result) {
                    $.post(ew.PATH_BASE + "api/LookUpList/CompleteMWT", { id: "@mwtOnlineEdit.Id.CurrentValue" }, function(res) {
                        if (res.success) {
                            sendComplete(connection, currentNoMwt, currentUser);
                            setTimeout(function () {
                                ew.alert("Task Completed Successfully!", function() {
                                    location.reload();
                                });
                            }, 2000);
                        } else {
                            ew.alert(res.message);
                        }
                    }).fail(function(xhr) {
                        ew.alert("Error: " + xhr.responseText);
                    });
                }
            });
        });
        connection.on("ReceiveMwtCompleted", function (sender) {
            if (sender != currentUser) {
                setTimeout(function () {
                    ew.alert("Status MWT Online telah berubah!", function() {
                        location.reload();
                    });
                }, 1000);
            }
        });
    }
    async function sendComplete(conn, noMwt, user) {
        conn.invoke("SendMwtCompleted", noMwt, user)
            .catch(err => console.error(err.toString()));
    }
    async function sendMessage(conn, noMwt, user) {
        let uploadedFilesData = [];
        const message = $('#chatMessageInput').val().trim();
        if (!message && selectedFiles.length === 0) return;
        if (selectedFiles.length > 0) {
            const formData = new FormData();
            // Append all files with the same key "files" so ASP.NET binds to List<IFormFile>
            selectedFiles.forEach(file => {
                formData.append("files", file);
            });
            $('#fileNamePreview').text("Uploading " + selectedFiles.length + " files...");
            try {
                const res = await $.ajax({
                    url: parent_url + "api/LookUpList/uploadChatFiles",
                    type: "POST",
                    data: formData,
                    contentType: false,
                    processData: false
                });
                if (res.success) {
                    uploadedFilesData = res.files;
                } else {
                    throw new Error("Server returned success:false");
                }
            } catch (err) {
                ew.alert("Upload file gagal.");
                console.log(err);
                $('#fileNamePreview').text("Error!");
                return;
            }
        }
        conn.invoke("SendMwtBatchMessage", noMwt, user, message, uploadedFilesData, parseInt(idPlant))
            .catch(err => console.error(err.toString()));
        $('#chatMessageInput').val('');
        $('#chatMessageInput').css('height', '40px');
        clearFile();
    }
    function clearFile() {
        $('#chatFileInput').val('');
        selectedFiles = [];
        $('#filePreviewChip').hide();
        $('#fileNamePreview').text('');
        chatFileUrl = null;
        chatFileType = null;
        chatFileOriginalName = null;
    }
    $(document).ready(function () {
        $('.preview-image').each(function () {
            const img = $(this);
            const wrapper = img.closest('.img-wrapper');
            const skeleton = wrapper.find('.img-skeleton');
            const overlay = wrapper.find('.img-overlay');
            const id = img.data('id');
            $.ajax({
                url: parent_url + `api/LookUpList/GetPreviewDocument?id=${id}`,
                type: "GET",
                xhrFields: { responseType: 'blob', withCredentials: true },
                success: function (blob) {
                    const url = URL.createObjectURL(blob);
                    img.attr('src', url);
                    img.removeClass('opacity-0').addClass('opacity-100');
                    skeleton.removeClass('opacity-100').addClass('opacity-0');
                }
            });
        });
        $('.status-mwt').addClass(`status-indicator status-${normalizeStatus(statusMwt)}`);
    });
</script></div>
</template>
