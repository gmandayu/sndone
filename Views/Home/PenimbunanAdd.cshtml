@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("Penimbunan");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    var parent_url = ew.PATH_BASE;
    $('#r_PlantForLookup').hide();
    $('#r_NomorPenimbunan').hide();
    $('#r_LookupJenisPlant').hide();
    $('#r_TipeProdukSTS').hide();
    $('#r_Plant').hide();
    $('#r_IdPenerimaan').hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant?Menu=Penimbunan',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty();
                $.each(data, function (index, item) {
                    ddl.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
                if (Array.isArray(data) && data.length > 0) {
                    const first = data[0];
                    ddl.val(first.Value).trigger('change');
                }
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Proses Penerimaan.');
            setTimeout(() => {
                window.location.href = parent_url+'PenimbunanList';
            }, 1000);
        }
    });

    // Ensure Plant is set before opening IdPenerimaan (lookup uses Plant as parent)
    $("#x_IdPenerimaan").on('select2:opening', function (e) {
        const plantVal = $('#x_Plant').val();
        if (!plantVal) {
            const lpVal = $('#x_LookupPlant').val();
            const lpText = $('#x_LookupPlant').find('option:selected').text();
            if (lpVal) {
                $('#x_Plant').val(lpVal).trigger('change');
                $('#sv_x_Plant').val(lpText || '');
            } else {
                ew.alert('Silakan pilih Plant terlebih dahulu');
                e.preventDefault();
            }
        }
    });
    $("#x_Plant").prop("readonly", true);
});
</script>
