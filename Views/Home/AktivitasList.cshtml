    @if (aktivitasList.IsTankEmptyAndDry.Visible) { // aktivitasList.IsTankEmptyAndDry.Visible (begin)
        <td data-name="IsTankEmptyAndDry" @Html.Raw(aktivitasList.IsTankEmptyAndDry.CellAttributes)>
<span id="el@(aktivitasList.RowIndex == "$rowindex$" ? "$rowindex$" : aktivitasList.RowCount)_Aktivitas_IsTankEmptyAndDry" class="el_Aktivitas_IsTankEmptyAndDry">
<span @Html.Raw(aktivitasList.IsTankEmptyAndDry.ViewAttributes)>
<i class="fa-regular @(ConvertToBool(aktivitasList.IsTankEmptyAndDry.CurrentValue) ? "fa-square-check" : "fa-square") ew-icon ew-boolean"></i>
</span>
</span>
</td>
    } @* aktivitasList.IsTankEmptyAndDry.Visible (end) *@
    @if (aktivitasList.IsDocumentationComplete.Visible) { // aktivitasList.IsDocumentationComplete.Visible (begin)
        <td data-name="IsDocumentationComplete" @Html.Raw(aktivitasList.IsDocumentationComplete.CellAttributes)>
<span id="el@(aktivitasList.RowIndex == "$rowindex$" ? "$rowindex$" : aktivitasList.RowCount)_Aktivitas_IsDocumentationComplete" class="el_Aktivitas_IsDocumentationComplete">
<span @Html.Raw(aktivitasList.IsDocumentationComplete.ViewAttributes)>
<i class="fa-regular @(ConvertToBool(aktivitasList.IsDocumentationComplete.CurrentValue) ? "fa-square-check" : "fa-square") ew-icon ew-boolean"></i>
</span>
</span>
</td>
    } @* aktivitasList.IsDocumentationComplete.Visible (end) *@
    @* Render list options (body, right) *@
    @aktivitasList.ListOptions.RenderBody("right", aktivitasList.RowCount)
    </tr>
    } @* End if *@

    // Reset for template row
    if (SameString(aktivitasList.RowIndex, "$rowindex$"))
        aktivitasList.RowIndex = 0;

    // Reset inline add/copy row
    if ((aktivitasList.IsCopy || aktivitasList.IsAdd) && aktivitasList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        aktivitasList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(aktivitasList.CurrentAction) && !aktivitasList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
@{ aktivitasList.CloseRecordset(); }
@if (!aktivitasList.IsExport()) {
<div class="card-footer ew-grid-lower-panel">
@if (!aktivitasList.IsGridAdd && !(aktivitasList.IsGridEdit && aktivitasList.ModalGridEdit) && !aktivitasList.IsMultiEdit) {
@Html.Raw(aktivitasList.Pager.Render())
}
<div class="ew-list-other-options">
@aktivitasList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@aktivitasList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @aktivitasList.FooterOptions.RenderBody()
</div>
</main>
@aktivitasList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!aktivitasList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("Aktivitas");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    $('[data-widget="expandable-table"]').removeAttr("data-widget");
    $('[data-name="preview"]').hide();
    $('[data-name="button"]').hide();
    $('[data-name="detail_AktivitasDokumen"]').hide();
    var IdReferensi = "@aktivitasList.No_Referensi.CurrentValue";
    var TipeProses = "@aktivitasList.TipeProses.CurrentValue";
    var TipeProsesView = "@aktivitasList.TipeProses.CurrentValue";
    let iconProses = "";
    if (TipeProses == "Penerimaan" || TipeProses == "PenerimaanSTSBBM" || TipeProses == "PenerimaanSTSLPG" || 
        TipeProses == "PenerimaanPipa" || TipeProses == "PenerimaanSalesPipa" || TipeProses == "PenerimaanRTW" ||
        TipeProses == "PenerimaanTruck" || TipeProses == "PenerimaanPipaRefinery") {
        TipeProses = "Penerimaan";
        TipeProsesView = "Penerimaan";
        iconProses = "fa-box-open";
    } else if (TipeProses == "Penyaluran" || TipeProses == "PenyaluranTasNgs" || TipeProses == "PenyaluranTruck" ||  
               TipeProses == "PenyaluranLPGTASNGS" || TipeProses == "PenyaluranKonsinyasiSTSBBM" || 
               TipeProses == "PenyaluranKonsinyasiSTSLPG" || TipeProses == "PenyaluranPipa" || TipeProses == "PenyaluranSalesPipa" ||
               TipeProses == "PenyaluranPipaLPG" || TipeProses == "PenyaluranKonsinyasiRTW" || TipeProses == "PenyaluranPipaJarakDekat"){
        TipeProses = "Penyaluran";
        TipeProsesView = "Proses Penyaluran";
        iconProses = "fa-truck-fast";
    } else if (TipeProses == "RencanaPenyaluran" || TipeProses == "RencanaPenyaluranLPG" || TipeProses == "RencanaPenyaluranPipa") {
        TipeProses = "RencanaPenyaluran";
        TipeProsesView = "Rencana & Realisasi Penyaluran";
        iconProses = "fa-solid fa-clipboard-list";
    } else if (TipeProses == "SamplingLabTest") {
        TipeProsesView = "Sampling Lab Test";
        iconProses = "fa-flask";
    } else if (TipeProses == "Penimbunan" || TipeProses == "PenyimpananPenerimaanLPG" || 
               TipeProses == "PenyimpananPenerimaanSTSBBM" || TipeProses == "PenyimpananPenerimaanLPGSTS" || 
               TipeProses == "PenyimpananPenerimaanPipa" || TipeProses == "PenyimpananPenerimaanPipaLPG" ||
               TipeProses == "PenyimpananPenerimaanRTW" || TipeProses == "PenyimpananPenerimaanTruck") {
        TipeProses = "Penimbunan";
        TipeProsesView = "Proses Penerimaan";
        iconProses = "fa-oil-can";
    } else if (TipeProses == "PenimbunanPenyaluran" || TipeProses == "PenimbunanPenyaluranLPG" || 
               TipeProses == "PenyimpananPenyaluranSalesSTSBBM" || TipeProses == "PenyimpananPenyaluranKonsinyasiSTSBBM" || 
               TipeProses == "PenyimpananPenyaluranSalesPipa" || TipeProses == "PenyimpananPenyaluranKonsinyasiPipa" ||
               TipeProses == "PenyimpananPenyaluranSalesSTSLPG" || TipeProses == "PenyimpananPenyaluranKonsinyasiSTSLPG" || TipeProses == "PenyimpananPenyaluranSalesRTW") {
        TipeProses = "PenimbunanPenyaluran";
        TipeProsesView = "Proses Penyaluran";
        iconProses = "fa-route";
    } else if (TipeProses == "ClosingStock" || TipeProses == "ClosingStockSTSBBM" || TipeProses == "ClosingStockSTSLPG") {
        TipeProses = "ClosingStock";
        TipeProsesView = "Closing Stock";
        iconProses = "fa-inbox";
    } else if (['PenyimpananPenyaluranKonsinyasiRTW', 'PenyimpananPenyaluranKonsinyasi'].includes(TipeProses)) {
        TipeProses = 'PenimbunanPenyaluran';
        TipeProsesView = 'Proses Penyaluran';
        iconProses = 'fa-route';
    } else if (['PenyaluranKonsinyasiTruck', 'PenyaluranKonsinyasiTruckTAS'].includes(TipeProses)) {
        TipeProses = "Penyaluran";
        TipeProsesView = "Proses Penyaluran";
        iconProses = "fa-truck-fast";
    }
    var parent_url = ew.PATH_BASE;
    var steps = [
        { number: 1, label: TipeProsesView, url: `${parent_url}${TipeProses}List`, icon: iconProses },
        { number: 2, label: "Proses", url: `${parent_url}ProsesList?cmd=search&x_IdReferensi%5B%5D=${IdReferensi}&search=&searchtype=`, icon: "fa-gears" },
        { number: 3, label: "Aktivitas", url: '', icon: "fa-list-check" },
    ];
    var currentStep = 3;
    $("<style>")
        .prop("type", "text/css")
        .html(`
            .stepper {
                display: flex;
                counter-reset: step;
            }
            .step {
                width: 150px;
                text-align: center;
                position: relative;
            }
            .step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 20px;
                right: -50%;
                width: 100%;
                height: 4px;
                background-color: #ccc;
                z-index: 0;
            }
            .step.completed:not(:last-child)::after {
                background-color: #3c6dbd;
            }
            .step-icon {
                width: 36px;
                height: 36px;
                line-height: 36px;
                border-radius: 50%;
                background: #ccc;
                display: inline-block;
                z-index: 1;
                position: relative;
                color: white;
                font-weight: bold;
            }
            .step.active .step-icon {
                background: #3c6dbd;
            }
            .step-label {
                margin-top: 8px;
                font-size: 14px;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 6px;
                color: #333;
            }
            .step-label {
                color: #3c6dbd !important;
                text-decoration: none;
                margin: 0;
                padding: 0;
            }
            .step-label-not-active {
                color: #CCCCCC !important;
            }

            /* warna selector */
            [data-bs-theme=light] .ew-grid .ew-table {
                --bs-table-active-bg: #98caef;
                --bs-table-active-color: #1d3343;
            }
            [data-bs-theme=light] .ew-grid .ew-table .table-active a  {
                color: #1d3343; /* Sesuaikan dengan active-color */
                text-decoration: underline; /* Optional */
            }
            [data-bs-theme=light] .ew-grid .ew-table a:hover {
                color: #0d1a23; /* Lebih gelap saat hover (optional) */
            }
            .table-hover>tbody>tr.table-active:hover>* {
                background-color: #77aacf !important;
                color: var(--primary-white) !important;
            }
        `)
        .appendTo("head");
    var $stepperWrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    var $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        var isActive = step.number === currentStep;
        var isCompleted = step.number < currentStep;
        var stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        var icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #3c6dbd;">${step.number}</div>`;
            labelContent = `<div class="step-label"><a href="${step.url}" class="text-primary"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    $(".content-header .container-fluid .row").append($stepperWrapper);
    $(document).ready(function () {
       let idProses = getURLParameter("x_IdProses[]") || [];
        if (idProses.length > 0) {
            idProses = idProses[0];
            createTextProses(idProses);
        }
    });
    function createTextProses(idReferensi) {
        $.ajax({
            url: parent_url + `api/LookUpList/get_referensi_detail?idProses=${idReferensi}`,
            type: 'GET',
            success: function (res) {
                // let produk = res.NamaProduk;
                // let tanggal = res.TanggalDibuat;
                // let kapal = res.NomorKendaraan;
                // let nomorPengiriman = res.NomorPengiriman;
                // let tanggalAktifitas = res.TanggalAktifitas;
                // let namaAktivitas = res.NamaAktivitas;

                // let detail = "";

                // // if (namaAktivitas) detail += ` Nama Aktivitas: <span style="color: red">${namaAktivitas}</span>`;
                // if (produk) detail += ` Produk: <span style="color: red">${produk}</span>`;
                // if (tanggal) detail += ` Dibuat: <span style="color: red">${tanggal}</span>`;
                // if (kapal) detail += ` Kendaraan: <span style="color: red">${kapal}</span>`;
                // if (nomorPengiriman) detail += ` No Pengiriman: <span style="color: red">${nomorPengiriman}</span>`;
                // if (tanggalAktifitas) detail += ` Tanggal Aktifitas: <span style="color: red">${tanggalAktifitas}</span>`;

                // if (detail) detail = ` , ${detail}`
                let namaJudul = res.namaJudul;
                let resultHtml = `<span class="ms-3" style="font-weight: bold; font-style: italic;">
                                    ${namaJudul} 
                                  </span>` ;

                    // Sisipkan setelah tombol export
                $(".ew-filter-option").after(resultHtml);
            },
            error: function (xhr, status, error) {
                console.error('Gagal update status aktivitas:', status, error);
            }
        })
    }
    function getURLParameter(param) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.has(param) ? urlParams.getAll(param) : null;
    }
});
</script>
}
