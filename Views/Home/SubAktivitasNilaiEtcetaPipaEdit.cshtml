<template id="tpm_SubAktivitasNilaiETCETAPipaedit">
<div id="ct_subAktivitasNilaiEtcetaPipaEdit">@{
    List<Dictionary<string, object>> resultList = new List<Dictionary<string, object>>();
    string NoReferensi = subAktivitasNilaiEtcetaPipaEdit.NoReferensi.CurrentValue?.ToString();
    string IdAktivitas = subAktivitasNilaiEtcetaPipaEdit.idAktifitas.CurrentValue?.ToString();
    string TipeProses = "", Caption = "(KL/Jam)";
    string sqlQuery = @"
        SELECT
            SA.id,
            SA.IsiPipa,
            SA.LamaPengiriman,
            SA.ETA,
            CONCAT(MP.Plant, ' - ', MP.Nama_Terminal) AS Tujuan
        FROM SubAktivitasAnakNilaiETCETAPipa SA
        LEFT JOIN MasterPlant MP ON SA.idPlantTujuan = MP.IdPlant
        WHERE NoReferensi = @NoReferensi
    ";
    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection()) {
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection)) {
            command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
            using (SqlDataReader rs = command.ExecuteReader()) {
                while (rs.Read()) {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++) {
                        row[rs.GetName(i)] = rs[i] != null? rs[i] : "";
                    }
                    resultList.Add(row);
                }
            }
        }
        sqlQuery = "SELECT TOP 1 TipeProses FROM Aktivitas WHERE IdAktivitas = @IdAktivitas";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection)) {
            command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
            using (SqlDataReader rs = command.ExecuteReader()) {
                if (rs.Read()) {
                    TipeProses = rs[0] != null? rs[0].ToString() : "";
                }
            }
        }
        if (TipeProses == "PenyaluranPipaLPG") {
            Caption = "(MT/Jam)";
        }
    }
}
