                else if (StatusAktivitas == "Draft")
                {
                    <button id="btn-save" data-nextstatus="Draft" class="btn btn-primary ew-btn">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Save
                    </button>
                    <button id="btn-submit" data-nextstatus="Completed" class="btn btn-success ew-btn">
                        <i class="fa-solid fa-paper-plane me-1"></i> Submit
                    </button>
