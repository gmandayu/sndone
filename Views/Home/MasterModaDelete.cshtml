@{
    // View
    View = this;

    // Check action result
    if (masterModaDelete.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterModaDelete.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(masterModaDelete.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterModa: currentTable } });
var currentPageID = ew.PAGE_ID = "delete";
var currentForm;
var fMasterModadelete;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterModadelete")
        .setPageId("delete")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    $('#fMasterModadelete').on('submit', function (e) {
        e.preventDefault();
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
});
</script>
@masterModaDelete.ShowPageHeader()
@masterModaDelete.ShowMessages()
<form name="fMasterModadelete" id="fMasterModadelete" class="ew-form ew-delete-form" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="action" id="action" value="delete">
@foreach (string key in masterModaDelete.RecordKeys) {
<input type="hidden" name="key_m[]" value="@key">
}
<div class="card ew-card ew-grid @(masterModaDelete.TableGridClass)">
<div class="card-body ew-grid-middle-panel @(masterModaDelete.TableContainerClass)" style="@(masterModaDelete.TableContainerStyle)">
<table class="@(masterModaDelete.TableClass)">
    <thead>
    <tr class="ew-table-header">
@if (masterModaDelete.IdModa.Visible) { // masterModaDelete.IdModa.Visible (begin)
        <th class="@Html.Raw(masterModaDelete.IdModa.HeaderCellClass)"><span id="elh_MasterModa_IdModa" class="MasterModa_IdModa">@Html.Raw(masterModaDelete.IdModa.Caption)</span></th>
} @* masterModaDelete.IdModa.Visible (end) *@
@if (masterModaDelete.NamaModa.Visible) { // masterModaDelete.NamaModa.Visible (begin)
        <th class="@Html.Raw(masterModaDelete.NamaModa.HeaderCellClass)"><span id="elh_MasterModa_NamaModa" class="MasterModa_NamaModa">@Html.Raw(masterModaDelete.NamaModa.Caption)</span></th>
} @* masterModaDelete.NamaModa.Visible (end) *@
    </tr>
    </thead>
    <tbody>
@{ masterModaDelete.RecordCount = 0; }
@while (masterModaDelete.Recordset != null && await masterModaDelete.Recordset.ReadAsync()) { // DN
    masterModaDelete.RecordCount++;
    masterModaDelete.RowCount++;

    // Set row properties
    masterModaDelete.ResetAttributes();
    masterModaDelete.RowType = RowType.View; // View

    // Get the field contents
    await masterModaDelete.LoadRowValues(masterModaDelete.Recordset);

    // Render row
    await masterModaDelete.RenderRow();
    <tr @Html.Raw(masterModaDelete.RowAttributes)>
@if (masterModaDelete.IdModa.Visible) { // masterModaDelete.IdModa.Visible (begin)
        <td @Html.Raw(masterModaDelete.IdModa.CellAttributes)>
<span id="">
<span @Html.Raw(masterModaDelete.IdModa.ViewAttributes)>
@Html.Raw(masterModaDelete.IdModa.GetViewValue())</span>
</span></td>
} @* masterModaDelete.IdModa.Visible (end) *@
@if (masterModaDelete.NamaModa.Visible) { // masterModaDelete.NamaModa.Visible (begin)
        <td @Html.Raw(masterModaDelete.NamaModa.CellAttributes)>
<span id="">
<span @Html.Raw(masterModaDelete.NamaModa.ViewAttributes)>
@Html.Raw(masterModaDelete.NamaModa.GetViewValue())</span>
</span></td>
} @* masterModaDelete.NamaModa.Visible (end) *@
    </tr>
}
@{ masterModaDelete.CloseRecordset(); }
</tbody>
</table>
</div>
</div>
<div class="ew-buttons ew-desktop-buttons">
<button class="btn btn-primary ew-btn" name="btn-action" id="btn-action" type="submit">@Html.Raw(Language.Phrase("DeleteBtn"))</button>
<button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-href="@AppPath(masterModaDelete.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
</div>
</form>
@masterModaDelete.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
