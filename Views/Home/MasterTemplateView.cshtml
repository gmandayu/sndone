@{
    // View
    View = this;

    // Check action result
    if (masterTemplateView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterTemplateView.UseLayout ? "_Layout" : "";
}
@if (!masterTemplateView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @masterTemplateView.ExportOptions.RenderBody()
    @masterTemplateView.OtherOptions.RenderBody()
</div>
}
@masterTemplateView.ShowPageHeader()
@masterTemplateView.ShowMessages()
<main class="view">
<form name="fMasterTemplateview" id="fMasterTemplateview" class="ew-form ew-view-form overlay-wrapper" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (!masterTemplateView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterTemplateView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterTemplate: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fMasterTemplateview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterTemplateview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="modal" value="@ConvertToInt(masterTemplateView.IsModal)">
<table class="@(masterTemplateView.TableClass)">
