            <div class="d-flex gap-3 align-items-center">
                <slot class="ew-slot" name="tpx_SetPjs_DiperbaharuiOleh"></slot>
                <button type="button" class="btn btn-primary ew-btn ps-2" expand-log="false">
                    <i class="fa-solid fa-caret-right fa-2xl me-2 caret-icon rotate-right"></i>
                    Log History
                    <i class="fa-solid fa-clock-rotate-left ms-1"></i> 
                </button>
            </div>
            <div id="log-table-row" class="d-none row m-0">
                <div class="p-0">
                    <div id="log-table-wrapper" style="overflow: hidden; transition: all 0.6s ease; max-height: 0;">
                        <div id="myGrid" class="ag-theme-quartz w-75 my-3" style="height: 300px;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row pb-3 border-bottom">
        <div class="col-2 fw-bold d-flex align-items-center">
            Tanggal Diperbaharui
        </div>
        <div class="col-10 d-flex gap-3">
            <slot class="ew-slot" name="tpx_SetPjs_DiperbaharuiTanggal"></slot>
