@if (!proofOfVisitView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(proofOfVisitView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { ProofOfVisit: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fProofOfVisitview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fProofOfVisitview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
