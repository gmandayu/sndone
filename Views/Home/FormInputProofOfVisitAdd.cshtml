<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    const NoReferensi = "@HttpContext.Request.Query["NoReferensi"]";
    //const currentUserName = '@CurrentUserInfo("NamaLengkap")';
    const currentUserName = '@CurrentUserName()';
    if (!NoReferensi) {
        ew.alert('URL Tidak Valid');
        setTimeout(function() {
            history.back();
        }, 1000);
    }
    const selfieTrigger = $("#selfie-trigger");
    const selfiePreview = $("#selfie-preview");
    const cameraView = $("#camera-view");
    const selfieVideo = document.getElementById("selfie-video");
    const captureButton = $("#capture-button");
    const cancelCaptureButton = $("#cancel-capture-button");

    // Get references to other form elements that need to be disabled
    const formInputsToDisable = $(`
        #x_Tanggal, 
        #x_Lokasi, 
        #x_Keterangan,
        #x_Ketidaksesuaiaan, 
        #fileInput, 
        #fileName, 
        #btn-submit-custom
    `);
    let selfieBlob = null;
    let stream = null;
    formInputsToDisable.prop("disabled", true).css("background-color", "#e9ecef");
    $("#fileName").parent().css("cursor", "not-allowed").off("click");
    selfieTrigger.on("click", async function() {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
            try {
                // Request front camera
                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'user' }
                });
                cameraView.show();
                selfieVideo.srcObject = stream;
                selfieTrigger.hide(); // Hide the initial button
            } catch (error) {
                console.error("Error accessing camera:", error);
                ew.alert("Could not access the camera. Please ensure you are on HTTPS and have granted camera permissions.");
            }
        } else {
            ew.alert("Your browser does not support camera access.");
        }
    });
    captureButton.on("click", function() {
        const canvas = document.createElement("canvas");
        canvas.width = selfieVideo.videoWidth;
        canvas.height = selfieVideo.videoHeight;
        const context = canvas.getContext("2d");
        context.drawImage(selfieVideo, 0, 0, canvas.width, canvas.height);
        canvas.toBlob(function(blob) {
            selfieBlob = blob;
            const previewUrl = URL.createObjectURL(blob);
            selfiePreview.attr("src", previewUrl).show();
            stopCamera();
            formInputsToDisable.prop("disabled", false).css("background-color", "");
            $("#fileName").parent().css("cursor", "pointer").on("click", function() {
                $("#fileInput").trigger("click");
            });
            ew.alert("Selfie captured. You can now fill out the rest of the form.");
        }, "image/jpeg", 0.9);
    });
    cancelCaptureButton.on("click", function() {
        stopCamera();
    });
    function stopCamera() {
        if (stream) {
            stream.getTracks().forEach(track => track.stop());
        }
        cameraView.hide();
        selfieTrigger.show();
    }
    let filesArr = [];
    $("#fileName").on("click", function () {
        $("#fileInput").trigger("click");
    });
    $("#fileInput").on("change", function(e) {
        let newFiles = Array.from(e.target.files);
        filesArr = filesArr.concat(newFiles);
        $(this).val('');
        renderTable();
    });
    function renderTable(){
        let $table = $("#fileTable");
        let $tbody = $table.find("tbody");
        $tbody.empty();
        if(filesArr.length === 0){
            $('#row-table').hide();
            return;
        }
        $('#row-table').show();
        filesArr.forEach((file, index) => {
            let sizeKB = (file.size / 1024).toFixed(2);
            let row = `
                <tr>
                    <td>${index+1}</td>
                    <td>${file.name}</td>
                    <td>
                        <button class="btn text-danger btn-delete" type="button" data-index="${index}"><i class="fa-solid fa-times"></i></button>
                    </td>
                </tr>
            `;
            $tbody.append(row);
        });
    }
    $(document).on("click", ".btn-delete", function(){
        let index = $(this).data("index");
        filesArr.splice(index, 1);
        renderTable();
    });
    $(document).on("click", "#btn-cancel-custom", function(){
        window.location.href = `${parent_url}FormInputProofOfVisitList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
    });
    $("#btn-submit-custom").on("click", function(){
        if (!selfieBlob) {
            ew.alert("Selfie for verification is required!");
            return;
        }
        if(filesArr.length === 0){
            ew.alert("File tidak boleh kosong!");
            return;
        }
        if($('#NoReferensi-custom').val() === ''){
            ew.alert("Nomor Proof of Visit tidak boleh kosong!");
            return;
        }
        if($('#x_Tanggal').val() === ''){
            ew.alert("Tanggal tidak boleh kosong!");
            return;
        }
        if($('#x_Lokasi').val() === ''){
            ew.alert("Lokasi tidak boleh kosong!");
            return;
        }
        if ($('#x_Lokasi').val() === '7' && $('#x_Keterangan').val().trim() === '') {
            ew.alert("Keterangan is required when Lokasi is 'Others'.");
            return;
        }
        let recognitionFormData = new FormData();
        recognitionFormData.append("Face", selfieBlob, "verify_selfie.jpg");
        recognitionFormData.append("IdUser", "0");
        recognitionFormData.append("Username", currentUserName);
        $.ajax({
            url: parent_url + "api/LookUpList/TestFace",
            type: "POST",
            data: recognitionFormData,
            processData: false,
            contentType: false,
            success: function(rs) {
                if (rs.success && rs.confidence >= 0.5 && rs.recognizedAs === currentUserName) {
                    submitMainForm();
                } else {
                    let failureReason = "Wajah tidak dikenali atau tidak cocok.";
                    if (!rs.success) failureReason = rs.message || failureReason;
                    else if (rs.recognizedAs !== currentUserName) failureReason = `Wajah dikenali sebagai ${rs.recognizedAs}, bukan ${currentUserName}.`;
                    else if (rs.confidence < 0.5) failureReason = `Tingkat keyakinan (${rs.confidence.toFixed(3)}) terlalu rendah.`;
                    ew.alert(`Verifikasi Wajah Gagal: ${failureReason} Silakan coba lagi.`);
                }
            },
            error: function(xhr) {
                ew.alert("Gagal melakukan verifikasi wajah: " + (xhr.responseJSON?.message || xhr.responseText));
            }
        });
    });
        @* showLoading(); *@
    function submitMainForm() {
        let formData = new FormData();
        formData.append("NoReferensi", $('#NoReferensi-custom').val());
        formData.append("Tanggal", $('#x_Tanggal').val()); 
        formData.append("Lokasi", $('#x_Lokasi').val());
        formData.append("Keterangan", $('#x_Keterangan').val());
        formData.append("Ketidaksesuaiaan", $('#x_Ketidaksesuaiaan').val());
        formData.append("Menu", "POV");
        formData.append("VerifikasiMOD", selfieBlob, "selfie-verification.jpg");
        filesArr.forEach((file) => {
            formData.append("files", file);
        });
        $.ajax({
            url: parent_url + "api/LookUpList/UploadDocumentGHKandPOV",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs){
                @* hideLoading(); *@
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = `${parent_url}FormInputProofOfVisitList?cmd=search&x_NoReferensi%5B%5D=${NoReferensi}&search=&searchtype=`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr){
                @* hideLoading(); *@
                ew.alert("Upload gagal: " + xhr.responseText);
            }
        });
    };
    const $lokasiSelect = $("#x_Lokasi");
    const $keteranganLabelDiv = $('#x_Keterangan').closest('.row').find('.col-2.fw-bold');
    function toggleKeteranganMandatory() {
        const isOthersSelected = $lokasiSelect.val() === '7'; 
        const $asterisk = $keteranganLabelDiv.find("span.keterangan-required");
        if (isOthersSelected) {
            if ($asterisk.length === 0) {
                $keteranganLabelDiv.append('<span class="text-danger keterangan-required ms-1">*</span>');
            }
        } else {
            $asterisk.remove();
        }
    }
    $lokasiSelect.on("change", toggleKeteranganMandatory);
    toggleKeteranganMandatory();
});
</script>
