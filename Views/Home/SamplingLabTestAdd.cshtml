<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    $('#fSamplingLabTestadd').on('submit', function (e) {
        e.preventDefault();
        const parent_url = ew.PATH_BASE;
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && idRole != '3') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Sampling Lab Test.');
            setTimeOut(() => {
                window.location.href = parent_url+'SamplingLabTestList';
            }, 1000);
            return false;
        }

        // Ensure hidden Plant value is set before submit
        const lpVal = $('#x_LookupPlant').val();
        const hidPlantVal = $('#x_IdPlant').val();
        if (!hidPlantVal && lpVal) {
            $('#x_IdPlant').val(lpVal).trigger('change');
            const $sv = $('#sv_x_IdPlant');
            if ($sv.length) {
                const txt = $('#x_LookupPlant option:selected').text();
                $sv.val(txt || '');
            }
        }
        if (!$('#x_IdPlant').val()) {
            ew.alert('Pilih Plant terlebih dahulu.');
            return false;
        }
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
    $('#x_LookupJenisPlant').change(function () {
        if ($(this).val() == 'STS') {
            $('#r_TipeProdukSTS').show();
        } else {
            $('#r_TipeProdukSTS').hide();
            $('#x_TipeProdukSTS').val('');
        }
    });
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_IdPlant').val(selectedValue).trigger('change');
        const $sv = $('#sv_x_IdPlant');
        if ($sv.length) {
            const txt = $('#x_LookupPlant option:selected').text();
            $sv.val(txt);
        }
        $('#x_IdReferensi').val(null).trigger('change');
        const ddlIdReferensi = $("#x_LookupIdReferensi");
        ddlIdReferensi.empty();
        ddlIdReferensi.append('<option value="">Loading...</option>');
        $.ajax({
            url: `${parent_url}api/LookUpList/get-dropdown/lookup-penyaluran?idPlant=${encodeURIComponent(selectedValue)}&menu=SamplingLabTest`,
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddlIdReferensi.empty(); 
                $.each(data, function (index, item) {
                    ddlIdReferensi.append(`<option value="${item.NomorPenyaluran}">${item.NomorPenyaluran}</option>`);
                });
                ddlIdReferensi.val(null).trigger('change');
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddlIdReferensi.empty();
            }
        });
    });
    $(document).on('select2:opening', '#x_IdReferensi', function (e) {
        let plantVal = $('#x_IdPlant').val();
        if (!plantVal) {
            const lp = $('#x_LookupPlant').val();
            if (lp) {
                $('#x_IdPlant').val(lp).trigger('change');
                const $sv = $('#sv_x_IdPlant');
                if ($sv.length) {
                    const txt = $('#x_LookupPlant option:selected').text();
                    $sv.val(txt);
                }
                plantVal = lp;
            }
        }
        if (!plantVal) {
            e.preventDefault();
            ew.alert('Pilih Plant terlebih dahulu.');
        }
    });
});
</script>
