                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                    </button>
                    <button id="btn-submit" data-nextstatus="Completed Edit" class="btn btn-success ew-btn">
                        <i class="fa-solid fa-paper-plane me-1"></i> Submit
