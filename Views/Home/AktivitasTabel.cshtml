                                    <input type="text" class="form-control-plaintext" id="Produk" name="Produk" readonly
                                           value="@(string.IsNullOrEmpty(GetFormValue("Produk")) ? Produk : GetFormValue("Produk"))">
                                </div>
                            </div>
                            <div id="row_PICPengisian" class="row mb-3">
                                <div class="col-2 fw-bold d-flex align-items-center">@GetFormLabel("PICPengisian")</div>
                                <div class="col-10">
                                    <input type="text" class="form-control" id="PICPengisian" name="PICPengisian" required
                                           value="@(GetFormValue("PICPengisian"))">
                                </div>
                            </div>
                            <div id="row_NoMeter" class="row mb-3">
                                <div class="col-2 fw-bold d-flex align-items-center">@GetFormLabel("NoMeter")</div>
                                <div class="col-10">
                                    <input type="text" class="form-control" id="NoMeter" name="NoMeter" required
                                           value="@(GetFormValue("NoMeter"))">
                                </div>
                            </div>
                            <div id="bulk-388" class="mb-3" style="display:none;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="fw-bold">Input Gerbong Ketel</div>
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="btn-add-row-388">
                                        <i class="fas fa-plus me-1"></i> Tambah GK
                                    </button>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-bordered align-middle" id="tbl-388">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="min-width:140px;">Nomor Gerbong Ketel</th>
                                                <th style="min-width:140px;">Quantity</th>
                                                <th style="min-width:140px;">Selisih Pengukuran T2 (cm)</th>
                                                <th style="width:60px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>

                                <small class="text-muted">
                                    * Maksimal 3 gerbong ketel.
                                </small>

                                <template id="row388Template">
                                    <tr>
                                        <td>
                                            <select class="ew-select form-select select2 NomorGerbongKertel" required>
                                                <option value="" disabled selected hidden>
                                                    Pilih Nomor Gerbong Ketel
                                                </option>
                                                @foreach (var gerbong in gerbongKetelList)
                                                {
                                                    <option value='@gerbong["NoKetel"]'>@gerbong["NoKetel"]</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input class="form-control text-rasa-number Quantity" inputmode="numeric" required readonly disabled />
                                        </td>
                                        <td>
                                            <input class="form-control text-rasa-number HasilPengukuranT2" inputmode="numeric" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm btn-del-row-388">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </template>
                            </div>
                            <!-- <script>
                                document.addEventListener("DOMContentLoaded", function() {
                                    const fieldId = 'x_388_NomorGerbongKertel';
                                    let selectOptions = {
                                        name: fieldId,
                                        selectId: '388_NomorGerbongKertel'
                                    };
                                    selectOptions.closeOnSelect = !selectOptions.multiple;
                                    selectOptions.dropdownParent = document.querySelector('#modal-popup') || document.body;
                                    selectOptions.minimumInputLength = ew.selectMinimumInputLength;
                                    selectOptions.allowClear = false;
                                    const extra = (ew.selectOptionList && ew.selectOptionList[fieldId]) ? ew.selectOptionList[fieldId] : {};
                                    selectOptions = Object.assign(selectOptions, extra);

                                    const el = document.querySelector('select[data-select2-id="' + selectOptions.selectId + '"]');
                                    if(el) ew.createSelect(selectOptions);
                                });
                            </script> -->
                        }
                        @{
                            var skipFields388 = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                                                {
                                                "Produk", "PICPengisian", "NoMeter",
                                                "NomorGerbongKertel", "Quantity", "HasilPengukuranT2",
                                                "NomorGerbongKertel2", "Quantity2", "HasilPengukuranT2_2",
                                                "NomorGerbongKertel3", "Quantity3", "HasilPengukuranT2_3"
                                                };
                        }
                        @foreach (var item in formList)
                        {
                            @if (IdTemplateAktivitas == "388" && (
                                                    item[2].Equals("Produk", StringComparison.OrdinalIgnoreCase) ||
                                                    item[2].Equals("PICPengisian", StringComparison.OrdinalIgnoreCase) ||
                                                    item[2].Equals("NoMeter", StringComparison.OrdinalIgnoreCase)
                                                    ))
                            {
                                continue;
                            }
                            if (IdTemplateAktivitas == "388" && skipFields388.Contains(item[2]))
                            {
                                continue;
                            }
                            @if (item[1] == "text" || item[1] == "datetime-local")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3">
                                    <div class="col-2 fw-bold d-flex align-items-center">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        <input type="@(item[1])" class="form-control" id="@(item[2])" name="@(item[2])" required value="@(item.Count > 3 && !string.IsNullOrEmpty(item[3]) ? item[3] : "")">
                                    </div>
                                </div>
                            }
                            else if (item[1] == "number")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3">
                                    <div class="col-2 fw-bold d-flex align-items-center">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        @{
                                            var req = (IdTemplateAktivitas == "388" && item[2] == "HasilPengukuranT2") ? "" : "required";
                                        }
                                        <input type="text" inputmode="numeric" class="form-control text-rasa-number" id="@(item[2])" name="@(item[2])" @req value="@(item.Count > 3 && !string.IsNullOrEmpty(item[3]) ? item[3] : "")">
                                    </div>
                                </div>
                            }
                            else if (item[1] == "select")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3 @(item.Count > 4 && !string.IsNullOrEmpty(item[4]) ? item[4] : "")">
                                    <div class="col-2 fw-bold d-flex align-items-center">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        <select id="@(item[2])" name="@(item[2])" class="form-select" required>
                                            <option></option>
                                            @if (item[2] == "Produk" || item[2] == "ProdukAll")
                                            {
                                                @foreach (var produk in produkList)
                                                {
                                                    if (produk["NoProduk"].ToString() == Produk)
                                                    {
                                                        <option value='@produk["NoProduk"]' selected>@produk["NoProduk"] - @produk["NamaProduk"]</option>
                                                    }
                                                    else
                                                    {
                                                        <option value='@produk["NoProduk"]'>@produk["NoProduk"] - @produk["NamaProduk"]</option>
                                                    }
                                                }
                                            }
                                            else if (item[2].Contains("Tangki"))
                                            {
                                                @foreach (var tangki in tangkiList)
                                                {
                                                    <option value='@tangki["id"]'>@tangki["Sloc"] - @(!string.IsNullOrEmpty(tangki["SeqTangki"].ToString()) ? tangki["SeqTangki"].ToString() + " - " : "") @tangki["NamaTerminal"]</option>
                                                }
                                            }
                                            else if (item[2] == "IdPlant")
                                            {
                                                @foreach (var plant in plantList)
                                                {
                                                    <option value='@plant["IdPlant"]'>@plant["Plant"] - @plant["Nama_Terminal"]</option>
                                                }
                                            }
                                            else if (item[2] == "IsQualityActive")
                                            {
                                                <option value='0' selected>Off</option>
                                                <option value='1'>On</option>
                                            }
                                            else if (item[2] == "NomorGerbongKertel")
                                            {
                                                @foreach (var gerbong in gerbongKetelList)
                                                {
                                                    Console.WriteLine(gerbong);
                                                    if (gerbong["NoKetel"].ToString() == NomorGerbongKertel)
                                                    {
                                                        <option value='@gerbong["NoKetel"]' selected>@gerbong["NoKetel"]</option>
                                                    }
                                                    else
                                                    {
                                                        <option value='@gerbong["NoKetel"]'>@gerbong["NoKetel"]</option>
                                                    }
                                                }
                                            }
                                        </select>
                                        @if (item[2] == "IsQualityActive")
                                        {
                                            <p class="small m-0 pt-1">
                                                Koordinasikan dengan QQ apabila ada indikasi Quality OFF.
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                            else if (item[1] == "textarea")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3">
                                    <div class="col-2 fw-bold d-flex">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        <textarea class="form-control" id="@(item[2])" name="@(item[2])" rows="3"></textarea>
                                    </div>
                                </div>
                            }
                            else if (item[1].Contains("readonly"))
                            {
                                <div id='@("row_" + item[2])' class="row mb-3">
                                    <div class="col-2 fw-bold d-flex align-items-center">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        <input type="text" class="form-control-plaintext" id="@(item[2])" name="@(item[2])" readonly value="@(item.Count > 3 && !string.IsNullOrEmpty(item[3]) ? item[3] : "")">
                                    </div>
                                </div>
                            }
                            else if (item[1] == "hidden")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3 d-none">
                                    <input type="hidden" class="form-control" id="@(item[2])" name="@(item[2])" value="@(item[0])" required>
                                </div>
                            }
                            else if (item[1] == "checkbox")
                            {
                                <div id='@("row_" + item[2])' class="row mb-3">
                                    <div class="col-2 fw-bold d-flex align-items-center">
                                        @(item[0])
                                    </div>
                                    <div class="col-10">
                                        <input class="form-check-input" type="checkbox" value="" id="@(item[2])" name="@(item[2])">
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success ew-btn"><i class="fas fa-plus me-1"></i> Add</button>
                        <button type="button" class="btn btn-default ew-btn" data-bs-dismiss="modal"><i class="fas fa-ban me-1"></i> Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

