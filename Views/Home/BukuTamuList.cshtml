<template id="tpsm_BukuTamulist">
<div id="BukuTamulist">@{
    var userLevel = CurrentUserLevel();
    var idPosition = CurrentUserInfo("IdPosition") ?? "0";
    var regions = new List<object>();
    var plants = new List<object>();
    if (userLevel == "-1" || userLevel == "3")
    {
        regions = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT IdRegion, Region AS NamaRegion FROM MasterRegion ORDER BY Region",
            reader => new {
                idRegion = reader.GetInt32("IdRegion").ToString(),
                namaRegion = reader.IsDBNull("NamaRegion") ? "" : reader.GetString("NamaRegion")
            });
        plants = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT IdPlant, Nama_Terminal AS NamaPlant, Region AS IdRegion FROM MasterPlant ORDER BY Nama_Terminal",
            reader => new {
                idPlant = reader.GetInt32("IdPlant").ToString(),
                namaPlant = reader.IsDBNull("NamaPlant") ? "" : reader.GetString("NamaPlant"),
                idRegion = reader.IsDBNull("IdRegion") ? "" : reader.GetString("IdRegion")
            });
    }
    else if (idPosition != "0")
    {
        regions = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT DISTINCT MR.IdRegion, MR.Region AS NamaRegion FROM MasterRegion MR JOIN MappingPosition MP ON MP.IdRegion = MR.IdRegion WHERE MP.IdPosition = @IdPosition ORDER BY MR.Region",
            reader => new {
                idRegion = reader.GetInt32("IdRegion").ToString(),
                namaRegion = reader.IsDBNull("NamaRegion") ? "" : reader.GetString("NamaRegion")
            },
            new Dictionary<string, object> {{ "@IdPosition", idPosition }});
        plants = await DatabaseQueryHelper.ExecuteSelectListQueryAsync<object>(
            "SELECT DISTINCT MP.IdPlant, MP.NamaPlant AS NamaPlant, MP.IdRegion AS IdRegion FROM MappingPosition MP WHERE MP.IdPosition = @IdPosition ORDER BY MP.NamaPlant",
            reader => new {
                idPlant = reader.GetInt32("IdPlant").ToString(),
                namaPlant = reader.IsDBNull("NamaPlant") ? "" : reader.GetString("NamaPlant"),
                idRegion = reader.GetInt32("IdRegion").ToString()
            },
            new Dictionary<string, object> {{ "@IdPosition", idPosition }});
    }
}
