            ["UploadEvidence", [fields.UploadEvidence.visible && fields.UploadEvidence.required ? ew.Validators.required(fields.UploadEvidence.caption) : null], fields.UploadEvidence.isInvalid],
            ["CreatedDate", [fields.CreatedDate.visible && fields.CreatedDate.required ? ew.Validators.required(fields.CreatedDate.caption) : null, ew.Validators.datetime(fields.CreatedDate.clientFormatPattern)], fields.CreatedDate.isInvalid],
            ["CreatedBy", [fields.CreatedBy.visible && fields.CreatedBy.required ? ew.Validators.required(fields.CreatedBy.caption) : null], fields.CreatedBy.isInvalid],
            ["LastUpdatedBy", [fields.LastUpdatedBy.visible && fields.LastUpdatedBy.required ? ew.Validators.required(fields.LastUpdatedBy.caption) : null], fields.LastUpdatedBy.isInvalid],
            ["LastUpdatedDate", [fields.LastUpdatedDate.visible && fields.LastUpdatedDate.required ? ew.Validators.required(fields.LastUpdatedDate.caption) : null, ew.Validators.datetime(fields.LastUpdatedDate.clientFormatPattern)], fields.LastUpdatedDate.isInvalid],
            ["StatusEmail", [fields.StatusEmail.visible && fields.StatusEmail.required ? ew.Validators.required(fields.StatusEmail.caption) : null], fields.StatusEmail.isInvalid],
            ["FileType", [fields.FileType.visible && fields.FileType.required ? ew.Validators.required(fields.FileType.caption) : null], fields.FileType.isInvalid],
            ["OriginalFileName", [fields.OriginalFileName.visible && fields.OriginalFileName.required ? ew.Validators.required(fields.OriginalFileName.caption) : null], fields.OriginalFileName.isInvalid],
            ["Flag", [fields.Flag.visible && fields.Flag.required ? ew.Validators.required(fields.Flag.caption) : null], fields.Flag.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
