        <td data-name="IdTemplate" @Html.Raw(masterTemplateView.IdTemplate.CellAttributes)>
<span id="el_MasterTemplate_IdTemplate">
<span @Html.Raw(masterTemplateView.IdTemplate.ViewAttributes)>
@Html.Raw(masterTemplateView.IdTemplate.GetViewValue())</span>
