@{
    // View
    View = this;

    // Check action result
    if (penimbunanDelete.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penimbunanDelete.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(penimbunanDelete.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penimbunan: currentTable } });
var currentPageID = ew.PAGE_ID = "delete";
var currentForm;
var fPenimbunandelete;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenimbunandelete")
        .setPageId("delete")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    $('#fPenimbunandelete button[type=submit]').on('click', function(e) {
        e.preventDefault();
        const data = $('#fPenimbunandelete').serializeArray();
        const parent_url = ew.PATH_BASE;
        const submitData = data
            .filter(field => field.name === "key_m[]")
            .map(field => field.value);
        showLoading();
        $.ajax({
            url: parent_url + 'api/LookUpList/CheckDeletableReferensi',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                Referensi: 'Penimbunan',
                IdReferensi: submitData
            }),
            success: function (res) {
                if (res.success) {
                    $('#fPenimbunandelete').submit();
                } else {
                    hideLoading();
                    ew.alert(res.message);
                    return false;
                }
            },
            error: function (err) {
                hideLoading();
                ew.alert('An error occured on the server.');
                console.error(err);
                return false;
            },
        });
    });
});
</script>
