@Html.Raw(masterPipaEdit.idPlantAsal.Lookup.GetParamTag(masterPipaEdit, "p_x_idPlantAsal"))
<script>
loadjs.ready("fMasterPipaedit", function() {
    var options = { name: "x_idPlantAsal", selectId: "fMasterPipaedit_x_idPlantAsal" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fMasterPipaedit.lists.idPlantAsal?.lookupOptions.length) {
        options.data = { id: "x_idPlantAsal", form: "fMasterPipaedit" };
    } else {
        options.ajax = { id: "x_idPlantAsal", form: "fMasterPipaedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.MasterPipa.fields.idPlantAsal.selectOptions);
    ew.createSelect(options);
});
</script>
</span>
