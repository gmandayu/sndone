    // View
    View = this;

    // Check action result
    if (masterUserAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterUserAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(masterUserAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterUser: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fMasterUseradd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterUseradd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["_Email", [fields._Email.visible && fields._Email.required ? ew.Validators.required(fields._Email.caption) : null, ew.Validators.email], fields._Email.isInvalid],
            ["_Username", [fields._Username.visible && fields._Username.required ? ew.Validators.required(fields._Username.caption) : null], fields._Username.isInvalid],
            ["PasswordHash", [fields.PasswordHash.visible && fields.PasswordHash.required ? ew.Validators.required(fields.PasswordHash.caption) : null], fields.PasswordHash.isInvalid],
            ["NamaLengkap", [fields.NamaLengkap.visible && fields.NamaLengkap.required ? ew.Validators.required(fields.NamaLengkap.caption) : null], fields.NamaLengkap.isInvalid],
            ["_UserLevel", [fields._UserLevel.visible && fields._UserLevel.required ? ew.Validators.required(fields._UserLevel.caption) : null], fields._UserLevel.isInvalid],
            ["Rule", [fields.Rule.visible && fields.Rule.required ? ew.Validators.required(fields.Rule.caption) : null], fields.Rule.isInvalid],
            ["IdPosition", [fields.IdPosition.visible && fields.IdPosition.required ? ew.Validators.required(fields.IdPosition.caption) : null, ew.Validators.integer], fields.IdPosition.isInvalid],
            ["Region", [fields.Region.visible && fields.Region.required ? ew.Validators.required(fields.Region.caption) : null], fields.Region.isInvalid],
            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["LookupPosition", [fields.LookupPosition.visible && fields.LookupPosition.required ? ew.Validators.required(fields.LookupPosition.caption) : null], fields.LookupPosition.isInvalid],
            ["StatusAktif", [fields.StatusAktif.visible && fields.StatusAktif.required ? ew.Validators.required(fields.StatusAktif.caption) : null], fields.StatusAktif.isInvalid],
            ["Keterangan", [fields.Keterangan.visible && fields.Keterangan.required ? ew.Validators.required(fields.Keterangan.caption) : null], fields.Keterangan.isInvalid],
            ["IdIdaman", [fields.IdIdaman.visible && fields.IdIdaman.required ? ew.Validators.required(fields.IdIdaman.caption) : null], fields.IdIdaman.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "_UserLevel": @Html.Raw(masterUserAdd._UserLevel.ToClientList(masterUserAdd)),
            "Rule": @Html.Raw(masterUserAdd.Rule.ToClientList(masterUserAdd)),
            "IdPosition": @Html.Raw(masterUserAdd.IdPosition.ToClientList(masterUserAdd)),
            "Region": @Html.Raw(masterUserAdd.Region.ToClientList(masterUserAdd)),
            "Plant": @Html.Raw(masterUserAdd.Plant.ToClientList(masterUserAdd)),
            "LookupPosition": @Html.Raw(masterUserAdd.LookupPosition.ToClientList(masterUserAdd)),
            "StatusAktif": @Html.Raw(masterUserAdd.StatusAktif.ToClientList(masterUserAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    // Write your client script here, no need to add script tags.
    const parent_url = ew.PATH_BASE;
    const userLevel = "@CurrentUserLevel()";
    let isAutoFillingFromApi = false;
    function setLookupSelect2Value($el, value, text) {
        if (!$el.length || value == null || value === '') return;
        const stringValue = String(value);
        const stringText = String(text ?? value);
        let $opt = $el.find(`option[value="${stringValue}"]`);
        if (!$opt.length) {
            $opt = $(new Option(stringText, stringValue, true, true));
            $el.append($opt);
        } else {
            $opt.text(stringText).prop('selected', true);
        }
        $el.val(stringValue).trigger('change');
        $el.trigger('change.select2');
    }
    $('#x_LookupPosition').on('change', function () {
        hideFeedback($(this));
        $('#x_IdPosition').val($(this).val());
    });
    function disabledPosition() {
        const $positionLookup = $('#x_LookupPosition');
        $('#r_LookupPosition').show();
        $positionLookup.empty();
        $positionLookup.append('<option value="">-- Pilih Position --</option>');
        $positionLookup.val('').trigger('change');
        $('#x_IdPosition').val('');
        $positionLookup.prop('disabled', false);
    }
    function getPosition(userLevel, role, region, plant, selectedPositionId = null) {
        const $positionLookup = $('#x_LookupPosition');
        $positionLookup.empty();
        $positionLookup.prop('disabled', false);
        $positionLookup.append('<option value="">Loading...</option>');
        $('#r_LookupPosition').show();
        let requestUrl = `${parent_url}api/LookUpList/get-dropdown/user-position?UserLevel=${encodeURIComponent(userLevel)}`;
        if (role) {
            requestUrl += `&IdRule=${encodeURIComponent(role)}`;
        }
        if (region) {
            requestUrl += `&IdRegion=${encodeURIComponent(region)}`;
        }
        if (plant) {
            requestUrl += `&IdPlant=${encodeURIComponent(plant)}`;
        }
        $.ajax({
            url: requestUrl,
            method: 'GET',
            dataType: 'json',
            beforeSend: function () {
                showLoading();
            },
            success: function (response) {
                $positionLookup.empty();
                $positionLookup.append('<option value="">-- Pilih Position --</option>');
                if ($.isArray(response) && response.length > 0) {
                    $.each(response, function (index, item) {
                        $positionLookup.append(`<option value="${item.Value}">${item.Label}</option>`);
                    });
                } else {
                    $positionLookup.append('<option value="">Data position tidak tersedia</option>');
                }
                if (selectedPositionId != null && selectedPositionId !== '') {
                    const selectedPositionIdString = String(selectedPositionId);
                    if ($positionLookup.find(`option[value="${selectedPositionIdString}"]`).length > 0) {
                        $positionLookup.val(selectedPositionIdString).trigger('change');
                        $('#x_IdPosition').val(selectedPositionIdString);
                    } else {
                        $positionLookup.val('');
                        $('#x_IdPosition').val('');
                    }
                } else {
                    $positionLookup.val('');
                    $('#x_IdPosition').val('');
                }
            },
            error: function (xhr, status, error) {
                console.error('Gagal ambil data dropdown:', error);
                $positionLookup.empty();
                $positionLookup.append('<option value="">Gagal memuat data</option>');
                $('#x_IdPosition').val('');
            },
            complete: function () {
                hideLoading();
            },
        });
    }
    function resetPositionDependencies() {
        setLookupSelect2Value($('#x__UserLevel'), '', '');
        $('#x__UserLevel').val('').trigger('change');
        setLookupSelect2Value($('#x_Rule'), '', '');
        $('#x_Rule').val('').trigger('change');
        setLookupSelect2Value($('#x_Region'), '', '');
        $('#x_Region').val('').trigger('change');
        setLookupSelect2Value($('#x_Plant'), '', '');
        $('#x_Plant').val('').trigger('change');
        $('#x_LookupPosition').empty().append('<option value="">-- Pilih Position --</option>').val('').trigger('change');
        $('#x_IdPosition').val('');
    }
    function handleUserLevelDependencies(selectedUserLevel) {
        if (!selectedUserLevel) {
            $('#r_Plant').hide();
            $('#r_Region').hide();
            $('#x_Plant').val('');
            $('#x_Region').val('');
            $('#x_Region').prop('disabled', true);
            $('#x_Plant').prop('disabled', true);
            return;
        }
        if (selectedUserLevel === '3') {
            $('#r_Plant').hide();
            $('#r_Region').hide();
            $('#x_Plant').val('');
            $('#x_Region').val('');
            $('#x_Region').prop('disabled', true);
            $('#x_Plant').prop('disabled', true);
            return;
        }
        if (selectedUserLevel === '4') {
            $('#r_Region').show();
            $('#r_Plant').hide();
            $('#x_Plant').val('');
            $('#x_Region').prop('disabled', false);
            $('#x_Plant').prop('disabled', true);
            return;
        }
        $('#r_Plant').show();
        $('#r_Region').show();
        $('#x_Region').prop('disabled', false);
        if (!$('#x_Region').val()) {
            $('#x_Plant').val('');
            $('#x_Plant').prop('disabled', true);
        } else {
            $('#x_Plant').prop('disabled', false);
        }
    }
    $('#x__UserLevel, #x_Rule, #x_Region, #x_Plant').on('change', function () {
        hideFeedback($(this));
        const selectedUserLevel = $('#x__UserLevel').val();
        const selectedRole = $('#x_Rule').val();
        const selectedRegion = $('#x_Region').val();
        const selectedPlant = $('#x_Plant').val();
        const selectedPositionId = isAutoFillingFromApi ? $('#x_IdPosition').val() : null;
        handleUserLevelDependencies(selectedUserLevel);
        if (!selectedUserLevel) {
            $('#x_IdPosition').val('');
            $('#x_LookupPosition').val('').trigger('change');
            disabledPosition();
            return;
        }
        if (!isAutoFillingFromApi) {
            $('#x_IdPosition').val('');
            $('#x_LookupPosition').val('').trigger('change');
        }
        getPosition(selectedUserLevel, selectedRole, selectedRegion, selectedPlant, selectedPositionId);
    });
    function hideFeedback($element) {
        const $feedback = $element.siblings('.invalid-feedback');
        $element.removeClass('is-invalid');
        $feedback.hide();
    }
    $('#fMasterUseradd').on('submit', function (e) {
        e.preventDefault();
        const selectedUserLevel = $('#x__UserLevel').val();
        const selectedPositionId = $('#x_IdPosition').val();
        const selectedRole = $('#x_Rule').val();
        if (!selectedUserLevel) {
            $('#x__UserLevel').addClass('is-invalid');
            $('#x__UserLevel').siblings('.invalid-feedback').text('User level harus dipilih.').show();
            return false;
        }
        if (!selectedRole) {
            $('#x_Rule').addClass('is-invalid');
            $('#x_Rule').siblings('.invalid-feedback').text('Role harus dipilih.').show();
            return false;
        }
        if (!selectedPositionId) {
            $('#x_LookupPosition').addClass('is-invalid');
            $('#x_LookupPosition').siblings('.invalid-feedback').text('Position harus dipilih.').show();
            return false;
        }
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        HTMLFormElement.prototype.submit.call(this);
    });
    if (userLevel === '-1') {
        const style = `
                <style>
                    #r__Email .input-group .form-control {
                        border-top-right-radius: 0;
                        border-bottom-right-radius: 0;
                    }
                    #r__Email .input-group .btn {
                        border-top-left-radius: 0;
                        border-bottom-left-radius: 0;
                        white-space: nowrap;
                    }
                </style>
            `;
        $('head').append(style);
        const $emailInput = $('#x__Email');
        const checkPositionButtonHtml = `
                <button type="button" class="btn btn-success" id="btn-email-check" title="Cek Jabatan">
                    <i class="fas fa-search"></i> Cek Jabatan
                </button>
            `;
        if (!$emailInput.length || $('#btn-email-check').length) {
            console.warn('Button tidak ter-generate.');
        } else {
            $emailInput.wrap('<div class="input-group w-100"></div>');
            $emailInput.after(checkPositionButtonHtml);
        }
        $(document).on('click', '#btn-email-check', function (e) {
            e.preventDefault();
            resetPositionDependencies();
            const emailAddress = ($('#x__Email').val() || '').trim();
            if (!emailAddress) {
                ew.alert('Email wajib diisi.');
                $('#x__Email').focus();
                return;
            }
            const $button = $(this);
            const originalButtonHtml = $button.html();
            $button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Checking...');
            $.ajax({
                url: `${ew.PATH_BASE}api/LookUpList/position-by-email`,
                type: 'POST',
                contentType: 'application/json',
                dataType: 'json',
                data: JSON.stringify({ email: emailAddress }),
                success: function (response) {
                    if (!response.success) {
                        ew.alert(response.message || 'Gagal cek jabatan.');
                        return;
                    }
                    const responseData = response.data || {};
                    const userData = responseData.user || {};
                    const levelData = userData.level || {};
                    const roleData = userData.role || {};
                    const idamanData = userData.idaman || {};
                    const positionData = idamanData.position || {};
                    const resolvedEmail = userData.email || '';
                    const resolvedUserName = userData.userName || '';
                    const resolvedFullName = userData.fullName || '';
                    const alreadyExistsInMasterUser = userData.exists === true;
                    const isPjs = userData.isPjs === true;
                    const resolvedUserLevel = levelData.id;
                    const resolvedUserLevelName = levelData.name || '';
                    const resolvedRole = roleData.id;
                    const resolvedRoleName = roleData.name || '';
                    const resolvedIdIdaman = idamanData.id || '';
                    const resolvedPositionId = positionData.id;
                    const resolvedPositionName = positionData.name || '';
                    isAutoFillingFromApi = true;
                    if ($('#x__Email').length && resolvedEmail) {
                        $('#x__Email').val(resolvedEmail);
                    }
                    if ($('#x__Username').length && resolvedUserName) {
                        $('#x__Username').val(resolvedUserName);
                    }
                    if ($('#x_NamaLengkap').length && resolvedFullName) {
                        $('#x_NamaLengkap').val(resolvedFullName);
                    }
                    if ($('#x_IdPosition').length && resolvedPositionId != null) {
                        $('#x_IdPosition').val(String(resolvedPositionId));
                    }
                    if ($('#x__UserLevel').length && resolvedUserLevel != null) {
                        setLookupSelect2Value($('#x__UserLevel'), resolvedUserLevel, resolvedUserLevelName || resolvedUserLevel);
                    }
                    if ($('#x_Rule').length && resolvedRole != null) {
                        setLookupSelect2Value($('#x_Rule'), resolvedRole, resolvedRoleName || resolvedRole);
                    }
                    // id idaman di-hide
                    if ($('#x_IdIdaman').length && resolvedIdIdaman) {
                        $('#x_IdIdaman').val(resolvedIdIdaman);
                    }
                    handleUserLevelDependencies(String(resolvedUserLevel ?? ''));
                    const selectedRegion = $('#x_Region').val();
                    const selectedPlant = $('#x_Plant').val();
                    if (resolvedUserLevel != null) {
                        getPosition(String(resolvedUserLevel), resolvedRole != null ? String(resolvedRole) : $('#x_Rule').val(), selectedRegion, selectedPlant, resolvedPositionId != null ? String(resolvedPositionId) : null);
                    }
                    let message = 'Jabatan berhasil ditemukan.';
                    if (alreadyExistsInMasterUser) {
                        message += ' Pengguna dengan email ini sudah ada di dalam sistem.';
                    }
                    if (isPjs) {
                        message += ' Pengguna termasuk Pengguna PJS.';
                    }
                    ew.alert(message);
                },
                error: function (xhr, status, error) {
                    console.error(error);
                    ew.alert('Terjadi error saat menghubungi server.');
                },
                complete: function () {
                    isAutoFillingFromApi = false;
                    $button.prop('disabled', false).html(originalButtonHtml);
                },
            });
        });
    }
});
</script>
