    View = this;

    // Check action result
    if (penimbunanView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penimbunanView.UseLayout ? "_Layout" : "";
}
@if (!penimbunanView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @penimbunanView.ExportOptions.RenderBody()
