        <td data-name="NomorBukuTamu" @Html.Raw(bukuTamuView.NomorBukuTamu.CellAttributes)>
<span id="el_BukuTamu_NomorBukuTamu">
<span @Html.Raw(bukuTamuView.NomorBukuTamu.ViewAttributes)>
@Html.Raw(bukuTamuView.NomorBukuTamu.GetViewValue())</span>
