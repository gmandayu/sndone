    ];
    let currentStep = 4;
    $("<style>")
        .prop("type", "text/css")
        .html(
            `
                .stepper {
                    display: flex;
                    counter-reset: step;
                }
                .step {
                    width: 150px;
                    text-align: center;
                    position: relative;
                }
                .step:not(:last-child)::after {
                    content: '';
                    position: absolute;
                    top: 20px;
                    right: -50%;
                    width: 100%;
                    height: 4px;
                    background-color: #ccc;
                    z-index: 0;
                }
                .step.completed:not(:last-child)::after {
                    background-color: #3c6dbd;
                }
                .step-icon {
                    width: 36px;
                    height: 36px;
                    line-height: 36px;
                    border-radius: 50%;
                    background: #ccc;
                    display: inline-block;
                    z-index: 1;
                    position: relative;
                    color: white;
                    font-weight: bold;
                }
                .step.active .step-icon {
                    background: #3c6dbd;
                }
                .step-label {
                    margin-top: 8px;
                    font-size: 14px;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    gap: 6px;
                    color: #333;
                }
                .step-label {
                    color: #3c6dbd !important;
                    text-decoration: none;
                    margin: 0;
                    padding: 0;
                }
                .step-label-not-active {
                    color: #CCCCCC !important;
                }
                .ag-theme-quartz .ag-header {
                    background-color: #3c6dbd !important;
                }
                .ag-theme-quartz .ag-header-cell-label {
                    color: #ffffff !important;
                }
                .ag-theme-quartz .ag-icon-filter {
                    color: #ffffff !important;
                }
                .rotate-down {
                    transform: rotate(90deg);
                    transition: transform 0.3s ease;
                }
                .rotate-right {
                    transform: rotate(0deg);
                    transition: transform 0.3s ease;
                }
                .view-page-table td {
                    white-space: normal !important;
                    word-wrap: break-word;
                }
                .view-page-table th {
                    background-color: #006BB7;
                }
                .body-table {
                    background-color: #fff;
                }
                .header-table {
                    background-color: #006BB7 !important;
                    color: #fff !important;
                }
                .view-page-table {
                    table-layout: fixed;
                }
                .btn {
                    white-space: nowrap;
                }
                .file-input-wrapper {
                    border: 1px solid #ced4da;
                    border-radius: .375rem;
                    overflow: hidden;
                    transition: border-color .15s, box-shadow .15s;
                }
                .file-input-wrapper:focus-within {
                    border-color: #86b7fe;
                    box-shadow: 0 0 0 .25rem rgba(13,110,253,.25);
                }
                .file-input-wrapper .btn {
                    border-radius: 0;
                }
                .file-input-wrapper .form-control {
                    border: none;
                    box-shadow: none !important;
                }
            `,
        )
        .appendTo("head");
    let $stepperWrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    let $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        let isActive = step.number === currentStep;
        let isCompleted = step.number < currentStep;
        let stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        let icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #3c6dbd;">${step.number}</div>`;
            labelContent = `<div class="step-label"><a href="${step.url}" class="text-primary"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    $(".content-header .container-fluid .row").append($stepperWrapper);
    let uploadModal = `
        <div class="modal modal-lg fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="background-color: #3c6dbd; color: white;">
                        <h5 class="modal-title" id="uploadModalLabel"></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body mx-0 px-0">
                        <form id="uploadForm">
                            <div class="pt-2 pb-4 border-bottom px-3">
                                <div class="input-group file-input-wrapper">
                                    <label class="btn btn-primary mb-0">
                                        Add Document <input type="file" id="fileInput" hidden multiple>
                                    </label>
                                    <input type="text" class="form-control" style="cursor: pointer;" id="fileName" value="Add Document" readonly>
                                </div>
                                <small class="text-muted">Maximum file size: 20 MB</small>
                                <div class="border rounded p-0 mt-2" id="row-table" style="display: none;">
                                    <table aria-hidden="true" class="table table-hover view-page-table w-100 m-0" id="fileTable">
                                        <thead>
                                            <tr>
                                                <th width="5%" class="fw-bold header-table">No</th>
                                                <th class="fw-bold header-table">Nama File</th>
                                                <th width="10%" class="fw-bold header-table"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- js render -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="pt-2 px-3 d-flex justify-content-end gap-2">
                                <button type="submit" class="btn btn-primary" id="btn-submit-modal"><i class="fas fa-upload"></i> Upload</button>
                                <button id="btn-cancel-modal" class="btn btn-default ew-btn"><i class="fas fa-ban"></i> Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        `;
    $("body").append(uploadModal);
    $(".upload-document").click(function (event) {
        event.preventDefault();
        if (StatusAktivitas == "Completed Edit") {
            ew.alert("Aktivitas telah Completed dan tidak dapat diedit lagi.");
            return;
        }
        IdAktivitasDokumen = $(this).attr("IdAktivitasDokumen");
        IdAktivitas = $(this).attr("IdAktivitas");
        NamaDokumen = $(this).attr("NamaDokumen");
        $("#uploadModalLabel").text("Upload Dokumen " + NamaDokumen);
        $.ajax({
            url: parent_url + `api/LookUpList/GetAktivitasDokumenDetail?IdAktivitasDokumen=${IdAktivitasDokumen}`,
            method: "GET",
            beforeSend: function () {
                showLoading();
            },
            success: function (rs) {
                rs.dataDokumen.forEach((item) => {
                    if (item.FileName) {
                        filesArr.push({
                            id: item.id,
                            FileName: item.FileName,
                        });
                    }
                });
                renderTable();
                $("#uploadModal").modal("show");
            },
            error: function (xhr, status, error) {
                hideLoading();
                console.error("API call failed:", status, error);
            },
            complete: function () {
                hideLoading();
            },
        });
    });
    $("#btn-cancel-modal").click(function (event) {
        event.preventDefault();
        ResetUpload();
        $("#uploadModal").modal("hide");
    });
    $(document).on("submit", "#uploadForm", function (e) {
        e.preventDefault();
        if (filesArr.length === 0 && deleteIds.length === 0) {
            ew.alert("Tidak ada perubahan file!");
            return;
        }
        let formData = new FormData();
        formData.append("IdAktivitasDokumen", IdAktivitasDokumen);
        formData.append("IdAktivitas", idAktivitas);
        formData.append("NoReferensi", IdReferensi);
        filesArr.forEach((item) => {
            if (item.file) {
                formData.append("files", item.file);
            }
        });
        deleteIds.forEach((id) => {
            formData.append("DeletedIds", id);
        });
        let parent_url = ew.PATH_BASE;
        $.ajax({
            url: parent_url + "api/LookUpList/UploadAktivitasDokumen",
            type: "POST",
            data: formData,
            contentType: false,
            processData: false,
            beforeSend: function () {
                showLoading();
            },
            success: function (rs) {
                ew.alert({
                    title: null,
                    text: rs.message,
                    icon: null,
                    timer: 1000,
                });
                if (rs.success) {
                    let $target = $('.not-uploaded[IdAktivitasDokumen="' + IdAktivitasDokumen + '"]');
                    $target.replaceWith(`
                            <a class="download-document btn btn-primary" IdAktivitasDokumen="${IdAktivitasDokumen}">
                                <i class="fas fa-download me-2"></i> Download Document
                            </a>
                        `);
                    let target2 = $("#btn-submit-keterangan");
                    if (rs.NotUploadedCount == 0 && target2.length == 0 && StatusAktivitas != "Waiting" && StatusAktivitas != "Completed Edit") {
                        let $btnSave = $("#btn-save-keterangan");
                        $btnSave.after(`
                                <button type="button" class="btn btn-success ew-btn ml-2" id="btn-submit-keterangan">
                                    <i class="fas fa-paper-plane"></i> Submit
                                </button>
                            `);
                    }
                }
            },
            error: function (xhr, status, error) {
                ew.alert("Error: " + xhr.responseText);
            },
            complete: function () {
                hideLoading();
            },
