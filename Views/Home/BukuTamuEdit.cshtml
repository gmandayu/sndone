                    border-radius: 4px !important;
                }
                @@media (max-width: 768px) {
                    #btGrid {
                        min-width: 500px !important;
                    }
                    .ag-theme-quartz .ag-cell {
                        padding: 6px 8px !important;
                        font-size: 12px !important;
                    }
                    .ag-theme-quartz .ag-header-cell {
                        padding: 8px 8px !important;
                        font-size: 12px !important;
                    }
                }
                @@media (max-width: 576px) {
                    #btGrid {
                        min-width: 400px !important;
                    }
                    .ag-theme-quartz .ag-cell {
                        padding: 4px 6px !important;
                        font-size: 11px !important;
                    }
                    .ag-theme-quartz .ag-header-cell {
                        padding: 6px 6px !important;
                        font-size: 11px !important;
                    }
                    .download-document {
                        font-size: 10px !important;
                        padding: 2px 6px !important;
                    }
                }
            `).appendTo("head");
        }
        var $btn = $("#bt-log-toggle");
        var opened = false, gridInited = false, gridApi = null;
        $("#bt-log-toggle").on('click', function () {
            if (!idBukuTamu || idBukuTamu.trim() === "") {
                ew.alert("ID BukuTamu tidak ditemukan. Tidak dapat memuat log history.");
                return;
            }
            const $btn = $(this);
            const isExpanded = $btn.attr('expand-log') === 'true';
            const $row = $('#bt-log-row');
            const $wrapper = $('#bt-log-pane');
            const $caret = $btn.find('.caret-icon');
            if (!isExpanded) {
                $btn.attr('expand-log', 'true');
                $row.removeClass('d-none').show();
                setTimeout(() => {
                    $wrapper.css({
                        maxHeight: '500px'
                    });
                }, 10);
                $caret.removeClass('rotate-right').addClass('rotate-down');
                if (!gridInited) {
                    ensureGrid();
                }
            } else {
                $btn.attr('expand-log', 'false');
                $wrapper.css({
                    maxHeight: '0'
                });
                setTimeout(() => {
                    $row.addClass('d-none').hide();
                }, 600);
                $caret.removeClass('rotate-down').addClass('rotate-right');
            }
        });
        function ensureGrid() {
            function buildGrid(rows) {
                if (!rows || rows.length === 0) {
                    $("#btGrid").hide();
                    $("#btLogEmpty").removeClass("d-none");
                    gridInited = true;
                    return;
                }
                $("#btGrid").show();
                $("#btLogEmpty").addClass("d-none");
                var columnDefs = [
                    { 
                        headerName: "No.", 
                        valueGetter: "node.rowIndex + 1", 
                        width: 60, 
                        minWidth: 50,
                        maxWidth: 80,
                        filter: false, 
                        sortable: false,
                        pinned: 'left',
                        cellClass: 'text-center'
                    },
                    { 
                        headerName: "Area", 
                        field: "Area", 
                        flex: 1,
                        minWidth: 150,
                        maxWidth: 250,
                        filter: 'agTextColumnFilter',
                        cellStyle: { 'white-space': 'nowrap', 'overflow': 'hidden', 'text-overflow': 'ellipsis' }
                    },
                    { 
                        headerName: "Area ID", 
                        field: "AreaId", 
                        width: 100,
                        minWidth: 80,
                        maxWidth: 120,
                        filter: 'agTextColumnFilter',
                        cellClass: 'text-center'
                    },
                    { 
                        headerName: "Tanggal", 
                        field: "Tanggal", 
                        width: 160,
                        minWidth: 140,
                        maxWidth: 200,
                        filter: 'agTextColumnFilter',
                        cellStyle: { 'white-space': 'nowrap', 'overflow': 'hidden', 'text-overflow': 'ellipsis' }
                    },
                    {
                        headerName: "Foto", 
                        field: "Foto", 
                        width: 120, 
                        minWidth: 100,
                        maxWidth: 140,
                        filter: false, 
                        sortable: false,
                        cellClass: 'text-center',
                        cellRenderer: function(params) {
                            if (!params.data || !params.data.Foto) {
                                return '<span class="text-muted">-</span>';
                            }
                            return '<button type="button" class="btn btn-sm btn-primary download-document" ' +
                                    'data-id="' + params.data.Id + '" ' +
                                    'data-field="Foto" ' +
                                    'title="Download Foto">' +
                                    '<i class="fa-solid fa-download me-1"></i>Download' +
                                    '</button>';
                        }
                    },
                    { 
                        headerName: "User Input", 
                        field: "UserInput", 
                        width: 130,
                        minWidth: 100,
                        maxWidth: 160,
                        filter: 'agTextColumnFilter'
                    }
                ];
                var gridOptions = {
                    rowData: rows,
                    columnDefs: columnDefs,
                    defaultColDef: {
                        sortable: false,
                        suppressMovable: true,
                        filter: true,
                        resizable: true,
                        wrapText: false,
                        autoHeight: false
                    },
                    rowSelection: 'multiple',
                    suppressRowClickSelection: true,
                    pagination: true,
                    paginationPageSize: 10,
                    suppressHorizontalScroll: false,
                    suppressColumnVirtualisation: true,
                    suppressRowVirtualisation: true,
                    animateRows: true,
                    rowHeight: 40,
                    headerHeight: 45
                };
                var gridEl = document.querySelector("#btGrid");
                if (gridEl && !gridEl._gridCreated) {
                    gridApi = agGrid.createGrid(gridEl, gridOptions);
                    gridEl._gridCreated = true;
                }
                gridInited = true;
            }
            function loadRows(callback) {
                $.ajax({
                    url: base + "api/LookUpList/GetBukuTamuDetail",
                    method: "GET",
                    data: { id: idBukuTamu },
                    dataType: "json",
                    success: function(resp) {
                        var list = [];
                        if (resp && resp.success && resp.data) {
                            list = resp.data;
                        } else if (resp && Array.isArray(resp)) {
                            list = resp;
                        } else if (resp && resp.result) {
                            list = resp.result;
                        }
                        var rows = list.map(function(x) {
                            return {
                                Id: x.Id || x.id || 0,
                                Area: x.Area || x.area || "",
                                AreaId: x.AreaId || x.areaId || "",
                                Tanggal: x.Tanggal || x.tanggal || "",
                                Foto: x.Foto || x.foto || "",
                                UserInput: x.UserInput || x.userInput || ""
                            };
                        });
                        callback(rows);
                    },
                    error: function(xhr, status, error) {
                        callback([]);
                    }
                });
            }
            if (window.agGrid && window.agGrid.createGrid) {
                loadRows(buildGrid);
            } else {
                $.getScript("https://cdn.jsdelivr.net/npm/ag-grid-community@31/dist/ag-grid-community.min.js", function() {
                    loadRows(buildGrid);
                }).fail(function(jqxhr, settings, exception) {
                    console.error("Failed to load AG-Grid:", exception);
                    $("#btLogEmpty").removeClass("d-none").html(
                        '<i class="fa-solid fa-exclamation-triangle me-2"></i>' +
                        'Gagal memuat library AG-Grid'
                    );
                });
            }
        }
    });
    $(document).on('click', '.download-document', function (e) {
        e.preventDefault();
        const id = $(this).data('id');
        const field = $(this).data('field');
        if (!id) {
            ew.alert("ID dokumen tidak ditemukan.");
            return;
        }
        $.ajax({
            url: parent_url + 'api/LookUpList/DownloadBukuTamuDetailFoto',
            type: 'GET',
            data: { 
                id: id
            },
            xhrFields: {
                responseType: 'blob'
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader('Content-Disposition');
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            }
        });
    });
    window.onload = function() {
        setTanggal();
    };
});
</script>
