@{
    // View
    View = this;

    // Check action result
    if (penyaluranAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penyaluranAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(penyaluranAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penyaluran: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fPenyaluranadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenyaluranadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["IdPlant", [fields.IdPlant.visible && fields.IdPlant.required ? ew.Validators.required(fields.IdPlant.caption) : null, ew.Validators.integer], fields.IdPlant.isInvalid],
            ["TipePenyaluran", [fields.TipePenyaluran.visible && fields.TipePenyaluran.required ? ew.Validators.required(fields.TipePenyaluran.caption) : null], fields.TipePenyaluran.isInvalid],
            ["TipeProdukSTS", [fields.TipeProdukSTS.visible && fields.TipeProdukSTS.required ? ew.Validators.required(fields.TipeProdukSTS.caption) : null], fields.TipeProdukSTS.isInvalid],
            ["KategoriPenyaluran", [fields.KategoriPenyaluran.visible && fields.KategoriPenyaluran.required ? ew.Validators.required(fields.KategoriPenyaluran.caption) : null], fields.KategoriPenyaluran.isInvalid],
            ["IdModa", [fields.IdModa.visible && fields.IdModa.required ? ew.Validators.required(fields.IdModa.caption) : null], fields.IdModa.isInvalid],
            ["NoShipment", [fields.NoShipment.visible && fields.NoShipment.required ? ew.Validators.required(fields.NoShipment.caption) : null], fields.NoShipment.isInvalid],
            ["IdPipa", [fields.IdPipa.visible && fields.IdPipa.required ? ew.Validators.required(fields.IdPipa.caption) : null], fields.IdPipa.isInvalid],
            ["NomorPolisi", [fields.NomorPolisi.visible && fields.NomorPolisi.required ? ew.Validators.required(fields.NomorPolisi.caption) : null], fields.NomorPolisi.isInvalid],
            ["NamaKapal", [fields.NamaKapal.visible && fields.NamaKapal.required ? ew.Validators.required(fields.NamaKapal.caption) : null], fields.NamaKapal.isInvalid],
            ["JenisProduk", [fields.JenisProduk.visible && fields.JenisProduk.required ? ew.Validators.required(fields.JenisProduk.caption) : null], fields.JenisProduk.isInvalid],
            ["StatusProses", [fields.StatusProses.visible && fields.StatusProses.required ? ew.Validators.required(fields.StatusProses.caption) : null], fields.StatusProses.isInvalid],
            ["IdTemplate", [fields.IdTemplate.visible && fields.IdTemplate.required ? ew.Validators.required(fields.IdTemplate.caption) : null], fields.IdTemplate.isInvalid],
            ["PersentaseProgress", [fields.PersentaseProgress.visible && fields.PersentaseProgress.required ? ew.Validators.required(fields.PersentaseProgress.caption) : null], fields.PersentaseProgress.isInvalid],
            ["Tujuan", [fields.Tujuan.visible && fields.Tujuan.required ? ew.Validators.required(fields.Tujuan.caption) : null], fields.Tujuan.isInvalid],
            ["TujuanKonsinyasi", [fields.TujuanKonsinyasi.visible && fields.TujuanKonsinyasi.required ? ew.Validators.required(fields.TujuanKonsinyasi.caption) : null], fields.TujuanKonsinyasi.isInvalid],
            ["Volume", [fields.Volume.visible && fields.Volume.required ? ew.Validators.required(fields.Volume.caption) : null, ew.Validators.float], fields.Volume.isInvalid],
            ["TanggalSandar", [fields.TanggalSandar.visible && fields.TanggalSandar.required ? ew.Validators.required(fields.TanggalSandar.caption) : null, ew.Validators.datetime(fields.TanggalSandar.clientFormatPattern)], fields.TanggalSandar.isInvalid],
            ["Catatan", [fields.Catatan.visible && fields.Catatan.required ? ew.Validators.required(fields.Catatan.caption) : null], fields.Catatan.isInvalid],
            ["LookupTipeProduk", [fields.LookupTipeProduk.visible && fields.LookupTipeProduk.required ? ew.Validators.required(fields.LookupTipeProduk.caption) : null], fields.LookupTipeProduk.isInvalid],
            ["LookupJenisPlant", [fields.LookupJenisPlant.visible && fields.LookupJenisPlant.required ? ew.Validators.required(fields.LookupJenisPlant.caption) : null], fields.LookupJenisPlant.isInvalid],
            ["MultipleTujuanKonsinyasi", [fields.MultipleTujuanKonsinyasi.visible && fields.MultipleTujuanKonsinyasi.required ? ew.Validators.required(fields.MultipleTujuanKonsinyasi.caption) : null], fields.MultipleTujuanKonsinyasi.isInvalid],
            ["MultipleTujuanKonsinyasiHidden", [fields.MultipleTujuanKonsinyasiHidden.visible && fields.MultipleTujuanKonsinyasiHidden.required ? ew.Validators.required(fields.MultipleTujuanKonsinyasiHidden.caption) : null], fields.MultipleTujuanKonsinyasiHidden.isInvalid],
            ["MultipleQuantity", [fields.MultipleQuantity.visible && fields.MultipleQuantity.required ? ew.Validators.required(fields.MultipleQuantity.caption) : null], fields.MultipleQuantity.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(penyaluranAdd.LookupPlant.ToClientList(penyaluranAdd)),
            "IdPlant": @Html.Raw(penyaluranAdd.IdPlant.ToClientList(penyaluranAdd)),
            "TipePenyaluran": @Html.Raw(penyaluranAdd.TipePenyaluran.ToClientList(penyaluranAdd)),
            "TipeProdukSTS": @Html.Raw(penyaluranAdd.TipeProdukSTS.ToClientList(penyaluranAdd)),
            "KategoriPenyaluran": @Html.Raw(penyaluranAdd.KategoriPenyaluran.ToClientList(penyaluranAdd)),
            "IdModa": @Html.Raw(penyaluranAdd.IdModa.ToClientList(penyaluranAdd)),
            "IdPipa": @Html.Raw(penyaluranAdd.IdPipa.ToClientList(penyaluranAdd)),
            "JenisProduk": @Html.Raw(penyaluranAdd.JenisProduk.ToClientList(penyaluranAdd)),
            "TujuanKonsinyasi": @Html.Raw(penyaluranAdd.TujuanKonsinyasi.ToClientList(penyaluranAdd)),
            "MultipleTujuanKonsinyasi": @Html.Raw(penyaluranAdd.MultipleTujuanKonsinyasi.ToClientList(penyaluranAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    const action = '@HttpContext.Request.Query["action"].ToString()';
    let tujuanOptionsDataGlobal = [];
    if (action !== "addproduct") {
        $("#x_TipePenyaluran, #x_IdModa, #x_IdPlant, #x_KategoriPenyaluran, #x_LookupTipeProduk, #x_LookupJenisPlant").change(function (e) {
            e.preventDefault();
            let TipePenyaluran = $("#x_TipePenyaluran").val();
            let IdModa = $("#x_IdModa").val();
            let IdPlant = $("#x_IdPlant").val();
            let KategoriPenyaluran = $("#x_KategoriPenyaluran").val();
            let TipeProduk = $("#x_LookupTipeProduk").val();
            let JenisPlant = $("#x_LookupJenisPlant").val();
            let idpipa = $("#x_IdPipa").val();
            if (IdModa == "1" || IdModa == "2") {
                $("#r_NamaKapal").show();
                $("#r_NomorPolisi").hide();
                $("#x_NomorPolisi").val("");
            } else if (IdModa == "3") {
                $("#r_NomorPolisi").show();
                $("#r_NamaKapal").hide();
                $("#x_NamaKapal").val("");
            } else {
                $("#r_NamaKapal").hide();
                $("#x_NamaKapal").val("");
                $("#r_NomorPolisi").hide();
                $("#x_NomorPolisi").val("");
            }
            if (IdModa == "5" || IdModa == "12") {
                $("#elh_Penyaluran_TanggalSandar").text("Tanggal");
                $("#x_TanggalSandar").attr("placeholder", "Tanggal");
                $("#qty_caption").text("Quantity (KL)");
            } else if (IdModa == "6") {
                $("#elh_Penyaluran_TanggalSandar").text("Tanggal");
                $("#x_TanggalSandar").attr("placeholder", "Tanggal");
                $("#qty_caption").text("Quantity (MT)");
            } else {
                $("#elh_Penyaluran_TanggalSandar").text("Tanggal Sandar");
                $("#x_TanggalSandar").attr("placeholder", "Tanggal Sandar");
            }
            if (IdModa == "12"){
                getTujuanKonsinyasi(0, IdModa);
            } else if (!idpipa) {
                $("#tujuanKonsinyasiContainer").remove();
                $("#x_MultipleTujuanKonsinyasiHidden").val("[]");
            }
            if (TipePenyaluran == "Konsinyasi") {
                if (IdModa == "3" && TipeProduk == "LPG") {
                    $("#r_Tujuan").show();
                    $("#r_KategoriPenyaluran").show();
                    $("#r_KategoriPenyaluran").insertAfter("#r_IdModa");
                    $("#r_TanggalSandar").hide();
                    $("#x_TanggalSandar").val("");
                    $("#r_TujuanKonsinyasi").hide();
                    $("#x_TujuanKonsinyasi").val("");
                    $("#r_JenisProduk").hide();
                    $("#r_Volume").hide();
                    $("#x_Volume").val("");
                    if (KategoriPenyaluran == "Non TAS/NGS") {
                        $("#r_JenisProduk").show();
                        $("#r_Volume").show();
                        if (JenisPlant == "STS") {
                            $("#r_TipeProdukSTS").show();
                        } else {
                            $("#r_TipeProdukSTS").hide();
                            $("#x_TipeProdukSTS").val("");
                        }
                    } else if (KategoriPenyaluran == "TAS/NGS") {
                        $("#r_NomorPolisi").hide();
                        $("#x_NomorPolisi").val("");
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                    }
                } else if (IdModa === "3" && TipeProduk == "BBM") {
                    $("#r_Tujuan").show();
                    $("#r_KategoriPenyaluran").show();
                    $("#r_KategoriPenyaluran").insertAfter("#r_IdModa");
                    $("#r_TanggalSandar").hide();
                    $("#x_TanggalSandar").val("");
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    //$("#r_JenisProduk").hide();
                    //$("#r_Volume").hide();
                    //$("#x_Volume").val("");
                    if (KategoriPenyaluran === "Non TAS/NGS") {
                        $("#r_JenisProduk").show();
                        $("#r_Volume").show();
                        if (JenisPlant == "STS") {
                            $("#r_TipeProdukSTS").show();
                        } else {
                            $("#r_TipeProdukSTS").hide();
                            $("#x_TipeProdukSTS").val("");
                        }
                    } else if (KategoriPenyaluran == "TAS/NGS") {
                        $("#r_NomorPolisi").hide();
                        $("#x_NomorPolisi").val("");
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_JenisProduk").hide();
                        $("#x_JenisProduk").val("");
                        $("#r_Volume").hide();
                        $("#x_Volume").val("");
                        $("#r_TujuanKonsinyasi").hide();
                        $("#x_TujuanKonsinyasi").val("");
                    }
                } else {
                    $("#r_JenisProduk").show();
                    $("#r_Volume").show();
                    $("#r_KategoriPenyaluran").hide();
                    $("#x_KategoriPenyaluran").val("");
                    $("#r_NoShipment").hide();
                    $("#r_NoShipment").val("");
                    if (IdModa == "1" || IdModa == "2") {
                        $("#r_TanggalSandar").show();
                        $("#r_TujuanKonsinyasi").show();
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_IdPipa").hide();
                        $("#x_IdPipa").val("").trigger("change");
                    } else if (IdModa == "5" || IdModa == "6" || IdModa == "12") {
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_TujuanKonsinyasi").hide();
                        $("#x_TujuanKonsinyasi").val("");
                        $("#r_TanggalSandar").hide();
                        $("#x_TanggalSandar").val("");
                        $("#r_Volume").hide();
                        $("#x_Volume").val("");
                        if (IdModa == "12") {
                            $("#r_IdPipa").hide();
                            $("#x_IdPipa").val("");
                        } else {
                            $("#r_IdPipa").show();
                        }
                    } else if (IdModa == "4") {
                        $("#r_TujuanKonsinyasi").show();
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_NoShipment").show();
                    } else if (IdModa == "3") {
                        // Truck dengan Tipe Produk BBM
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_TujuanKonsinyasi").show();
                        $("#r_TanggalSandar").hide();
                        $("#x_TanggalSandar").val("");
                        $("#r_IdPipa").hide();
                        $("#x_IdPipa").val("").trigger("change");
                    } else {
                        $("#r_TujuanKonsinyasi").show();
                        $("#r_Tujuan").hide();
                        $("#x_Tujuan").val("");
                        $("#r_TanggalSandar").hide();
                        $("#x_TanggalSandar").val("");
                        $("#r_IdPipa").hide();
                        $("#x_IdPipa").val("").trigger("change");
                    }
                    if (JenisPlant == "STS") {
                        $("#r_TipeProdukSTS").show();
                    } else {
                        $("#r_TipeProdukSTS").hide();
                        $("#x_TipeProdukSTS").val("");
                    }
                }
            } else {
                $("#r_Tujuan").show();
                $("#r_KategoriPenyaluran").insertBefore("#r_IdModa");
                $("#r_KategoriPenyaluran").show();
                $("#r_TanggalSandar").hide();
                $("#x_TanggalSandar").val("");
                $("#r_TujuanKonsinyasi").hide();
                $("#x_TujuanKonsinyasi").val("");
                $("#r_JenisProduk").hide();
                $("#x_JenisProduk").val("");
                $("#r_Volume").hide();
                $("#x_Volume").val("");
                if (KategoriPenyaluran == "Non TAS/NGS" && TipeProduk == "LPG") {
                    $("#r_JenisProduk").show();
                    $("#r_Volume").show();
                    if (JenisPlant == "STS") {
                        $("#r_TipeProdukSTS").show();
                    } else {
                        $("#r_TipeProdukSTS").hide();
                        $("#x_TipeProdukSTS").val("");
                    }
                } else if (IdModa == "5") {
                    $("#r_JenisProduk").show();
                    if (JenisPlant == "STS") {
                        $("#r_TipeProdukSTS").show();
                    } else {
                        $("#r_TipeProdukSTS").hide();
                        $("#x_TipeProdukSTS").val("");
                    }
                } else {
                    $("#r_JenisProduk").hide();
                    $("#x_JenisProduk").val("");
                }
                if (KategoriPenyaluran == "TAS/NGS") {
                    $("#r_NomorPolisi").hide();
                    $("#x_NomorPolisi").val("");
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                }
            }
        });
    }
    $("#x_IdPipa").on("change", function (e) {
        e.preventDefault();
        const val = $(this).val();
        const idModa = $("#x_IdModa").val();
        if (val) {
            getTujuanKonsinyasi(val, idModa);
        } else {
            $("#tujuanKonsinyasiContainer").remove();
            $("#x_MultipleTujuanKonsinyasiHidden").val("[]");
        }
    });
    function setNumericFields() {
        $("#x_Volume, .number-format")
            .attr("inputmode", "numeric")
            .on("input", function () {
                let val = $(this).val();
                let isNegative = val.startsWith("-");
                val = val.replace(",", ".");
                val = val.replace(/[^0-9.]/g, "");
                const parts = val.split(".");
                if (parts.length > 2) {
                    val = parts[0] + "." + parts.slice(1).join("");
                }
                if (isNegative) {
                    val = "-" + val;
                }
                $(this).val(val);
            });
    }
    $("#fPenyaluranadd button[type=submit]").on("click", function (e) {
        e.preventDefault();
        const currentHiddenPlant = $("#x_IdPlant").val();
        const currentPipa = $("#x_IdPipa").val();
        const currentModa = $("#x_IdModa").val();
        const lookupPlantVal = $("#x_LookupPlant").val();
        if (!currentHiddenPlant && lookupPlantVal) {
            const lookupPlantText = $("#x_LookupPlant").find("option:selected").text();
            $("#x_IdPlant").val(lookupPlantVal);
            $("#sv_x_IdPlant").val(lookupPlantText || "");
        }
        if (!$("#x_IdPlant").val()) {
            ew.alert("Silakan pilih Plant terlebih dahulu");
            return false;
        }
        const parent_url = ew.PATH_BASE;
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != "1" && idRole != "12" && idRole != "13") {
            ew.alert("Anda tidak memiliki akses untuk menambah data Penerimaan.");
            setTimeOut(() => {
                window.location.href = parent_url + "PenerimaanList";
            }, 1000);
            return false;
        }
        if (currentPipa || currentModa == "12") {
            syncTujuanKonsinyasiHidden();
            const payload = $("#x_MultipleTujuanKonsinyasiHidden").val();
            const arr = payload ? JSON.parse(payload) : [];
            if (arr.length === 0) {
                ew.alert("Minimal pilih 1 Tujuan Konsinyasi.");
                return false;
            }
            for (let i = 0; i < arr.length; i++) {
                const item = arr[i];
                const tujuan = (item.Label || item.Value || "").toString().trim();
                const qtyRaw = (item.Qty ?? "").toString().trim();
                if (!qtyRaw) {
                    ew.alert(`Quantity untuk "${tujuan}" tidak boleh kosong.`);
                    return false;
                }
                const qtyNumber = parseFloat(qtyRaw.replace(",", "."));
                if (isNaN(qtyNumber) || qtyNumber <= 0) {
                    ew.alert(`Quantity untuk "${tujuan}" harus angka lebih dari 0.`);
                    return false;
                }
            }
        }
        showLoading();
        $("#fPenyaluranadd").submit();
    });
    $("#x_LookupPlant").on("change", function (e) {
        e.preventDefault();
        const selectedValue = $(this).val();
        $("#x_IdPlant").val(selectedValue).trigger("change");
    });
    function getTujuanKonsinyasi(idPipa, idModa) {
        $.ajax({
            url: parent_url + "api/LookUpList/get-dropdown/tujuan-konsinyasi?idPipa=" + encodeURIComponent(idPipa) + "&idModa=" + encodeURIComponent(idModa),
            method: "GET",
            dataType: "json",
            success: function (data) {
                tujuanOptionsDataGlobal = data || [];
                renderTujuanKonsinyasiTable(data);
                syncTujuanKonsinyasiHidden();
                enforceUniqueTujuanSelectionsRemove();
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                tujuanOptionsDataGlobal = [];
                renderTujuanKonsinyasiTable([]);
                syncTujuanKonsinyasiHidden();
            },
        });
    }
    function renderTujuanKonsinyasiTable(optionsData) {
        ensureTujuanKonsinyasiUI();
        const container = $("#tujuanKonsinyasiContainer");
        const IdModa = $("#x_IdModa").val();
        container.show();
        container.empty();
        let caption = "Quantity";
        if ($("#x_IdModa").val() == "5") {
            caption = "Quantity (KL)";
        } else if ($("#x_IdModa").val() == "6") {
            caption = "Quantity (MT)";
        }
        const html = `
                    <div class='row'>
                        <div class='col-2'>
                        </div>
                        <div class='col-10'>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <button type="button" class="btn btn-primary" id="btnAddTujuanRow">
                                    <i class='fas fa-plus me-2'></i> Tambah
                                </button>
                            </div>
                            <table class="table" id="tblTujuanKonsinyasi">
                                <thead class="table-primary">
                                    <tr>
                                        <th style="width:60px;">No</th>
                                        <th>Tujuan Konsinyasi</th>
                                        <th id='qty_caption' style="width:160px;">${caption}</th>
                                        <th style="width:80px;">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                `;
        container.append(html);
        if (optionsData && optionsData.length > 0) {
            if (IdModa == '12') {
                addTujuanRow(optionsData, '', '');
            } else {
                for (let i = 0; i < optionsData.length; i++) {
                    addTujuanRow(optionsData, optionsData[i].Value, optionsData[i].Volume);
                }
            }
        } else {
            addTujuanRow([], "", "");
        }
        $("#btnAddTujuanRow")
            .off("click")
            .on("click", function () {
                addTujuanRow(optionsData || [], "", "");
                syncTujuanKonsinyasiHidden();
                enforceUniqueTujuanSelectionsRemove();
            });
        renumberTujuanRows();
        syncTujuanKonsinyasiHidden();
        enforceUniqueTujuanSelectionsRemove();
    }
    function addTujuanRow(optionsData, selectedValue, qtyValue) {
        const tbody = $("#tblTujuanKonsinyasi tbody");
        if (tbody.length === 0) return;
        const rowId = "tujuanRow_" + Date.now() + "_" + Math.floor(Math.random() * 9999);
        const selectHtml = buildSelectOptions(optionsData, selectedValue);
        let caption = "Quantity";
        if ($("#x_IdModa").val() == "5") {
            caption = "Quantity (KL)";
        } else if ($("#x_IdModa").val() == "6") {
            caption = "Quantity (MT)";
        }
        const tr = `
                    <tr data-rowid="${rowId}">
                        <td class="text-center nomor"></td>
                        <td>
                            <select class="form-select tujuan-select" style="width: 100%;">
                                ${selectHtml}
                            </select>
                        </td>
                        <td>
                            <input type="text" class="form-control qty-input number-format"
                                    placeholder="" value="" />
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-danger btnRemoveTujuanRow">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
        tbody.append(tr);
        const $row = tbody.find(`tr[data-rowid="${rowId}"]`);
        $row.find(".tujuan-select").select2({
            placeholder: "Pilih Tujuan",
            width: "100%",
            allowClear: true
        });
        $row.find(".tujuan-select")
            .off("change")
            .on("change", function () {
                syncTujuanKonsinyasiHidden();
            })
            .on("click.tujuan focus.tujuan", function () {
                syncTujuanKonsinyasiHidden();
            });
        $row.find(".qty-input")
            .off("input")
            .on("input", function () {
                syncTujuanKonsinyasiHidden();
            });
        $row.find(".btnRemoveTujuanRow")
            .off("click")
            .on("click", function () {
                $(this).closest("tr").remove();
                renumberTujuanRows();
                syncTujuanKonsinyasiHidden();
                enforceUniqueTujuanSelectionsRemove();
            });
        renumberTujuanRows();
        setNumericFields();
        enforceUniqueTujuanSelectionsRemove();
    }
    function buildSelectOptions(optionsData, selectedValue) {
        let opt = `<option value="">- Pilih -</option>`;
        if (optionsData && optionsData.length > 0) {
            optionsData.forEach((x) => {
                const isSelected = x.Value == selectedValue ? "selected" : "";
                opt += `<option value="${x.Value}">${x.Label}</option>`;
            });
        }
        return opt;
    }
    function syncTujuanKonsinyasiHidden() {
        const selected = [];
        $("#tblTujuanKonsinyasi tbody tr").each(function () {
            const ddl = $(this).find(".tujuan-select");
            const val = ddl.val();
            const text = ddl.find("option:selected").text();
            const qtyRaw = $(this).find(".qty-input").val();
            const qty = qtyRaw !== null && qtyRaw !== undefined && qtyRaw !== "" ? qtyRaw : "0";
            if (val) {
                selected.push({
                    Value: val,
                    Label: text,
                    Qty: qty,
                });
            }
        });
        $("#x_MultipleTujuanKonsinyasiHidden").val(JSON.stringify(selected));
    }
    function renumberTujuanRows() {
        $("#tblTujuanKonsinyasi tbody tr").each(function (idx) {
            $(this)
                .find("td.nomor")
                .text(idx + 1);
        });
    }
    function ensureTujuanKonsinyasiUI() {
        if ($("#x_MultipleTujuanKonsinyasiHidden").length === 0) {
            $("<input>", {
                type: "hidden",
                id: "x_MultipleTujuanKonsinyasiHidden",
                name: "x_MultipleTujuanKonsinyasiHidden",
                value: "[]",
            }).appendTo("#fPenyaluranadd");
        }
        if ($("#tujuanKonsinyasiContainer").length === 0) {
            $("<div>", {
                id: "tujuanKonsinyasiContainer",
                class: "mt-2",
            }).insertAfter($("#r_IdPipa"));
        }
    }
    function enforceUniqueTujuanSelectionsRemove() {
        const IdPlant = $("#x_IdPlant").val();
        const IdModa = $("#x_IdModa").val();
        const allSelected = [];
        $("#tblTujuanKonsinyasi .tujuan-select").each(function () {
            const v = $(this).val();
            if (v) allSelected.push(String(v));
        });
        $("#tblTujuanKonsinyasi .tujuan-select").each(function () {
            const $ddl = $(this);
            const currentVal = String($ddl.val() || "");
            const blocked = allSelected.filter(v => v !== currentVal);
            $ddl.empty();

            // hanya moda 12 yang butuh placeholder kosong
            if (IdModa === "12") {
                $ddl.append(`<option value=""></option>`);
            }
            (tujuanOptionsDataGlobal || []).forEach((x) => {
                const v = String(x.Value);
                const label = x.Label ?? "";
                if (blocked.includes(v)) return;
                if (String(IdPlant) === v) return;
                const selectedAttr = v === currentVal ? "selected" : "";
                $ddl.append(`<option value="${v}" ${selectedAttr}>${label}</option>`);
            });
            $ddl.select2({
                placeholder: "Pilih Tujuan",
                width: "100%",
                allowClear: true
            });
            if (IdModa === "12") {
                if (currentVal) {
                    $ddl.val(currentVal);
                } else {
                    $ddl.val(null);
                }
            } else {
                if (currentVal) {
                    $ddl.val(currentVal);
                } else {
                    const firstVal = $ddl.find("option:first").val();
                    $ddl.val(firstVal);
                }
            }
            $ddl.trigger("change.select2");
        });
    }
    ensureTujuanKonsinyasiUI();
    setNumericFields();
});
</script>
