@if (!setPjsList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("SetPjs");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    const parent_url = ew.PATH_BASE;
    // Stepper untuk halaman ProofOfVisit (tampilkan hanya step 1)
    (function() {
        // definisi 1 langkah saja
        const steps = [
            { number: 1, label: "Set User PJS", url: "", icon: "fa-user-clock" }
        ];
        const currentStep = 1;

        // sisipkan CSS stepper sekali saja
        if (!document.querySelector("style[data-hsse-stepper]")) {
            $("<style data-hsse-stepper>")
              .prop("type", "text/css")
              .html(`
                .stepper{display:flex;counter-reset:step}
                .step{width:150px;text-align:center;position:relative}
                .step:not(:last-child)::after{content:'';position:absolute;top:20px;right:-50%;width:100%;height:4px;background-color:#ccc;z-index:0}
                .step.completed:not(:last-child)::after{background-color:#3c6dbd}
                .step-icon{width:36px;height:36px;line-height:36px;border-radius:50%;background:#ccc;display:inline-block;z-index:1;position:relative;color:#fff;font-weight:bold}
                .step.active .step-icon{background:#3c6dbd}
                .step-label{margin-top:8px;font-size:14px;display:flex;justify-content:center;align-items:center;gap:6px;color:#3c6dbd;text-decoration:none}
                .step-label-not-active{color:#CCC!important}
            `).appendTo("head");
        }

        // bangun HTML stepper
        const $wrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
        const $stepper = $wrapper.find(".stepper");
        steps.forEach(step => {
            const isActive = step.number === currentStep;
            const icon = `<div class="step-icon${isActive ? ' bg-success' : ''}">${step.number}</div>`;
            const label = isActive
                ? `<div class="step-label text-success"><i class="fa-solid ${step.icon} me-1 text-success"></i>${step.label}</div>`
                : `<div class="step-label-not-active"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</div>`;
            $stepper.append(`<div class="step ${isActive ? 'active text-success' : 'text-secondary'}">${icon}${label}</div>`);
        });
        $(".content-header .container-fluid .row").append($wrapper);
    })();

    // ===== Pindahkan tombol Add ke samping Search =====
    (function () {
      const addUrl = `${parent_url}SetPjsAdd`;
      const $addBtn = $(`
        <a href="${addUrl}" class="btn btn-success ms-2" id="btn-add-pjs">
          <i class="fa-solid fa-plus"></i> Add New
        </a>
      `);

      // Cari tombol Search di panel pencarian lalu sisipkan tombol Add setelahnya
      const $searchBtn =
        $('.ew-search-panel button[type="submit"].btn-primary').first()   // ASP.NET Maker default
        .add($('#btn-search').first());                                   // fallback kalau ada id custom
      if ($searchBtn.length) {
        $searchBtn.after($addBtn);
      } else {
        // Fallback terakhir: taruh di ujung panel pencarian
        $('.ew-search-panel .ew-extended-search, .ew-search-panel').first().append($('<div class="mt-2"></div>').append($addBtn));
      }

      // Sembunyikan tombol Add di bagian bawah grid agar tidak dobel
      $('.ew-grid-lower-panel .ew-list-other-options a, .ew-grid-lower-panel a').filter(function () {
        return (this.href || '').includes('SetPjsAdd');
      }).closest('.ew-list-other-options, .btn, a').hide();

      // Jika tombol Add di footer berupa ikon (+), sembunyikan juga
      $('.ew-grid-lower-panel .btn, .ew-grid-lower-panel a').filter(function () {
        return $(this).find('.fa-plus, .fa-solid.fa-plus').length > 0;
      }).closest('.btn, a').hide();
    })();
    $.ajax({
        url: `${parent_url}api/LookUpList/GetDetailPjs`,
        type: 'GET',
        success: function (res) {
            let resultHtml = '';
            const username = "@CurrentUserName()";
            if (res.success) {
                if (res.result.exception) {
                    resultHtml  =   `<span class="ms-3 fw-bold">
                                        Saat ini user <span style="color: red; font-style: italic;">${username}</span> sedang menjabat sebagai PJS 
                                        <span style="color: red; font-style: italic;">${res.result.PosisiPJS}</span>, 
                                        mulai tanggal <span style="color: red; font-style: italic;">${res.result.TanggalMulai}</span> 
                                        hingga tanggal <span style="color: red; font-style: italic;">${res.result.TanggalSelesai}</span>
                                    </span>` ;
                } else {
                    resultHtml  =   `<span class="ms-3 fw-bold">
                                        Saat ini user <span style="color: red; font-style: italic;">${username}</span> tidak sedang menjabat sebagai PJS 
                                    </span>` ;
                }
            }
            $(".ew-filter-option").after(resultHtml);
        },
        error: function (xhr, status, error) {
            console.error('Gagal get detail pjs:', status, error);
        }
    });
});
</script>
}
