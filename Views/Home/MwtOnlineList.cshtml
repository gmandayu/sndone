@if (!mwtOnlineList.IsModal) {
<form name="fMWTOnlinesrch" id="fMWTOnlinesrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fMWTOnlinesrch_search_panel" class="mb-2 mb-sm-0 @(mwtOnlineList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(mwtOnlineList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MWTOnline: currentTable } });
var currentForm;
var fMWTOnlinesrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fMWTOnlinesrch")
        .setPageId("list")
@if (mwtOnlineList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "NoMWTOnline": @Html.Raw(mwtOnlineList.NoMWTOnline.ToClientList(mwtOnlineList)),
            "LinkRedirect": @Html.Raw(mwtOnlineList.LinkRedirect.ToClientList(mwtOnlineList)),
            "LookupPlant": @Html.Raw(mwtOnlineList.LookupPlant.ToClientList(mwtOnlineList)),
            "IdPlant": @Html.Raw(mwtOnlineList.IdPlant.ToClientList(mwtOnlineList)),
            "TaskList": @Html.Raw(mwtOnlineList.TaskList.ToClientList(mwtOnlineList)),
            "Status": @Html.Raw(mwtOnlineList.Status.ToClientList(mwtOnlineList)),
            "_File": @Html.Raw(mwtOnlineList._File.ToClientList(mwtOnlineList)),
            "StatusEmail": @Html.Raw(mwtOnlineList.StatusEmail.ToClientList(mwtOnlineList)),
            "CreatedBy": @Html.Raw(mwtOnlineList.CreatedBy.ToClientList(mwtOnlineList)),
            "CreatedDate": @Html.Raw(mwtOnlineList.CreatedDate.ToClientList(mwtOnlineList)),
            "LastUpdatedBy": @Html.Raw(mwtOnlineList.LastUpdatedBy.ToClientList(mwtOnlineList)),
            "LastUpdatedDate": @Html.Raw(mwtOnlineList.LastUpdatedDate.ToClientList(mwtOnlineList)),
            "CompletedBy": @Html.Raw(mwtOnlineList.CompletedBy.ToClientList(mwtOnlineList)),
            "CompletedDate": @Html.Raw(mwtOnlineList.CompletedDate.ToClientList(mwtOnlineList)),
        })

        // Filters
        .setFilterList(@Html.Raw(mwtOnlineList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
