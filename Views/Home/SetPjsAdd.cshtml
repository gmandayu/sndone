            "DiperbaharuiOleh": @Html.Raw(setPjsAdd.DiperbaharuiOleh.ToClientList(setPjsAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    var parent_url = ew.PATH_BASE;
    $("#SuratTugas-Name").on("click", function (e) {
        $("#SuratTugas").trigger("click");
    });
    $("#SuratTugas").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#SuratTugas-Name").val(file.name);
    });
    $("#btn-back").on("click", function (e) {
        window.location.href = `${parent_url}SetPjsList`;
    });
    $("#x_OrganizationLevel, #x_Region, #x_Plant").on("change", function(e) {
        const value = $('#x_OrganizationLevel').val();
        const ddl = $("#x_LookupPosition");
        const rRegion = $("#rRegion");
        const rPlant = $("#rPlant");
        const elRegion = $("#x_Region");
        const elPlant = $("#x_Plant");
        const idRegion = elRegion.val();
        const idPlant = elPlant.val();
        ddl.empty();
        if (!value) {
            return;
        }
        ddl.append('<option value="">Loading...</option>');
        let urlApi = `${parent_url}api/LookUpList/get-dropdown/pjs-position?OrganizationLevel=${value}`;
        if (value === 'REGION') {
            rRegion.show();
            rPlant.hide();
            if (idRegion) {
                urlApi += `&IdRegion=${idRegion}`;
                fillIdPosition(urlApi);
            }
        } else if (value === 'PLANT') {
            rRegion.show();
            rPlant.show();
            if (idRegion && idPlant) {
                urlApi += `&IdRegion=${idRegion}&IdPlant=${idPlant}`;
                fillIdPosition(urlApi);
            }
        } else {
            rRegion.hide();
            rPlant.hide();
            fillIdPosition(urlApi);
        }
    });
    function fillIdPosition(urlApi) {
        const ddl = $("#x_LookupPosition");
        $.ajax({
            url: urlApi,
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                $.each(data, function (index, item) {
                    ddl.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
    }
    $(document).on("click", "#btn-submit-custom", function(){
        const OrganizationLevel = $('#x_OrganizationLevel').val();
        const Position = $('#x_LookupPosition').val();
        const TanggalMulai = $('#x_TanggalMulai').val();
        const TanggalSelesai = $('#x_TanggalSelesai').val();
        const Keterangan = $('#x_Keterangan').val();
        const Plant = $('#x_Plant').val();
        const Region = $('#x_Region').val();
        if (!OrganizationLevel) return ew.alert("Organization Level baru tidak boleh kosong!");
        if (!Position) return ew.alert("Position baru tidak boleh kosong!");
        if (!TanggalMulai) return ew.alert("Tanggal Mulai tidak boleh kosong!");
        if (!TanggalSelesai) return ew.alert("Tanggal Selesai tidak boleh kosong!");
        let formData = new FormData();
        formData.append("OrganizationLevel", OrganizationLevel);
        formData.append("PosisiPJS", Position);
        formData.append("TanggalMulai", TanggalMulai);
        formData.append("TanggalSelesai", TanggalSelesai);
        formData.append("Keterangan", Keterangan);
        formData.append("IdPlant", Plant);
        formData.append("IdRegion", Region);
        const file = $("#SuratTugas")[0].files[0];
        if (file) {
            formData.append("SuratTugas", file);
        } else {
            return ew.alert("Surat Tugas tidak boleh kosong!");
        }
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/AddNewPjs",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = `${parent_url}SetPjsList`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Error: " + xhr.responseText);
            }
        });
    });
    $(document).ready(function() {
        $("#x_OrganizationLevel").trigger("change");
        const steps = [
            { number: 1, label: "Set User PJS", url: "", icon: "fa-user-clock" }
        ];
        const currentStep = 1;
        if (!document.querySelector("style[data-hsse-stepper]")) {
            $("<style data-hsse-stepper>")
                .prop("type", "text/css")
                .html(`
                .stepper{display:flex;counter-reset:step}
                .step{width:150px;text-align:center;position:relative}
                .step:not(:last-child)::after{content:'';position:absolute;top:20px;right:-50%;width:100%;height:4px;background-color:#ccc;z-index:0}
                .step.completed:not(:last-child)::after{background-color:#3c6dbd}
                .step-icon{width:36px;height:36px;line-height:36px;border-radius:50%;background:#ccc;display:inline-block;z-index:1;position:relative;color:#fff;font-weight:bold}
                .step.active .step-icon{background:#3c6dbd}
                .step-label{margin-top:8px;font-size:14px;display:flex;justify-content:center;align-items:center;gap:6px;color:#3c6dbd;text-decoration:none}
                .step-label-not-active{color:#CCC!important}
            `).appendTo("head");
        }
        const $wrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
        const $stepper = $wrapper.find(".stepper");
        steps.forEach(step => {
            const isActive = step.number === currentStep;
            const icon = `<div class="step-icon${isActive ? ' bg-success' : ''}">${step.number}</div>`;
            const label = isActive
                ? `<div class="step-label text-success"><i class="fa-solid ${step.icon} me-1 text-success"></i>${step.label}</div>`
                : `<div class="step-label-not-active"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</div>`;
            $stepper.append(`<div class="step ${isActive ? 'active text-success' : 'text-secondary'}">${icon}${label}</div>`);
        });
        $(".content-header .container-fluid .row").append($wrapper);
    });
});
</script>
