<input type="@(setPjsEdit.TanggalMulai.InputTextType)" name="x_TanggalMulai" id="x_TanggalMulai" data-table="SetPjs" data-field="x_TanggalMulai" value="@Html.Raw(setPjsEdit.TanggalMulai.EditValue)" placeholder="@Html.Raw(HtmlEncode(setPjsEdit.TanggalMulai.PlaceHolder))" data-format-pattern="@(setPjsEdit.TanggalMulai.FormatPattern)"@Html.Raw(setPjsEdit.TanggalMulai.EditAttributes) aria-describedby="x_TanggalMulai_help">
