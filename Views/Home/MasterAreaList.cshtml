@{
    // View
    View = this;

    // Check action result
    if (masterAreaList.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterAreaList.UseLayout ? "_Layout" : "";
}
@if (!masterAreaList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterAreaList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterArea: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(masterAreaList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(masterAreaList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(masterAreaList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(masterAreaList.FormKeyCountName)")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (!masterAreaList.IsExport()) {
<div class="btn-toolbar ew-toolbar">
@if (masterAreaList.TotalRecords > 0 && masterAreaList.ExportOptions.Visible) {
    masterAreaList.ExportOptions.Render("body");
}
@if (masterAreaList.ImportOptions.Visible) {
    masterAreaList.ImportOptions.Render("body");
}
@if (masterAreaList.SearchOptions.Visible) {
    masterAreaList.SearchOptions.Render("body");
}
@if (masterAreaList.FilterOptions.Visible) {
    masterAreaList.FilterOptions.Render("body");
}
</div>
}
@if (!masterAreaList.IsModal) {
<form name="fMasterAreasrch" id="fMasterAreasrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fMasterAreasrch_search_panel" class="mb-2 mb-sm-0 @(masterAreaList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(masterAreaList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterArea: currentTable } });
var currentForm;
var fMasterAreasrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fMasterAreasrch")
        .setPageId("list")
@if (masterAreaList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Dynamic selection lists
        .setLists({
        })

        // Filters
        .setFilterList(@Html.Raw(masterAreaList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
<input type="hidden" name="cmd" value="search">
@if (Security.CanSearch) {
if (!masterAreaList.IsExport() && Empty(masterAreaList.CurrentAction) && masterAreaList.HasSearchFields()) { @* Show search form (begin) *@
<div class="ew-extended-search container-fluid ps-2">
<div class="row mb-0">
    <div class="col-sm-auto px-0 pe-sm-2">
        <div class="ew-basic-search input-group">
            <input type="search" name="@(Config.TableBasicSearch)" id="@(Config.TableBasicSearch)" class="form-control ew-basic-search-keyword" value="@Html.Raw(HtmlEncode(masterAreaList.BasicSearch.SessionKeyword))" placeholder="@(HtmlEncode(Language.Phrase("Search")))" aria-label="@(HtmlEncode(Language.Phrase("Search")))">
            <input type="hidden" name="@(Config.TableBasicSearchType)" id="@(Config.TableBasicSearchType)" class="ew-basic-search-type" value="@(HtmlEncode(masterAreaList.BasicSearch.SessionType))">
            <button type="button" data-bs-toggle="dropdown" class="btn btn-outline-secondary dropdown-toggle dropdown-toggle-split" aria-haspopup="true" aria-expanded="false">
                <span id="searchtype">@Html.Raw(masterAreaList.BasicSearch.TypeNameShort)</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
                <button type="button" class="dropdown-item@(masterAreaList.BasicSearch.SessionType == "" ? " active" : "")" form="fMasterAreasrch" data-ew-action="search-type">@Html.Raw(Language.Phrase("QuickSearchAuto"))</button>
                <button type="button" class="dropdown-item@(masterAreaList.BasicSearch.SessionType == "=" ? " active" : "")" form="fMasterAreasrch" data-ew-action="search-type" data-search-type="=">@Html.Raw(Language.Phrase("QuickSearchExact"))</button>
                <button type="button" class="dropdown-item@(masterAreaList.BasicSearch.SessionType == "AND" ? " active" : "")" form="fMasterAreasrch" data-ew-action="search-type" data-search-type="AND">@Html.Raw(Language.Phrase("QuickSearchAll"))</button>
                <button type="button" class="dropdown-item@(masterAreaList.BasicSearch.SessionType == "OR" ? " active" : "")" form="fMasterAreasrch" data-ew-action="search-type" data-search-type="OR">@Html.Raw(Language.Phrase("QuickSearchAny"))</button>
            </div>
        </div>
    </div>
    <div class="col-sm-auto mb-3">
        <button class="btn btn-primary" name="btn-submit" id="btn-submit" type="submit">@Html.Raw(Language.Phrase("SearchBtn"))</button>
    </div>
</div>
</div><!-- /.ew-extended-search -->
} @* Show search form (end) *@
}
</div><!-- /.ew-search-panel -->
</form>
}
@masterAreaList.ShowPageHeader()
@masterAreaList.ShowMessages()
<main class="list @(masterAreaList.TotalRecords == 0 && !masterAreaList.IsAdd ? " ew-no-record" : "")">
<div id="ew-header-options">
    @masterAreaList.HeaderOptions.RenderBody()
</div>
<div id="ew-list">
@if (masterAreaList.TotalRecords > 0 || !Empty(masterAreaList.CurrentAction)) {
<div class="card ew-card ew-grid@(masterAreaList.IsAddOrEdit ? " ew-grid-add-edit" : "") @(masterAreaList.TableGridClass)">
<form name="@(masterAreaList.FormName)" id="@(masterAreaList.FormName)" class="ew-form ew-list-form" action="@AppPath(masterAreaList.PageName)" method="post" novalidate autocomplete="off">
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
@if (masterAreaList.IsModal) {
<input type="hidden" name="modal" value="1">
}
<div id="gmp_MasterArea" class="card-body ew-grid-middle-panel @(masterAreaList.TableContainerClass)" style="@(masterAreaList.TableContainerStyle)">
@if (masterAreaList.TotalRecords > 0 || masterAreaList.IsGridEdit || masterAreaList.IsMultiEdit) {
<table id="tbl_MasterArealist" class="@(masterAreaList.TableClass)"><!-- .ew-table -->
<thead>
    <tr class="ew-table-header">
@{
    // Header row
    masterAreaList.RowType = RowType.Header;

    // Render list options
    await masterAreaList.RenderListOptions();
}
@* Render list options (header, left) *@
@masterAreaList.ListOptions.RenderHeader("left")
@if (masterAreaList.ID.Visible) { // masterAreaList.ID.Visible (begin)
        <th data-name="ID" class="@(masterAreaList.ID.HeaderCellClass)"><div id="elh_MasterArea_ID" class="MasterArea_ID">@Html.Raw(masterAreaList.RenderFieldHeader(masterAreaList.ID))</div></th>
} @* masterAreaList.ID.Visible (end) *@
@if (masterAreaList.Area.Visible) { // masterAreaList.Area.Visible (begin)
        <th data-name="Area" class="@(masterAreaList.Area.HeaderCellClass)"><div id="elh_MasterArea_Area" class="MasterArea_Area">@Html.Raw(masterAreaList.RenderFieldHeader(masterAreaList.Area))</div></th>
} @* masterAreaList.Area.Visible (end) *@
@* Render list options (header, right) *@
@masterAreaList.ListOptions.RenderHeader("right")
    </tr>
</thead>
<tbody data-page="@(masterAreaList.PageNumber)">
@{
    await masterAreaList.SetupGrid();
    bool eof = masterAreaList.Recordset == null; // DN
}
@while (masterAreaList.RecordCount < masterAreaList.StopRecord || SameString(masterAreaList.RowIndex, "$rowindex$")) { // Begin While
    if (!eof && !SameString(masterAreaList.RowIndex, "$rowindex$") &&
        (!masterAreaList.IsGridAdd || masterAreaList.CurrentMode == "copy") &&
        (!((masterAreaList.IsCopy || masterAreaList.IsAdd) && masterAreaList.RowIndex is int rowIndex && rowIndex == 0))) // DN
        eof = !await masterAreaList.Recordset.ReadAsync();
    masterAreaList.RecordCount++;
    if (masterAreaList.RecordCount >= masterAreaList.StartRecord) {
        await masterAreaList.SetupRow();
    <tr @Html.Raw(masterAreaList.RowAttributes)>
    @* Render list options (body, left) *@
    @masterAreaList.ListOptions.RenderBody("left", masterAreaList.RowCount)
    @if (masterAreaList.ID.Visible) { // masterAreaList.ID.Visible (begin)
        <td data-name="ID" @Html.Raw(masterAreaList.ID.CellAttributes)>
<span id="el@(SameString(masterAreaList.RowIndex, "$rowindex$") ? "$rowindex$" : masterAreaList.RowCount)_MasterArea_ID" class="el_MasterArea_ID">
<span @Html.Raw(masterAreaList.ID.ViewAttributes)>
@Html.Raw(masterAreaList.ID.GetViewValue())</span>
</span>
</td>
    } @* masterAreaList.ID.Visible (end) *@
    @if (masterAreaList.Area.Visible) { // masterAreaList.Area.Visible (begin)
        <td data-name="Area" @Html.Raw(masterAreaList.Area.CellAttributes)>
<span id="el@(SameString(masterAreaList.RowIndex, "$rowindex$") ? "$rowindex$" : masterAreaList.RowCount)_MasterArea_Area" class="el_MasterArea_Area">
<span @Html.Raw(masterAreaList.Area.ViewAttributes)>
@Html.Raw(masterAreaList.Area.GetViewValue())</span>
</span>
</td>
    } @* masterAreaList.Area.Visible (end) *@
    @* Render list options (body, right) *@
    @masterAreaList.ListOptions.RenderBody("right", masterAreaList.RowCount)
    </tr>
    } @* End if *@

    // Reset for template row
    if (SameString(masterAreaList.RowIndex, "$rowindex$"))
        masterAreaList.RowIndex = 0;

    // Reset inline add/copy row
    if ((masterAreaList.IsCopy || masterAreaList.IsAdd) && masterAreaList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        masterAreaList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(masterAreaList.CurrentAction) && !masterAreaList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
@{ masterAreaList.CloseRecordset(); }
@if (!masterAreaList.IsExport()) {
<div class="card-footer ew-grid-lower-panel">
@if (!masterAreaList.IsGridAdd && !(masterAreaList.IsGridEdit && masterAreaList.ModalGridEdit) && !masterAreaList.IsMultiEdit) {
@Html.Raw(masterAreaList.Pager.Render())
}
<div class="ew-list-other-options">
@masterAreaList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@masterAreaList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @masterAreaList.FooterOptions.RenderBody()
</div>
</main>
@masterAreaList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!masterAreaList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MasterArea");
});
</script>
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
}
