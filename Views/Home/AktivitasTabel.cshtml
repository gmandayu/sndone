                LEFT JOIN Penyaluran P ON PP.NoPenyaluran = P.NomorPenyaluran
                LEFT JOIN MasterProduk MP ON P.JenisProduk = MP.NoProduk
            WHERE
                PP.NomorPenimbunanPenyaluran = @NoReferensi;";
            Console.WriteLine("[INFO]: " + sqlQuery);
            Console.WriteLine("[INFO]: " + NoReferensi);
            using (SqlCommand cmd = new SqlCommand(sqlQuery, sqlConnection))
            {
                cmd.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = cmd.ExecuteReader())
                {
                    if (rs.Read())
                    {
                        Produk = rs["JenisProduk"] != null ? rs["JenisProduk"].ToString() : "";
                        produkView = rs["produk_view"] != null ? rs["produk_view"].ToString() : "";
                    }
                }
            }
            formList = new List<List<string>> {
                new List<string> { "Nama Kegiatan", "text", "NamaKegiatan", $"Logbook Penerimaan ({produkView})" },
                new List<string> { "Produk", "select", "Produk" },
                new List<string> { "Tanggal", "datetime-local", "Tanggal" },
                new List<string> { "Density", "number", "Density" },
                new List<string> { "Temperature", "number", "Temperatur" },
                new List<string> { "Level", "number", "Level" },
                new List<string> { "Volume", "number", "Volume" },
                new List<string> { "Flowrate", "number", "Flowrate" },
                new List<string> { "Keterangan", "textarea", "Keterangan" },
                new List<string> { Produk, "hidden", "Produk" }
            };
        }
        else if (IdTemplateAktivitas == "447")
        {
            tangkiList.Clear();
            resultList.Clear();

            string IdPlant = generalList["IdPlant"] != null ? generalList["IdPlant"].ToString() : "";

            sqlQuery = $@"
            SELECT
                A.id,
                A.LO,
                A.NomorTangki,
                A.NomorTangki2,
                A.Produk,
                A.MeterAwal,
                A.MeterAkhir,
                A.Volume,
                A.BayNumber,
                A.NoMeter,
                A.NomorKompartment,
                A.InLineBlending,
                MT.Sloc,
                MT.SeqTangki,
                MT.NamaTerminal,
                MT2.Sloc AS Sloc2,
                MT2.SeqTangki AS SeqTangki2,
                MT2.NamaTerminal AS NamaTerminal2,
                MP.NoProduk,
                MP.NamaProduk,
                MP.NoProduk + ' - ' + MP.NamaProduk AS Produk_disabled
            FROM {TableAnak} A
            LEFT JOIN MasterProduk MP ON A.Produk = MP.NoProduk
            LEFT JOIN MasterTangki MT ON A.NomorTangki = MT.id
            LEFT JOIN MasterTangki MT2 ON A.NomorTangki2 = MT2.id
            WHERE A.idAktifitas = @IdAktivitas;";

            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    while (rs.Read())
                    {
                        Dictionary<string, object> row = new Dictionary<string, object>();
                        for (int i = 0; i < rs.FieldCount; i++)
                        {
                            row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                        }
                        resultList.Add(row);
                    }
                }
            }

            sqlQuery = @"SELECT
                MT.id,
                MT.NamaTerminal,
                MT.Plant,
                MT.Sloc,
                MT.MatNo,
                MT.SeqTangki,
                MP.NamaProduk
            FROM MasterTangki MT
            LEFT JOIN MasterProduk MP ON MT.MatNo = MP.NoProduk
            WHERE MT.Status = 'OPERASI' AND MT.Plant = (
                SELECT TOP 1 MPL.Plant FROM MasterPlant MPL
                WHERE MPL.IdPlant = (
                    SELECT TOP 1 P.IdPlant FROM Penyaluran P
                    WHERE P.NomorPenyaluran = @NoReferensi
                )
            );";
            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    while (rs.Read())
                    {
                        Dictionary<string, object> row = new Dictionary<string, object>();
                        for (int i = 0; i < rs.FieldCount; i++)
                        {
                            row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                        }
                        tangkiList.Add(row);
                    }
                }
            }
            formList = new List<List<string>> {
                new List<string> { "Tangki", "select", "NomorTangki" },
                new List<string> { "In Line Blending", "checkbox", "InLineBlending" },
                new List<string> { "Tangki 2", "select", "NomorTangki2", "", "d-none" },
                new List<string> { "Produk", "select", "Produk" },
                new List<string> { "LO", "number", "LO" },
                new List<string> { "Volume (KL)", "number", "Volume" },
                new List<string> { "Bay Number", "number", "BayNumber" },
                new List<string> { "No Meter", "number", "NoMeter" },
                new List<string> { "Meter Awal", "number", "MeterAwal" },
                new List<string> { "Meter Akhir", "number", "MeterAkhir" },
                new List<string> { "Nomor Kompartment", "number", "NomorKompartment" },
                new List<string> { Produk, "hidden", "Produk" }
            };
        }
        else if (IdTemplateAktivitas == "412")
        {
            resultList.Clear();

            sqlQuery = $@"
                SELECT
                    A.id,
                    A.NoTangki,
                    A.Produk,
                    A.Volume,
                    A.Aktivitas,
                    A.LevelTangki,
                    A.Flowrate,
                    MT.Sloc,
                    MT.SeqTangki,
                    MT.NamaTerminal,
                    MP.NoProduk,
                    MP.NamaProduk,
                    MP.NoProduk + ' - ' + MP.NamaProduk AS Produk_disabled
                FROM {TableAnak} A
                LEFT JOIN MasterProduk MP ON A.Produk = MP.NoProduk
                LEFT JOIN MasterTangki MT ON A.NoTangki = MT.id
                WHERE A.idAktifitas = @IdAktivitas;";

            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    while (rs.Read())
                    {
                        Dictionary<string, object> row = new Dictionary<string, object>();
                        for (int i = 0; i < rs.FieldCount; i++)
                        {
                            row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                        }
                        resultList.Add(row);
                    }
                }
            }

            string labelProduk = "", labelTangki = "";
            sqlQuery = $@"
                SELECT
                    MP.NoProduk,
                    MP.NoProduk + ' - ' + MP.NamaProduk AS Produk_disabled,
                    MT.Sloc + ' - ' + MT.SeqTangki + ' - ' + MT.NamaTerminal AS Nomor_Tangki_disabled,
                    MPT.Plant + ' - ' + MPT.Nama_Terminal AS IdPlant_disabled
                FROM {TipeProses} A
                LEFT JOIN MasterPlant MPT ON A.Plant = MPT.IdPlant
                LEFT JOIN MasterTangki MT ON A.IdTangki = MT.id
                LEFT JOIN MasterProduk MP ON MT.MatNo = MP.NoProduk
                WHERE A.NomorPenimbunanPenyaluran = @NoReferensi;";

            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    if (rs.Read())
                    {
                        for (int i = 0; i < rs.FieldCount; i++)
                        {
                            if (rs.GetName(i) == "NoProduk")
                            {
                                Produk = rs[i] != null ? rs[i].ToString() : "";
                            }

                            if (labelProduk == "" && rs.GetName(i) == "Produk_disabled")
                            {
                                labelProduk = rs[i] != null ? rs[i].ToString() : "";
                            }
                            if (labelTangki == "" && rs.GetName(i) == "Nomor_Tangki_disabled")
                            {
                                labelTangki = rs[i] != null ? rs[i].ToString() : "";
                            }
                        }
                    }
                }
            }

            formList = new List<List<string>> {
                new List<string> { "Kegiatan", "text", "Aktivitas", $"Logbook Monitoring Stock Tangki {labelTangki}, Produk {labelProduk}" },
                new List<string> { "Tangki", "readonly disabled", "Nomor_Tangki_disabled", labelTangki },
                new List<string> { "Produk", "readonly disabled", "Produk_disabled", labelProduk },
                new List<string> { generalList["IdTangki"] != null? generalList["IdTangki"].ToString() : "", "hidden", "NoTangki" },
                new List<string> { Produk, "hidden", "Produk" },
                new List<string> { "Level Tangki", "number", "LevelTangki" },
                new List<string> { "Volume (KL)", "number", "Volume" },
                new List<string> { "Flowrate", "number", "Flowrate" }
            };
        }

        sqlQuery = "SELECT a.NamaAktivitas as Aktivitas, log.username as Username, log.status_aktivitas as StatusAktivitas, log.etl_date as Tanggal, log.Catatan FROM log_aktivitas log INNER JOIN Aktivitas a ON log.id_aktivitas = a.IdAktivitas WHERE log.id_aktivitas = @IdAktivitas ORDER BY Tanggal DESC;";
        using (SqlCommand sqlCommand = new SqlCommand(sqlQuery, sqlConnection))
        {
            sqlCommand.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
            using (SqlDataReader reader = sqlCommand.ExecuteReader())
            {
                if (reader.HasRows)
                {
                    while (reader.Read())
                    {
                        dataLog.Add(new Dictionary<string, object> {
                            { "Aktivitas", reader["Aktivitas"]?.ToString() ?? "" },
                            { "Username", reader["Username"]?.ToString() ?? "" },
                            { "StatusAktivitas", reader["StatusAktivitas"]?.ToString() ?? "" },
                            { "Tanggal", reader["Tanggal"]?.ToString() ?? "" },
                            { "Catatan", reader["Catatan"]?.ToString() ?? "" }
                        });
                    }
                }
            }
        }

        string currentUser = CurrentUserLevel().ToString();

        sqlQuery = @"EXEC CheckIsEditableAktivitasForm_ByAktivitasId @IdAktivitas";

        using (SqlCommand sqlCommand = new SqlCommand(sqlQuery, sqlConnection))
        {
            sqlCommand.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);

            using (SqlDataReader reader = sqlCommand.ExecuteReader())
            {
                if (reader.Read())
                {
                    isEditable = reader["IsEditable"] != DBNull.Value && Convert.ToBoolean(reader["IsEditable"]);
                }
            }
        }

        if (currentUser != "-1")
        {
            string idPic = CurrentUserInfo("Rule")?.ToString();

            if (!string.IsNullOrEmpty(idPic))
            {
                string sqlCekRole = $@"WITH SplitValues AS (
                    SELECT
                        A.IdTemplateAktivitas,
                        TRIM(value) AS IdPIC,
                        A.IdAktivitas
                    FROM Aktivitas A
                    JOIN TemplateAktivitas TA ON A.IdTemplateAktivitas = TA.IdTemplateAktivitas
                    CROSS APPLY STRING_SPLIT(TA.IdPIC, ',')
                )
                SELECT COUNT(DISTINCT IdTemplateAktivitas) AS JumlahAktivitas
                FROM SplitValues
                WHERE IdPIC = @IdPIc and IdAktivitas = @IdAktivitas";

                using (SqlCommand sqlCommandRole = new SqlCommand(sqlCekRole, sqlConnection))
                {
                    sqlCommandRole.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
                    sqlCommandRole.Parameters.AddWithValue("@IdPic", idPic);

                    using (SqlDataReader readerRole = sqlCommandRole.ExecuteReader())
                    {
                        if (readerRole.Read())
                        {
                            countRole = readerRole["JumlahAktivitas"] != DBNull.Value ? Convert.ToInt32(readerRole["JumlahAktivitas"]) : 0;
                        }
                    }
                }

                if (countRole < 1)
                {
                    isEditable = false;
                }
            }
            else
            {
                isEditable = false;
            }
        }

        if (currentUser == "3")
        {
            isEditable = false;
        }
        else if (currentUser == "6")
        {
            isEditable = true;
            string idPos = CurrentUserInfo("IdPosition")?.ToString();
            if (!string.IsNullOrEmpty(idPos))
            {
                string sqlData = $@"SELECT COUNT(*) AS JumlahSesuai
                                    FROM Aktivitas a
                                    JOIN {TipeProses} p ON a.No_Referensi = p.Nomor{TipeProses}
                                    JOIN MasterPlant mp ON p.{colPlant} = mp.IdPlant
                                    WHERE a.IdAktivitas = @IdAktivitas
                                    AND mp.JenisPlant = 'STS'
                                    AND p.{colPlant} IN (
                                        SELECT IdPlant
                                        FROM MappingPosition
                                        WHERE IdPosition = @IdPosition
                                    );
                                    ";
                int plantCount = 0;
                using (SqlCommand sqlCommand = new SqlCommand(sqlData, sqlConnection))
                {
                    sqlCommand.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
                    sqlCommand.Parameters.AddWithValue("@IdPosition", idPos);
                    using (SqlDataReader reader = sqlCommand.ExecuteReader())
                    {
                        if (reader.Read())
                        {
                            plantCount = reader["JumlahSesuai"] != DBNull.Value ? Convert.ToInt32(reader["JumlahSesuai"]) : 0;
                        }
                    }
                }

                if (plantCount <= 0)
                {
                    var idTemplateProses = 0;
                    var acceptProcessListUser6 = new List<int> { 23, 49, 77, 80, 21, 26, 160, 161 };

                    sqlData = @"SELECT P.IdTemplateProses
                        from Aktivitas A
                    JOIN dbo.Proses P on A.IdProses = P.IdProses
                    WHERE A.IdAktivitas = @IdAktivitas";
                    using (SqlCommand sqlCommandUser6 = new SqlCommand(sqlData, sqlConnection))
                    {
                        sqlCommandUser6.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
                        using (SqlDataReader readerUser6 = sqlCommandUser6.ExecuteReader())
                        {
                            if (readerUser6.Read())
                            {
                                idTemplateProses = readerUser6["IdTemplateProses"] != DBNull.Value ? Convert.ToInt32(readerUser6["IdTemplateProses"]) : 0;
                            }
                        }
                    }

                    if (!acceptProcessListUser6.Contains(idTemplateProses))
                    {
                        isEditable = false;
                    }
                }
            }
            else
            {
                isEditable = false;
            }
        }
        if (string.IsNullOrEmpty(TipeProduk))
        {
            if (generalList.ContainsKey("TipeProduk") && !string.IsNullOrEmpty(generalList["TipeProduk"].ToString()))
            {
                TipeProduk = generalList["TipeProduk"].ToString();
            }
            else if (TipeProses.Contains("LPG"))
            {
                TipeProduk = "LPG";
            }
            else if (TableAnak.Contains("LPG"))
            {
                TipeProduk = "LPG";
            }
            else
            {
                TipeProduk = "BBM";
            }
        }
    }

    var jsonData = JsonConvert.SerializeObject(resultList);
    var jsonLog = JsonConvert.SerializeObject(dataLog);
    var jsonForm = JsonConvert.SerializeObject(formList);
    var jsonTangki = JsonConvert.SerializeObject(tangkiList);
    var jsonProduk = JsonConvert.SerializeObject(produkList);
}

<!DOCTYPE html>
<html lang='en'>
