}
<input type="hidden" name="action" id="action" value="update">
<input type="hidden" name="modal" value="@ConvertToInt(masterPositionEdit.IsModal)">
@if (IsJsonResponse()) {
<input type="hidden" name="json" value="1">
}
<input type="hidden" name="@(masterPositionEdit.OldKeyName)" value="@Html.Raw(masterPositionEdit.OldKey)">
<div class="ew-edit-div"><!-- page* -->
@if (masterPositionEdit.IdPosition.Visible) { // masterPositionEdit.IdPosition.Visible (begin)
    <div id="r_IdPosition" @Html.Raw(masterPositionEdit.IdPosition.RowAttributes)>
