@{
    // View
    View = this;

    // Check action result
    if (masterPositionEdit.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterPositionEdit.UseLayout ? "_Layout" : "";
}
@masterPositionEdit.ShowPageHeader()
@masterPositionEdit.ShowMessages()
<main class="edit">
<form name="fMasterPositionedit" id="fMasterPositionedit" class="@(masterPositionEdit.FormClassName)" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
<script>
var currentTable = @Html.Raw(ConvertToJson(masterPositionEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterPosition: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fMasterPositionedit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterPositionedit")
        .setPageId("edit")

        // Add fields
        .setFields([

            ["IdPosition", [fields.IdPosition.visible && fields.IdPosition.required ? ew.Validators.required(fields.IdPosition.caption) : null, ew.Validators.integer], fields.IdPosition.isInvalid],
            ["NamaPosition", [fields.NamaPosition.visible && fields.NamaPosition.required ? ew.Validators.required(fields.NamaPosition.caption) : null], fields.NamaPosition.isInvalid],
            ["Location", [fields.Location.visible && fields.Location.required ? ew.Validators.required(fields.Location.caption) : null], fields.Location.isInvalid],
            ["_UserLevel", [fields._UserLevel.visible && fields._UserLevel.required ? ew.Validators.required(fields._UserLevel.caption) : null], fields._UserLevel.isInvalid],
            ["Role", [fields.Role.visible && fields.Role.required ? ew.Validators.required(fields.Role.caption) : null], fields.Role.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "_UserLevel": @Html.Raw(masterPositionEdit._UserLevel.ToClientList(masterPositionEdit)),
            "Role": @Html.Raw(masterPositionEdit.Role.ToClientList(masterPositionEdit)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
@if (CurrentPage?.CheckToken ?? false) {
