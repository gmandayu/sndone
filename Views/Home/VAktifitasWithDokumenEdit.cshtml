    <div id="template-document" class="row">
        <label class="col-sm-2 col-form-label ew-label">Template Dokumen</label>
        <div class="col-sm-10"> 
            <a class="download-template btn btn-primary" href="${parent_url}TemplateDokumen?IdDokumen=${IdDokumen}"><i class="fa-solid fa-download"></i> Download Template</a>
        </div>
    </div>
    `;
    $('#r_NamaDokumen').after(templateElement);
    var statusElement = "";
    if (!PathFile) {
        statusElement = `
        <div class="row">
            <label class="col-sm-2 col-form-label ew-label">Status Dokumen</label>
            <div class="col-sm-10"> 
                NotUploaded  
            </div>
        </div>
        `;
    } else {
        statusElement = `
        <div class="row">
            <label class="col-sm-2 col-form-label ew-label">Status Dokumen</label>
            <div class="col-sm-10"> 
                <button IdAktivitas="${IdAktivitas}" class="download-document btn btn-primary"><i class="fa-solid fa-download"></i> Download Dokumen</button> 
            </div>
        </div>
        `;
    }
    $('#template-document').after(statusElement);
    var IdReferensi = "@vAktifitasWithDokumenEdit.No_referensi.CurrentValue";
    var IdAktivitas = "@vAktifitasWithDokumenEdit.IdAktivitas.CurrentValue";
    var IdProses = "@vAktifitasWithDokumenEdit.IdProses.CurrentValue";
    var NamaAktivitas = "@vAktifitasWithDokumenEdit.NamaAktivitas.CurrentValue";
    $('#r_IdProses').hide();
    var steps = [
        { number: 1, label: "Penerimaan", url: `${parent_url}PenerimaanList`, icon: "fa-box-open" },
        { number: 2, label: "Proses", url: `${parent_url}ProsesList?cmd=search&x_IdReferensi%5B%5D=${IdReferensi}&search=&searchtype=`, icon: "fa-gears" },
        { number: 3, label: "Aktivitas", url: `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`, icon: "fa-list-check" },
        { number: 4, label: NamaAktivitas, url: '', icon: "fa-file-circle-check" }
    ];
    var currentStep = 4;
    $("<style>")
        .prop("type", "text/css")
        .html(`
            .stepper {
                display: flex;
                counter-reset: step;
            }
            .step {
                width: 150px;
                text-align: center;
                position: relative;
            }
            .step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 20px;
                right: -50%;
                width: 100%;
                height: 4px;
                background-color: #ccc;
                z-index: 0;
            }
            .step.completed:not(:last-child)::after {
                background-color: #006BB7;
            }
            .step-icon {
                width: 36px;
                height: 36px;
                line-height: 36px;
                border-radius: 50%;
                background: #ccc;
                display: inline-block;
                z-index: 1;
                position: relative;
                color: white;
                font-weight: bold;
            }
            .step.active .step-icon {
                background: #006BB7;
            }
            .step-label {
                margin-top: 8px;
                font-size: 14px;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 6px;
                color: #333;
            }
            .step-label {
                color: #006BB7 !important;
                text-decoration: none;
                margin: 0;
                padding: 0;
            }
            .step-label-not-active {
                color: #CCCCCC !important;
            }
        `)
        .appendTo("head");
    var $stepperWrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    var $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        var isActive = step.number === currentStep;
        var isCompleted = step.number < currentStep;
        var stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        var icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #006BB7;">${step.number}</div>`;
            labelContent = `<div><a href="${step.url}" class="step-label"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    $(".content-header .container-fluid .row").append($stepperWrapper);
    $("#btn-action").hide();
    $("#btn-cancel").html('<i class="fa-solid fa-ban"></i></i> Cancel');
        const $cancelButton = $("#btn-cancel");
        if ($cancelButton.length) {
            // Sisipkan tombol custom
            let $customButtons = ``;
            let status = $("#x_StatusAktivitas").val();
            switch (status) {
            case "Waiting":
                    $customButtons = `
                        <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-draft">
                            <i class="fas fa-save"></i> Save
                        </button>
                    `;
                    break;
                case "Draft":
                    $customButtons = `
                        <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-draft">
                            <i class="fas fa-save"></i> Save
                        </button>
                        <button type="button" class="btn btn-success ew-btn ml-2" id="btn-completed">
                            <i class="fas fa-paper-plane"></i> Submit
                        </button>
                    `
                    break;
                case "Completed":
                    $customButtons = `
                        <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-editing">
                            <i class="fas fa-edit"></i> Save
                        </button>
                        <button type="button" class="btn btn-success ew-btn ml-2" id="btn-completedEdit">
                            <i class="fas fa-paper-plane"></i> Submit
                        </button>
                    `;
                    break;
                case "Editing":
                    $customButtons = `
                        <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-editing">
                            <i class="fas fa-edit"></i> Save
                        </button>
                        <button type="button" class="btn btn-success ew-btn ml-2" id="btn-completedEdit">
                            <i class="fas fa-paper-plane"></i> Submit
                        </button>
                    `;
                    break;
            }
            $cancelButton.before($customButtons);
            checkIsEditable();
        }
    function checkIsEditable() {
        $.ajax({
            url: parent_url + `api/LookUpList/check_iseditable_aktivitas_form?idAktivitas=${IdAktivitas}`,
            type: 'GET',
            success: function(response) {
                if(!response.isEditable){
                    $("#btn-draft").hide();
                    $("#btn-editing").hide();
                    $("#btn-completed").hide();
                    $("#btn-completedEdit").hide();
                    $('input, select, textarea, button').prop('disabled', true);
                    $('#btn-cancel').prop('disabled', false);
                }
            },
            error: function(xhr, status, error) {
                console.error('API call failed:', status, error);
            }
        });
    }
});
</script>
