@{ subaktivitasNilaiAgreementEdit.CloseRecordset(); }
@Html.Raw(subaktivitasNilaiAgreementEdit.IsModal ? "<template class=\"ew-modal-buttons\">" : "<div class=\"row ew-buttons\">")<!-- buttons .row -->
    <div class="@(subaktivitasNilaiAgreementEdit.OffsetColumnClass)"><!-- buttons offset -->
