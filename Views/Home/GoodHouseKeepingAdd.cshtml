loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fGoodHouseKeepingadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["NomorGoodHouseKeeping", [fields.NomorGoodHouseKeeping.visible && fields.NomorGoodHouseKeeping.required ? ew.Validators.required(fields.NomorGoodHouseKeeping.caption) : null], fields.NomorGoodHouseKeeping.isInvalid],
            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["Catatan", [fields.Catatan.visible && fields.Catatan.required ? ew.Validators.required(fields.Catatan.caption) : null], fields.Catatan.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(goodHouseKeepingAdd.LookupPlant.ToClientList(goodHouseKeepingAdd)),
            "Plant": @Html.Raw(goodHouseKeepingAdd.Plant.ToClientList(goodHouseKeepingAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    // Write your client script here, no need to add script tags.
    const syncPlantFields = (value, label) => {
        if (label !== undefined) {
            $('#sv_x_Plant').val(label);
        }
        if (value !== undefined) {
            $('#x_Plant').val(value).attr('value', value).trigger('change');
            const selectionList = document.querySelector('selection-list[name="x_Plant"]');
            if (selectionList) {
                selectionList.value = value;
                selectionList.setAttribute('value', value);
                selectionList.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }
    };
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        const selectedLabel = $(this).find('option:selected').text();
        syncPlantFields(selectedValue, selectedLabel);
    });
    $('#fGoodHouseKeepingadd').on('submit', function () {
        const selectedValue = $('#x_LookupPlant').val();
        const selectedLabel = $('#x_LookupPlant option:selected').text();
        syncPlantFields(selectedValue, selectedLabel);
    });
});
</script>
