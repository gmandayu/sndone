<input type="@(penyaluranAdd.MultipleQuantity.InputTextType)" name="x_MultipleQuantity" id="x_MultipleQuantity" data-table="Penyaluran" data-field="x_MultipleQuantity" value="@Html.Raw(penyaluranAdd.MultipleQuantity.EditValue)" size="30" maxlength="1" placeholder="@Html.Raw(HtmlEncode(penyaluranAdd.MultipleQuantity.PlaceHolder))" data-format-pattern="@(penyaluranAdd.MultipleQuantity.FormatPattern)"@Html.Raw(penyaluranAdd.MultipleQuantity.EditAttributes) aria-describedby="x_MultipleQuantity_help">
@Html.Raw(penyaluranAdd.MultipleQuantity.GetCustomMessage)
<div class="invalid-feedback">@Html.Raw(penyaluranAdd.MultipleQuantity.GetErrorMessage())</div>
</span>
</div></div>
    </div>
} @* penyaluranAdd.MultipleQuantity.Visible (end) *@
</div><!-- /page* -->
@{ penyaluranAdd.CloseRecordset(); }
@Html.Raw(penyaluranAdd.IsModal ? "<template class=\"ew-modal-buttons\">" : "<div class=\"row ew-buttons\">")<!-- buttons .row -->
    <div class="@(penyaluranAdd.OffsetColumnClass)"><!-- buttons offset -->
    <button class="btn btn-primary ew-btn" name="btn-action" id="btn-action" type="submit" form="fPenyaluranadd">@Html.Raw(Language.Phrase("AddBtn"))</button>
@if (IsJsonResponse()) {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-bs-dismiss="modal">@Html.Raw(Language.Phrase("CancelBtn"))</button>
} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fPenyaluranadd" data-href="@AppPath(penyaluranAdd.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
}
    </div><!-- /buttons offset -->
@Html.Raw(penyaluranAdd.IsModal ? "</template>" : "</div>")<!-- /buttons .row -->
</form>
@penyaluranAdd.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("Penyaluran");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    var parent_url = ew.PATH_BASE;
    const userLevel = "@CurrentUserLevel()";
    const idPic = '@CurrentUserInfo("Rule")?.ToString()';
    if ((userLevel == "5" || idPic == "1" || idPic == "12") && userLevel != "-1") {
        $("#x_TipePenyaluran").val("Konsinyasi").trigger("change");
        setTimeout(() => {
            $("#x_TipePenyaluran").find("option[value='Sales']").remove();
        }, 200);
    } else if (userLevel == "6" || (idPic == "13" && userLevel != "-1")) {
        $("#x_TipePenyaluran").val("Sales").trigger("change");
        setTimeout(() => {
            $("#x_TipePenyaluran").find("option[value='Konsinyasi']").remove();
        }, 200);
    }
    $("#r_NomorPolisi").hide();
    $("#r_NamaKapal").hide();
    $("#r_TanggalSandar").hide();
    $("#r_JenisProduk").hide();
    $("#r_LookupTipeProduk").hide();
    $("#r_LookupJenisPlant").hide();
    $("#r_TipeProdukSTS").hide();
    $("#r_NomorPenyaluran").hide();
    $("#r_IdPlant").hide();
    $("#r_IdPipa").hide();
    $("#r_Volume2").hide();
    $("#r_TujuanKonsinyasi2").hide();
    $("#r_MultipleQuantity").hide();
    $("#r_MultipleTujuanKonsinyasi").hide();
    $("#r_MultipleTujuanKonsinyasiHidden").hide();
    $("#r_MultipleTujuanKonsinyasiHidden").val("[]");
    $("#r_NoShipment").hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + "api/LookUpList/get-dropdown/plant?Menu=Penyaluran",
            method: "GET",
            dataType: "json",
            success: function (data) {
                ddl.empty();
                var targetPlantId = "@Html.Raw(penyaluranAdd.IdPlant.CurrentValue)";
                $.each(data, function (index, item) {
                    let isSelected = false;
                    if (targetPlantId && (item.Value == targetPlantId || item.Value.toString() == targetPlantId.toString())) {
                        isSelected = true;
                    } else if (!targetPlantId && index === 0) {
                        isSelected = true;
                    }
                    const selectedAttr = isSelected ? "selected" : "";
                    ddl.append(`<option value="${item.Value}" ${selectedAttr}>${item.Label}</option>`);
                    if (isSelected) {
                        $("#x_IdPlant").val(item.Value).trigger("change");
                    }
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            },
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != "1" && idRole != "12" && idRole != "13") {
            ew.alert("Anda tidak memiliki akses untuk menambah data Proses Penyaluran.");
            setTimeout(() => {
                window.location.href = parent_url + "PenyaluranList";
            }, 1000);
        }
    });
    const action = '@HttpContext.Request.Query["action"].ToString()';
    if (action === "addproduct") {
        $("#x_JenisProduk").val("");
        $("#x_Volume").val("");
        $("#x_IdPlant").trigger("change");
        checkInput();
        setTimeout(() => {
            $("#x_TipePenyaluran, #x_IdModa, #x_IdPlant, #x_KategoriPenyaluran, #x_LookupTipeProduk, #x_LookupJenisPlant").change(function () {
                checkInput();
            });
        }, 2000);
    }
    function checkInput() {
        let TipePenyaluran = $("#x_TipePenyaluran").val();
        let IdModa = $("#x_IdModa").val();
        let IdPlant = $("#x_IdPlant").val();
        let KategoriPenyaluran = $("#x_KategoriPenyaluran").val();
        let TipeProduk = $("#x_LookupTipeProduk").val();
        let JenisPlant = $("#x_LookupJenisPlant").val();
        let idpipa = $("#x_IdPipa").val();
        if (IdModa == "1" || IdModa == "2") {
            $("#r_NamaKapal").show();
            $("#r_NomorPolisi").hide();
            $("#x_NomorPolisi").val("");
        } else if (IdModa == "3") {
            $("#r_NomorPolisi").show();
            $("#r_NamaKapal").hide();
            $("#x_NamaKapal").val("");
        } else {
            $("#r_NamaKapal").hide();
            $("#x_NamaKapal").val("");
            $("#r_NomorPolisi").hide();
            $("#x_NomorPolisi").val("");
        }
        if (IdModa == "5" || IdModa == "12") {
            $("#elh_Penyaluran_TanggalSandar").text("Tanggal");
            $("#x_TanggalSandar").attr("placeholder", "Tanggal");
            $("#qty_caption").text("Quantity (KL)");
        } else if (IdModa == "6") {
            $("#elh_Penyaluran_TanggalSandar").text("Tanggal");
            $("#x_TanggalSandar").attr("placeholder", "Tanggal");
            $("#qty_caption").text("Quantity (MT)");
        } else {
            $("#elh_Penyaluran_TanggalSandar").text("Tanggal Sandar");
            $("#x_TanggalSandar").attr("placeholder", "Tanggal Sandar");
        }
        if (IdModa == "12"){
            getTujuanKonsinyasi(0, IdModa);
        } else if (!idpipa) {
            $("#tujuanKonsinyasiContainer").remove();
            $("#x_MultipleTujuanKonsinyasiHidden").val("[]");
        }
        if (TipePenyaluran == "Konsinyasi") {
            if (IdModa == "3" && TipeProduk == "LPG") {
                $("#r_Tujuan").show();
                $("#r_KategoriPenyaluran").show();
                $("#r_KategoriPenyaluran").insertAfter("#r_IdModa");
                $("#r_TanggalSandar").hide();
                $("#x_TanggalSandar").val("");
                $("#r_TujuanKonsinyasi").hide();
                $("#x_TujuanKonsinyasi").val("");
                $("#r_JenisProduk").hide();
                $("#r_Volume").hide();
                $("#x_Volume").val("");
                if (KategoriPenyaluran == "Non TAS/NGS") {
                    $("#r_JenisProduk").show();
                    $("#r_Volume").show();
                    if (JenisPlant == "STS") {
                        $("#r_TipeProdukSTS").show();
                    } else {
                        $("#r_TipeProdukSTS").hide();
                        $("#x_TipeProdukSTS").val("");
                    }
                } else if (KategoriPenyaluran == "TAS/NGS") {
                    $("#r_NomorPolisi").hide();
                    $("#x_NomorPolisi").val("");
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                }
            } else if (IdModa === "3" && TipeProduk == "BBM") {
                $("#r_Tujuan").show();
                $("#r_KategoriPenyaluran").show();
                $("#r_KategoriPenyaluran").insertAfter("#r_IdModa");
                $("#r_TanggalSandar").hide();
                $("#x_TanggalSandar").val("");
                $("#r_Tujuan").hide();
                $("#x_Tujuan").val("");
                //$("#r_JenisProduk").hide();
                //$("#r_Volume").hide();
                //$("#x_Volume").val("");
                if (KategoriPenyaluran === "Non TAS/NGS") {
                    $("#r_JenisProduk").show();
                    $("#r_Volume").show();
                    if (JenisPlant == "STS") {
                        $("#r_TipeProdukSTS").show();
                    } else {
                        $("#r_TipeProdukSTS").hide();
                        $("#x_TipeProdukSTS").val("");
                    }
                } else if (KategoriPenyaluran == "TAS/NGS") {
                    $("#r_NomorPolisi").hide();
                    $("#x_NomorPolisi").val("");
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_JenisProduk").hide();
                    $("#x_JenisProduk").val("");
                    $("#r_Volume").hide();
                    $("#x_Volume").val("");
                    $("#r_TujuanKonsinyasi").hide();
                    $("#x_TujuanKonsinyasi").val("");
                }
            } else {
                $("#r_JenisProduk").show();
                $("#r_Volume").show();
                $("#r_KategoriPenyaluran").hide();
                $("#x_KategoriPenyaluran").val("");
                $("#r_NoShipment").hide();
                $("#r_NoShipment").val("");
                if (IdModa == "1" || IdModa == "2") {
                    $("#r_TanggalSandar").show();
                    $("#r_TujuanKonsinyasi").show();
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_IdPipa").hide();
                    $("#x_IdPipa").val("").trigger("change");
                } else if (IdModa == "5" || IdModa == "6" || IdModa == "12") {
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_TujuanKonsinyasi").hide();
                    $("#x_TujuanKonsinyasi").val("");
                    $("#r_TanggalSandar").hide();
                    $("#x_TanggalSandar").val("");
                    $("#r_Volume").hide();
                    $("#x_Volume").val("");
                    if (IdModa == "12") {
                        $("#r_IdPipa").hide();
                        $("#x_IdPipa").val("");
                    } else {
                        $("#r_IdPipa").show();
                    }
                } else if (IdModa == "4") {
                    $("#r_TujuanKonsinyasi").show();
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_NoShipment").show();
                } else if (IdModa == "3") {
                    // Truck dengan Tipe Produk BBM
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_TujuanKonsinyasi").show();
                    $("#r_TanggalSandar").hide();
                    $("#x_TanggalSandar").val("");
                    $("#r_IdPipa").hide();
                    $("#x_IdPipa").val("").trigger("change");
                } else {
                    $("#r_TujuanKonsinyasi").show();
                    $("#r_Tujuan").hide();
                    $("#x_Tujuan").val("");
                    $("#r_TanggalSandar").hide();
                    $("#x_TanggalSandar").val("");
                    $("#r_IdPipa").hide();
                    $("#x_IdPipa").val("").trigger("change");
                }
                if (JenisPlant == "STS") {
                    $("#r_TipeProdukSTS").show();
                } else {
                    $("#r_TipeProdukSTS").hide();
                    $("#x_TipeProdukSTS").val("");
                }
            }
        } else {
            $("#r_Tujuan").show();
            $("#r_KategoriPenyaluran").insertBefore("#r_IdModa");
            $("#r_KategoriPenyaluran").show();
            $("#r_TanggalSandar").hide();
            $("#x_TanggalSandar").val("");
            $("#r_TujuanKonsinyasi").hide();
            $("#x_TujuanKonsinyasi").val("");
            $("#r_JenisProduk").hide();
            $("#x_JenisProduk").val("");
            $("#r_Volume").hide();
            $("#x_Volume").val("");
            if (KategoriPenyaluran == "Non TAS/NGS" && TipeProduk == "LPG") {
                $("#r_JenisProduk").show();
                $("#r_Volume").show();
                if (JenisPlant == "STS") {
                    $("#r_TipeProdukSTS").show();
                } else {
                    $("#r_TipeProdukSTS").hide();
                    $("#x_TipeProdukSTS").val("");
                }
            } else if (IdModa == "5") {
                $("#r_JenisProduk").show();
                if (JenisPlant == "STS") {
                    $("#r_TipeProdukSTS").show();
                } else {
                    $("#r_TipeProdukSTS").hide();
                    $("#x_TipeProdukSTS").val("");
                }
            } else {
                $("#r_JenisProduk").hide();
                $("#x_JenisProduk").val("");
            }
            if (KategoriPenyaluran == "TAS/NGS") {
                $("#r_NomorPolisi").hide();
                $("#x_NomorPolisi").val("");
                $("#r_Tujuan").hide();
                $("#x_Tujuan").val("");
            }
        }
    }
});
</script>
