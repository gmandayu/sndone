        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "IdPosition": @Html.Raw(masterPositionList.IdPosition.ToClientList(masterPositionList)),
            "NamaPosition": @Html.Raw(masterPositionList.NamaPosition.ToClientList(masterPositionList)),
            "Location": @Html.Raw(masterPositionList.Location.ToClientList(masterPositionList)),
            "_UserLevel": @Html.Raw(masterPositionList._UserLevel.ToClientList(masterPositionList)),
            "Role": @Html.Raw(masterPositionList.Role.ToClientList(masterPositionList)),
        })

        // Filters
        .setFilterList(@Html.Raw(masterPositionList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
