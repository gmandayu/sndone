ew.deepAssign(ew.vars, { tables: { Proses: currentTable } });
var currentForm;
var fProsessrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fProsessrch")
        .setPageId("list")
@if (prosesList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "IdReferensi": @Html.Raw(prosesList.IdReferensi.ToClientList(prosesList)),
            "IdTemplateProses": @Html.Raw(prosesList.IdTemplateProses.ToClientList(prosesList)),
            "NamaProses": @Html.Raw(prosesList.NamaProses.ToClientList(prosesList)),
            "Aktivitas2": @Html.Raw(prosesList.Aktivitas2.ToClientList(prosesList)),
