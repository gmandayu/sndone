<script>
loadjs.ready("fClosingStocksearch", function() {
    var options = { name: "x_Produk", selectId: "fClosingStocksearch_x_Produk" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fClosingStocksearch.lists.Produk?.lookupOptions.length) {
        options.data = { id: "x_Produk", form: "fClosingStocksearch" };
    } else {
        options.ajax = { id: "x_Produk", form: "fClosingStocksearch", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.ClosingStock.fields.Produk.selectOptions);
    ew.createSelect(options);
});
</script>
