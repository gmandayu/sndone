<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    $("#File-Name").on("click", function (e) {
        $("#File").trigger("click");
    });
    $("#btn-add-modal").on("click", function (e) {
        ew.alert('Under Development');
    });
    $("#btn-submit-custom").on("click", function (e) {
        ew.alert('Under Development');
    });
    $("#File").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#File-Name").val(file.name);
    });
    $(document).on("click", "#btn-cancel-custom", function(){
        window.location.href = `${parent_url}MWTOnlineList`;
    });
    $(document).on("submit", "#form-add-reply", function(){
        const Deskripsi = $('#Penjelasan').val().trim();
        let formData = new FormData();
        formData.append("Deskripsi", Deskripsi);
        const file = $("#File")[0].files[0];
        formData.append("File", file);
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/AddReplyMWTOnline",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        location.reload();
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Gagal menambah data: " + xhr.responseText);
            }
        });
    });
    $(document).on('click', '.btn-download', function (e) {
        e.preventDefault();
        const id = $(this).data('id');
        if (!id) {
            ew.alert("ID dokumen tidak ditemukan.");
            return;
        }
        $.ajax({
            url: parent_url + 'api/LookUpList/DownloadSingleDocument',
            type: 'GET',
            data: { 
                id: id,
                menu: 'MWTOnline'
            },
            xhrFields: {
                responseType: 'blob'
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader('Content-Disposition');
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            }
        });
    });
});
</script>
