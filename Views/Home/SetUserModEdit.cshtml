    var options = { name: "x_LookupUserMod", selectId: "fSetUserMODedit_x_LookupUserMod" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fSetUserMODedit.lists.LookupUserMod?.lookupOptions.length) {
        options.data = { id: "x_LookupUserMod", form: "fSetUserMODedit" };
    } else {
        options.ajax = { id: "x_LookupUserMod", form: "fSetUserMODedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumResultsForSearch = Infinity;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.SetUserMOD.fields.LookupUserMod.selectOptions);
