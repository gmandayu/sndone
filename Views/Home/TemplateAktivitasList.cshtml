    if (SameString(templateAktivitasList.RowIndex, "$rowindex$"))
        templateAktivitasList.RowIndex = 0;

    // Reset inline add/copy row
    if ((templateAktivitasList.IsCopy || templateAktivitasList.IsAdd) && templateAktivitasList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        templateAktivitasList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(templateAktivitasList.CurrentAction) && !templateAktivitasList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
