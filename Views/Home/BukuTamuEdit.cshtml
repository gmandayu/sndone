<script>
loadjs.ready("load", function() {
    // Startup script
    // startup script
    const parent_url = ew.PATH_BASE;
    $(document).ready(function() {
        $('#PintuUtamaInFields').hide();
        $('#PintuUtamaOutFields').hide();
        $('#LobbyUtamaInFields').hide();
        $('#LobbyUtamaOutFields').hide();
        $('#AreaTerlarangInFields').hide();
        $('#AreaTerlarangOutFields').hide();
        $('#PilihPintuPilihPintu').select2({
            placeholder: '-- Pilih Pintu --',
            allowClear: true
        });
        var StatusZona = $('#x_StatusZona').val()?.trim() || '';
        var tLobbyOut = $('#x_LobbyUtamaId').val()?.trim();
        var tAreaOut = $('#x_AreaTerlarangId').val()?.trim();
        var $select = $('#PilihPintu');
        $select.empty().append('<option></option>');
        if (StatusZona === "Pintu Utama") {
            // if (!tLobbyOut) $select.append('<option value="LobbyUtamaIn">Lobby Utama In</option>');
            // if (!tAreaOut) $select.append('<option value="AreaTerlarangIn">Area Terlarang In</option>');
            $select.append('<option value="LobbyUtamaIn">Lobby Utama In</option>');
            $select.append('<option value="AreaTerlarangIn">Area Terlarang In</option>');
            $select.append('<option value="PintuUtamaOut">Pintu Utama Out</option>');
        }
        else if (StatusZona === "Lobby Utama") {
            // if (!tAreaOut) $select.append('<option value="AreaTerlarangIn">Area Terlarang In</option>');
            $select.append('<option value="AreaTerlarangIn">Area Terlarang In</option>');
            $select.append('<option value="LobbyUtamaOut">Lobby Utama Out</option>');
        }
        else if (StatusZona === "Area Terlarang") {
            $select.append('<option value="AreaTerlarangOut">Area Terlarang Out</option>');
        }
        else if (StatusZona === "Keluar") {
            $('#PilihPintu').closest('.row').hide();
            $('#btn-submit-custom').hide();
        }
        $select.trigger('change.select2');
        $select.trigger('change');
        function showFields(val) {
            const all = ['#PintuUtamaInFields','#PintuUtamaOutFields','#LobbyUtamaInFields',
                            '#LobbyUtamaOutFields','#AreaTerlarangInFields','#AreaTerlarangOutFields'];
            $(all.join(',')).hide();
            if (val) $('#' + val + 'Fields').show();
        }
        const fileInputs = [
            'PintuUtamaIn', 'PintuUtamaOut', 'LobbyUtamaIn', 
            'LobbyUtamaOut', 'AreaTerlarangIn', 'AreaTerlarangOut'
        ];
        fileInputs.forEach(function(inputId) {
            $("#" + inputId + "-Name").on("click", function(e) {
                $("#" + inputId).trigger("click");
            });
            $("#" + inputId).on("change", function(e) {
                const file = $(this)[0].files[0];
                if (file) $("#" + inputId + "-Name").val(file.name);
            });
        });
        $("#PilihPintu").on("change", function(){ showFields(this.value); });
        $(document).on("click", "#btn-cancel-custom", function(){
            window.location.href = `${parent_url}BukuTamuList`;
        });
        $(document).on("click", "#btn-submit-custom", function(){
            let formData = new FormData();
            const id = "@Html.Raw(HtmlEncode(bukuTamuEdit.id.CurrentValue))";
            const pintu = $('#PilihPintu').val();
            if (!pintu) return ew.alert("Pintu belum dipilih!");
            formData.append("Pintu", pintu);
            formData.append("Id", id);
            if (pintu == 'LobbyUtamaIn') {
                let LobbyUtamaId = $('#x_LobbyUtamaId').val();
                if (!LobbyUtamaId) return ew.alert("Lobby Utama Id tidak boleh kosong!");
                formData.append("Tanggal", $('#x_LobbyUtamaInTanggal').val());
                formData.append("PintuId", LobbyUtamaId);
                const file = $("#LobbyUtamaIn")[0].files[0];
                if (file) formData.append("File", file);
            } else if (pintu == 'LobbyUtamaOut') {
                formData.append("Tanggal", $('#x_LobbyUtamaOutTanggal').val());
                const file = $("#LobbyUtamaOut")[0].files[0];
                if (file) formData.append("File", file);
            } else if (pintu == 'PintuUtamaOut') {
                formData.append("Tanggal", $('#x_PintuUtamaOutTanggal').val());
                const file = $("#PintuUtamaOut")[0].files[0];
                if (file) formData.append("File", file);
            } else if (pintu == 'AreaTerlarangIn') {
                let AreaTerlarangId = $('#x_AreaTerlarangId').val();
                if (!AreaTerlarangId) return ew.alert("Area Terlarang Id tidak boleh kosong!");
                formData.append("Tanggal", $('#x_AreaTerlarangInTanggal').val());
                formData.append("PintuId", AreaTerlarangId);
                const file = $("#AreaTerlarangIn")[0].files[0];
                if (file) formData.append("File", file);
            } else if (pintu == 'AreaTerlarangOut') {
                formData.append("Tanggal", $('#x_AreaTerlarangOutTanggal').val());
                const file = $("#AreaTerlarangOut")[0].files[0];
                if (file) formData.append("File", file);
            }
            showLoading();
            $.ajax({
                url: parent_url + "api/LookUpList/UpdateBukuTamu",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function(rs) {
                    hideLoading();
                    if (rs.success) {
                        ew.alert(rs.message, function() {
                            window.location.href = parent_url + "BukuTamuList";
                        });
                    } else {
                        ew.alert(rs.message || "Update gagal");
                    }
                },
                error: function(xhr) {
                    hideLoading();
                    console.error("Update error:", xhr);
                    ew.alert("Upload gagal: " + (xhr.responseText || xhr.statusText));
                }
            });
        });
    });

    // Set tanggal ke semua field
    function setTanggal() {
        const today = new Date();
        const formattedDate =
            today.getFullYear() + "/" +
            String(today.getMonth() + 1).padStart(2, '0') + "/" +
            String(today.getDate()).padStart(2, '0') + " " +
            String(today.getHours()).padStart(2, '0') + ":" +
            String(today.getMinutes()).padStart(2, '0') + ":" +
            String(today.getSeconds()).padStart(2, '0');
        const tanggalFields = [
            'x_PintuUtamaInTanggal', 'x_PintuUtamaOutTanggal',
            'x_LobbyUtamaInTanggal', 'x_LobbyUtamaOutTanggal',
            'x_AreaTerlarangInTanggal', 'x_AreaTerlarangOutTanggal'
        ];
        tanggalFields.forEach(function(fieldId) {
            const el = document.getElementById(fieldId);
            if (el) el.value = formattedDate;
        });
    }

    // log history
    var idBukuTamu = "";
    try {
        idBukuTamu = "@Html.Raw(HtmlEncode(bukuTamuEdit.id.CurrentValue))";
    } catch(e) {
        console.log("ID dari Razor tidak tersedia, coba dari URL");
    }
    if (!idBukuTamu || idBukuTamu.trim() === "") {
        var m = (location.pathname || "").match(/bukutamuedit\/(\d+)/i);
        idBukuTamu = m ? m[1] : "";
    }
    var base = (typeof parent_url !== "undefined" && parent_url) ? parent_url : (ew.PATH_BASE || "/");
    $(function() {
        if (!$('link[href*="ag-grid-community"]').length) {
            $('head').append(
