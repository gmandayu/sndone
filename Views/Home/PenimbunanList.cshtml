@{
    // View
    View = this;

    // Check action result
    if (penimbunanList.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penimbunanList.UseLayout ? "_Layout" : "";
}
@if (!penimbunanList.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(penimbunanList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penimbunan: currentTable } });
var currentPageID = ew.PAGE_ID = "list";
var currentForm;
var @(penimbunanList.FormName);
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("@(penimbunanList.FormName)")
        .setPageId("list")
        .setSubmitWithFetch(@(penimbunanList.UseAjaxActions ? "true" : "false"))
        .setFormKeyCountName("@(penimbunanList.FormKeyCountName)")

        // Dynamic selection lists
        .setLists({
            "Proses2": @Html.Raw(penimbunanList.Proses2.ToClientList(penimbunanList)),
            "Plant": @Html.Raw(penimbunanList.Plant.ToClientList(penimbunanList)),
            "IdPenerimaan": @Html.Raw(penimbunanList.IdPenerimaan.ToClientList(penimbunanList)),
            "IdTangki": @Html.Raw(penimbunanList.IdTangki.ToClientList(penimbunanList)),
            "StatusProses": @Html.Raw(penimbunanList.StatusProses.ToClientList(penimbunanList)),
            "PersentaseProgress": @Html.Raw(penimbunanList.PersentaseProgress.ToClientList(penimbunanList)),
            "DibuatOleh": @Html.Raw(penimbunanList.DibuatOleh.ToClientList(penimbunanList)),
            "TanggalDibuat": @Html.Raw(penimbunanList.TanggalDibuat.ToClientList(penimbunanList)),
            "DiperbaruiOleh": @Html.Raw(penimbunanList.DiperbaruiOleh.ToClientList(penimbunanList)),
            "TanggalDiperbarui": @Html.Raw(penimbunanList.TanggalDiperbarui.ToClientList(penimbunanList)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
