<script>
loadjs.ready("head", function() {
    // Client script
    var parent_url = ew.PATH_BASE;
    $("#SuratTugas-Name").on("click", function (e) {
        $("#SuratTugas").trigger("click");
    });
    $("#SuratTugas").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#SuratTugas-Name").val(file.name);
    });
    $("#btn-back").on("click", function (e) {
        window.location.href = `${parent_url}SetPjsList`;
    });
    $("#x_OrganizationLevel, #x_Region, #x_Plant").on("change", function(e) {
        const value = $('#x_OrganizationLevel').val();
        const ddl = $("#x_LookupPosition");
        const rRegion = $("#rRegion");
        const rPlant = $("#rPlant");
        const elRegion = $("#x_Region");
        const elPlant = $("#x_Plant");
        const idRegion = elRegion.val();
        const idPlant = elPlant.val();
        ddl.empty();
        if (!value) {
            return;
        }
        ddl.append('<option value="">Loading...</option>');
        let urlApi = `${parent_url}api/LookUpList/get-dropdown/pjs-position?OrganizationLevel=${value}`;
        if (value === 'REGION') {
            rRegion.show();
            rPlant.hide();
            if (idRegion) {
                urlApi += `&IdRegion=${idRegion}`;
                fillIdPosition(urlApi);
            }
        } else if (value === 'PLANT') {
            rRegion.show();
            rPlant.show();
            if (idRegion && idPlant) {
                urlApi += `&IdRegion=${idRegion}&IdPlant=${idPlant}`;
                fillIdPosition(urlApi);
            }
        } else {
            rRegion.hide();
            rPlant.hide();
            fillIdPosition(urlApi);
        }
    });
    function fillIdPosition(urlApi) {
        const ddl = $("#x_LookupPosition");
        $.ajax({
            url: urlApi,
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                $.each(data, function (index, item) {
                    ddl.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
    }
    $(document).on("click", "#btn-submit-custom", function(){
        const OrganizationLevel = $('#x_OrganizationLevel').val();
        const Position = $('#x_LookupPosition').val();
        const TanggalMulai = $('#x_TanggalMulai').val();
        const TanggalSelesai = $('#x_TanggalSelesai').val();
        const Keterangan = $('#x_Keterangan').val();
        const Plant = $('#x_Plant').val();
        const Region = $('#x_Region').val();
        if (!OrganizationLevel) return ew.alert("Organization Level baru tidak boleh kosong!");
        if (!Position) return ew.alert("Position baru tidak boleh kosong!");
        if (!TanggalMulai) return ew.alert("Tanggal Mulai tidak boleh kosong!");
        if (!TanggalSelesai) return ew.alert("Tanggal Selesai tidak boleh kosong!");
        let formData = new FormData();
        formData.append("Id", "@setPjsEdit.Id.CurrentValue");
        formData.append("OrganizationLevel", OrganizationLevel);
        formData.append("PosisiPJS", Position);
        formData.append("TanggalMulai", TanggalMulai);
        formData.append("TanggalSelesai", TanggalSelesai);
        formData.append("Keterangan", Keterangan);
        const file = $("#SuratTugas")[0].files[0];
        if (file) {
            formData.append("SuratTugas", file);
        }
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/UpdatePjs",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = `${parent_url}SetPjsList`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Error: " + xhr.responseText);
            }
        });
    });
    $(document).on('click', '.btn-download', function (e) {
        e.preventDefault();
        const id = $(this).data('id');
        if (!id) {
            ew.alert("ID dokumen tidak ditemukan.");
            return;
        }
        $.ajax({
            url: parent_url + 'api/LookUpList/DownloadSingleDocument',
            type: 'GET',
            data: { 
                id: id,
                menu: 'PJS'
            },
            xhrFields: {
                responseType: 'blob'
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader('Content-Disposition');
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            }
        });
    });
    $(document).ready(function() {
        $("#x_OrganizationLevel").trigger("change");
        $('#x_OrganizationLevel').prop('disabled', true);
        $('#x_Region').prop('disabled', true);
        $('#x_Plant').prop('disabled', true);
    });
    $(document).on('click', 'button[expand-log]', function () {
        const $btn = $(this);
        const isExpanded = $btn.attr('expand-log') === 'true';
        const $row = $('#log-table-row');
        const $wrapper = $('#log-table-wrapper');
        const $caret = $btn.find('.caret-icon');
        if (!isExpanded) {
            $btn.attr('expand-log', 'true');
            $row.removeClass('d-none');
            setTimeout(() => {
                $wrapper.css({
                    maxHeight: '500px'
                });
            }, 10);
            $caret.removeClass('rotate-right').addClass('rotate-down');
        } else {
            $btn.attr('expand-log', 'false');
            $wrapper.css({
                maxHeight: '0'
            });
            setTimeout(() => {
                $row.addClass('d-none');
            }, 600);
            $caret.removeClass('rotate-down').addClass('rotate-right');
        }
    });
});
</script>
