@{
    // View
    View = this;

    // Check action result
    if (bukuTamuView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = bukuTamuView.UseLayout ? "_Layout" : "";
}
@if (!bukuTamuView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @bukuTamuView.ExportOptions.RenderBody()
    @bukuTamuView.OtherOptions.RenderBody()
</div>
}
@bukuTamuView.ShowPageHeader()
@bukuTamuView.ShowMessages()
<main class="view">
<form name="fBukuTamuview" id="fBukuTamuview" class="ew-form ew-view-form overlay-wrapper" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (!bukuTamuView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(bukuTamuView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { BukuTamu: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fBukuTamuview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fBukuTamuview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="modal" value="@ConvertToInt(bukuTamuView.IsModal)">
<table class="@(bukuTamuView.TableClass)">
@if (bukuTamuView.NomorBukuTamu.Visible) { // bukuTamuView.NomorBukuTamu.Visible (begin)
