@{
    // View
    View = this;

    // Check action result
    if (masterRegionView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterRegionView.UseLayout ? "_Layout" : "";
}
@if (!masterRegionView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @masterRegionView.ExportOptions.RenderBody()
    @masterRegionView.OtherOptions.RenderBody()
</div>
}
@masterRegionView.ShowPageHeader()
@masterRegionView.ShowMessages()
<main class="view">
<form name="fMasterRegionview" id="fMasterRegionview" class="ew-form ew-view-form overlay-wrapper" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (!masterRegionView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(masterRegionView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterRegion: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fMasterRegionview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterRegionview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="modal" value="@ConvertToInt(masterRegionView.IsModal)">
<table class="@(masterRegionView.TableClass)">
@if (masterRegionView.IdRegion.Visible) { // masterRegionView.IdRegion.Visible (begin)
    <tr id="r_IdRegion" @Html.Raw(masterRegionView.IdRegion.RowAttributes)>
        <td class="@(masterRegionView.TableLeftColumnClass)"><span id="elh_MasterRegion_IdRegion">@Html.Raw(masterRegionView.IdRegion.Caption)</span></td>
        <td data-name="IdRegion" @Html.Raw(masterRegionView.IdRegion.CellAttributes)>
<span id="el_MasterRegion_IdRegion">
<span @Html.Raw(masterRegionView.IdRegion.ViewAttributes)>
@Html.Raw(masterRegionView.IdRegion.GetViewValue())</span>
</span></td>
    </tr>
} @* masterRegionView.IdRegion.Visible (end) *@
@if (masterRegionView.Region.Visible) { // masterRegionView.Region.Visible (begin)
    <tr id="r_Region" @Html.Raw(masterRegionView.Region.RowAttributes)>
        <td class="@(masterRegionView.TableLeftColumnClass)"><span id="elh_MasterRegion_Region">@Html.Raw(masterRegionView.Region.Caption)</span></td>
        <td data-name="Region" @Html.Raw(masterRegionView.Region.CellAttributes)>
<span id="el_MasterRegion_Region">
<span @Html.Raw(masterRegionView.Region.ViewAttributes)>
@Html.Raw(masterRegionView.Region.GetViewValue())</span>
</span></td>
    </tr>
} @* masterRegionView.Region.Visible (end) *@
@if (masterRegionView.RegionCode.Visible) { // masterRegionView.RegionCode.Visible (begin)
    <tr id="r_RegionCode" @Html.Raw(masterRegionView.RegionCode.RowAttributes)>
        <td class="@(masterRegionView.TableLeftColumnClass)"><span id="elh_MasterRegion_RegionCode">@Html.Raw(masterRegionView.RegionCode.Caption)</span></td>
        <td data-name="RegionCode" @Html.Raw(masterRegionView.RegionCode.CellAttributes)>
<span id="el_MasterRegion_RegionCode">
<span @Html.Raw(masterRegionView.RegionCode.ViewAttributes)>
@Html.Raw(masterRegionView.RegionCode.GetViewValue())</span>
</span></td>
    </tr>
} @* masterRegionView.RegionCode.Visible (end) *@
</table>
@{ masterRegionView.CloseRecordset(); }
</form>
</main>
@masterRegionView.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!masterRegionView.IsExport()) {
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
}
