    ew.deepAssign(ew.vars, { tables: { TemplateAktivitasDokumen: currentTable } });
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fTemplateAktivitasDokumengrid")
        .setPageId("grid")
        .setFormKeyCountName("@(templateAktivitasDokumenGrid.FormKeyCountName)")

        // Add fields
