        masterTemplateList.RowIndex = 0;

    // Reset inline add/copy row
    if ((masterTemplateList.IsCopy || masterTemplateList.IsAdd) && masterTemplateList.RowIndex is int rowIndex2 && rowIndex2 == 0)
        masterTemplateList.RowIndex = 1;
} @* End While *@
</tbody>
</table><!-- /.ew-table -->
} @* End If TotalRecords > 0 *@
</div><!-- /.ew-grid-middle-panel -->
@if (Empty(masterTemplateList.CurrentAction) && !masterTemplateList.UseAjaxActions) {
<input type="hidden" name="action" id="action" value="">
}
</form><!-- /.ew-list-form -->
@{ masterTemplateList.CloseRecordset(); }
@if (!masterTemplateList.IsExport()) {
<div class="card-footer ew-grid-lower-panel">
@if (!masterTemplateList.IsGridAdd && !(masterTemplateList.IsGridEdit && masterTemplateList.ModalGridEdit) && !masterTemplateList.IsMultiEdit) {
@Html.Raw(masterTemplateList.Pager.Render())
}
<div class="ew-list-other-options">
@masterTemplateList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@masterTemplateList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @masterTemplateList.FooterOptions.RenderBody()
</div>
</main>
@masterTemplateList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!masterTemplateList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MasterTemplate");
});
</script>
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
}
