    </thead>
    <tbody>
@{ masterRegionDelete.RecordCount = 0; }
@while (masterRegionDelete.Recordset != null && await masterRegionDelete.Recordset.ReadAsync()) { // DN
    masterRegionDelete.RecordCount++;
    masterRegionDelete.RowCount++;

    // Set row properties
    masterRegionDelete.ResetAttributes();
    masterRegionDelete.RowType = RowType.View; // View

