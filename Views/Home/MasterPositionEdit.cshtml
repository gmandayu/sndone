        <div class="@(masterPositionEdit.RightColumnClass)"><div @Html.Raw(masterPositionEdit.Location.CellAttributes)>
<span id="el_MasterPosition_Location">
<input type="@(masterPositionEdit.Location.InputTextType)" name="x_Location" id="x_Location" data-table="MasterPosition" data-field="x_Location" value="@Html.Raw(masterPositionEdit.Location.EditValue)" size="30" maxlength="100" placeholder="@Html.Raw(HtmlEncode(masterPositionEdit.Location.PlaceHolder))" data-format-pattern="@(masterPositionEdit.Location.FormatPattern)"@Html.Raw(masterPositionEdit.Location.EditAttributes) aria-describedby="x_Location_help">
@Html.Raw(masterPositionEdit.Location.GetCustomMessage)
