@{
    // View
    View = this;

    // Check action result
    if (aktivitasTabel.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = aktivitasTabel.UseLayout ? "_Layout" : "";
}
@aktivitasTabel.ShowMessages()
@{
    string IdAktivitas = HttpContext.Request.Query["IdAktivitas"].ToString();

    string DibuatOleh = "", TanggalDibuat = "", IdTemplateAktivitas = "", TableAnak = "", NamaAktivitas = "", produkView = "", IdProses = "", NamaProduk = "", NamaProses = "", NoReferensi = "", DiperbaruiOleh = "", TanggalDiperbarui = "", StatusAktivitas = "", Produk = "", TipeProses = "", NamaKapal = "", NomorPolisi = "", Sloc = "", NamaTerminal = "", LabelProduk = "", TipeProduk = "", colPlant = "", totalTerima = "", ETCval = "", ETAval = "", ETAval2 = "", ETAval3 = "", noUrut = "", NomorGerbongKertel = "";
    bool isEditable = true;
    int countRole = 0;
    DateTime startDate = DateTime.Now;
    Dictionary<string, object> generalList = new Dictionary<string, object>();
    List<Dictionary<string, object>> resultList = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> plantList = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> produkList = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> tangkiList = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> dataLog = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> etaList = new List<Dictionary<string, object>>();
    List<Dictionary<string, object>> gerbongKetelList = new List<Dictionary<string, object>>();
    List<List<string>> formList = new List<List<string>>();
    List<string> currentGuideFields = new List<string>();

    bool IsCustomLogbookPenyaluranContext() =>
        !string.IsNullOrEmpty(TableAnak) &&
        (TableAnak.Equals("SubAktivitasLogbookPenerimaanPenyaluran", StringComparison.OrdinalIgnoreCase) ||
         TableAnak.Equals("SubAktivitasLogbookPenerimaanPenyaluranLPG", StringComparison.OrdinalIgnoreCase));

    string GetCustomVolumeUnit(string tipeProdukContext)
    {
        if (!IsCustomLogbookPenyaluranContext())
            return "";

        return tipeProdukContext == "LPG" ? "Kg" : "L / DaL";
    }

    string GetFieldUnit(string fieldName, string tipeProdukContext)
    {
        string normalizedField = fieldName.ToLower().Replace("_", "");
        string customVolumeUnit = GetCustomVolumeUnit(tipeProdukContext);

        switch (normalizedField)
        {
            case "pressure":
                return "Kg/cm²";

            case "density":
                return "g/cm³";

            case "temperature":
            case "temperatur":
                return "°C";

            case "level":
            case "leveltangki":
                return "mm";

            case "volume":
            case "volumeklobs":
            case "volumedischarge":
            case "volumekl":
                if (!string.IsNullOrEmpty(customVolumeUnit))
                    return customVolumeUnit;
                return tipeProdukContext == "LPG" ? "MT" : "KL";

            case "quantity":
            case "quantityawal":
            case "quantityakhir":
                if (!string.IsNullOrEmpty(customVolumeUnit))
                    return customVolumeUnit;
                return tipeProdukContext == "LPG" ? "MT" : (tipeProdukContext == "RTW") ? "L" : "KL";

            case "flowrate":
                return tipeProdukContext == "LPG" ? "MT/jam" : "KL/jam";

            case "timbanganawal":
            case "timbanganakhir":
            case "netwight":
                return "Kg";

            case "meterawal":
            case "meterakhir":
                return "L";
            default:
                return "";
        }
    }

    string GetFieldLabel(string fieldName)
    {
        if (fieldName.Contains("Volume") || fieldName.Contains("volume"))
        {
            fieldName = fieldName.Replace("Volume", "Quantity")
                            .Replace("volume", "Quantity")
                            .Replace("VOLUME", "Quantity");
        }

        var labelMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase) {
            { "Density", "Density" },
            { "Temperature", "Temperature" },
            { "Temperatur", "Temperature" },
            { "Pressure", "Pressure" },
            { "Level", "Level Tangki" },
            { "Level_Tangki", "Level Tangki" },
            { "Volume", "Quantity" },
            { "Volume_KLObs", "Quantity" },
            { "VolumeDischarge", "Quantity" },
            { "Volume_KL", "Quantity" },
            { "Quantity", "Quantity" },
            { "QuantityDischarge", "Quantity" },
            { "Quantity_KLObs", "Quantity" },
            { "Quantity_KL", "Quantity" },
            { "Flowrate", "Flowrate" },
            { "QuantityAwal", "Quantity" },
            { "QuantityAkhir", "Quantity" },
            { "TimbanganAwal", "Timbangan Awal" },
            { "TimbanganAkhir", "Timbangan Akhir" },
            { "NetWight", "Net Weight" },
            { "MeterAwal", "Meter Awal" },
            { "MeterAkhir", "Meter Akhir" }
        };

        return labelMap.ContainsKey(fieldName) ? labelMap[fieldName] : fieldName;
    }

    Dictionary<string, List<string>> fieldGuides = new Dictionary<string, List<string>> {
        { "SubAktivitasLogbookPenerimaan", new List<string> { "Level", "Volume", "Flowrate" } },
        { "SubAktivitasLogbookMonitoringStock", new List<string> { "Level_Tangki", "Volume_KLObs" } },
        { "SubAktivitasLogbookPenerimaanPenyaluran", new List<string> { "Volume" } },
        { "SubAktivitasHasilPemeriksaanPenyaluran", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasInputLogbookPenerimaanPenKon", new List<string> { "Density", "Temperatur" } },
        { "SubAktivitasHasilPemeriksaanLPG", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasLogbookPenerimaanLPG", new List<string> { "Density", "Temperatur", "Level", "Volume", "Flowrate" } },
        { "SubAktivitasInputLogbookPenerimaanPenKonLPG", new List<string> { "Density", "Temperatur" } },
        { "SubAktivitasInputLogbookPenerimaanPipa", new List<string> { "Density", "Temperature" } },
        { "SubAktivitasHasilPemeriksaanPenyaluranLPG", new List<string> { "Density", "Temperature" } },
        { "SubAktivitasLogbookPenerimaanPenyaluranLPG", new List<string> { "Quantity" } },
        { "SubaktivitasInputLogbookPenyaluranPipa", new List<string> { "Quantity" } },
        { "SubaktivitasHasilPemeriksaanSTSPnrBBM", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasLogbookPenerimaanSTSPymBBM", new List<string> { "Density", "Temperatur", "Level", "Volume", "Flowrate" } },
        { "SubAktivitasFormInputMonitoringStockSTSPymSBBM", new List<string> { "Flowrate", "QuantityAwal", "QuantityAkhir" } },
        { "SubAktivitasFormInputLogbookPenerimaanSTSPymBBM", new List<string> { "Density", "Temperatur" } },
        { "SubAktivitasHasilPemeriksaanPenyaluranSTSPyrBBM", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasLogbookPenerimaanSTSPymLPG", new List<string> { "Density", "Temperatur", "Level", "Volume", "Flowrate" } },
        { "SubAktivitasFormInputMonitoringStockSTSPymSLPG", new List<string> { "QuantityAwal", "QuantityAkhir", "Flowrate" } },
        { "SubAktivitasHasilPemeriksaanSTSLPG", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasFormInputLogbookPenerimaanSTSPymLPG", new List<string> { "Density", "Temperatur" } },
        { "SubAktivitasHasilPemeriksaanPenyaluranSTSPyrLPG", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasFormInputHasilPemeriksaanPipa", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasHasilPemeriksaanPipa", new List<string> { "Density", "Temperatur", "Pressure", "VolumeDischarge", "Flowrate" } },
        { "SubAktivitasFormInputLogbookPenerimaanPipa", new List<string> { "Level", "Volume", "Flowrate" } },
        { "SubAktivitasLogbookMonitoringStockPipa", new List<string> { "Level_Tangki", "Volume_KL", "Flowrate" } },
        { "SubaktivitasHasilPemeriksaan", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasFormInputHslPemeriksaan", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubAktivitasFormInputHslPemeriksaanRTW", new List<string> { "Density", "Temperature", "Pressure" } },
        { "SubaktivitasInputHasilPemeriksaanPipa", new List<string> { "Density", "Temperature", "Pressure", "Flowrate", "Quantity" } },
        { "SubAktivitasLogbookJembatanTimbangLPG", new List<string> { "TimbanganAwal", "TimbanganAkhir", "NetWight" } },
        { "SubAktivitasFormInputLogbookPenerimaanRTW", new List<string> { "Level", "Quantity", "Flowrate" } },
        { "SubAktivitasInputDataRTW", new List<string> { "Quantity", "MeterAwal", "MeterAkhir" } },
        { "SubAktivitasFormInputLogbMonitoringStockRTW", new List<string> { "Quantity", "Flowrate" } },
        { "SubAktivitasLogbookPenerimaanRTW", new List<string> { "Density", "Temperatur" } },
        { "SubAktivitasFormInputLogbookPenerimaanTruck", new List<string> { "Level", "Volume", "Flowrate" } }
    };

    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection())
    {
        string sqlQuery = $@"SELECT
                A.TipeProses,
                A.TableAnak,
                A.No_Referensi,
                A.NamaAktivitas,
                A.StatusAktivitas,
                A.DiperbaruiOleh,
                A.TanggalDiperbarui,
                A.DibuatOleh,
                A.TanggalDibuat,
                A.Produk,
                A.IdProses,
                A.IdTemplateAktivitas,
                P.NamaProses,
                MP.TipeProduk,
                MP.NoProduk + ' - ' + MP.NamaProduk AS produkView
            FROM Aktivitas A JOIN Proses P ON A.IdProses = P.IdProses
            LEFT JOIN MasterProduk MP ON A.Produk = MP.NoProduk
            WHERE A.IdAktivitas = @IdAktivitas;";

        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
            using (SqlDataReader rs = command.ExecuteReader())
            {
                if (rs.Read())
                {
                    TipeProses = rs["TipeProses"] != null ? rs["TipeProses"].ToString() : "";
                    TableAnak = rs["TableAnak"] != null ? rs["TableAnak"].ToString() : "";
                    if (fieldGuides.ContainsKey(TableAnak))
                    {
                        currentGuideFields = fieldGuides[TableAnak];
                    }
                    NoReferensi = rs["No_Referensi"] != null ? rs["No_Referensi"].ToString() : "";
                    NamaAktivitas = rs["NamaAktivitas"] != null ? rs["NamaAktivitas"].ToString() : "";
                    StatusAktivitas = rs["StatusAktivitas"] != null ? rs["StatusAktivitas"].ToString() : "";
                    NamaProses = rs["NamaProses"] != null ? rs["NamaProses"].ToString() : "";
                    DiperbaruiOleh = rs["DiperbaruiOleh"] != null ? rs["DiperbaruiOleh"].ToString() : "";
                    DibuatOleh = rs["DibuatOleh"] != null ? rs["DibuatOleh"].ToString() : "";
                    Produk = rs["Produk"] != null ? rs["Produk"].ToString() : "";
                    TipeProduk = rs["TipeProduk"] != null ? rs["TipeProduk"].ToString() : "";
                    IdProses = rs["IdProses"] != null ? rs["IdProses"].ToString() : "";
                    IdTemplateAktivitas = rs["IdTemplateAktivitas"] != null ? rs["IdTemplateAktivitas"].ToString() : "";
                    produkView = rs["produkView"] != null ? rs["produkView"].ToString() : "";
                    if (rs["TanggalDiperbarui"] != null && DateTime.TryParse(rs["TanggalDiperbarui"].ToString(), out DateTime parsedTanggal))
                    {
                        TanggalDiperbarui = parsedTanggal.ToString("yyyy/MM/dd HH:mm:ss");
                    }
                    if (rs["TanggalDibuat"] != null && DateTime.TryParse(rs["TanggalDibuat"].ToString(), out DateTime parsedTanggal2))
                    {
                        TanggalDibuat = parsedTanggal2.ToString("yyyy/MM/dd HH:mm:ss");
                    }
                }
            }
        }

        switch (TipeProses)
        {
            case "PenyaluranTruck" or "PenyaluranLPGTASNGS" or "PenyaluranKonsinyasiSTSBBM" or "PenyaluranKonsinyasiRTW" or
                 "PenyaluranKonsinyasiSTSLPG" or "PenyaluranPipa" or "Penyaluran" or "PenyaluranSalesPipa" or "PenyaluranPipaLPG" or 
                 "PenyaluranKonsinyasiTruck" or "PenyaluranPipaJarakDekat":
                TipeProses = "Penyaluran";
                colPlant = "IdPlant";
                break;
            case "PenerimaanSTSBBM" or "PenerimaanSTSLPG" or "Penerimaan" or "PenerimaanRTW" or "PenerimaanTruck" or "PenerimaanPipaRefinery":
                TipeProses = "Penerimaan";
                colPlant = "IdPlant";
                break;
            case "PenyimpananPenerimaanLPG" or "PenyimpananPenerimaanSTSBBM" or "PenyimpananPenerimaanLPGSTS" or
                 "Penimbunan" or "PenyimpananPenerimaanPipa" or "PenyimpananPenerimaanPipaLPG" or "PenyimpananPenerimaanRTW" or
                 "PenyimpananPenerimaanTruck":
                TipeProses = "Penimbunan";
                colPlant = "Plant";
                break;
            case "PenimbunanPenyaluran" or "PenimbunanPenyaluranLPG" or "PenyimpananPenyaluranSalesSTSBBM" or
                 "PenyimpananPenyaluranKonsinyasiSTSBBM" or "PenyimpananPenyaluranSalesSTSLPG" or
                 "PenyimpananPenyaluranKonsinyasiSTSLPG" or "PenyimpananPenyaluranSalesPipa" or
                 "PenyimpananPenyaluranKonsinyasiPipa" or "PenyimpananPenyaluranSalesRTW" or "PenyimpananPenyaluranKonsinyasiRTW" or "PenyimpananPenyaluranKonsinyasi":
                TipeProses = "PenimbunanPenyaluran";
                colPlant = "Plant";
                break;
            case "RencanaPenyaluran" or "RencanaPenyaluranLPG" or "RencanaPenyaluranPipa":
                TipeProses = "RencanaPenyaluran";
                colPlant = "IdPlant";
                break;
            case "SamplingLabTest":
                colPlant = "IdPlant";
                break;
            case "ClosingStock":
                colPlant = "Plant";
                break;
        }

        sqlQuery = $"SELECT p.*,mp.TipeProduk FROM {TipeProses} p JOIN MasterPlant mp ON p.{colPlant} = mp.IdPlant WHERE Nomor{TipeProses} = @NoReferensi;";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        generalList[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                }
            }
        }

        if (TipeProses.Contains("LPG") || TipeProduk == "LPG" || generalList["TipeProduk"].ToString() == "LPG" || generalList["TipeProdukSTS"].ToString() == "LPG")
        {
            sqlQuery = "SELECT * FROM MasterProduk WHERE TipeProduk = 'LPG';";
        }
        else
        {
            sqlQuery = "SELECT * FROM MasterProduk WHERE TipeProduk = 'BBM';";
        }

        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                    produkList.Add(row);
                }
            }
        }

        sqlQuery = $"SELECT * FROM {TableAnak} A LEFT JOIN MasterProduk M ON A.Produk = M.NoProduk WHERE A.idAktifitas = @IdAktivitas;";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                    resultList.Add(row);
                }
            }
        }

        sqlQuery = "SELECT IdPlant, Nama_Terminal, Plant FROM MasterPlant;";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                    plantList.Add(row);
                }
            }
        }

        sqlQuery = "SELECT NoKetel, Quantity FROM MasterGerbongRTW Where Plant = @plant;";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            command.Parameters.AddWithValue(
                "@plant",
                generalList.TryGetValue("IdPlant", out var plantValue)
                    ? plantValue?.ToString() ?? ""
                    : ""
            );
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                    gerbongKetelList.Add(row);
                }
            }
        }

        if (IdTemplateAktivitas == "402")
        {
            gerbongKetelList.Clear();
            sqlQuery = "SELECT NoKetel, Quantity FROM MasterGerbongRTW WHERE " +
                $"Plant = (SELECT IdPlant FROM Penyaluran WHERE IdPenyaluran = (SELECT IdPenyaluran FROM Penerimaan WHERE NomorPenerimaan = '{NoReferensi}')) AND " +
                $"NoKetel NOT IN (SELECT NomorGerbongKertel FROM SubAktivitasNilaiBDperGerbong Where idAktifitas = @IdAktivitas);";
            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue(
                    "@IdAktivitas",
                    IdAktivitas
                );
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    while (rs.Read())
                    {
                        Dictionary<string, object> row = new Dictionary<string, object>();
                        for (int i = 0; i < rs.FieldCount; i++)
                        {
                            row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                        }
                        gerbongKetelList.Add(row);
                    }
                }
            }
        }

        sqlQuery = @"SELECT
                        MT.id,
                        MT.NamaTerminal,
                        MT.Plant,
                        MT.Sloc,
                        MT.MatNo,
                        MP.NamaProduk
                    FROM MasterTangki MT
                    LEFT JOIN MasterProduk MP ON MT.MatNo = MP.NoProduk
                    WHERE MT.Status = 'OPERASI';
                    ";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
        {
            using (SqlDataReader rs = command.ExecuteReader())
            {
                while (rs.Read())
                {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++)
                    {
                        row[rs.GetName(i)] = rs[i] != null ? rs[i] : "";
                    }
                    tangkiList.Add(row);
                }
            }
        }

        if (generalList.ContainsKey("NamaKapal"))
        {
            NamaKapal = generalList["NamaKapal"].ToString() ?? "";
        }

        if (IdTemplateAktivitas == "13" || IdTemplateAktivitas == "140" || IdTemplateAktivitas == "199" || IdTemplateAktivitas == "273")
        {
            string tableStart = "SubaktivitasStartBongkar";
            if (IdTemplateAktivitas == "140")
            {
                tableStart = "SubAktivitasStartBongkarLPG";
            }
            else if (IdTemplateAktivitas == "199")
            {
                tableStart = "SubaktivitasStartBongkarSTSPnrBBM";
            }
            else if (IdTemplateAktivitas == "273")
            {
                tableStart = "SubAktivitasStartBongkarSTSLPG";
            }

            sqlQuery = $@"SELECT tglStartBongkar FROM {tableStart} WHERE NoReferensi = @NoReferensi;";
            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    if (rs.Read())
                    {
                        if (rs["tglStartBongkar"] != null && DateTime.TryParse(rs["tglStartBongkar"].ToString(), out DateTime startDateParsed))
                        {
                            startDate = startDateParsed;
                        }
                    }
                }
            }

            formList = new List<List<string>> {
                new List<string> { "Nama Kegiatan", "text", "NamaKegiatan", $"Monitoring Pembongkaran {NamaKapal}, Produk {produkView}" },
                new List<string> { "Tanggal & Jam SOP", "hiddenform", "TanggalJamSOP" },
                new List<string> { "Tanggal & Jam Aktual", "hiddenform", "TanggalJam" },
                new List<string> { "Selisih Waktu (Menit)", "hiddenform", "SelisihWaktu" },
                new List<string> { "Quality", "select", "IsQualityActive" },
                new List<string> { "Density", "number", "Density" },
                new List<string> { "Temperature", "number", "Temperature" },
                new List<string> { "Pressure", "number", "Pressure" },
                new List<string> { "Keterangan", "textarea", "Keterangan" },
                new List<string> { NamaKapal, "hidden", "NamaKapal" },
                new List<string> { Produk, "hidden", "Produk" }
            };
        }
        else if (IdTemplateAktivitas == "378")
        {
            sqlQuery = $@"SELECT Tanggal FROM SubAktivitasDataStartPembongkaranRTW WHERE NoReferensi = @NoReferensi;";
            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    if (rs.Read())
                    {
                        if (rs["Tanggal"] != null && DateTime.TryParse(rs["Tanggal"].ToString(), out DateTime startDateParsed))
                        {
                            startDate = startDateParsed;
                        }
                    }
                }
            }

            formList = new List<List<string>> {
                new List<string> { "Nama Kegiatan", "text", "NamaKegiatan", $"Monitoring Pembongkaran Produk {produkView}" },
                new List<string> { "Tanggal & Jam SOP", "hiddenform", "TanggalJamSOP" },
                new List<string> { "Tanggal & Jam Aktual", "hiddenform", "TanggalJam" },
                new List<string> { "Selisih Waktu (Menit)", "hiddenform", "SelisihWaktu" },
                new List<string> { "Quality", "select", "IsQualityActive" },
                new List<string> { "Density", "number", "Density" },
                new List<string> { "Temperature", "number", "Temperature" },
                new List<string> { "Pressure", "number", "Pressure" },
                new List<string> { "Keterangan", "textarea", "Keterangan" },
                new List<string> { Produk, "hidden", "Produk" }
            };
        }
        else if (IdTemplateAktivitas == "426")
        {
            sqlQuery = $@"SELECT Tanggal FROM SubAktivitasFormInputDataStartPembongkaran WHERE NoReferensi = @NoReferensi;";
            using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection))
            {
                command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
                using (SqlDataReader rs = command.ExecuteReader())
                {
                    if (rs.Read())
                    {
                        if (rs["Tanggal"] != null && DateTime.TryParse(rs["Tanggal"].ToString(), out DateTime startDateParsed))
                        {
                            startDate = startDateParsed;
                        }
                    }
                }
            }

            formList = new List<List<string>> {
                new List<string> { "Nama Kegiatan", "text", "NamaKegiatan", $"Monitoring Pembongkaran Produk {produkView}" },
                new List<string> { "Tanggal & Jam SOP", "hiddenform", "TanggalJamSOP" },
                new List<string> { "Tanggal & Jam Aktual", "hiddenform", "Tanggal" },
