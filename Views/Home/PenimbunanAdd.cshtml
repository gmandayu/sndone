@{
    // View
    View = this;

    // Check action result
    if (penimbunanAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penimbunanAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(penimbunanAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penimbunan: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fPenimbunanadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenimbunanadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["IdTemplate", [fields.IdTemplate.visible && fields.IdTemplate.required ? ew.Validators.required(fields.IdTemplate.caption) : null], fields.IdTemplate.isInvalid],
            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["LookupPenerimaan", [fields.LookupPenerimaan.visible && fields.LookupPenerimaan.required ? ew.Validators.required(fields.LookupPenerimaan.caption) : null], fields.LookupPenerimaan.isInvalid],
            ["IdPenerimaan", [fields.IdPenerimaan.visible && fields.IdPenerimaan.required ? ew.Validators.required(fields.IdPenerimaan.caption) : null, ew.Validators.integer], fields.IdPenerimaan.isInvalid],
            ["IdTangki", [fields.IdTangki.visible && fields.IdTangki.required ? ew.Validators.required(fields.IdTangki.caption) : null], fields.IdTangki.isInvalid],
            ["StatusProses", [fields.StatusProses.visible && fields.StatusProses.required ? ew.Validators.required(fields.StatusProses.caption) : null], fields.StatusProses.isInvalid],
            ["PersentaseProgress", [fields.PersentaseProgress.visible && fields.PersentaseProgress.required ? ew.Validators.required(fields.PersentaseProgress.caption) : null], fields.PersentaseProgress.isInvalid],
            ["Catatan", [fields.Catatan.visible && fields.Catatan.required ? ew.Validators.required(fields.Catatan.caption) : null], fields.Catatan.isInvalid],
            ["DibuatOleh", [fields.DibuatOleh.visible && fields.DibuatOleh.required ? ew.Validators.required(fields.DibuatOleh.caption) : null], fields.DibuatOleh.isInvalid],
            ["PlantForLookup", [fields.PlantForLookup.visible && fields.PlantForLookup.required ? ew.Validators.required(fields.PlantForLookup.caption) : null], fields.PlantForLookup.isInvalid],
            ["LookupJenisPlant", [fields.LookupJenisPlant.visible && fields.LookupJenisPlant.required ? ew.Validators.required(fields.LookupJenisPlant.caption) : null], fields.LookupJenisPlant.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(penimbunanAdd.LookupPlant.ToClientList(penimbunanAdd)),
            "Plant": @Html.Raw(penimbunanAdd.Plant.ToClientList(penimbunanAdd)),
            "LookupPenerimaan": @Html.Raw(penimbunanAdd.LookupPenerimaan.ToClientList(penimbunanAdd)),
            "IdTangki": @Html.Raw(penimbunanAdd.IdTangki.ToClientList(penimbunanAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    $('#fPenimbunanadd').on('submit', function (e) {
        e.preventDefault();
        const parent_url = ew.PATH_BASE;
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Proses Penerimaan.');
            setTimeOut(() => {
                window.location.href = parent_url+'PenimbunanList';
            }, 1000);
            return false;
        }
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
    $('#x_LookupPlant').on("change", function () {
        const $this = $(this);
        const selectedValue = $this.val();
        const selectedText = $this.find('option:selected').text();
        $('#x_Plant').val(selectedValue || '').trigger('change');
        $('#sv_x_Plant').val(selectedText || '');
        $('#x_IdPenerimaan').val(null).trigger('change');
        $('#x_IdTangki').val(null).trigger('change');
        if (selectedValue) {
            fillPenerimaanList(selectedValue);
        }
    });
    $('#x_LookupPenerimaan').on("change", function () {
        const value = $(this).val();
        $('#x_IdPenerimaan').val(value);
    });
    function fillPenerimaanList(idPlant){
        const penerimaanSelection = $("#x_LookupPenerimaan");
        penerimaanSelection.empty();
        penerimaanSelection.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/penerimaan-to-penimbunan',
            method: 'GET',
            dataType: 'json',
            data: { plantId: idPlant },
            success: function (data) {
                penerimaanSelection.empty(); 
                $.each(data, function (index, item) {
                    penerimaanSelection.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
                penerimaanSelection.trigger("change");
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                penerimaanSelection.empty();
            }
        });
    }
});
</script>
