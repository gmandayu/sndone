<input type="@(closingStockSearch.TanggalClosingStock.InputTextType)" name="x_TanggalClosingStock" id="x_TanggalClosingStock" data-table="ClosingStock" data-field="x_TanggalClosingStock" value="@Html.Raw(closingStockSearch.TanggalClosingStock.EditValue)" placeholder="@Html.Raw(HtmlEncode(closingStockSearch.TanggalClosingStock.PlaceHolder))" data-format-pattern="@(closingStockSearch.TanggalClosingStock.FormatPattern)"@Html.Raw(closingStockSearch.TanggalClosingStock.EditAttributes)>
