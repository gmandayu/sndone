            data-select2-id="fMasterTemplatesrch_x_NamaTemplate"
            data-table="MasterTemplate"
            data-field="x_NamaTemplate"
            data-caption="@Html.Raw(HtmlEncode(RemoveHtml(masterTemplateList.NamaTemplate.Caption)))"
            data-filter="true"
            multiple
            size="1"
            data-value-separator="@(masterTemplateList.NamaTemplate.DisplayValueSeparatorAttribute)"
