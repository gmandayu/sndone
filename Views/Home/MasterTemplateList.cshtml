@if (masterTemplateList.NamaTemplate.Visible) { // masterTemplateList.NamaTemplate.Visible (begin)
    if (!masterTemplateList.NamaTemplate.UseFilter) {
        masterTemplateList.SearchColumnCount++;
    }
    <div id="xs_NamaTemplate" class="col-sm-auto d-sm-flex align-items-start mb-3 px-0 pe-sm-2@(masterTemplateList.NamaTemplate.UseFilter ? " ew-filter-field" : "")">
        <select
            id="x_NamaTemplate"
