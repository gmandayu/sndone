<script>
loadjs.ready("head", function() {
    // Client script
    $('#r_IdModa').show();
    $('#x_IdModa').show();
    $('#r_LookupNoPenyaluran').hide();
    const parent_url = ew.PATH_BASE;
    $('#r_LookupNoPenyaluran').after(`
        <div id="r_LookupNoPenyaluranSelect" class="row">
            <label id="elh_PenimbunanPenyaluran_LookupNoPenyaluranSelect"
                for="x_LookupNoPenyaluranSelect"
                class="col-sm-2 col-form-label ew-label">
                Nomor Penyaluran
            </label>
            <div class="col-sm-10">
                <div>
                    <span id="el_PenimbunanPenyaluran_LookupNoPenyaluranSelect">
                        <select
                            id="x_LookupNoPenyaluranSelect"
                            name="x_LookupNoPenyaluranSelect"
                            class="form-select ew-select"
                            data-select2-id="fPenimbunanPenyaluranadd_x_LookupNoPenyaluranSelect"
                            data-value-separator=""
                            data-placeholder="Nomor Penyaluran">
                        </select>
                    </span>
                </div>
            </div>
        </div>
    `);
    // initialize select options START
    let options = { name: "x_LookupNoPenyaluranSelect", selectId: `fPenimbunanPenyaluranadd_x_LookupNoPenyaluranSelect` };
    const el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables["PenimbunanPenyaluran"].fields.LookupNoPenyaluran.selectOptions);
    ew.createSelect(options);
    function fillPenyaluranSelect(idPlant, idModa) {
        $.ajax({
            url: `${parent_url}api/LookUpList/get-dropdown/lookup-penyaluran?idPlant=${encodeURIComponent(idPlant)}&menu=PenimbunanPenyaluran&idModa=${encodeURIComponent(idModa)}`,
            method: 'GET',
            dataType: 'json',
            success: function(data) {
                $('#x_LookupNoPenyaluranSelect').html('');
                $.each(data, function (index, item) {
                    $('#x_LookupNoPenyaluranSelect').append(new Option(item.NomorPenyaluran, item.NomorPenyaluran, false, false)).trigger('change');
                });
                $('#x_LookupNoPenyaluranSelect').val(null).trigger('change');
            },
            error: function(xhr, textStatus, errorThrown) {
                console.error("Gagal ambil data dropdown:", error);
            }
        });
    }
    // initialize select options END
    $('#fPenimbunanPenyaluranadd').on('submit', function (e) {
        e.preventDefault();
        const parent_url = ew.PATH_BASE;
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Proses Penyaluran.');
            setTimeOut(() => {
                window.location.href = parent_url+'PenimbunanPenyaluranList';
            }, 1000);
            return false;
        }
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
    $('#x_LookupJenisPlant, #x_TipePenyaluran').change(function () {
        let JenisPlant = $('#x_LookupJenisPlant').val();
        let TipePenyaluran = $('#x_TipePenyaluran').val();
        if (JenisPlant == 'STS') {
            $('#r_TipeProdukSTS').show();
        } else {
            $('#r_TipeProdukSTS').hide();
            $('#r_TipeProdukSTS').val('');
        }
        if (JenisPlant == 'STS' && TipePenyaluran == 'Sales') {
            $('#r_JenisProduk').show();
        } else {
            $('#r_JenisProduk').hide();
            $('#r_JenisProduk').val('');
        }
        if (TipePenyaluran == 'Konsinyasi') {
            $('#r_LookupNoPenyaluranSelect').show();
        } else {
            $('#r_LookupNoPenyaluranSelect').hide();
            $('#x_LookupNoPenyaluranSelect').val(null).trigger('change');
        }
        $('#r_IdModa').show();
        // if (TipePenyaluran == 'Sales') {
        //     $('#r_IdModa').show();
        // } else {
        //     $('#r_IdModa').hide();
        //     $('#x_IdModa').val('');
        // }
    });
    $('#x_IdModa').on("change", function () {
        const selectedValue = $(this).val();
        const idPlant = $('#x_Plant').val();
        if (selectedValue != null && selectedValue != '' && idPlant != null && idPlant != '')
        {
            fillPenyaluranSelect(idPlant, selectedValue);
        }
        else
        {
            $('#x_NoPenyaluran').val(null).trigger('change');
            // $('#x_LookupNoPenyaluran').val(null).trigger('change');
            $('#x_LookupNoPenyaluranSelect').val(null).trigger('change');
        }
    });
    $('#x_LookupPlant').on("change", function () {
        const $this = $(this);
        const selectedValue = $this.val();
        const selectedText = $this.find('option:selected').text();
        const idModa = $('#x_IdModa').val();
        $('#x_Plant').val(selectedValue || '').trigger('change');
        $('#sv_x_Plant').val(selectedText || '');
        // Clear dependents so they reload with new Plant
        $('#x_IdTangki').val(null).trigger('change');
        $('#x_NoPenyaluran').val(null).trigger('change');
        if (selectedValue != null && selectedValue != '' && idModa != null && idModa != '')
        {
            fillPenyaluranSelect(selectedValue, idModa);
        }

        // const ddlNoPenyaluran = $("#x_LookupNoPenyaluran");
        // ddlNoPenyaluran.empty();
        // ddlNoPenyaluran.append('<option value="">Loading...</option>');

        // $.ajax({
        //     url: `${parent_url}api/LookUpList/get-dropdown/lookup-penyaluran?idPlant=${encodeURIComponent(selectedValue)}&menu=PenimbunanPenyaluran`,
        //     method: 'GET',
        //     dataType: 'json',
        //     success: function (data) {
        //         ddlNoPenyaluran.empty(); 
        //         $.each(data, function (index, item) {
        //             ddlNoPenyaluran.append(`<option value="${item.NomorPenyaluran}">${item.NomorPenyaluran}</option>`);
        //         });
        //         ddlNoPenyaluran.val(null).trigger('change');
        //     },
        //     error: function (xhr, status, error) {
        //         console.error("Gagal ambil data dropdown:", error);
        //         ddlNoPenyaluran.empty();
        //     }
        // });
    });
    $('#x_LookupNoPenyaluranSelect').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_NoPenyaluran').val(selectedValue).trigger('change');
    });
    // $('#x_LookupNoPenyaluran').on("change", function () {
    //     const selectedValue = $(this).val();
    //     $('#x_NoPenyaluran').val(selectedValue).trigger('change');
    // });
});
</script>
