</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    var parent_url = ew.PATH_BASE;
    $('#r_Plant').hide();
    $('#r_UserMOD').hide();
    $(document).ready(function () {
        const userMod = $("#x_UserMOD");
        userMod.empty();
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                $.each(data, function (index, item) {
                    const selected = index === 0 ? 'selected' : '';
                    ddl.append(`<option value="${item.Value}" ${selected}>${item.Label}</option>`);
                });
                ddl.trigger('change');
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
        const element = document.getElementById('datetimepicker_fSetUserMODadd_x_Tanggal');
        if (!element) return;

        // Ambil format dari atribut bawaan ASP.NET Maker
        const input = document.getElementById('x_Tanggal');
        const formatPattern = input?.dataset.formatPattern || 'yyyy/MM/dd HH:mm:ss';

        // Siapkan opsi picker dengan format Luxon yang sesuai
        const options = {
            localization: {
                format: formatPattern
            },
            restrictions: {
                minDate: tempusDominus.DateTime.convert(new Date()) // format aman Luxon
            },
            display: {
                components: {
                    calendar: true,
                    date: true,
                    month: true,
                    year: true,
                    hours: true,
                    minutes: true,
                    seconds: true
                }
            }
        };

        // Inisialisasi datepicker baru
        new tempusDominus.TempusDominus(element, options);
    });
    function setTanggal() {
        const today = new Date();

        // Format ke yyyy/mm/dd hh:mm:ss
        const formattedDate =
            today.getFullYear() + "/" +
            String(today.getMonth() + 1).padStart(2, '0') + "/" +
            String(today.getDate()).padStart(2, '0') + " " +
            String(today.getHours()).padStart(2, '0') + ":" +
            String(today.getMinutes()).padStart(2, '0') + ":" +
            String(today.getSeconds()).padStart(2, '0');

        // Set ke input #x_Tanggal
        document.getElementById("x_Tanggal").value = formattedDate;
    }

    // Jalankan saat halaman/form Add terbuka
    window.onload = function() {
        setTanggal();
    };
    (function () {
        const role = parseInt('@CurrentUserInfo("Rule")') || 0; // 0=Superadmin, 10=OH
        const isAllowed = (role === 0 || role === 10);
        if (isAllowed) return;

        // ====== Blokir akses & tampilkan peringatan ======
        const $container = $(".content .container-fluid").first();
        const $form = $("form.ew-form").first(); // form Add bawaan ASP.NET Maker (id biasanya f<TableName>add)
        const listUrl = ew.PATH_BASE + "SetUserMODList"; // ganti jika route Anda berbeda

        // Alert peringatan (Bootstrap)
        const $alert = $(`
          <div class="alert alert-warning d-flex align-items-start" role="alert" id="no-access-alert">
            <i class="fa-solid fa-triangle-exclamation me-2 mt-1"></i>
            <div>
              <div class="fw-bold">Tidak ada akses untuk membuat Set User MOD.</div>
              <div class="small">
                Hanya pengguna dengan Role <strong>Superadmin</strong> atau <strong>OH</strong> yang dapat menambah data di halaman ini.
                <br>Solusi: <em>Ganti Akun</em> atau <em>minta diberikan akses oleh Superadmin</em>.
              </div>
              <div class="mt-2">
                <a href="${ew.PATH_BASE}logout" class="btn btn-outline-secondary btn-sm me-2">
                  <i class="fa-solid fa-right-from-bracket"></i> Ganti Akun
                </a>
                <a href="${listUrl}" class="btn btn-primary btn-sm">
                  <i class="fa-solid fa-list"></i> Kembali ke List
                </a>
              </div>
            </div>
          </div>
        `);

        // Sisipkan alert di atas form
        if ($container.length) $container.prepend($alert);
        else $("body").prepend($alert);

        // Nonaktifkan input & tombol di form
        if ($form.length) {
          // Blokir submit (klik, enter, dll.)
          $form.on("submit", function (e) { e.preventDefault(); return false; });

          // Disable semua kontrol
          $form.find("input, select, textarea, button").prop("disabled", true);

          // Re-enable tombol/link Cancel jika ada
          $form.find('a.btn-secondary, a.ew-btn, a.btn')
               .filter(function () {
                  const href = (this.getAttribute("href") || "").toLowerCase();
                  return href.includes("list") || href.includes("cancel");
               })
               .prop("disabled", false)
               .removeClass("disabled");
        }

        // Bersihkan tombol Add/Save lain yang mungkin muncul
        $(".ew-toolbar a.ew-add, .ew-grid-lower-panel a, button[name='btn-action'], button[name='btn-submit']").hide();

        // Tambahan UX: scroll ke atas supaya alert terlihat
        window.scrollTo({ top: 0, behavior: "smooth" });
      })();
});
</script>
