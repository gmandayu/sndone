        options.ajax = { id: "x_IdTemplate", form: "fTemplateProsesedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.TemplateProses.fields.IdTemplate.selectOptions);
    ew.createSelect(options);
});
</script>
</span>
