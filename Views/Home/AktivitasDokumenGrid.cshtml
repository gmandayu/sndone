<script>
var fAktivitasDokumengrid;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let currentTable = @Html.Raw(ConvertToJson(aktivitasDokumenGrid.ToClientVar()));
    ew.deepAssign(ew.vars, { tables: { AktivitasDokumen: currentTable } });
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fAktivitasDokumengrid")
        .setPageId("grid")
        .setFormKeyCountName("@(aktivitasDokumenGrid.FormKeyCountName)")

        // Add fields
        .setFields([

            ["NoReferensi", [fields.NoReferensi.visible && fields.NoReferensi.required ? ew.Validators.required(fields.NoReferensi.caption) : null], fields.NoReferensi.isInvalid],
            ["IdProses", [fields.IdProses.visible && fields.IdProses.required ? ew.Validators.required(fields.IdProses.caption) : null, ew.Validators.integer], fields.IdProses.isInvalid],
            ["IdAktivitas", [fields.IdAktivitas.visible && fields.IdAktivitas.required ? ew.Validators.required(fields.IdAktivitas.caption) : null], fields.IdAktivitas.isInvalid],
            ["NamaDokumen", [fields.NamaDokumen.visible && fields.NamaDokumen.required ? ew.Validators.required(fields.NamaDokumen.caption) : null], fields.NamaDokumen.isInvalid],
            ["UploadDokumen", [fields.UploadDokumen.visible && fields.UploadDokumen.required ? ew.Validators.required(fields.UploadDokumen.caption) : null], fields.UploadDokumen.isInvalid],
            ["DownloadDokumen", [fields.DownloadDokumen.visible && fields.DownloadDokumen.required ? ew.Validators.required(fields.DownloadDokumen.caption) : null], fields.DownloadDokumen.isInvalid],
            ["DiunggahOleh", [fields.DiunggahOleh.visible && fields.DiunggahOleh.required ? ew.Validators.required(fields.DiunggahOleh.caption) : null], fields.DiunggahOleh.isInvalid],
            ["TanggalUpload", [fields.TanggalUpload.visible && fields.TanggalUpload.required ? ew.Validators.required(fields.TanggalUpload.caption) : null, ew.Validators.datetime(fields.TanggalUpload.clientFormatPattern)], fields.TanggalUpload.isInvalid],
            ["DiperbaruiOleh", [fields.DiperbaruiOleh.visible && fields.DiperbaruiOleh.required ? ew.Validators.required(fields.DiperbaruiOleh.caption) : null], fields.DiperbaruiOleh.isInvalid],
            ["TanggalDiperbarui", [fields.TanggalDiperbarui.visible && fields.TanggalDiperbarui.required ? ew.Validators.required(fields.TanggalDiperbarui.caption) : null, ew.Validators.datetime(fields.TanggalDiperbarui.clientFormatPattern)], fields.TanggalDiperbarui.isInvalid],
            ["WajibUpload", [fields.WajibUpload.visible && fields.WajibUpload.required ? ew.Validators.required(fields.WajibUpload.caption) : null], fields.WajibUpload.isInvalid],
            ["TipeProses", [fields.TipeProses.visible && fields.TipeProses.required ? ew.Validators.required(fields.TipeProses.caption) : null], fields.TipeProses.isInvalid]
        ])

        // Check empty row
        .setEmptyRow(
            function (rowIndex) {
                let fobj = this.getForm(),
                    fields = [["NoReferensi",false],["IdProses",false],["IdAktivitas",false],["NamaDokumen",false],["UploadDokumen",false],["DownloadDokumen",false],["DiunggahOleh",false],["TanggalUpload",false],["DiperbaruiOleh",false],["TanggalDiperbarui",false],["WajibUpload",true],["TipeProses",false]];
                if (fields.some(field => ew.valueChanged(fobj, rowIndex, ...field)))
                    return false;
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "IdProses": @Html.Raw(aktivitasDokumenGrid.IdProses.ToClientList(aktivitasDokumenGrid)),
            "IdAktivitas": @Html.Raw(aktivitasDokumenGrid.IdAktivitas.ToClientList(aktivitasDokumenGrid)),
            "WajibUpload": @Html.Raw(aktivitasDokumenGrid.WajibUpload.ToClientList(aktivitasDokumenGrid)),
        })
        .build();
    window[form.id] = form;
    loadjs.done(form.id);
});
</script>
}
