<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("FormInputProofOfVisit");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    const parent_url = ew.PATH_BASE;

    /* ==== Ambil NoReferensi dari URL / form (tanpa bergantung data list) ==== */
    function resolveNoRef() {
        const qs = new URLSearchParams(location.search);
        let v = (qs.getAll("x_NoReferensi[]")[0] || "").trim();
        if (!v) v = (qs.get("x_NoReferensi") || "").trim();
        if (!v) v = (qs.get("NoReferensi") || "").trim();
        if (!v) {
            v = ($('input[name="x_NoReferensi[]"]').val() || $('input[name="x_NoReferensi"]').val() || "").trim();
        }
        return v;
    }
    const NoReferensi = resolveNoRef();

    /* ==== Stepper ==== */
    (function () {
        const steps = [
            { number: 1, label: "Proof of Visit", url: parent_url + 'ProofOfVisitList', icon: "fa-clipboard-list" },
            { number: 2, label: "Input Data", url: "", icon: "fa-pen-to-square" }
        ];
        const currentStep = 2;
        if (!document.querySelector("style[data-hsse-stepper]")) {
            $("<style data-hsse-stepper>")
                .prop("type", "text/css")
                .html(`
                .stepper{display:flex;counter-reset:step}
                .step{width:150px;text-align:center;position:relative}
                .step:not(:last-child)::after{content:'';position:absolute;top:20px;right:-50%;width:100%;height:4px;background-color:#ccc;z-index:0}
                .step.completed:not(:last-child)::after{background-color:#3c6dbd}
                .step-icon{width:36px;height:36px;line-height:36px;border-radius:50%;background:#ccc;display:inline-block;z-index:1;position:relative;color:#fff;font-weight:bold}
                .step.active .step-icon{background:#28a745}
                .step-label{margin-top:8px;font-size:14px;display:flex;justify-content:center;align-items:center;gap:6px;color:#3c6dbd;text-decoration:none}
                .step-label-not-active{color:#CCC!important}
            `).appendTo("head");
        }
        const $wrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
        const $stepper = $wrapper.find(".stepper");
        steps.forEach(step => {
            const isActive = step.number === currentStep;
            const isCompleted = step.number < currentStep;
            let icon, label, html;
            if (isActive) {
                icon = `<div class="step-icon bg-success">${step.number}</div>`;
                label = `<div class="step-label text-success"><i class="fa-solid ${step.icon} me-1 text-success"></i>${step.label}</div>`;
                html = `<div class="step active text-success">${icon}${label}</div>`;
            } else if (isCompleted) {
                icon = `<div class="step-icon" style="background:#3c6dbd">${step.number}</div>`;
                label = `<div class="step-label"><a href="${step.url}" class="text-primary"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
                html = `<div class="step completed text-primary">${icon}${label}</div>`;
            } else {
                icon = `<div class="step-icon">${step.number}</div>`;
                label = `<div class="step-label-not-active"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</div>`;
                html = `<div class="step text-secondary">${icon}${label}</div>`;
            }
            $stepper.append(html);
        });
        $(".content-header .container-fluid .row").append($wrapper);
    })();

    /* ==== Judul kecil di samping Filter (pakai NoReferensi dari URL) ==== */
    (function () {
        const id = "title-pov-plant-date";
        $("#" + id).remove();
        const noRef = NoReferensi;
        if (!noRef) return;
        $.get(ew.PATH_BASE + "api/LookUpList/get_pov_header", { nomorReferensi: noRef })
            .done(res => {
                const plant = (res && res.success && (res.plantDisplay || res.plant)) || "-";
                const tgl = (res && res.success && res.tanggal) || "-";
                const html =
                    `<span id="${id}" class="ms-3 fw-bold fst-italic d-inline-block align-middle">
                Nomor Referensi: <span style="color:red">${noRef}</span>,
                Plant: <span style="color:red">${plant}</span>,
                Tanggal: <span style="color:red">${tgl}</span>
                </span>`;
                const $filter = $(".ew-toolbar .ew-filter-option").first();
                if ($filter.length) $filter.after(html);
                else $(".ew-toolbar").first().append(html);
            });
    })();

    /* ==== Tombol Add kustom (selalu pakai NoReferensi dari URL) ==== */
    (function () {
        const $originalButton = $(`a.btn.btn-default.ew-add-edit.ew-add[href="${parent_url}FormInputProofOfVisitAdd"]`);
        if ($originalButton.length) {
            $originalButton.remove(); // Remove the default button
            const nref = resolveNoRef();
            if (!nref) {
                return;
            }
            $.ajax({
                url: parent_url + "api/LookUpList/GetTanggalDibuatPOV",
                type: 'GET',
                data: { noReferensi: nref },
                success: function(response) {
                    if (response && response.success) {
                        const tanggalDibuat = new Date(response.tanggalDibuat);
                        const now = new Date();
                        const offsetWIB = 7 * 60; // 7 hours in minutes
                        const todayWIB = new Date(now.getTime() + (offsetWIB + now.getTimezoneOffset()) * 60000);
                        const isSameDate =
                                tanggalDibuat.getFullYear() === todayWIB.getFullYear() &&
                                tanggalDibuat.getMonth() === todayWIB.getMonth() &&
                                tanggalDibuat.getDate() === todayWIB.getDate();
                        if (isSameDate) {
                            const $buttonContainer = $('button.btn-primary[name="btn-submit"]').first().parent();
                            const $addButton = $(`
                                <button class="btn btn-success ms-2" id="btn-add-pov">
                                    <i class="fas fa-plus"></i> Add New
                                </button>
                            `);
                            $addButton.on('click', function (e) {
                                e.preventDefault();
                                window.location.href = `${parent_url}FormInputProofOfVisitAdd?NoReferensi=${encodeURIComponent(nref)}`;
                            });
                            ($buttonContainer.length ? $buttonContainer : $(".ew-toolbar").first()).append($addButton);
                        }
                    }
                },
                error: function() {
                    console.error("Failed to verify POV creation date.");
                }
            });
        }
    })();

    /* ==== Gate akses List: Admin/OH bebas; lainnya harus MOD (API GetMODForPOV) ==== */
    (function () {
        const role = parseInt('@CurrentUserInfo("Rule")') || 0; // 0 = Superadmin, 10 = OH
        if (role == 0 || role === 10) return;
        const noRef = NoReferensi;
        if (!noRef) return; // jika NoReferensi tidak ada, biarkan UI default
        const hideRestrictedUI = () => {
            // Add (default & custom)
            $('.ew-toolbar a.ew-add, .ew-grid-lower-panel a').filter(function () {
                const href = (this.href || "").toLowerCase();
                return href.includes("forminputproofofvisitadd");
            }).closest('.btn, a, .ew-list-other-options').hide();
            $('#btn-add-pov').closest('.btn, button').hide();

            // Multi-delete
            $('.ew-toolbar .ew-multi-delete, .ew-grid-lower-panel .ew-multi-delete')
                .closest('.btn, button, a, .ew-list-other-options').hide();

            // Per-row Edit/Delete/Copy
            $('a.ew-row-link.ew-edit, a.ew-row-link.ew-delete, a.ew-row-link.ew-copy, button.ew-row-link.ew-delete')
                .closest('.ew-list-options, .ew-list-option-body, a, button, li').hide();

            // Checkbox seleksi
            $('input[type="checkbox"][name="key_m[]"], input#key, input#toggle-all')
                .closest('th, td, .form-check, label').hide();

            // Info kecil
            const $filter = $(".ew-toolbar .ew-filter-option").first();
            if ($filter.length) {
                $filter.after('<span class="ms-3 text-warning fw-bold">Akses dibatasi: hanya User MOD / OH / Admin.</span>');
            }
        };
        $.get(ew.PATH_BASE + "api/LookUpList/GetMODForPOV", { noRef: noRef })
            .done(function (res) {
                if (!res || res.success !== true || res.isCurrentUserMOD !== true) {
                    hideRestrictedUI();
                    if (parseInt('@CurrentUserInfo("UserLevel")') == 4) $('a.ew-row-link.ew-edit').show();
                }
            })
            .fail(function () {
                hideRestrictedUI();
            });
    })();
});
</script>
}
