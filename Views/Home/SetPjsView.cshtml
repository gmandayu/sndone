@if (!setPjsView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(setPjsView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { SetPjs: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fSetPjsview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fSetPjsview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    $(document).on('click', '.btn-download', function (e) {
        e.preventDefault();
        const id = $(this).data('id');
        if (!id) {
            ew.alert("ID dokumen tidak ditemukan.");
            return;
        }
        $.ajax({
            url: parent_url + 'api/LookUpList/DownloadSingleDocument',
            type: 'GET',
            data: { 
                id: id,
                menu: 'PJS'
            },
            xhrFields: {
                responseType: 'blob'
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader('Content-Disposition');
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            }
        });
    });
    $("#btn-back").on("click", function (e) {
        window.location.href = `${parent_url}SetPjsList`;
    });
    $('#btn-approve').on('click', function () {
        Swal.fire({
            title: 'Approve PJS?',
            text: 'Apakah anda yakin, ingin approve PJS ini?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Ya, Approve',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d'
        }).then((result) => {
            if (result.isConfirmed) {
                approval('Approved');
            }
        });
    });
    $('#btn-canceling').on('click', function () {
        Swal.fire({
            title: 'Cancel PJS?',
            text: 'Data yang sudah di-cancel tidak bisa diubah.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Ya, Cancel',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d'
        }).then((result) => {
            if (result.isConfirmed) {
                approval('Canceled');
            }
        });
    });
    $('#btn-reject').on('click', function () {
        Swal.fire({
            title: 'Reject PJS',
            input: 'textarea',
            inputLabel: 'Remarks',
            inputPlaceholder: 'Tulis alasan reject di sini...',
            inputAttributes: {
                'aria-label': 'Alasan Reject'
            },
            showCancelButton: true,
            confirmButtonText: 'Reject',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            inputValidator: (value) => {
                if (!value) {
                    return 'Alasan wajib diisi!';
                }
            }
        }).then((result) => {
            if (result.isConfirmed) {
                approval('Rejected', result.value);
            }
        });
    });
    function approval(status, remarks = "") {
        const Id = "@setPjsView.Id.CurrentValue";
        const PosisiPJS = "@setPjsView.PosisiPJS.CurrentValue";
        let formData = new FormData();
        formData.append("Id", Id);
        formData.append("PosisiPJS", PosisiPJS);
        formData.append("ApprovalStatus", status);
        formData.append("Remarks", remarks);
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/ApprovalPjs",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = `${parent_url}SetPjsList`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Error: " + xhr.responseText);
            }
        });
    }
    $(document).on('click', 'button[expand-log]', function () {
        const $btn = $(this);
        const isExpanded = $btn.attr('expand-log') === 'true';
        const $row = $('#log-table-row');
        const $wrapper = $('#log-table-wrapper');
        const $caret = $btn.find('.caret-icon');
        if (!isExpanded) {
            $btn.attr('expand-log', 'true');
            $row.removeClass('d-none');
            setTimeout(() => {
                $wrapper.css({
                    maxHeight: '500px'
                });
            }, 10);
            $caret.removeClass('rotate-right').addClass('rotate-down');
        } else {
            $btn.attr('expand-log', 'false');
            $wrapper.css({
                maxHeight: '0'
            });
            setTimeout(() => {
                $row.addClass('d-none');
            }, 600);
            $caret.removeClass('rotate-down').addClass('rotate-right');
        }
    });
});
</script>
}
