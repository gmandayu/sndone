@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("FormInputControlRutinSecurity");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    const parent_url = ew.PATH_BASE;

    /* --- Ambil NoReferensi (prioritas dari input readonly) --- */
    function resolveNoRefEdit() {
        // 1) Dari input readonly yang kamu tampilkan di Edit
        let v = ($("#NoReferensi-custom").val() || "").trim();
        if (v) return v;

        // 2) Fallback dari URL / form jika suatu saat berubah
        const qs = new URLSearchParams(location.search);
        v = (qs.getAll("NoReferensi")[0] || qs.getAll("x_NoReferensi[]")[0] || "").trim();
        if (!v) v = (qs.get("x_NoReferensi") || "").trim();
        if (!v) v = ($('input[name="x_NoReferensi[]"]').val() || $('input[name="x_NoReferensi"]').val() || "").trim();
        return v;
    }
    const NoReferensi = resolveNoRefEdit();

    /* --- Guard akses: OH (Rule 10) bebas; lainnya harus MOD (API GetMODForPOV) --- */
    (function () {
        const role = parseInt('@CurrentUserInfo("Rule")') || 0; // hanya OH yang auto-lolos
        if (true) return;
        const noRef = NoReferensi;
        if (!noRef) return; // jika NoRef belum ada (edge), biarkan default

        // id form edit (sesuaikan jika generator memberi id berbeda)
        const $form = $("#fFormControlRutinSecurityedit").length ?
            $("#fFormControlRutinSecurityedit") :
            $("form.ew-form").first();
        if (!$form.length) return;
        const backUrl = `${parent_url}FormControlRutinSecurityList?cmd=search&x_NoReferensi%5B%5D=${encodeURIComponent(noRef)}`;
        const denyAccess = (msg) => {
            const $cancelCandidates = $(
                '#btn-cancel-custom, a[data-ew-action="cancel"], button[name="btn-cancel"], a.btn-secondary, a.btn-default'
            );

            // 1) Disable semua kontrol KECUALI Cancel
            // $form.find("input,select,textarea,button")
            //     .not($cancelCandidates)
            //     .prop("disabled", true);

            // 2) Sembunyikan tombol aksi utama (Save/Submit)
            $form.find('button[name="btn-action"], button[name="btn-submit"], .ew-btn[data-ew-action]')
                .not($cancelCandidates)
                .hide();

            // 3) Aktifkan & arahkan Cancel → backUrl
            const enableCancel = ($el) => {
                if (!$el || !$el.length) return;
                if ($el.is("a")) {
                    $el.attr("href", backUrl);
                } else {
                    $el.off("click").on("click", function (e) {
                        e.preventDefault();
                        window.location.href = backUrl;
                    });
                }
                $el.prop("disabled", false).removeAttr("disabled").removeClass("disabled").css("pointer-events", "auto").show();
            };
            $cancelCandidates.each(function () {
                enableCancel($(this));
            });

            // Fallback Cancel jika tidak ada sama sekali
            if (!$cancelCandidates.length && !$("#btn-cancel-fallback").length) {
                const $fallback = $(
                    `<a class="btn btn-secondary ms-2" id="btn-cancel-fallback" href="${backUrl}">
                    <i class="fa-solid fa-xmark"></i> Cancel
                    </a>`
                );
                const $btnWrap = $form.find('button[name="btn-submit"]').first().parent();
                ($btnWrap.length ? $btnWrap : $(".ew-toolbar").first()).append($fallback);
            }

            // 4) Alert peringatan
            const $container = $(".content .container-fluid").first();
            const $alert = $(`
            <div class="alert alert-warning d-flex align-items-start mt-3" role="alert" id="no-access-alert">
                <i class="fa-solid fa-triangle-exclamation me-2 mt-1"></i>
                <div>
                <div class="fw-bold">Tidak ada akses untuk mengedit Control Rutin Security.</div>
                <div class="small">
                    ${msg || "Akses dibatasi: hanya User MOD / OH / Admin yang dapat mengedit data."}
                    <br>Solusi: <em>Ganti Akun</em> atau <em>minta diberikan akses oleh OH</em>.
                </div>
                <div class="mt-2">
                    <a href="${parent_url}logout" class="btn btn-outline-secondary btn-sm me-2">
                    <i class="fa-solid fa-right-from-bracket"></i> Ganti Akun
                    </a>
                    <a href="${backUrl}" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-list"></i> Kembali ke List
                    </a>
                </div>
                </div>
            </div>
            `);
            if ($container.length) $container.prepend($alert);
            else $("body").prepend($alert);

            // Pastikan cancel custom (jika ada) benar-benar aktif
            setTimeout(() => {
                $("#btn-cancel-custom").prop("disabled", false).removeAttr("disabled").removeClass("disabled");
            }, 0);
            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        };

        // Cek MOD via API
        $.get(ew.PATH_BASE + "api/LookUpList/GetMODForPOV", {
                noRef
            })
            .done(function (res) {
                if ((!res || res.success !== true || res.isCurrentUserMOD !== true) && parseInt('@CurrentUserInfo("UserLevel")') != 4) {
                    denyAccess("Anda bukan User MOD untuk plant & tanggal ini. Minta akses ke OH atau gunakan akun yang tepat.");
                }
            })
            .fail(function () {
                denyAccess("Gagal memverifikasi MOD. Hubungi Administrator / OH.");
            });
    })();
});
</script>
