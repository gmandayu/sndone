@{
    // View
    View = this;

    // Check action result
    if (masterAreaEdit.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterAreaEdit.UseLayout ? "_Layout" : "";
}
@masterAreaEdit.ShowPageHeader()
@masterAreaEdit.ShowMessages()
<main class="edit">
<form name="fMasterAreaedit" id="fMasterAreaedit" class="@(masterAreaEdit.FormClassName)" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
<script>
var currentTable = @Html.Raw(ConvertToJson(masterAreaEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterArea: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fMasterAreaedit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterAreaedit")
        .setPageId("edit")

        // Add fields
        .setFields([

            ["ID", [fields.ID.visible && fields.ID.required ? ew.Validators.required(fields.ID.caption) : null], fields.ID.isInvalid],
            ["Area", [fields.Area.visible && fields.Area.required ? ew.Validators.required(fields.Area.caption) : null], fields.Area.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
<input type="hidden" name="action" id="action" value="update">
<input type="hidden" name="modal" value="@ConvertToInt(masterAreaEdit.IsModal)">
@if (IsJsonResponse()) {
<input type="hidden" name="json" value="1">
}
<input type="hidden" name="@(masterAreaEdit.OldKeyName)" value="@Html.Raw(masterAreaEdit.OldKey)">
<div class="ew-edit-div"><!-- page* -->
@if (masterAreaEdit.ID.Visible) { // masterAreaEdit.ID.Visible (begin)
    <div id="r_ID" @Html.Raw(masterAreaEdit.ID.RowAttributes)>
        <label id="elh_MasterArea_ID" class="@(masterAreaEdit.LeftColumnClass)">@Html.Raw(masterAreaEdit.ID.Caption)@Html.Raw(masterAreaEdit.ID.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(masterAreaEdit.RightColumnClass)"><div @Html.Raw(masterAreaEdit.ID.CellAttributes)>
<span id="el_MasterArea_ID">
<span @Html.Raw(masterAreaEdit.ID.ViewAttributes)>
<input type="text" readonly class="form-control-plaintext" value="@Html.Raw(RemoveHtml(ConvertToString(masterAreaEdit.ID.EditValue)))"></span>
<input type="hidden" data-table="MasterArea" data-field="x_ID" data-hidden="1" name="x_ID" id="x_ID" value="@Html.Raw(HtmlEncode(masterAreaEdit.ID.CurrentValue))">
</span>
</div></div>
    </div>
} @* masterAreaEdit.ID.Visible (end) *@
@if (masterAreaEdit.Area.Visible) { // masterAreaEdit.Area.Visible (begin)
    <div id="r_Area" @Html.Raw(masterAreaEdit.Area.RowAttributes)>
        <label id="elh_MasterArea_Area" for="x_Area" class="@(masterAreaEdit.LeftColumnClass)">@Html.Raw(masterAreaEdit.Area.Caption)@Html.Raw(masterAreaEdit.Area.Required ? Language.Phrase("FieldRequiredIndicator") : "")</label>
        <div class="@(masterAreaEdit.RightColumnClass)"><div @Html.Raw(masterAreaEdit.Area.CellAttributes)>
<span id="el_MasterArea_Area">
<input type="@(masterAreaEdit.Area.InputTextType)" name="x_Area" id="x_Area" data-table="MasterArea" data-field="x_Area" value="@Html.Raw(masterAreaEdit.Area.EditValue)" size="30" maxlength="50" placeholder="@Html.Raw(HtmlEncode(masterAreaEdit.Area.PlaceHolder))" data-format-pattern="@(masterAreaEdit.Area.FormatPattern)"@Html.Raw(masterAreaEdit.Area.EditAttributes) aria-describedby="x_Area_help">
@Html.Raw(masterAreaEdit.Area.GetCustomMessage)
<div class="invalid-feedback">@Html.Raw(masterAreaEdit.Area.GetErrorMessage())</div>
</span>
</div></div>
    </div>
} @* masterAreaEdit.Area.Visible (end) *@
</div><!-- /page* -->
@{ masterAreaEdit.CloseRecordset(); }
@Html.Raw(masterAreaEdit.IsModal ? "<template class=\"ew-modal-buttons\">" : "<div class=\"row ew-buttons\">")<!-- buttons .row -->
    <div class="@(masterAreaEdit.OffsetColumnClass)"><!-- buttons offset -->
    <button class="btn btn-primary ew-btn" name="btn-action" id="btn-action" type="submit" form="fMasterAreaedit">@Html.Raw(Language.Phrase("SaveBtn"))</button>
@if (IsJsonResponse()) {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" data-bs-dismiss="modal">@Html.Raw(Language.Phrase("CancelBtn"))</button>
} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fMasterAreaedit" data-href="@AppPath(masterAreaEdit.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
}
    </div><!-- /buttons offset -->
@Html.Raw(masterAreaEdit.IsModal ? "</template>" : "</div>")<!-- /buttons .row -->
</form>
</main>
@masterAreaEdit.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MasterArea");
});
</script>
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
