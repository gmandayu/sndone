@Html.Raw(subaktivitasDataKapalEdit.IsModal ? "<template class=\"ew-modal-buttons\">" : "<div class=\"row ew-buttons\">")<!-- buttons .row -->
    <div class="@(subaktivitasDataKapalEdit.OffsetColumnClass)"><!-- buttons offset -->
