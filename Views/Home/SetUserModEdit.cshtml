<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("SetUserMOD");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    var parent_url = ew.PATH_BASE;
    $('#r_UserMOD').hide();
    (function () {
        const role = parseInt('@CurrentUserInfo("Rule")') || 0; // 0=Superadmin, 10=OH
        const isAllowed = (role === 0 || role === 10);
        console.log("Role = ", role)
        if (isAllowed) return;

        // ====== Blokir akses & tampilkan peringatan ======
        const $container = $(".content .container-fluid").first();
        const $form = $("form.ew-form").first();
        const listUrl = ew.PATH_BASE + "SetUserMODList";

        // Alert peringatan (Bootstrap)
        const $alert = $(`
          <div class="alert alert-warning d-flex align-items-start" role="alert" id="no-access-alert">
            <i class="fa-solid fa-triangle-exclamation me-2 mt-1"></i>
            <div>
              <div class="fw-bold">Tidak ada akses untuk menyunting Set User MOD.</div>
              <div class="small">
                Hanya pengguna dengan peran <strong>Superadmin</strong> (Rule 0) atau <strong>OH</strong> (Rule 10) yang dapat menyunting data di halaman ini.
                <br>Solusi: <em>Ganti Akun</em> atau <em>minta diberikan akses oleh OH</em>.
              </div>
              <div class="mt-2">
                <a href="${ew.PATH_BASE}logout" class="btn btn-outline-secondary btn-sm me-2">
                  <i class="fa-solid fa-right-from-bracket"></i> Ganti Akun
                </a>
                <a href="${listUrl}" class="btn btn-primary btn-sm">
                  <i class="fa-solid fa-list"></i> Kembali ke List
                </a>
              </div>
            </div>
          </div>
        `);

        // Sisipkan alert di atas form
        if ($container.length) $container.prepend($alert);
        else $("body").prepend($alert);

        // Nonaktifkan input & tombol di form
        if ($form.length) {
          // Blokir submit (klik, enter, dll.)
          $form.on("submit", function (e) { e.preventDefault(); return false; });

          // Disable semua kontrol
          $form.find("input, select, textarea, button").prop("disabled", true);

          // Re-enable tombol/link Cancel jika ada
          $form.find('a.btn-secondary, a.ew-btn, a.btn')
               .filter(function () {
                  const href = (this.getAttribute("href") || "").toLowerCase();
                  return href.includes("list") || href.includes("cancel");
               })
               .prop("disabled", false)
               .removeClass("disabled");
        }

        // Bersihkan tombol Add/Save lain yang mungkin muncul
        $(".ew-toolbar a.ew-add, .ew-grid-lower-panel a, button[name='btn-action'], button[name='btn-submit'], [name='btn-save'],.ew-btn[href*='update']").hide();

        // Tambahan UX: scroll ke atas supaya alert terlihat
        window.scrollTo({ top: 0, behavior: "smooth" });
    })();
    function autoFillLookupUserMod() {
        const lookupUserModId = $("#x_LookupUserMod");
        const userModId = $("#x_UserMOD");
        const plantId = $("#x_Plant");
        const plantIdVal = plantId.val();
        const userModVal = userModId.val();
        const lookupUserModIdVal = lookupUserModId.val();
        if (plantIdVal){
            $.ajax({
                url: parent_url + 'api/LookUpList/get-dropdown/user-plant?plantId=' + plantIdVal,
                method: 'GET',
                dataType: 'json',
                success: function (data) {
                    lookupUserModId.empty(); 
                    $.each(data, function (index, item) {
                        if (item.Value == userModVal){
                            lookupUserModId.append(`<option selected value="${item.Value}">${item.Label}</option>`);
                        } else {
                            lookupUserModId.append(`<option value="${item.Value}">${item.Label}</option>`);
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Gagal ambil data dropdown:", error);
                    lookupUserModId.empty();
                }
            });
        }
        const element = document.getElementById('datetimepicker_fSetUserMODedit_x_Tanggal');
        if (!element) return;
        const input = document.getElementById('x_Tanggal');
        const formatPattern = input?.dataset.formatPattern || 'yyyy/MM/dd HH:mm:ss';
        const options = {
            localization: {
                format: formatPattern
            },
            restrictions: {
                minDate: tempusDominus.DateTime.convert(new Date())
            },
            display: {
                components: {
                    calendar: true,
                    date: true,
                    month: true,
                    year: true,
                    hours: true,
                    minutes: true,
                    seconds: true
                }
            }
        };
        new tempusDominus.TempusDominus(element, options);
    }
    autoFillLookupUserMod();
});
</script>
