<template id="tpm_MWTOnlineedit">
<div id="ct_mwtOnlineEdit">@{
    string NoReferensi = mwtOnlineEdit.NoMWTOnline.CurrentValue?.ToString();
    int idPlant = Convert.ToInt32(mwtOnlineEdit.IdPlant.CurrentValue.ToString());
    List<Dictionary<string, object>> dataList = new List<Dictionary<string, object>>();
    string sqlData = "SELECT * FROM MWTOnlineDetail WHERE NoReferensi = @NoReferensi ORDER BY CreatedDate ASC;";
    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection()) {
        using (SqlCommand command = new SqlCommand(sqlData, sqlConnection)) {
            command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
            using (SqlDataReader rs = command.ExecuteReader()) {
                while (rs.Read()) {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++) {
                        row[rs.GetName(i)] = rs[i] != null? rs[i] : "";
                    }
                    dataList.Add(row);
                }
            }
        }
    }
    var flagOneMessages = dataList
        .Where(x => Convert.ToString(x["Flag"]) == "1")
        .ToList();
    Dictionary<string, object>? firstMessage = flagOneMessages.FirstOrDefault();
    var chatHistory = dataList.Skip(flagOneMessages.Count).ToList();
}
<style>
    .stepper { display: flex; counter-reset: step; flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 8px; }
