    function submitAktivitasDokumen() {
        event.preventDefault();
        let formData = new FormData();
        formData.append("IdAktivitas", idAktivitas);
        const originalStatus = document.querySelector("#el_Aktivitas_StatusAktivitas span").textContent;
        let keterangan = $("#InputKeterangan").val();
        if (!keterangan) {
            keterangan = "";
        }
        let catatanText = $("#catatanReverseStatusEditing").val();
        if (!catatanText) {
            catatanText = "";
        }
        formData.append("Keterangan", keterangan);
        formData.append("Catatan", catatanText);
        if (StatusAktivitas == "Completed" || StatusAktivitas == "Editing") {
            formData.append("StatusAktivitas", "Completed Edit");
        } else if (StatusAktivitas == "Completed Edit") {
            formData.append("StatusAktivitas", "Editing");
        } else {
            formData.append("StatusAktivitas", "Completed");
        }
        const isNonNominationReceivingLineClosedAndSealed = $("#InputIsNonNominationReceivingLineClosedAndSealed").is(":checked");
        const isNominationTankReceivingLineOpen = $("#InputIsNominationTankReceivingLineOpen").is(":checked");
        const isTankEmptyAndDry = $("#InputIsTankEmptyAndDry").is(":checked");
        const isDocumentationComplete = $("#InputIsDocumentationComplete").is(":checked");
        if (["306", "460"].includes(idTemplateAktivitas) && !isNominationTankReceivingLineOpen) {
            return ew.alert("Jalur penerimaan yang berhubungan dengan Tangki Nominasi BELUM TERBUKA.");
        }
        if (["306", "460"].includes(idTemplateAktivitas) && !isNonNominationReceivingLineClosedAndSealed) {
            return ew.alert("Jalur penerimaan yang TIDAK berhubungan dengan Tangki Nominasi BELUM TERTUTUP dan TERSEGEL.");
        }
        if (["429"].includes(idTemplateAktivitas)) {
            if (!isTankEmptyAndDry) return ew.alert(`Tangki mobil <strong>belum dalam kondisi kering</strong> dan <strong>masih terdapat sisa muatan</strong>.` );
            if (!isDocumentationComplete) return ew.alert(`Seluruh dokumen <strong>belum</strong> didokumentasikan dengan baik.`);
        }
        formData.append("IsNominationTankReceivingLineOpen", isNominationTankReceivingLineOpen);
        formData.append("IsNonNominationReceivingLineClosedAndSealed", isNonNominationReceivingLineClosedAndSealed);
        formData.append("IsTankEmptyAndDry", isTankEmptyAndDry);
        formData.append("IsDocumentationComplete", isDocumentationComplete);
        $.ajax({
            url: parent_url + `api/LookUpList/check_valid_status_aktivitas?idAktivitas=${idAktivitas}&originalStatus=${originalStatus}`,
            type: "GET",
            beforeSend: function () {
                showLoading();
            },
            success: function (response) {
                if (!response.IsValid) {
                    hideLoading();
                    ew.alert(response.Message ?? "Status aktivitas telah diubah oleh pengguna lain");
                    return;
                } else {
                    $.ajax({
                        url: parent_url + "api/LookUpList/UpdateStatusAktivitasByDocument",
                        type: "POST",
                        data: formData,
                        contentType: false,
                        processData: false,
                        success: function (rs) {
                            ew.alert(rs.message);
                            if (rs.success) {
                                setTimeout(function () {
                                    window.location = `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`;
                                }, 1000);
                            }
                        },
                        error: function (xhr, status, error) {
                            ew.alert("Error: " + xhr.responseText);
                        },
                        complete: function () {
                            hideLoading();
                        },
                    });
                }
            },
            error: function (xhr, status, error) {
                hideLoading();
                ew.alert("Gagal menyimpan data.");
                console.error("Form submit gagal:", error);
            },
        });
    }

    // --- log aktivitas start ---
