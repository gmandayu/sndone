<template id="tpm_SetPjsedit">
<div id="ct_setPjsEdit">@{
    int CurrentPositionId = Convert.ToInt32(setPjsEdit.PosisiAwal.CurrentValue);
    string CurrentPosition = "";
    string status = setPjsEdit.Status.CurrentValue.ToString();
    string idUserPjs = setPjsEdit.DibuatOleh.CurrentValue.ToString();
    string idUser = CurrentUserInfo("IdUser").ToString();
    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection()) {
        using (SqlCommand sqlCommand = sqlConnection.CreateCommand()) {
            sqlCommand.CommandType = CommandType.Text;
            sqlCommand.CommandText = "SELECT CONCAT(IdPosition, ' - ', NamaPosition) as Position FROM MasterPosition WHERE IdPosition = @CurrentPositionId";
            sqlCommand.Parameters.AddWithValue("@CurrentPositionId", CurrentPositionId);
            CurrentPosition = ConvertToString(sqlCommand.ExecuteScalar());
        }
    }
}
<style>
    .stepper {
        display: flex;
        counter-reset: step;
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 8px;
    }
    .stepper::-webkit-scrollbar {
        height: 6px; /* tipis */
    }
    .stepper::-webkit-scrollbar-thumb {
        background-color: #ccc;
        border-radius: 3px;
    }
    .step {
        width: 150px;
        text-align: center;
        position: relative;
    }
    .step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 20px;
        right: -50%;
        width: 100%;
        height: 4px;
        background-color: #ccc;
        z-index: 0;
    }
    .step.completed:not(:last-child)::after {
        background-color: #3c6dbd;
    }
    .step-icon {
        width: 36px;
        height: 36px;
        line-height: 36px;
        border-radius: 50%;
        background: #ccc;
        display: inline-block;
        z-index: 1;
        position: relative;
        color: white;
        font-weight: bold;
    }
    .step.active .step-icon {
        background: #3c6dbd;
    }
    .step-label {
        margin-top: 8px;
        font-size: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        color: #333;
    }
    .step-label {
        color: #3c6dbd !important;
        text-decoration: none;
        margin: 0;
        padding: 0;
    }
    .step-label-not-active {
        color: #CCCCCC !important;
    }
    .ew-buttons {
        display: none;
    }
    .view-page-table td {
        white-space: normal !important;
        word-wrap: break-word;
    }
    .view-page-table th {
        background-color: #006BB7;
    }
    .body-table {
        background-color: #fff;
    }
    .header-table {
        background-color: #006BB7 !important;
        color: #fff !important;
    }
    .view-page-table {
        table-layout: fixed;
    }
    .btn {
        white-space: nowrap;
    }
    .file-input-wrapper {
        border: 1px solid #ced4da;
        border-radius: .375rem;
        overflow: hidden;
        transition: border-color .15s, box-shadow .15s;
    }
    .file-input-wrapper:focus-within {
        border-color: #86b7fe;
        box-shadow: 0 0 0 .25rem rgba(13,110,253,.25);
    }
    .file-input-wrapper .btn {
        border-radius: 0;
    }
    .file-input-wrapper .form-control {
        border: none;
        box-shadow: none !important;
    }
    #el_SetPjs_OrganizationLevel,
    #el_SetPjs_Region,
    #el_SetPjs_Plant,
    #el_SetPjs_LookupPosition,
    #el_SetPjs_TanggalMulai,
    #el_SetPjs_TanggalSelesai,
    #el_SetPjs_Keterangan {
        width: 100%;
    }
    .status-approved {
        background-color: #baffc9 !important;
        color: #155724;
    }
    .status-requested {
        background-color: #a3e0f7 !important;
        color: #0c5460;
    }
    .status-canceled {
        background-color: #e2e3e5 !important;
        color: #41464b;
    }
    .ag-theme-quartz .ag-header {
        background-color: #006BB7 !important;
    }
    .ag-theme-quartz .ag-header-cell-label {
        color: #ffffff !important;
    }
    .ag-theme-quartz .ag-icon-filter {
        color: #ffffff !important;
    }
    .rotate-down {
        transform: rotate(90deg);
        transition: transform 0.3s ease;
    }
    .rotate-right {
        transform: rotate(0deg);
        transition: transform 0.3s ease;
    }
</style>
<form id="CustomFormPJS" autocomplete="off">
    <div class="row pb-3 border-bottom">
        <div class="col-2 fw-bold d-flex align-items-center">
            Nomor PJS
        </div>
        <div class="col-10 d-flex gap-3">
            @setPjsEdit.NomorPjs.CurrentValue
        </div>
    </div>
    <div class="row pb-3 border-bottom mb-0">
        <div class="col-2 fw-bold d-flex align-items-center">
            Nama
        </div>
        <div class="col-10 d-flex gap-3">
            @setPjsEdit.Nama.CurrentValue
        </div>
    </div>
    <div class="row border-bottom">
        <div class="col-2 fw-bold d-flex align-items-center py-3">
            Status PJS
        </div>
        @if (status.ToLower() == "approved") {
            <div class="col-10 py-3 fw-bold status-approved">
                @status
            </div>
        } else if (status.ToLower() == "requested") {
            <div class="col-10 py-3 fw-bold status-requested">
                @status
            </div>
        } else if (status.ToLower() == "rejected") {
            <div class="col-10 py-3 fw-bold bg-danger text-white">
                @status
            </div>
        } else {
            <div class="col-10 py-3 fw-bold status-canceled">
                @status
            </div>
        }
    </div>
    <div class="row pb-3 border-bottom">
        <div class="col-2 fw-bold d-flex align-items-center">
            Diperbaharui Oleh
        </div>
