@{
    // View
    View = this;

    // Check action result
    if (setUserModAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = setUserModAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(setUserModAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { SetUserMOD: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fSetUserMODadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fSetUserMODadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["Tanggal", [fields.Tanggal.visible && fields.Tanggal.required ? ew.Validators.required(fields.Tanggal.caption) : null, ew.Validators.datetime(fields.Tanggal.clientFormatPattern)], fields.Tanggal.isInvalid],
            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["LookupUserMod", [fields.LookupUserMod.visible && fields.LookupUserMod.required ? ew.Validators.required(fields.LookupUserMod.caption) : null], fields.LookupUserMod.isInvalid],
            ["UserMOD", [fields.UserMOD.visible && fields.UserMOD.required ? ew.Validators.required(fields.UserMOD.caption) : null], fields.UserMOD.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(setUserModAdd.LookupPlant.ToClientList(setUserModAdd)),
            "Plant": @Html.Raw(setUserModAdd.Plant.ToClientList(setUserModAdd)),
            "LookupUserMod": @Html.Raw(setUserModAdd.LookupUserMod.ToClientList(setUserModAdd)),
            "UserMOD": @Html.Raw(setUserModAdd.UserMOD.ToClientList(setUserModAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    $(document).on("change", "#x_Plant", function () {
        $("#x_UserMOD").val(null).trigger("change"); // kosongkan saat plant berubah
    });
    var parent_url = ew.PATH_BASE;
    $('#x_UserMOD').on('change', function() {
        const $select = $(this);
        const userModId = String($select.val() || '').trim();
        if (userModId) {
            if (typeof showLoading === 'function') showLoading();
            $.ajax({
                url: parent_url + 'api/LookUpList/CheckFaceEnrollment',
                type: 'GET',
                data: { idUser: userModId },
                success: function(faceRes) {
                    if (typeof hideLoading === 'function') hideLoading();
                    if (faceRes && faceRes.success) {
                        if (!faceRes.isEnrolled) {
                            if (confirm("User MOD yang dipilih belum mendaftarkan wajahnya. Apakah Anda ingin pergi ke halaman Pendaftaran Wajah sekarang?")) {
                                window.location.href = parent_url + 'VFaceEnrollmentList';
                            } else {
                                $select.val(null).trigger('change.select2');
                                ew.alert("Pilih User MOD lain yang wajahnya terdaftar di Face Enrollment.");
                            }
                        }
                    } else {
                        ew.alert((faceRes && faceRes.message) || "Gagal memeriksa status pendaftaran wajah.");
                        $select.val(null).trigger('change.select2'); 
                    }
                },
                error: function() {
                    if (typeof hideLoading === 'function') hideLoading();
                    ew.alert("Gagal memeriksa status pendaftaran wajah (jaringan/server).");
                    $select.val(null).trigger('change.select2'); 
                }
            });
        }
    });
    $('#btn-action').on('click', function (e) {
        e.preventDefault();
        const $btn = $(this);
        const idPlant = String($('#x_Plant').val() || '').trim();
        const tanggal = String($('#x_Tanggal').val() || '').trim();
        const userMod = String($('#x_UserMOD').val() || '').trim();
        if (!idPlant) {
            ew.alert("Plant tidak boleh kosong.");
            return;
        }
        if (!tanggal) {
            ew.alert("Tanggal tidak boleh kosong.");
            return;
        }
        if (!userMod) {
            ew.alert("User MOD wajib dipilih.");
            return;
        }
        $btn.prop('disabled', true);
        if (typeof showLoading === 'function') showLoading();
        $.ajax({
            url: parent_url + 'api/LookUpList/CheckFaceEnrollment',
            type: 'GET',
            data: { idUser: userMod },
            success: function(faceRes) {
                if (faceRes && faceRes.success) {
                    if (faceRes.isEnrolled) {
                        checkDuplicateMod(idPlant, tanggal);
                    } else {
                        if (typeof hideLoading === 'function') hideLoading();
                        ew.alert("User MOD yang dipilih belum mendaftarkan wajahnya. Silakan pilih User MOD lain atau daftarkan wajah user ini terlebih dahulu.");
                        $btn.prop('disabled', false); 
                    }
                } else {
                    if (typeof hideLoading === 'function') hideLoading();
                    ew.alert((faceRes && faceRes.message) || "Gagal memeriksa status pendaftaran wajah saat submit.");
                    $btn.prop('disabled', false);
                }
            },
            error: function() {
                if (typeof hideLoading === 'function') hideLoading();
                ew.alert("Gagal memeriksa status pendaftaran wajah (jaringan/server) saat submit.");
                $btn.prop('disabled', false);
            }
        });
    }); 
    function checkDuplicateMod(plantToCheck, dateToCheck) {
        $.ajax({
            url: parent_url + 'api/LookUpList/CheckPlantDateMod',
            type: 'GET',
            data: { idPlant: plantToCheck, tanggal: dateToCheck },
            success: function (modRes) {
                if (typeof hideLoading === 'function') hideLoading(); 
                if (!modRes || modRes.success !== true) {
                    ew.alert((modRes && modRes.message) || "Gagal melakukan pengecekan MOD.");
                    $btn.prop('disabled', false);
                    return;
                }
                if (modRes.exists === true) {
                    const plantLabel = (modRes.terminalName && modRes.terminalName.trim())
                        ? `${modRes.plant} - ${modRes.terminalName}`
                        : modRes.plant;
                    ew.alert(`Sudah ada MOD untuk Plant ${plantLabel} pada tanggal ${modRes.tanggal}. Silakan cek kembali.`);
                    $btn.prop('disabled', false); 
                } else {
                    $('#fSetUserMODadd').submit();
                }
            },
            error: function () {
                if (typeof hideLoading === 'function') hideLoading();
                ew.alert("Gagal melakukan pengecekan duplikasi MOD (jaringan/server).");
                $btn.prop('disabled', false);
            }
        });
    }
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_Plant').val(selectedValue).trigger('change');
        const lookupUserModId = $("#x_LookupUserMod");
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/user-plant?plantId=' + selectedValue,
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                lookupUserModId.empty(); 
                lookupUserModId.append('<option value="" selected>-- Pilih Plant --</option>');
                $.each(data, function (index, item) {
                    lookupUserModId.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                lookupUserModId.empty();
            }
        });
    });
    $('#x_LookupUserMod').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_UserMOD').val(selectedValue).trigger('change');
    });
});
</script>
