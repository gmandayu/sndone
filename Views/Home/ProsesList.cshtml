    //             }

    //             if (statusText === "Completed") {
    //                 foundCompleted = true; // Mark that "Completed" has been found
    //                 return; // Skip processing this row
    //             }

    //             if (foundCompleted && !processedNextRow) {
    //                 // Allow the first row after "Completed" to retain <a> tag
    //                 processedNextRow = true;
    //                 return;
    //             }

    //             // For all other rows, remove <a> tags
    //             var aktivitasCell = $(this).find('[data-name="Aktivitas2"]');
    //             var aktivitasText = aktivitasCell.text().trim();
    //             aktivitasCell.find('a').replaceWith(aktivitasText);
    //         });
    // });
    function GetIdReferensi() {
        $.ajax({
            url: parent_url + 'api/LookUpList/GetIdReferensi',
            type: 'GET',
            data: {
                NoReferensi: NoReferensi,
                Referensi: TipeProses
            },
            success: function (rs) {
                if (rs.success && rs.IdReferensi && rs.Referensi) {
                    let newHref = parent_url + `${rs.Referensi}Add/${rs.IdReferensi}?action=addproduct`;
                    $("#btn-copy-referensi").prop("disabled", false);
                    $("#btn-copy-referensi").click(function() {
                        window.location.href = newHref;
                    });
                }
            },
            error: function (xhr, status, error) {
                console.error("Error AJAX:", status, error);
            }
