<main class="edit">
<form name="fMasterDermagaedit" id="fMasterDermagaedit" class="@(masterDermagaEdit.FormClassName)" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
<script>
var currentTable = @Html.Raw(ConvertToJson(masterDermagaEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterDermaga: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fMasterDermagaedit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterDermagaedit")
        .setPageId("edit")

        // Add fields
        .setFields([

            ["IdDermaga", [fields.IdDermaga.visible && fields.IdDermaga.required ? ew.Validators.required(fields.IdDermaga.caption) : null], fields.IdDermaga.isInvalid],
            ["Region", [fields.Region.visible && fields.Region.required ? ew.Validators.required(fields.Region.caption) : null], fields.Region.isInvalid],
            ["Id_Plant", [fields.Id_Plant.visible && fields.Id_Plant.required ? ew.Validators.required(fields.Id_Plant.caption) : null], fields.Id_Plant.isInvalid],
            ["TBBM", [fields.TBBM.visible && fields.TBBM.required ? ew.Validators.required(fields.TBBM.caption) : null], fields.TBBM.isInvalid],
            ["Equipment_ID", [fields.Equipment_ID.visible && fields.Equipment_ID.required ? ew.Validators.required(fields.Equipment_ID.caption) : null], fields.Equipment_ID.isInvalid],
            ["Fungsi", [fields.Fungsi.visible && fields.Fungsi.required ? ew.Validators.required(fields.Fungsi.caption) : null], fields.Fungsi.isInvalid],
            ["Kapasitas_DWT", [fields.Kapasitas_DWT.visible && fields.Kapasitas_DWT.required ? ew.Validators.required(fields.Kapasitas_DWT.caption) : null], fields.Kapasitas_DWT.isInvalid],
            ["Kategori_Kapasitas", [fields.Kategori_Kapasitas.visible && fields.Kategori_Kapasitas.required ? ew.Validators.required(fields.Kategori_Kapasitas.caption) : null], fields.Kategori_Kapasitas.isInvalid],
            ["Jenis_Sartam", [fields.Jenis_Sartam.visible && fields.Jenis_Sartam.required ? ew.Validators.required(fields.Jenis_Sartam.caption) : null], fields.Jenis_Sartam.isInvalid],
            ["Type_Sartam", [fields.Type_Sartam.visible && fields.Type_Sartam.required ? ew.Validators.required(fields.Type_Sartam.caption) : null], fields.Type_Sartam.isInvalid],
            ["Tahun_Pembuatan", [fields.Tahun_Pembuatan.visible && fields.Tahun_Pembuatan.required ? ew.Validators.required(fields.Tahun_Pembuatan.caption) : null], fields.Tahun_Pembuatan.isInvalid],
            ["Kategori_Port", [fields.Kategori_Port.visible && fields.Kategori_Port.required ? ew.Validators.required(fields.Kategori_Port.caption) : null], fields.Kategori_Port.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "Id_Plant": @Html.Raw(masterDermagaEdit.Id_Plant.ToClientList(masterDermagaEdit)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    $('#fMasterDermagaedit').on('submit', function (e) {
        e.preventDefault();
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
});
</script>
