<span id="el_MasterPosition_IdPosition">
<input type="@(masterPositionEdit.IdPosition.InputTextType)" name="x_IdPosition" id="x_IdPosition" data-table="MasterPosition" data-field="x_IdPosition" value="@Html.Raw(masterPositionEdit.IdPosition.EditValue)" size="30" placeholder="@Html.Raw(HtmlEncode(masterPositionEdit.IdPosition.PlaceHolder))" data-format-pattern="@(masterPositionEdit.IdPosition.FormatPattern)"@Html.Raw(masterPositionEdit.IdPosition.EditAttributes) aria-describedby="x_IdPosition_help">
@Html.Raw(masterPositionEdit.IdPosition.GetCustomMessage)
<div class="invalid-feedback">@Html.Raw(masterPositionEdit.IdPosition.GetErrorMessage())</div>
<input type="hidden" data-table="MasterPosition" data-field="x_IdPosition" data-hidden="1" data-old name="o_IdPosition" id="o_IdPosition" value="@Html.Raw(HtmlEncode(masterPositionEdit.IdPosition.OldValue ?? masterPositionEdit.IdPosition.CurrentValue))">
</span>
</div></div>
    </div>
} @* masterPositionEdit.IdPosition.Visible (end) *@
