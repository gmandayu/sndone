        <div class="@(subaktivitasDataKapalEdit.RightColumnClass)"><div @Html.Raw(subaktivitasDataKapalEdit.nominasi.CellAttributes)>
<span id="el_SubaktivitasDataKapal_nominasi">
<input type="@(subaktivitasDataKapalEdit.nominasi.InputTextType)" name="x_nominasi" id="x_nominasi" data-table="SubaktivitasDataKapal" data-field="x_nominasi" value="@Html.Raw(subaktivitasDataKapalEdit.nominasi.EditValue)" size="30" maxlength="255" placeholder="@Html.Raw(HtmlEncode(subaktivitasDataKapalEdit.nominasi.PlaceHolder))" data-format-pattern="@(subaktivitasDataKapalEdit.nominasi.FormatPattern)"@Html.Raw(subaktivitasDataKapalEdit.nominasi.EditAttributes) aria-describedby="x_nominasi_help">
