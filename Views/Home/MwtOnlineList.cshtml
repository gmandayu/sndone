@if (!mwtOnlineList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MWTOnline");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    var parent_url = ew.PATH_BASE;
    let index = $('th[data-name="edit"]').index();
    $('th[data-name="edit"]').hide();
    $('td:nth-child(' + (index + 1) + ')').hide();
    $('th[data-name="File"], td[data-name="File"]').css('display', 'none');
    var steps = [
        { number: 1, label: "MWT Online", url: '', icon: "fa-comment-dots" },
    ];
    var currentStep = 1;
    $("<style>")
        .prop("type", "text/css")
        .html(`
            .stepper {
                display: flex;
                counter-reset: step;
            }
            .step {
                width: 150px;
                text-align: center;
                position: relative;
            }
            .step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 20px;
                right: -50%;
                width: 100%;
                height: 4px;
                background-color: #ccc;
                z-index: 0;
            }
            .step.completed:not(:last-child)::after {
                background-color: #3c6dbd;
            }
            .step-icon {
                width: 36px;
                height: 36px;
                line-height: 36px;
                border-radius: 50%;
                background: #ccc;
                display: inline-block;
                z-index: 1;
                position: relative;
                color: white;
                font-weight: bold;
            }
            .step.active .step-icon {
                background: #3c6dbd;
            }
            .step-label {
                margin-top: 8px;
                font-size: 14px;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 6px;
                color: #333;
            }
            .step-label {
                color: #3c6dbd !important;
                text-decoration: none;
                margin: 0;
                padding: 0;
            }
            .step-label-not-active {
                color: #CCCCCC !important;
            }
        `)
        .appendTo("head");
    var $stepperWrapper = $('<div id="bread-crumb-nav" class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    var $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        var isActive = step.number === currentStep;
        var isCompleted = step.number < currentStep;
        var stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        var icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #3c6dbd;">${step.number}</div>`;
            labelContent = `<div><a href="${step.url}" class="step-label"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    if ($('#bread-crumb-nav').length == 0) {
        $(".content-header .container-fluid .row").append($stepperWrapper);
    }
    $(document).ready(function() {
        $.post(parent_url + "api/LookUpList/CheckAndSetBacklog", function(res) {
            if (res.success) {
                console.log("Backlog check completed.");
            }
        });
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        var parrentButton = $('button.btn-primary[name="btn-submit"]');
        var addButton = $(`
            <button class="btn btn-success ms-2" id="btn-add-mwt">
                <i class="fas fa-plus me-1"></i> Add New
            </button>
        `);
        $(`a.btn.btn-default.ew-add-edit.ew-add[href="${parent_url}MwtOnlineAdd"]`).remove();
        parrentButton.parent().append(addButton);
        addButton.on('click', function (e) {
            e.preventDefault();
            window.location.href = parent_url+'MwtOnlineAdd';
        });
    }); 

    // $('#tbl_MWTOnlinelist tbody tr').each(function() {
    //     var $row = $(this);
    //     var $fileCell = $row.find('td[data-name="File"]');
    //     var fileName = $fileCell.text().trim();
    //     var $downloadCell = $row.find('td[data-name="DownloadFile"] .el_MWTOnline_DownloadFile');

    //     var editLink = $row.find('a.ew-row-link.ew-edit').attr('href');
    //     var viewLink = $row.find('a.ew-row-link.ew-view').attr('href');
    //     var urlWithId = editLink || viewLink;
    //     var id = null;

    //     if (urlWithId) {
    //         var match = urlWithId.match(/\/(\d+)$/) || urlWithId.match(/id=(\d+)/);
    //         if (match && match[1]) {
    //             id = match[1];
    //         }
    //     }

    //     if (fileName && id) {
    //         var downloadBtn = `
    //             <button type="button" 
    //                     class="btn btn-sm btn-info text-white btn-download-mwt" 
    //                     data-id="${id}"
    //                     data-filename="${fileName}"
    //                     title="Download ${fileName}">
    //                 <i class="fas fa-download me-1"></i> Download
    //             </button>`;
    //         $downloadCell.html(downloadBtn);
    //     } else {
    //         $downloadCell.html('<span class="badge bg-secondary">Not Uploaded</span>');
    //     }
    // });
    $(document).on('click', '.btn-download-mwt', function(e) {
        e.preventDefault();
        var $btn = $(this);
        var id = $btn.data('id');
        var originalContent = $btn.html();
        if (!id) {
            ew.alert("ID file tidak ditemukan.");
            return;
        }
        $btn.html('<i class="fas fa-spinner fa-spin me-2"></i> Downloading...');
        $btn.prop('disabled', true);
        $.ajax({
            url: parent_url + "api/LookUpList/DownloadMwtMainFile",
            type: "GET",
            data: { id: id },
            xhrFields: {
                responseType: 'blob' 
            },
            success: function(blob, status, xhr) {
                var disposition = xhr.getResponseHeader('Content-Disposition');
                if (disposition && disposition.indexOf('attachment') !== -1) {
                    var filenameRegex = /filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/;
                    var matches = filenameRegex.exec(disposition);
                    if (matches != null && matches[1]) { 
                        fileName = matches[1].replace(/['"]/g, '');
                    }
                }
                var link = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(link);
            },
            error: function(xhr, status, error) {
                console.error("Download error:", xhr);
                var msg = "Gagal mengunduh file.";
                if(xhr.status === 404) msg = "File tidak ditemukan di server.";
                ew.alert(msg);
            },
            complete: function() {
                $btn.html(originalContent);
                $btn.prop('disabled', false);
            }
        });
    });
});
</script>
}
