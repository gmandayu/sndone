</script>
<script>
loadjs.ready("head", function() {
    // Client script
    //client script > table specific > add/copy page > client script
    const parent_url = ew.PATH_BASE;
    $("#TandaTangan-Name").on("click", function (e) {
        $("#TandaTangan").trigger("click");
    });
    $("#PintuUtamaIn-Name").on("click", function (e) {
        $("#PintuUtamaIn").trigger("click");
    });
    $("#PintuUtamaIn").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#PintuUtamaIn-Name").val(file.name);
    });
    $("#TandaTangan").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#TandaTangan-Name").val(file.name);
    });
    $("#btnSignature").off("click").on("click", () => $("#signatureModal").modal("show"));
    $("#signatureModal").off("shown.bs.modal").on("shown.bs.modal", () => initSignaturePad());
    $(document).on("click", "#btn-cancel-custom", function(){
        window.location.href = `${parent_url}BukuTamuList`;
    });
    $(document).on("click", "#btn-submit-custom", function(){
        const Plant = $('#x_LookupPlant').val();
        const Tanggal = $('#x_Tanggal').val();
        const Nama = $('#x_Nama').val();
        const AsalPerusahaan = $('#x_AsalPerusahaan').val();
        const Jabatan = $('#x_Jabatan').val();
        const FungsiYgDikunjungi = $('#x_FungsiygDikunjungi').val();
        const MaksudKunjungan = $('#x_MaksudKunjungan').val();
        const TandaPengenal = $('#x_TandaPengenal').val();
        const PintuId = $('#x_PintuUtamaId').val();
        const PintuUtamaInTanggal = $('#x_PintuUtamaInTanggal').val();
        const Keterangan = $('#x_Keterangan').val();
        if (!Plant) return ew.alert("Plant tidak boleh kosong!");
        if (!Tanggal) return ew.alert("Tanggal tidak boleh kosong!");
        if (!Nama) return ew.alert("Nama tidak boleh kosong!");
        if (!AsalPerusahaan) return ew.alert("Asal Perusahaan tidak boleh kosong!");
        if (!Jabatan) return ew.alert("Jabatan tidak boleh kosong!");
        if (!FungsiYgDikunjungi) return ew.alert("Fungsi yang dikunjungi tidak boleh kosong!");
        if (!MaksudKunjungan) return ew.alert("Maksud kunjungan tidak boleh kosong!");
        if (!TandaPengenal) return ew.alert("Tanda pengenal tidak boleh kosong!");
        if (!PintuId) return ew.alert("Id Pintu Utama tidak boleh kosong!");
        if (FungsiYgDikunjungi === '13' && Keterangan.trim() === '') {
            ew.alert("Keterangan wajib diisi jika memilih 'Others' pada Fungsi yang Dikunjungi.");
            return; // Stop the submission
        }
        let formData = new FormData();
        formData.append("Plant", Plant);
        formData.append("Tanggal", Tanggal);
        formData.append("Nama", Nama);
        formData.append("AsalPerusahaan", AsalPerusahaan);
        formData.append("Jabatan", Jabatan);
        formData.append("FungsiYgDikunjungi", FungsiYgDikunjungi);
        formData.append("MaksudKunjungan", MaksudKunjungan);
        formData.append("TandaPengenal", TandaPengenal);
        formData.append("PintuId", PintuId);
        formData.append("PintuUtamaInTanggal", PintuUtamaInTanggal);
        formData.append("Keterangan", Keterangan);
        const file = $("#PintuUtamaIn")[0].files[0];
        formData.append("File", file);
        const dataURL = $("#hiddenSignature").val();
        if (dataURL) {
            const file = dataURLtoFile(dataURL, "ttd.png");
            formData.append("TandaTangan", file);
        } else {
            ew.alert('Tanda tangan tidak boleh kosong!');
            return false;
        }
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/AddBukuTamu",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        window.location.href = `${parent_url}BukuTamuList`;
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Upload gagal: " + xhr.responseText);
            }
        });
    });
    function initSignaturePad() {
        const canvas = document.getElementById("signaturePad");
        if (!canvas) return;

        // prevent double-binding by cloning
        canvas.replaceWith(canvas.cloneNode(true));
        const c = document.getElementById("signaturePad");
        const ctx = c.getContext("2d");
        const $preview = $("#signaturePreview");
        c.style.touchAction = "none";
        function style() {
            ctx.lineWidth = 2;
            ctx.lineCap = "round";
            ctx.strokeStyle = "#000";
        }
        function resize() {
            const r = window.devicePixelRatio || 1;
            const w = c.clientWidth || c.offsetWidth || 600;
            const h = c.clientHeight || 200;
            c.width = Math.max(1, w * r);
            c.height = Math.max(1, h * r);
            ctx.setTransform(1, 0, 0, 1, 0, 0);
            ctx.scale(r, r);
            style();
            // refresh preview after resize
            if ($preview.length) $preview.attr("src", c.toDataURL("image/png"));
        }
        resize();
        function updatePreview() {
            if ($preview.length) $preview.attr("src", c.toDataURL("image/png"));
        }
        let drawing = false;
        function pos(e) {
            const r = c.getBoundingClientRect();
            return {
                x: e.clientX - r.left,
                y: e.clientY - r.top
            };
        }
        function start(e) {
            e.preventDefault();
            drawing = true;
            const p = pos(e);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
        }
        function move(e) {
            if (!drawing) return;
            e.preventDefault();
            const p = pos(e);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
            updatePreview();
        }
        function end() {
            drawing = false;
            updatePreview();
        }
        c.addEventListener("pointerdown", start, {
            passive: false
        });
        c.addEventListener("pointermove", move, {
            passive: false
        });
        document.addEventListener("pointerup", end, {
            passive: false
        });
        $("#clearSignature").off("click").on("click", () => {
            ctx.clearRect(0, 0, c.width, c.height);
            updatePreview();
        });
        $("#saveSignature").off("click").on("click", () => {
            const dataURL = c.toDataURL("image/png");
            $('#TandaTangan-Name').val('ttd.png');
            $("#hiddenSignature").val(dataURL);
            $("#signatureModal").modal("hide");
        });
    }
    function dataURLtoFile(dataURL, filename) {
        const arr = dataURL.split(',');
        const mime = arr[0].match(/:(.*?);/)[1];
        const bstr = atob(arr[1]);
        let n = bstr.length;
        const u8arr = new Uint8Array(n);
        while (n--) {
            u8arr[n] = bstr.charCodeAt(n);
        }
        return new File([u8arr], filename, { type: mime });
    }
    const $fungsiSelect = $("#x_FungsiygDikunjungi");
    const $keteranganLabelDiv = $('#x_Keterangan').closest('.row').find('.col-2.fw-bold');
    function toggleKeteranganFungsiMandatory() {
        const isOthersSelected = $fungsiSelect.val() === '13';
        const $asterisk = $keteranganLabelDiv.find("span.keterangan-fungsi-required");
        if (isOthersSelected) {
            if ($asterisk.length === 0) {
                $keteranganLabelDiv.append('<span class="text-danger keterangan-fungsi-required ms-1">*</span>');
            }
        } else {
            $asterisk.remove();
        }
    }
    $fungsiSelect.on("change", toggleKeteranganFungsiMandatory);
    toggleKeteranganFungsiMandatory();
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_Plant').val(selectedValue).trigger('change');
    });
});
</script>
