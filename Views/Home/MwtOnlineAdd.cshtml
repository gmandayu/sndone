@{
    // View
    View = this;

    // Check action result
    if (mwtOnlineAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = mwtOnlineAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(mwtOnlineAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MWTOnline: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fMWTOnlineadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMWTOnlineadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["LinkRedirect", [fields.LinkRedirect.visible && fields.LinkRedirect.required ? ew.Validators.required(fields.LinkRedirect.caption) : null], fields.LinkRedirect.isInvalid],
            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["TaskList", [fields.TaskList.visible && fields.TaskList.required ? ew.Validators.required(fields.TaskList.caption) : null], fields.TaskList.isInvalid],
            ["KeteranganFile", [fields.KeteranganFile.visible && fields.KeteranganFile.required ? ew.Validators.required(fields.KeteranganFile.caption) : null], fields.KeteranganFile.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(mwtOnlineAdd.LookupPlant.ToClientList(mwtOnlineAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    const parent_url = ew.PATH_BASE;
    $("#File-Name").on("click", function (e) {
        $("#File").trigger("click");
    });
    $("#File").on("change", function(e) {
        const file = $(this)[0].files[0];
        $("#File-Name").val(file.name);
    });
    $(document).on("click", "#btn-cancel-custom", function(){
        window.location.href = `${parent_url}MWTOnlineList`;
    });

    // ===========
    let selectedFiles = []; // { id, file }
    const bytesToSize = (bytes) => {
        if (bytes === 0) return "0 B";
        const sizes = ["B", "KB", "MB", "GB"];
        const i = Math.floor(Math.log(bytes) / Math.log(1024));
        return (bytes / Math.pow(1024, i)).toFixed(1) + " " + sizes[i];
    };
    const renderFileList = () => {
        const $table = $("#file-list-table");
        const $tbody = $table.find("tbody");
        $tbody.empty();
        if (!selectedFiles.length) {
            $table.hide();
            $("#File-Name").val("Add File");
            $('#keterangan-file').hide();
            return;
        }
        selectedFiles.forEach((item) => {
            const f = item.file;
            const row = `
                <tr data-id="${item.id}">
                    <td title="${f.name}">${f.name}</td>
                    <td>${bytesToSize(f.size)}</td>
                    <td>${f.type || "-"}</td>
                    <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-file">
                            <i class="fa-solid fa-trash-can me-1"></i> Remove
                        </button>
                    </td>
                </tr>`;
            $tbody.append(row);
        });
        $table.show();
        $('#keterangan-file').show();
        if (selectedFiles.length === 1) {
            $("#File-Name").val(selectedFiles[0].file.name);
        } else {
            $("#File-Name").val(selectedFiles.length + " files selected");
        }
    };
    $("#File").on("change", function () {
        const files = this.files;
        if (!files || !files.length) return;
        Array.from(files).forEach(f => {
            if (f.size > 20 * 1024 * 1024) {
                ew.alert("File `" + f.name + "` is larger than 20 MB and will be skipped.");
                return;
            }
            selectedFiles.push({
                id: crypto.randomUUID ? crypto.randomUUID() : (Date.now() + "_" + Math.random()),
                file: f
            });
        });
        $(this).val("");
        renderFileList();
    });

        // remove single file from list
    $(document).on("click", ".btn-remove-file", function () {
        const rowId = $(this).closest("tr").data("id");
        selectedFiles = selectedFiles.filter(x => x.id !== rowId);
        renderFileList();
    });
    $(document).on("click", "#btn-submit-custom", function(){
        const Plant = $('#x_LookupPlant').val();
        const Deskripsi = $('#x_TaskList').val().trim();
        const DeskripsiFile = $('#x_KeteranganFile').val().trim();
        if (!Plant) return ew.alert("Plant tidak boleh kosong!");
        let formData = new FormData();
        formData.append("Plant", Plant);
        formData.append("Deskripsi", Deskripsi);
        formData.append("DeskripsiFile", DeskripsiFile);
        selectedFiles.forEach((item, idx) => {
            formData.append(`Files`, item.file);
        });
        showLoading();
        $.ajax({
            url: parent_url + "api/LookUpList/v2/AddMWTOnline",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function(rs) {
                hideLoading();
                if (rs.success) {
                    ew.alert(rs.message);
                    setTimeout(function() {
                        if (rs.id) {
                            window.location.href = `${parent_url}MwtOnlineEdit/${rs.id}`;
                        } else {
                            window.location.href = `${parent_url}MWTOnlineList`;
                        }
                    }, 2000);
                } else {
                    ew.alert(rs.message);
                }
            },
            error: function(xhr) {
                hideLoading();
                ew.alert("Gagal menambah data: " + xhr.responseText);
            }
        });
    });
});
</script>
