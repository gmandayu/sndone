        :root {
            --ts-border-radius: 0.5rem;
            --ts-border-color: #d1d5db;
            --ts-control-min-height: calc(1.5em + 0.75rem + 2px);
            --ts-dropdown-border-color: #e2e8f0;
            --ts-dropdown-box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
        .ts-control {
            font-weight: 500;
        }
        .ts-dropdown {
            font-weight: 500;
        }
        .ts-dropdown .active {
            background-color: #667eea;
            color: white;
        }
        .ts-wrapper .ts-control .remove {
            border-left-color: #4a5568;
        }
        
        .icon-total { color: #4299e1; } 
        .icon-notok { color: #ef4444; }

        .badge-total { background-color: #4299e1; color: #fff; } 
        .badge-notok { background-color: #ef4444; color: #fff; }  
        
    </style>
</head>
<body>

    <div class="py-2">
    <div class="text-center mb-4">
            <h1><b>Welcome to S&amp;D One</b></h1>
            <!-- Date Filter Section -->
            <div class="filter-section d-flex flex-column mb-4 gap-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md">
                        <label for="regionFilter" class="form-label">Region</label>
                        <select id="regionFilter" placeholder="Pilih region..."></select>
                    </div>
                    <div class="col-md">
                        <label for="plantFilter" class="form-label">Plant</label>
                        <select id="plantFilter" placeholder="Pilih plant..."></select>
                    </div>
                    <div class="col-md">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="text" class="form-control" id="startDate" placeholder="Select start date...">
                    </div>
                    <div class="col-md">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="text" class="form-control" id="endDate" placeholder="Select end date...">
                    </div>
                    
                </div>
                <div class="row g-3 align-items-end justify-content-end">
                    <div class="col-md-auto d-grid">
                        <button class="btn btn-primary" id="filterBtn"><i class="bi bi-funnel-fill"></i> Filter</button>
                    </div>
                    <div class="col-md-auto d-grid">
                        <button class="btn btn-primary-hehe" id="exportBtn"><i class="bi bi-file-earmark-excel-fill"></i> Export</button>
                    </div>
                    <div class="col-md-auto d-grid">
                        <button class="btn btn-outline-secondary" id="resetBtn"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <!-- Card Template -->
            <script id="card-template" type="text/template">
                <div class="col-lg-4 col-md-6">
                    <div class="card status-card">
                        <div class="card-header">
                            {{name}}
                        </div>
                        <div class="card-body">
                            <div class="total-section">
                                <div class="total-label">Total</div>
                                <div class="total-value">{{total}}</div>
                            </div>
                            <div class="status-list">
                                <div class="status-item">
                                    <span class="status-label"><i class="bi bi-hourglass-split icon-waiting"></i> Waiting</span>
                                    <span class="badge rounded-pill badge-waiting">{{waiting}}</span>
                                </div>
                                <div class="status-item">
                                    <span class="status-label"><i class="bi bi-gear-fill icon-processing"></i> In Progress</span>
                                    <span class="badge rounded-pill badge-processing">{{processing}}</span>
                                </div>
                                <div class="status-item">
                                    <span class="status-label"><i class="bi bi-check-circle-fill icon-complete"></i> Complete</span>
                                    <span class="badge rounded-pill badge-complete">{{complete}}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </script>
        </div>
        <div id="special-card-container" class="row">
            <!-- Special Card Template -->
            <script id="special-card-template" type="text/template">
                <div class="col-12">
                    <div class="special-card">
                        <div class="special-card-header">{{title}}</div>
                        <div class="row row-cols-1">
                            <div class="col data-column" id="sales-column">
                                <div class="column-title">Sales</div>
                            </div>
                            <div class="col data-column" id="konsinyasi-column">
                                <div class="column-title">Konsinyasi</div>
                            </div>
                        </div>
                    </div>
                </div>
            </script>
        </div>
    </div>
</div>
</body>
</html>

    <!-- Bootstrap 5 JS Bundle with Popper -->
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <!-- Tom Select JS -->
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script>
    window._welcomePageConfig = {
        dashboardData: @Html.Raw(Json.Serialize(result ?? new List<object>())),
        penyaluranProcessSales: @Html.Raw(Json.Serialize(penyaluranProcessSalesList ?? new List<object>())),
        penyaluranProcessKonsinyasi: @Html.Raw(Json.Serialize(penyaluranProcessKonsinyasiList ?? new List<object>())),
        regionListRaw: @Html.Raw(Json.Serialize(regions ?? new List<object>())),
        plantListRaw: @Html.Raw(Json.Serialize(plants ?? new List<object>())),
        currentUserLevel: @Html.Raw(Json.Serialize(userLevel))
    };
    </script>
    <script src="~/js/WelcomePage.js"></script>

@Html.Raw(GetDebugMessage())
