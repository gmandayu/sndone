<script>
var currentTable = @Html.Raw(ConvertToJson(setUserModEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { SetUserMOD: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fSetUserMODedit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fSetUserMODedit")
        .setPageId("edit")

        // Add fields
        .setFields([

            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["LookupUserMod", [fields.LookupUserMod.visible && fields.LookupUserMod.required ? ew.Validators.required(fields.LookupUserMod.caption) : null], fields.LookupUserMod.isInvalid],
            ["UserMOD", [fields.UserMOD.visible && fields.UserMOD.required ? ew.Validators.required(fields.UserMOD.caption) : null], fields.UserMOD.isInvalid],
            ["userInput", [fields.userInput.visible && fields.userInput.required ? ew.Validators.required(fields.userInput.caption) : null], fields.userInput.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupUserMod": @Html.Raw(setUserModEdit.LookupUserMod.ToClientList(setUserModEdit)),
            "UserMOD": @Html.Raw(setUserModEdit.UserMOD.ToClientList(setUserModEdit)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    // Write your client script here, no need to add script tags.
    var parent_url = ew.PATH_BASE;
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_Plant').val(selectedValue).trigger('change');
        const lookupUserModId = $("#x_LookupUserMod");
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/user-plant?plantId=' + selectedValue,
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                lookupUserModId.empty(); 
                lookupUserModId.append('<option value="" selected>-- Pilih Plant --</option>');
                $.each(data, function (index, item) {
                    lookupUserModId.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                lookupUserModId.empty();
            }
        });
    });
    $('#x_LookupUserMod').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_UserMOD').val(selectedValue).trigger('change');
    });
});
</script>
