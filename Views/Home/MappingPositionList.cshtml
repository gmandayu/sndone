@if (!mappingPositionList.IsExport()) {
<div class="card-footer ew-grid-lower-panel">
@if (!mappingPositionList.IsGridAdd && !(mappingPositionList.IsGridEdit && mappingPositionList.ModalGridEdit) && !mappingPositionList.IsMultiEdit) {
@Html.Raw(mappingPositionList.Pager.Render())
}
<div class="ew-list-other-options">
@mappingPositionList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@mappingPositionList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @mappingPositionList.FooterOptions.RenderBody()
</div>
</main>
@mappingPositionList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
@ElapsedTime()
@if (!mappingPositionList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("MappingPosition");
});
</script>
<script>
loadjs.ready("load", function() {
    // Write your table-specific startup script here
    // document.write("page loaded");
});
</script>
}
