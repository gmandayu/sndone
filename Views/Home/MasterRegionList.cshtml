@masterRegionList.ShowPageHeader()
@masterRegionList.ShowMessages()
<main class="list @(masterRegionList.TotalRecords == 0 && !masterRegionList.IsAdd ? " ew-no-record" : "")">
<div id="ew-header-options">
    @masterRegionList.HeaderOptions.RenderBody()
</div>
<div id="ew-list">
@if (masterRegionList.TotalRecords > 0 || !Empty(masterRegionList.CurrentAction)) {
