<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("RencanaPenyaluran");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Startup script
    var parent_url = ew.PATH_BASE;$('#r_NomorRencanaPenyaluran').hide();
    $('#r_LookupJenisPlant').hide();
    $('#r_TipeProdukSTS').hide();
    $('#r_IdPlant').hide();
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty();
                $.each(data, function (index, item) {
                    ddl.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
                if (Array.isArray(data) && data.length > 0) {
                    ddl.val(data[0].Value).trigger('change');
                }
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
    });

    // Guard dependent select openings to ensure Plant set
    const ensurePlantBeforeOpen = function(e) {
        const plantVal = $('#x_IdPlant').val();
        if (!plantVal) {
            const lpVal = $('#x_LookupPlant').val();
            const lpText = $('#x_LookupPlant').find('option:selected').text();
            if (lpVal) {
                $('#x_IdPlant').val(lpVal).trigger('change');
                $('#sv_x_IdPlant').val(lpText || '');
            } else {
                ew.alert('Silakan pilih Plant terlebih dahulu');
                e.preventDefault();
            }
        }
    };
    $('#x_IdModa').on('select2:opening', ensurePlantBeforeOpen);
    $('#x_TipePenyaluran').on('select2:opening', ensurePlantBeforeOpen);
    $('#x_KategoriPenyaluran').on('select2:opening', ensurePlantBeforeOpen);
    $("#x_IdPlant").prop("readonly", true);
});
</script>
