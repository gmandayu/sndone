<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    const parentURL = ew.PATH_BASE;
    const showMessage = m => (ew?.alert ? ew.alert(m) : alert(m));
    const showLoadingSafe = () => (typeof showLoading === 'function' ? showLoading() : null);
    const hideLoadingSafe = () => (typeof hideLoading === 'function' ? hideLoading() : null);
    const $plant = $('#x_idPlant');
    const $fileInput = $('#cstm_x_UploadHasil');
    const $fileLabel = $('#cstm_x_UploadHasil-Name');
    const $rowWrap = $('#row-table');
    const $tableBody = $('#cstm_x_UploadHasil-Table tbody');
    let files = [];
    const escapeHtml = s => String(s).replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
    function setLabel() {
        const n = files.length;
        $fileLabel.val(n === 0 ? 'Add Files' : `${n} File${n > 1 ? 's' : ''} Selected`);
    }
    function renderFileTable() {
        if (!$rowWrap.length || !$tableBody.length) return;
        setLabel();
        $tableBody.empty();
        if (files.length === 0) {
            $rowWrap.hide();
            return;
        }
        $rowWrap.show();
        files.forEach((file, i) => {
            const sizeKB = (file.size / 1024).toFixed(2);
            $tableBody.append(`
            <tr>
                <td class="text-center">${i + 1}</td>
                <td>${escapeHtml(file.name)} <small class="text-muted">(${sizeKB} KB)</small></td>
                <td class="text-center">
                    <button class="btn btn-sm text-danger btn-delete" type="button" data-index="${i}">
                    <i class="fa-solid fa-times"></i>
                    </button>
                </td>
                </tr>
            `);
        });
    }
    function addFiles(newFiles) {
        newFiles.forEach(f => {
            const key = `${f.name}|${f.size}|${f.lastModified}`;
            const exists = files.some(x => `${x.name}|${x.size}|${x.lastModified}` === key);
            if (!exists) files.push(f);
        });
    }
    $fileLabel.on('click', () => $fileInput.trigger('click'));
    $fileInput.on('change', function (e) {
        const picked = Array.from(e.target.files || []);
        if (!picked.length) return;
        addFiles(picked);
        $(this).val('');
        renderFileTable();
    });
    $rowWrap.on('click', '.btn-delete', function () {
        const idx = Number($(this).data('index'));
        if (!Number.isFinite(idx)) return;
        files.splice(idx, 1);
        renderFileTable();
    });
    function loadPlantDropdown() {
        $plant.empty().append('<option value="">Please Select</option>');
        $.ajax({
            url: `${parentURL}api/LookUpList/get-dropdown/plant`,
            method: 'GET',
            dataType: 'json',
            success: res => {
                (res || []).forEach(r => $plant.append(new Option(r.Label, r.Value)));
                if (res && res.length > 0) $plant.val(res[0].Value).trigger('change');
            },
            error: (_, __, err) => {
                console.error(err);
                showMessage(err || 'Failed to load plant dropdown');
            },
        });
    }
    $('#btn-submit-custom').on('click', function (e) {
        e.preventDefault();
        const requiredFields = ['idPlant', 'Tanggal', 'Produk'];
        for (const field of requiredFields) {
            const val = $(`#x_${field}`).val();
            if (!val) {
                showMessage(`${field} is required`);
                return;
            }
        }
        const formData = new FormData();
        requiredFields.forEach(field => formData.append(field, $(`#x_${field}`).val()));
        files.forEach((f) => formData.append('files', f));
        showLoadingSafe();
        $.ajax({
            url: `${parentURL}api/qq/psl-add`,
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: res => {
                hideLoadingSafe();
                if (!res?.success) {
                    showMessage(res?.message || 'An error occurred while adding record');
                    return;
                }
                showMessage(res?.message || 'Record added successfully!');
                window.location.href = `${parentURL}PengujianSampleLainnyaList`;
            },
            error: (_, __, err) => {
                hideLoadingSafe();
                console.error(err);
                showMessage(err || 'Request failed');
            },
        });
    });
    $('#btn-cancel-custom').on('click', () => {
        window.location.href = `${parentURL}PengujianSampleLainnyaList`;
    });
    loadPlantDropdown();
    renderFileTable();
});
</script>
