<script>
loadjs.ready("load", function() {
    // Startup script
    var parent_url = ew.PATH_BASE;
    $('#r_NomorGoodHouseKeeping').hide();
    $('#r_Plant').hide();
    const syncPlantFields = (value, label) => {
        if (label !== undefined) {
            $('#sv_x_Plant').val(label);
        }
        if (value !== undefined) {
            $('#x_Plant').val(value).attr('value', value).trigger('change');
            const selectionList = document.querySelector('selection-list[name="x_Plant"]');
            if (selectionList) {
                selectionList.value = value;
                selectionList.setAttribute('value', value);
                selectionList.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }
    };
    $(document).ready(function () {
        const ddl = $("#x_LookupPlant");
        ddl.empty();
        ddl.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/plant',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                ddl.empty(); 
                $.each(data, function (index, item) {
                    const selected = index === 0 ? 'selected' : '';
                    ddl.append(`<option value="${item.Value}" ${selected}>${item.Label}</option>`);
                    if (selected){
                        syncPlantFields(item.Value, item.Label);
                    }
                });
                const selectedOption = ddl.find('option:selected');
                syncPlantFields(selectedOption.val(), selectedOption.text());
                ddl.trigger('change');
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                ddl.empty();
            }
        });
    });
});
</script>
