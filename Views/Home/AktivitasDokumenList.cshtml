<script>
loadjs.ready("head", function() {
    // Client script
    // Write your client script here, no need to add script tags.
    let parent_url = ew.PATH_BASE;
    let IdProses = "@aktivitasDokumenList.IdProses.CurrentValue";
    let prosesId = "@aktivitasDokumenList.IdProses.CurrentValue";
    $(document).on("click", ".download-document", function (e) {
        let IdAktivitasDokumen = $(this).attr("IdAktivitasDokumen");
        e.preventDefault();
        $.ajax({
            url: parent_url + "api/LookUpList/DownloadDocumentZip",
            type: "GET",
            data: {
                idRef: IdAktivitasDokumen,
                table: "AktivitasDokumenDetail",
                colRef: "IdAktivitasDokumen",
                path: "ActivityDocument",
            },
            xhrFields: {
                responseType: "blob",
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader("Content-Disposition");
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement("a");
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            },
        });
    });
    $(document).on("click", ".btn-download-single", function (e) {
        e.preventDefault();
        const id = $(this).data("id");
        if (!id) {
            ew.alert("ID dokumen tidak ditemukan.");
            return;
        }
        $.ajax({
            url: parent_url + "api/LookUpList/DownloadSingleDocument",
            type: "GET",
            data: {
                id: id,
                menu: "AktivitasDokumen",
            },
            xhrFields: {
                responseType: "blob",
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (response, status, xhr) {
                const disposition = xhr.getResponseHeader("Content-Disposition");
                let fileName = "download_file";
                if (disposition) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    }
                    const utf8FileNameMatch = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/);
                    if (utf8FileNameMatch && utf8FileNameMatch[1]) {
                        fileName = decodeURIComponent(utf8FileNameMatch[1]);
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement("a");
                a.href = blobUrl;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download berhasil!");
            },
            error: function (xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File tidak ditemukan di server.");
                } else if (xhr.status === 500) {
                    ew.alert("Terjadi kesalahan server. Coba lagi nanti.");
                } else {
                    ew.alert("Gagal mendownload file. Error: " + xhr.responseText);
                }
            },
            complete: function () {
                hideLoading();
            },
        });
    });
    let IdAktivitas = "@aktivitasDokumenList.IdAktivitas.CurrentValue";
    let StatusAktivitas = $("#el_Aktivitas_StatusAktivitas").text().trim();
    function updateStatusDokumen() {
        let formData = new FormData();
        formData.append("IdAktivitas", IdAktivitas);
        const originalStatus = document.querySelector("#el_Aktivitas_StatusAktivitas span").textContent;
        let keterangan = $("#InputKeterangan").val();
        if (!keterangan) {
            keterangan = "";
        }
        formData.append("Keterangan", keterangan);
        if (StatusAktivitas == "Completed") {
            formData.append("StatusAktivitas", "Editing");
        } else if (StatusAktivitas == "Editing" || StatusAktivitas == "Completed Edit") {
            formData.append("StatusAktivitas", "Editing");
        } else {
            formData.append("StatusAktivitas", "Draft");
        }
        const idTemplateAktivitas = "@aktivitas.IdTemplateAktivitas.CurrentValue";
        const isNonNominationReceivingLineClosedAndSealed = $("#InputIsNonNominationReceivingLineClosedAndSealed").is(":checked");
        const isNominationTankReceivingLineOpen = $("#InputIsNominationTankReceivingLineOpen").is(":checked");
        const isTankEmptyAndDry = $("#InputIsTankEmptyAndDry").is(":checked");
        const isDocumentationComplete = $("#InputIsDocumentationComplete").is(":checked");
        if (["306", "460"].includes(idTemplateAktivitas) && !isNominationTankReceivingLineOpen) {
            return ew.alert("Jalur penerimaan yang berhubungan dengan Tangki Nominasi BELUM TERBUKA.");
        }
        if (["306", "460"].includes(idTemplateAktivitas) && !isNonNominationReceivingLineClosedAndSealed) {
            return ew.alert("Jalur penerimaan yang TIDAK berhubungan dengan Tangki Nominasi BELUM TERTUTUP dan TERSEGEL.");
        }
        if (["429"].includes(idTemplateAktivitas)) {
            if (!isTankEmptyAndDry) return ew.alert(`Tangki mobil <strong>belum dalam kondisi kering</strong> dan <strong>masih terdapat sisa muatan</strong>.` );
            if (!isDocumentationComplete) return ew.alert(`Seluruh dokumen <strong>belum</strong> didokumentasikan dengan baik.`);
        }
        formData.append("IsNominationTankReceivingLineOpen", isNominationTankReceivingLineOpen);
        formData.append("IsNonNominationReceivingLineClosedAndSealed", isNonNominationReceivingLineClosedAndSealed);
        formData.append("IsTankEmptyAndDry", isTankEmptyAndDry);
        formData.append("IsDocumentationComplete", isDocumentationComplete);
        $.ajax({
            url: parent_url + `api/LookUpList/check_valid_status_aktivitas?idAktivitas=${IdAktivitas}&originalStatus=${originalStatus}`,
            type: "GET",
            beforeSend: function () {
                showLoading();
            },
            success: function (response) {
                if (!response.IsValid) {
                    hideLoading();
                    ew.alert(response.Message ?? "Status aktivitas telah diubah oleh pengguna lain");
                    return;
                } else {
                    $.ajax({
                        url: parent_url + "api/LookUpList/UpdateStatusAktivitasByDocument",
                        type: "POST",
                        data: formData,
                        contentType: false,
                        processData: false,
                        success: function (rs) {
                            ew.alert(rs.message);
                            if (rs.success) {
                                setTimeout(function () {
                                    if (formData.get("StatusAktivitas") == "Completed" || formData.get("StatusAktivitas") == "Completed Edit") {
                                        window.location.href = `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${prosesId}&search=&searchtype=`;
                                    } else {
                                        location.reload();
                                    }
                                }, 1000);
                            }
                        },
                        error: function (xhr, status, error) {
                            ew.alert("Error: " + xhr.responseText);
                        },
                        complete: function () {
                            hideLoading();
                        },
                    });
                }
            },
            error: function (xhr, status, error) {
                ew.alert("Gagal menyimpan data.");
                console.error("Form submit gagal:", error);
            },
        });
    }
    $(document).on("click", "#btn-save-keterangan", function () {
        event.preventDefault();
        updateStatusDokumen();
    });
});
</script>
}
