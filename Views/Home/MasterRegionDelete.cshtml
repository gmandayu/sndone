    <tr @Html.Raw(masterRegionDelete.RowAttributes)>
@if (masterRegionDelete.IdRegion.Visible) { // masterRegionDelete.IdRegion.Visible (begin)
        <td @Html.Raw(masterRegionDelete.IdRegion.CellAttributes)>
<span id="">
<span @Html.Raw(masterRegionDelete.IdRegion.ViewAttributes)>
@Html.Raw(masterRegionDelete.IdRegion.GetViewValue())</span>
</span></td>
} @* masterRegionDelete.IdRegion.Visible (end) *@
@if (masterRegionDelete.Region.Visible) { // masterRegionDelete.Region.Visible (begin)
        <td @Html.Raw(masterRegionDelete.Region.CellAttributes)>
<span id="">
<span @Html.Raw(masterRegionDelete.Region.ViewAttributes)>
@Html.Raw(masterRegionDelete.Region.GetViewValue())</span>
</span></td>
} @* masterRegionDelete.Region.Visible (end) *@
@if (masterRegionDelete.RegionCode.Visible) { // masterRegionDelete.RegionCode.Visible (begin)
        <td @Html.Raw(masterRegionDelete.RegionCode.CellAttributes)>
<span id="">
<span @Html.Raw(masterRegionDelete.RegionCode.ViewAttributes)>
@Html.Raw(masterRegionDelete.RegionCode.GetViewValue())</span>
</span></td>
} @* masterRegionDelete.RegionCode.Visible (end) *@
