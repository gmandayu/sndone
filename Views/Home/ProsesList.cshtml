        //             Proses ${TipeProses} Produk <span style="color: red">${produk} ${kapal}</span> SN <span style="color: red">${nomorPengiriman}</span>
        //         </span>`;

        //             // Sisipkan setelah tombol export
        //         $(".ew-filter-option").after(resultHtml);
        //     },
        //     error: function (xhr, status, error) {
        //         console.error('Gagal update status aktivitas:', status, error);
        //     }
        // })
    $.ajax({
            url: parent_url + `api/LookUpList/get_referensi_detail?nomorReferensi=${idReferensi}`,
            type: 'GET',
            success: function (res) { 

                // let produk = res.NamaProduk;
                // let tanggal = res.TanggalDibuat;
                // let kapal = res.NomorKendaraan;
                // let nomorPengiriman = res.NomorPengiriman;
                // let tanggalAktifitas = res.TanggalAktifitas;

                // let detail = "";

                // if (produk) detail += ` Produk: <span style="color: red">${produk}</span>`;
