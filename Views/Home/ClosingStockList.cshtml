@if (!closingStockList.IsModal) {
<form name="fClosingStocksrch" id="fClosingStocksrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fClosingStocksrch_search_panel" class="mb-2 mb-sm-0 @(closingStockList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(closingStockList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { ClosingStock: currentTable } });
var currentForm;
var fClosingStocksrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fClosingStocksrch")
        .setPageId("list")
@if (closingStockList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "NomorClosingStock": @Html.Raw(closingStockList.NomorClosingStock.ToClientList(closingStockList)),
            "Proses2": @Html.Raw(closingStockList.Proses2.ToClientList(closingStockList)),
            "Plant": @Html.Raw(closingStockList.Plant.ToClientList(closingStockList)),
            "TipeProdukSTS": @Html.Raw(closingStockList.TipeProdukSTS.ToClientList(closingStockList)),
            "IdTangki": @Html.Raw(closingStockList.IdTangki.ToClientList(closingStockList)),
            "StatusProses": @Html.Raw(closingStockList.StatusProses.ToClientList(closingStockList)),
            "PersentaseProgress": @Html.Raw(closingStockList.PersentaseProgress.ToClientList(closingStockList)),
            "Catatan": @Html.Raw(closingStockList.Catatan.ToClientList(closingStockList)),
            "DibuatOleh": @Html.Raw(closingStockList.DibuatOleh.ToClientList(closingStockList)),
            "TanggalDibuat": @Html.Raw(closingStockList.TanggalDibuat.ToClientList(closingStockList)),
            "DiperbaruiOleh": @Html.Raw(closingStockList.DiperbaruiOleh.ToClientList(closingStockList)),
            "TanggalDiperbarui": @Html.Raw(closingStockList.TanggalDiperbarui.ToClientList(closingStockList)),
        })

        // Filters
        .setFilterList(@Html.Raw(closingStockList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
