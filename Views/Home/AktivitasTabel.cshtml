            width: 150px;
            text-align: center;
            position: relative;
        }

            .step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 20px;
                right: -50%;
                width: 100%;
                height: 4px;
                background-color: #ccc;
                z-index: 0;
            }

            .step.completed:not(:last-child)::after {
                background-color: #3c6dbd;
