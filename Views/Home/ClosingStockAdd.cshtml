            "IdTangki": @Html.Raw(closingStockAdd.IdTangki.ToClientList(closingStockAdd)),
            "Produk": @Html.Raw(closingStockAdd.Produk.ToClientList(closingStockAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    var parent_url = ew.PATH_BASE;
    $('#btn-action').on('click', function(e) {
        e.preventDefault();
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && UserLevel != "6" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Closing Stock.');
            setTimeOut(() => {
                window.location.href = parent_url+'ClosingStockList';
            }, 1000);
            return false;
        }
        const idTangki = $('#x_IdTangki').val();
        const idProduk = $('#x_Produk').val();
        const plantValue = $('#sv_x_Plant').val(); // yg pilih user
        const idPlant = $('#x_Plant').val(); // yg dikirim (dihide) 
        if (!plantValue){
            ew.alert("Plant tidak boleh kosong.");
            return;
        }
        if (plantValue && !idPlant) {
            $('#x_Plant').val($('#x_LookupPlant').val());
        }
        if (!idTangki) {
            ew.alert("Tangki tidak boleh kosong.");
            return;
        }
        const selectedTangkiLabel = $('#x_IdTangki').find('option:selected').text();
        if (selectedTangkiLabel && selectedTangkiLabel.toLowerCase().includes("pipe")) {
                if (!idProduk) {
                    ew.alert("Produk tidak boleh kosong untuk Tangki Pipa.");
                    return;
                }
        }
        $.ajax({
            url: parent_url + `api/LookUpList/GetTotalTangki`,
            type: 'GET',
            beforeSend: function () {
                showLoading();
            },
            data: {
                idTangki: idTangki,
                idProduk: idProduk,
                idPlant: idPlant
            },
            success: function (res) {
                if (res.totalTangki > 0) {
                    hideLoading();
                    if (idProduk) {
                        ew.alert("Closing Stock untuk Tangki (Pipa) dengan Produk ini sudah dilakukan hari ini.");
                    } else {
                        ew.alert("Tangki ini sudah melakukan closing stock hari ini. Silahkan cek kembali.");
                    }
                    // stop di sini, jangan biarkan submit
                } else {
                    hideLoading();
                    $('#fClosingStockadd').submit();
                }
            },
            error: function () {
                ew.alert("Gagal melakukan pengecekan data tangki.");
                hideLoading();
            }
        });
    });
    function checkTangkiTypeAndToggleProduk() {
        const selectedLabel = $('#x_IdTangki').find('option:selected').text();
        const $produkRow = $('#r_Produk');
        if (selectedLabel && selectedLabel.toLowerCase().includes("pipe")) {
            $produkRow.show();
        } else {
            $produkRow.hide();
            $('#x_Produk').val(null).trigger('change'); 
        }
    }
    $('#x_IdTangki').on('change', function() {
        $('#x_Produk').val(null).trigger('change'); 
        checkTangkiTypeAndToggleProduk();
    });
    $(document).ready(function() {
            checkTangkiTypeAndToggleProduk();
    });
    $('#x_LookupJenisPlant').change(function () {
        if ($(this).val() == 'STS') {
            $('#r_TipeProdukSTS').show();
        } else {
            $('#r_TipeProdukSTS').hide();
            $('#x_TipeProdukSTS').val('');
        }
    });
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        const selectedLabel = $(this).find('option:selected').text();
        $('#sv_x_Plant').val(selectedLabel);
        $('#x_Plant').val(selectedValue).trigger('change');
        $('#x_IdTangki').val(null).trigger('change');
        $('#x_Produk').val(null).trigger('change');
        const $produkSelect = $('#x_Produk');
        $produkSelect.empty().append('<option value="">Loading...</option>');
        if (selectedValue) {
            $.ajax({
                url: parent_url + 'api/LookUpList/get-dropdown/produk-by-plant',
                type: 'GET',
                data: { plantId: selectedValue },
                success: function(data) {
                    $produkSelect.empty();
                    $produkSelect.append('<option value="">Please Select</option>');
                    if (data && data.length > 0) {
                        $.each(data, function(i, item) {
                            var newOption = new Option(item.Label, item.Value, false, false);
                            $produkSelect.append(newOption);
                        });
                    } else {
                        console.warn("No products found for this plant type.");
                    }
                    $produkSelect.trigger('change'); 
                },
            });
        } else {
            $produkSelect.empty().append('<option value="">Please Select</option>');
        }
    });
});
</script>
