@if (!penimbunanList.IsModal) {
<form name="fPenimbunansrch" id="fPenimbunansrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fPenimbunansrch_search_panel" class="mb-2 mb-sm-0 @(penimbunanList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(penimbunanList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penimbunan: currentTable } });
var currentForm;
var fPenimbunansrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fPenimbunansrch")
        .setPageId("list")
@if (penimbunanList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "Proses2": @Html.Raw(penimbunanList.Proses2.ToClientList(penimbunanList)),
            "NomorPenimbunan": @Html.Raw(penimbunanList.NomorPenimbunan.ToClientList(penimbunanList)),
            "Plant": @Html.Raw(penimbunanList.Plant.ToClientList(penimbunanList)),
            "IdPenerimaan": @Html.Raw(penimbunanList.IdPenerimaan.ToClientList(penimbunanList)),
            "IdTangki": @Html.Raw(penimbunanList.IdTangki.ToClientList(penimbunanList)),
            "StatusProses": @Html.Raw(penimbunanList.StatusProses.ToClientList(penimbunanList)),
            "PersentaseProgress": @Html.Raw(penimbunanList.PersentaseProgress.ToClientList(penimbunanList)),
            "Catatan": @Html.Raw(penimbunanList.Catatan.ToClientList(penimbunanList)),
            "DibuatOleh": @Html.Raw(penimbunanList.DibuatOleh.ToClientList(penimbunanList)),
            "TanggalDibuat": @Html.Raw(penimbunanList.TanggalDibuat.ToClientList(penimbunanList)),
            "DiperbaruiOleh": @Html.Raw(penimbunanList.DiperbaruiOleh.ToClientList(penimbunanList)),
            "TanggalDiperbarui": @Html.Raw(penimbunanList.TanggalDiperbarui.ToClientList(penimbunanList)),
        })

        // Filters
        .setFilterList(@Html.Raw(penimbunanList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
