    $("#el_Aktivitas_Keterangan").empty();
    $("#el_Aktivitas_Keterangan").append(`
            <textarea id="InputKeterangan" class="form-control" rows="3">${keterangan.trim()}</textarea>
        `);
    function makeMasterCheckboxEditable(trSelector, elSelector, inputId) {
        const $tr = $(trSelector);
        const $captionTd = $tr.find("td.w-col-2").first();
        const labelText = $captionTd.text().trim();
        const $el = $(elSelector);
        const $i = $el.find("i").first();
        const checked = $i.hasClass("fa-square-check") || $i.hasClass("fa-check-square");
        $tr.empty();
        $tr.append(`
                <td colspan="2">
                    <div class="d-flex align-items-start gap-2">
                        <input
                            class="form-check-input m-0"
                            type="checkbox"
                            id="${inputId}" ${checked ? "checked" : ""}
                        >
                        <label
                            class="mb-0"
                            for="${inputId}"
                            style="line-height:1.4; white-space:normal;"
                        >
                            ${labelText}
                        </label>
                    </div>
                </td>
            `);
    }
    const idTemplateAktivitas = "@aktivitas.IdTemplateAktivitas.CurrentValue";
    if (["306", "460"].includes(idTemplateAktivitas)) {
        $("#r_IsTankEmptyAndDry").remove();
        $("#r_IsDocumentationComplete").remove();
        makeMasterCheckboxEditable("#r_IsNominationTankReceivingLineOpen", "#el_Aktivitas_IsNominationTankReceivingLineOpen", "InputIsNominationTankReceivingLineOpen");
        makeMasterCheckboxEditable("#r_IsNonNominationReceivingLineClosedAndSealed", "#el_Aktivitas_IsNonNominationReceivingLineClosedAndSealed", "InputIsNonNominationReceivingLineClosedAndSealed");
    } else if (["429"].includes(idTemplateAktivitas)) {
        $("#r_IsNominationTankReceivingLineOpen").remove();
        $("#r_IsNonNominationReceivingLineClosedAndSealed").remove();
        makeMasterCheckboxEditable("#r_IsTankEmptyAndDry", "#el_Aktivitas_IsTankEmptyAndDry", "InputIsTankEmptyAndDry");
        makeMasterCheckboxEditable("#r_IsDocumentationComplete", "#el_Aktivitas_IsDocumentationComplete", "InputIsDocumentationComplete");
    } else {
        $("#r_IsNominationTankReceivingLineOpen").remove();
        $("#r_IsNonNominationReceivingLineClosedAndSealed").remove();
        $("#r_IsTankEmptyAndDry").remove();
        $("#r_IsDocumentationComplete").remove();
    }
    if (StatusAktivitas == "Completed Edit") {
        let reverseStatusButton = ``;
        if (userLevel === "4") {
            reverseStatusButton = `<button type="button" class="btn btn-warning ew-btn ml-2" id="btn-reverse-status">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit 
                                    </button>`;
        }
        $(".content").append(`
            <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                ${reverseStatusButton}
                <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                    <i class="fas fa-ban"></i> Cancel
                </a>
            </div>
            `);
        $(".upload-document").prop("disabled", true);
    } else if (StatusAktivitas == "Waiting") {
        $(".content").append(`
            <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                <button type="button" class="btn btn-primary ew-btn" id="btn-save-keterangan">
                    <i class="fas fa-save"></i> Save
                </button>
                <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                    <i class="fas fa-ban"></i> Cancel
                </a>
            </div>
            `);
    } else if (!hasNotUploaded && StatusAktivitas == "Draft") {
        $(".content").append(`
            <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                <button type="button" class="btn btn-primary ew-btn" id="btn-save-keterangan">
                    <i class="fas fa-save"></i> Save
                </button>
                <button type="button" class="btn btn-success ew-btn ml-2" id="btn-submit-keterangan">
                    <i class="fas fa-paper-plane"></i> Submit
                </button>
                <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                    <i class="fas fa-ban"></i> Cancel
                </a>
            </div>
            `);
    } else if (StatusAktivitas == "Editing" || StatusAktivitas == "Completed") {
        $(".content").append(`
            <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                <button type="button" class="btn btn-primary ew-btn" id="btn-save-keterangan">
                    <i class="fa-solid fa-pen-to-square"></i> Edit
                </button>
                <button type="button" class="btn btn-success ew-btn ml-2" id="btn-submit-keterangan">
                    <i class="fas fa-paper-plane"></i> Submit
                </button>
                <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                    <i class="fas fa-ban"></i> Cancel
                </a>
            </div>
            `);
    } else if (hasNotUploaded) {
        let WajibUpload = false;
        $(".not-uploaded").each(function () {
            const wajib = $(this).attr("WajibUpload");
            if (wajib === "1") {
                WajibUpload = true;
                return;
            }
        });
        if (!WajibUpload && StatusAktivitas != "Waiting") {
            $(".content").append(`
                <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                    <button type="button" class="btn btn-primary ew-btn" id="btn-save-keterangan">
                        <i class="fas fa-save"></i> Save
                    </button>
                    <button type="button" class="btn btn-success ew-btn ml-2" id="btn-submit-keterangan">
                        <i class="fas fa-paper-plane"></i> Submit
                    </button>
                    <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                        <i class="fas fa-ban"></i> Cancel
                    </a>
                </div>
                `);
        } else {
            $(".content").append(`
                <div id="custom-buttons" class="d-flex gap-2 mb-3 ms-2">
                    <button type="button" class="btn btn-primary ew-btn" id="btn-save-keterangan">
                        <i class="fas fa-save"></i> Save
                    </button>
                    <a class="btn btn-default ew-btn" href="${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=">
                        <i class="fas fa-ban"></i> Cancel
                    </a>
                </div>
                `);
        }
    }
    $(document).on("click", "#btn-submit-keterangan", function () {
        submitAktivitasDokumen();
    });
    $(document).on("submit", "#reverseStatusEditingModalForm", function () {
        submitAktivitasDokumen();
    });
    function submitAktivitasDokumen() {
        event.preventDefault();
        let formData = new FormData();
        formData.append("IdAktivitas", idAktivitas);
        const originalStatus = document.querySelector("#el_Aktivitas_StatusAktivitas span").textContent;
        let keterangan = $("#InputKeterangan").val();
        if (!keterangan) {
            keterangan = "";
        }
        let catatanText = $("#catatanReverseStatusEditing").val();
        if (!catatanText) {
            catatanText = "";
        }
        formData.append("Keterangan", keterangan);
        formData.append("Catatan", catatanText);
        if (StatusAktivitas == "Completed" || StatusAktivitas == "Editing") {
            formData.append("StatusAktivitas", "Completed Edit");
        } else if (StatusAktivitas == "Completed Edit") {
            formData.append("StatusAktivitas", "Editing");
        } else {
            formData.append("StatusAktivitas", "Completed");
        }
        const isNonNominationReceivingLineClosedAndSealed = $("#InputIsNonNominationReceivingLineClosedAndSealed").is(":checked");
        const isNominationTankReceivingLineOpen = $("#InputIsNominationTankReceivingLineOpen").is(":checked");
        const isTankEmptyAndDry = $("#InputIsTankEmptyAndDry").is(":checked");
        const isDocumentationComplete = $("#InputIsDocumentationComplete").is(":checked");
        if (["306", "460"].includes(idTemplateAktivitas) && !isNominationTankReceivingLineOpen) {
            return ew.alert("Jalur penerimaan yang berhubungan dengan Tangki Nominasi BELUM TERBUKA.");
        }
        if (["306", "460"].includes(idTemplateAktivitas) && !isNonNominationReceivingLineClosedAndSealed) {
            return ew.alert("Jalur penerimaan yang TIDAK berhubungan dengan Tangki Nominasi BELUM TERTUTUP dan TERSEGEL.");
        }
        if (["429"].includes(idTemplateAktivitas)) {
            if (!isTankEmptyAndDry) return ew.alert(`Tangki mobil <strong>belum dalam kondisi kering</strong> dan <strong>masih terdapat sisa muatan</strong>.` );
            if (!isDocumentationComplete) return ew.alert(`Seluruh dokumen <strong>belum</strong> didokumentasikan dengan baik.`);
        }
        formData.append("IsNominationTankReceivingLineOpen", isNominationTankReceivingLineOpen);
        formData.append("IsNonNominationReceivingLineClosedAndSealed", isNonNominationReceivingLineClosedAndSealed);
        formData.append("IsTankEmptyAndDry", isTankEmptyAndDry);
        formData.append("IsDocumentationComplete", isDocumentationComplete);
        $.ajax({
            url: parent_url + `api/LookUpList/check_valid_status_aktivitas?idAktivitas=${idAktivitas}&originalStatus=${originalStatus}`,
            type: "GET",
            beforeSend: function () {
                showLoading();
            },
            success: function (response) {
                if (!response.IsValid) {
                    hideLoading();
                    ew.alert(response.Message ?? "Status aktivitas telah diubah oleh pengguna lain");
                    return;
                } else {
                    $.ajax({
                        url: parent_url + "api/LookUpList/UpdateStatusAktivitasByDocument",
                        type: "POST",
                        data: formData,
                        contentType: false,
                        processData: false,
                        success: function (rs) {
                            ew.alert(rs.message);
                            if (rs.success) {
                                setTimeout(function () {
                                    window.location = `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`;
                                }, 1000);
                            }
                        },
                        error: function (xhr, status, error) {
                            ew.alert("Error: " + xhr.responseText);
                        },
                        complete: function () {
                            hideLoading();
                        },
                    });
                }
            },
            error: function (xhr, status, error) {
                hideLoading();
                ew.alert("Gagal menyimpan data.");
                console.error("Form submit gagal:", error);
            },
        });
    }

    // --- log aktivitas start ---
    $("#el_Aktivitas_DiperbaruiOleh").append(`
            <button type="button" class="ms-3 btn btn-primary ew-btn ps-2" expand-log="false" id="btn-log-history">
                <i class="fa-solid fa-caret-right fa-2xl me-2 caret-icon rotate-right"></i>
                Log History
                <i class="fa-solid fa-clock-rotate-left ms-1"></i> 
            </button>
        `);
    $(document).on("click", "button[expand-log]", function () {
        const $btn = $(this);
        const isExpanded = $btn.attr("expand-log") === "true";
        const $row = $("#log-table-row");
        const $wrapper = $("#log-table-wrapper");
        const $caret = $btn.find(".caret-icon");
        if (!isExpanded) {
            $btn.attr("expand-log", "true");
            $row.removeClass("d-none");
            setTimeout(() => {
                $wrapper.css({
                    maxHeight: "500px",
                });
            }, 10);
            $caret.removeClass("rotate-right").addClass("rotate-down");
        } else {
            $btn.attr("expand-log", "false");
            $wrapper.css({
                maxHeight: "0",
            });
            setTimeout(() => {
                $row.addClass("d-none");
            }, 400);
            $caret.removeClass("rotate-down").addClass("rotate-right");
        }
    });
    if (idAktivitas && idAktivitas !== "0") {
        $.ajax({
            url: parent_url + `api/LookUpList/sub-aktivitas/startup?IdAktivitas=${idAktivitas}`,
            method: "GET",
            success: function (response) {
                // Cek is editable
                if (!response.IsEditable || response.StatusAktivitas === "Completed Edit") {
                    $("#btn-draft, #btn-editing, #btn-completed, #btn-completedEdit").hide();
                    $("input, select, textarea, button").prop("disabled", true);
                    $("#btn-cancel, #btn-log-history, #btn-cancel-modal, #catatanReverseStatusEditing, #btnReverseStatusEditingModalSubmit, #btn-reverse-status, #btnReverseStatusEditingModalCancel, #closeReverseModal").prop("disabled", false);
                    $(".upload-document").prop("disabled", true);
                }
                const mappedData = response.LogAktivitas.map((item) => ({
                    Aktivitas: item.Aktivitas,
                    Username: item.UserName,
                    StatusAktivitas: item.StatusAktivitas,
                    Tanggal: item.Tanggal,
                    Catatan: item.Catatan,
                }));
                $.getScript("https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js", function () {
                    $("#r_DiperbaruiOleh").after(`
                        <tr id="log-table-row" class="d-none">
                            <td class="p-0"></td>
                            <td class="p-0">
                                <div id="log-table-wrapper" style="overflow: hidden; transition: all 0.6s ease; max-height: 0;">
                                    <div id="myGrid" class="ag-theme-quartz w-100 my-3" style="height: 300px;"></div>
                                </div>
                            </td>
                        </tr>
                    `);
                    const gridOptions = {
                        rowData: mappedData,
                        columnDefs: [
                            {
                                headerName: "No.",
                                valueGetter: "node.rowIndex + 1",
                                width: 80,
                                filter: false,
                            },
                            {
                                headerName: "Aktivitas",
                                field: "Aktivitas",
                                flex: 1,
                            },
                            {
                                headerName: "Username",
                                field: "Username",
                                flex: 1,
                            },
                            {
                                headerName: "Status Aktivitas",
                                field: "StatusAktivitas",
                                flex: 1,
                            },
                            {
                                headerName: "Tanggal",
                                field: "Tanggal",
                                flex: 1,
                            },
                            {
                                headerName: "Catatan",
                                field: "Catatan",
                                flex: 1,
                            },
                        ],
                        defaultColDef: {
                            sortable: false,
                            suppressMovable: true,
                            filter: true,
                            resizable: false,
                        },
                        rowSelection: "multiple",
                        suppressRowClickSelection: true,
                        pagination: true,
                        paginationPageSize: 10,
                    };
                    const myGridElement = document.querySelector("#myGrid");
                    agGrid.createGrid(myGridElement, gridOptions);
                });
            },
            error: function (xhr, status, error) {
                console.error("API call failed:", status, error);
            },
        });
    } else {
        console.warn("Skipping startup API call: Invalid IdAktivitas");
        $("input, select, textarea, button").prop("disabled", true);
    }
    // --- log aktivitas end ---
    // Reverse Status to Editing
    let reverseModal = `<div class="modal fade" id="confirmReverseStatusEditingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                    <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-primary">
                        <h1 class="modal-title fs-5" id="confirmReverseStatusEditingModalTitle">Konfirmasi Kembalikan Status</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" id="closeReverseModal" aria-label="Close"></button>
                        </div>
                        <form id="reverseStatusEditingModalForm">
                        <div class="modal-body px-2 py-1">
                            <div class="mb-3">
                                <label for="message-text" class="col-form-label">Catatan:</label>
                                <textarea class="form-control" id="catatanReverseStatusEditing" required rows="4"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="btnReverseStatusEditingModalCancel">Batal</button>
                            <button type="submit" class="btn btn-primary" id="btnReverseStatusEditingModalSubmit">Lanjutkan</button>
                        </div>
                        </form>
                    </div>
                    </div>
                </div>`;
    $("body").append(reverseModal);
    $("#btnReverseStatusEditingModalCancel").click(function (event) {
        event.preventDefault();
        $("#confirmReverseStatusEditingModal").modal("hide");
    });
    $(document).on("click", "#btn-reverse-status", function () {
        $("#confirmReverseStatusEditingModal").modal("show");
    });
    if (TipeProsesAsli === "PenyaluranTasNgs") {
        let elemenInformasi = `
            <div class="mt-2">
                <div class="card border-primary shadow-sm" style="max-width: 850px;">
                    <div class="card-header bg-primary text-white py-2 px-3">
                        <strong>Informasi Pengisian Dokumen</strong>
                    </div>
                    <div class="card-body py-2 px-3 text-dark">
                        <p class="mb-2">
                            Pengunggahan dokumen pada <strong>Penyaluran Sales TAS/NGS</strong> dilakukan dengan menggunakan dokumen yang berasal dari 
                            <strong>SIOD/TAS/NGS/ETEDA</strong>.
                        </p>
                    </div>
                </div>
            </div>
            `;
        $(".ew-list-form").before(elemenInformasi);
    }
    if (TipeProsesAsli === "PenyaluranLPGTASNGS") {
        let elemenInformasi = `
            <div class="mt-2">
                <div class="card border-primary shadow-sm" style="max-width: 850px;">
                    <div class="card-header bg-primary text-white py-2 px-3">
                        <strong>Informasi Pengisian Dokumen</strong>
                    </div>
                    <div class="card-body py-2 px-3 text-dark">
                        <p class="mb-2">
                            Pengunggahan dokumen pada <strong>Penyaluran Sales TAS/NGS</strong> dilakukan dengan menggunakan dokumen yang berasal dari 
                            <strong>SIOD/TAS/NGS/ETEDA</strong>.
                        </p>
                    </div>
                </div>
            </div>
            `;
        $(".ew-list-form").before(elemenInformasi);
    }
    function ResetUpload() {
        $("#fileInput").val("");
        filesArr.length = 0;
        deleteIds.length = 0;
    }
    $(document).on("click", "#fileName", function () {
        $("#fileInput").trigger("click");
    });
    $(document).on("change", "#fileInput", function (e) {
        let newFiles = Array.from(e.target.files);
        let mapped = [];
        for (let f of newFiles) {
            if (f.size > 20 * 1024 * 1024) {
                ew.alert(`File "${f.name}" melebihi 20 MB dan tidak dapat diupload.`);
                continue;
            }
            mapped.push({
                file: f,
                FileName: f.name,
            });
        }
        if (mapped.length > 0) {
            filesArr = filesArr.concat(mapped);
            renderTable();
        }
        $(this).val("");
    });
    function renderTable() {
        let $table = $("#fileTable");
        let $tbody = $table.find("tbody");
        $tbody.empty();
        if (filesArr.length === 0) {
            $("#row-table").hide();
            return;
        }
        $("#row-table").show();
        filesArr.forEach((item, index) => {
            let FileEl = item.id ? `<button class="btn text-primary btn-download-single p-0" type="button" data-id="${item.id}">${item.FileName}</button>` : item.FileName;
            let row = `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${FileEl}</td>
                        <td>
                            <button class="btn text-danger btn-delete" 
                                    type="button" 
                                    data-index="${index}" 
                                    data-id="${item.id || ""}">
                                <i class="fa-solid fa-times"></i>
                            </button>
                        </td>
                    </tr>
                `;
            $tbody.append(row);
        });
    }
    $(document).on("click", ".btn-delete", function () {
        let index = $(this).data("index");
        let id = $(this).data("id");
        if (id) {
            deleteIds.push(id);
        }
        filesArr.splice(index, 1);
        renderTable();
    });
});
</script>
}
