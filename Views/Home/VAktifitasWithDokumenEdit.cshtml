<script>
loadjs.ready("head", function() {
    // Client script
    var parent_url = ew.PATH_BASE;
    $(document).on('click', '.download-document', function () {
        var IdAktivitas = $(this).attr('IdAktivitas');
        event.preventDefault();
        $.ajax({
            url: parent_url + 'api/LookUpList/download_activity_document',
            type: 'GET',
            data: { IdAktivitas: IdAktivitas },
            xhrFields: {
                responseType: 'blob'
            },
            success: function(response, status, xhr) {
                const disposition = xhr.getResponseHeader('Content-Disposition');
                let fileName = "file_download";
                if (disposition && disposition.indexOf('filename=') !== -1) {
                    const fileNameMatch = disposition.match(/filename="?([^";]+)"?/);
                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }
                }
                const blobUrl = window.URL.createObjectURL(response);
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = fileName; 
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(blobUrl);
                ew.alert("Download successful!");
            },
            error: function(xhr, status, error) {
                if (xhr.status === 404) {
                    ew.alert("File not found on the server.");
                } else if (xhr.status === 500) {
                    ew.alert("An error occurred. Please try again later.");
                } else {
                    ew.alert("Failed to download the file. Error: " + xhr.responseText);
                }
            }
        });
    });
    function handleCustomSubmit(status) {
        let idAktivitas = $("#x_IdAktivitas").val();
        $.ajax({
            url: parent_url + `api/LookUpList/update_status_aktivitas?idAktivitas=${idAktivitas}&statusAktivitas=${status}`,
            type: 'POST',
            success: function(response) {
                $("#fv_aktifitas_with_dokumenedit").submit();
            },
            error: function(xhr, status, error) {
                console.error('API call failed:', status, error);
            }
        });
    }
    $(document).on("click", "#btn-draft", function () {
        handleCustomSubmit("Draft");
    });
    $(document).on("click", "#btn-completed", function () {
        handleCustomSubmit("Completed");
    });
    $(document).on("click", "#btn-editing", function () {
        handleCustomSubmit("Editing");
    });
    $(document).on("click", "#btn-completedEdit", function () {
        handleCustomSubmit("Completed Edit");
    });
});
</script>
