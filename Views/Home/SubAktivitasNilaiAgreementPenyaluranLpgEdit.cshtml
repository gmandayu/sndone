} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fSubAktivitasNilaiAgreementPenyaluranLPGedit" data-href="@AppPath(subAktivitasNilaiAgreementPenyaluranLpgEdit.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
