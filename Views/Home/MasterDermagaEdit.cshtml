<script>
loadjs.ready("fMasterDermagaedit", function() {
    var options = { name: "x_Id_Plant", selectId: "fMasterDermagaedit_x_Id_Plant" },
        el = document.querySelector("select[data-select2-id='" + options.selectId + "']");
    if (!el)
        return;
    options.closeOnSelect = !options.multiple;
    options.dropdownParent = el.closest("#ew-modal-dialog, #ew-add-opt-dialog");
    if (fMasterDermagaedit.lists.Id_Plant?.lookupOptions.length) {
        options.data = { id: "x_Id_Plant", form: "fMasterDermagaedit" };
    } else {
        options.ajax = { id: "x_Id_Plant", form: "fMasterDermagaedit", limit: ew.LOOKUP_PAGE_SIZE };
    }
    options.minimumInputLength = ew.selectMinimumInputLength;
    options = Object.assign({}, ew.selectOptions, options, ew.vars.tables.MasterDermaga.fields.Id_Plant.selectOptions);
    ew.createSelect(options);
});
</script>
