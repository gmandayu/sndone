@Html.Raw(closingStockEdit.IsModal ? "<template class=\"ew-modal-buttons\">" : "<div class=\"row ew-buttons\">")<!-- buttons .row -->
    <div class="@(closingStockEdit.OffsetColumnClass)"><!-- buttons offset -->
