            moveField("el_SubAktivitasSFADNewBLLPG_AR45B_mt", "td_ar45b_Mt");
        var r4Value = 0;
        var r4ImportValue = 0;
        // Fungsi toggle
        function toggleROBSection() {
            const isChecked = $("#x_ApakahTerdapatROB").prop("checked");
            if (isChecked) {
                $("#r_Tujuan").show();
                $("#robSection").show();
                $("#r1r4table").show();
                $('.newblsfad').show();
                $("#R445").text("0.000%");
                $("#R4").text("0.000%");
            } else {
                $("#r_Tujuan").hide();
                $("#robSection").hide();
                $("#r1r4table").hide();
                $('.newblsfad').hide();
                $("#R445").text(r4ImportValue.toFixed(3) + "%");
                if (r4Value < -0.125) {
                    color = "#ba313b";
                } else if (r4Value >= -0.125 && r4Value <= 0) {
                    color = "#3c6dbd";
                } else {
                    color = "#198754";
                }
                $("#R4").text(r4Value.toFixed(3) + "%");
                $("#R4").color = color;
            }
        }
        function toggleImportSection() {
            const isImport = $("#x_Import").prop("checked");
            if (isImport){
                $('.ar45b').show();
            } else {
                $('.ar45b').hide();
            }
        }

        // Jalankan saat awal
        toggleROBSection();
        toggleImportSection();

        // Jalankan saat checkbox diubah
        $("#x_ApakahTerdapatROB").on("change", toggleROBSection);
        $("#x_Import").on("change", toggleImportSection);
    function GetOtherValue(StatusAktivitas) {
        $.ajax({
            url: parent_url + "api/LookUpList/GetRValue",
            type: "GET",
            data: {
                NoReferensi: IdReferensi,
                Menu: "NEWBL",
                Jenis: "LPG"
            },
            success: function(rs){
                if (rs.success) {

                    ["R1", "R2", "R3", "R4"].forEach(key => {
                        let val = parseFloat(rs[key]);
                        const el = document.getElementById(key);
                        if (!isNaN(val)) {
                            let color = "";
                            val = val * 100;
                            if (key === "R2") {
                                if (val < -0.07) {
                                    color = "#ba313b";
                                } else if (val >= -0.07 && val <= 0) {
                                    color = "#3c6dbd";
                                } else {
                                    color = "#198754";
                                }
                            } else {
                                if (key == "R4"){
                                    r4Value = val;
                                    const isChecked = $("#x_ApakahTerdapatROB").prop("checked");
                                    if (isChecked){
                                        val = 0;
                                    }
                                }
                                if (val < -0.125) {
                                    color = "#ba313b";
                                } else if (val >= -0.125 && val <= 0) {
                                    color = "#3c6dbd";
                                } else {
                                    color = "#198754";
                                }
                            }
                            el.textContent = val.toFixed(3) + "%";
                            el.style.color = color;
                        }
                    });
                    $.get(parent_url + `api/LookUpList/GetSFBDValue?NoReferensi=${IdReferensi}&Jenis=LPG`, function (data) {
                        if (data.success) {
                            $("#td_SFBD_Mt_api").text(data.mt);
                        }
                    });

                    // Panggil API BLSFAL
                    $.get(parent_url + `api/LookUpList/GetBLSFALValue?NoReferensi=${IdReferensi}&Jenis=LPG`, function (data) {
                        if (data.success) {
                            // BL
                            $("#td_BL_Mt_api").text(data.bl_mt);
                            // SFAL
                            $("#td_SFAL_Mt_api").text(data.sfal_mt);
                            const ar45Raw = $("#x_AR45B_barrels").val();
                            const ar45 = parseFloat(ar45Raw || "0");
                            const bl = parseFloat(data.bl_barrels);
                            if (!isNaN(ar45) && !isNaN(bl) && bl !== 0) {
                                const result = ((ar45 - bl) / bl)*100;
                                r4ImportValue = result;
                                const isChecked = $("#x_ApakahTerdapatROB").prop("checked");
                                if (isChecked){
                                    $("#R445").text("0.000%");
                                } else {
                                    $("#R445").text(result.toFixed(3) + "%");
                                }
                            } else {
                                $("#R445").text("0.000%");
                            }
                            const isChecked = $("#x_ApakahTerdapatROB").prop("checked");
                            if (isChecked){
                                $("#R445").text("0.000%");
                            } else {
                                if (!isNaN(ar45) && !isNaN(bl) && bl !== 0) {
                                    const result = ((ar45 - bl) / bl)*100;
                                    $("#R445").text(result.toFixed(3) + "%");
                                } else {
                                    $("#R445").text("0.000%");
                                }
                            }
                        }
                    });
                    $.get(parent_url + `api/LookUpList/GetARValue?NoReferensi=${IdReferensi}&Jenis=LPG`, function (data) {
                        if (data.success) {
                            $("#td_AR_Mt_api").text(data.mt);
                        }
                    });
                    if (StatusAktivitas === 'Waiting' || StatusAktivitas === 'Draft' || StatusAktivitas === 'Completed' || StatusAktivitas === "Editing" || StatusAktivitas === "Completed Edit") {
                        $.get(parent_url + `api/LookUpList/GetNewBLValue?NoReferensi=${IdReferensi}&Jenis=LPG`, function (data) {
                            if (data.success) {
                                $("#x_NewBl_mt").val(data.mt);
                                const sfadRaw = $("#x_SFAD_mt").val();
                                const sfad = parseFloat(sfadRaw || "0");
                                const newbl = parseFloat(data.mt);
                                if (!isNaN(sfad) && !isNaN(newbl) && newbl !== 0) {
                                    const result = ((sfad - newbl) / newbl);
                                    $("#R1_").text(result.toFixed(3) + "%");
                                } else {
                                    $("#R1_").text("0.000%");
                                }
                            }
                        });          
                    }
                    // $("#x_NewBl_mt").prop("readonly", true);
                }
            },
            error: function (xhr, status, error) {
                console.log("Error: " + xhr.responseText);
            }
        });
    }
    let uploadModal = `<div class="modal fade" id="warningValueModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
