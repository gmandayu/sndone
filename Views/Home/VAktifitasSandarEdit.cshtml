<script>
loadjs.ready("load", function() {
    // Startup script
    let status = $("#x_StatusAktivitas").val();
    let $btn = $("#btn-action");
    if (status == "Waiting") {
        $btn
            .removeClass("btn-success")     // hapus kelas hijau (jika ada)
            .addClass("btn-primary")        // biru
            .html('<i class="fas fa-save"></i> Save');
    } else if (status == "Draft") {
        $btn
            .removeClass("btn-primary")     // hapus kelas biru (jika ada)
            .addClass("btn-success")        // hijau
            .html('<i class="fas fa-paper-plane"></i> Submit');
    }
    var IdReferensi = "@vAktifitasSandarEdit.No_referensi.CurrentValue";
    var IdAktivitas = "@vAktifitasSandarEdit.IdAktivitas.CurrentValue";
    var IdProses = "@vAktifitasSandarEdit.IdProses.CurrentValue";
    var NamaAktivitas = "@vAktifitasSandarEdit.NamaAktivitas.CurrentValue";
    $('#r_IdProses').hide();
    var parent_url = ew.PATH_BASE;
    var steps = [
        { number: 1, label: "Penerimaan", url: `${parent_url}PenerimaanList`, icon: "fa-box-open" },
        { number: 2, label: "Proses", url: `${parent_url}ProsesList?cmd=search&x_IdReferensi%5B%5D=${IdReferensi}&search=&searchtype=`, icon: "fa-gears" },
        { number: 3, label: "Aktivitas", url: `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`, icon: "fa-list-check" },
        { number: 4, label: NamaAktivitas, url: `${parent_url}VAktifitasSandarEdit/${IdAktivitas}`, icon: "fa-file-circle-check" }
    ];
    var currentStep = 4;
    $("<style>")
        .prop("type", "text/css")
        .html(`
            .stepper {
                width: 50%;
                display: flex;
                counter-reset: step;
            }
            .step {
                flex: 1;
                text-align: center;
                position: relative;
            }
            .step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 20px;
                right: -50%;
                width: 100%;
                height: 4px;
                background-color: #ccc;
                z-index: 0;
            }
            .step.completed:not(:last-child)::after {
                background-color: #006BB7;
            }
            .step-icon {
                width: 36px;
                height: 36px;
                line-height: 36px;
                border-radius: 50%;
                background: #ccc;
                display: inline-block;
                z-index: 1;
                position: relative;
                color: white;
                font-weight: bold;
            }
            .step.active .step-icon {
                background: #006BB7;
            }
            .step-label {
                margin-top: 8px;
                font-size: 14px;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 6px;
                color: #333;
            }
            .step-label {
                color: #006BB7 !important;
                text-decoration: none;
                margin: 0;
                padding: 0;
            }
            .step-label-not-active {
                color: #CCCCCC !important;
            }
        `)
        .appendTo("head");
    var $stepperWrapper = $('<div class="d-flex border-bottom border-2 pb-2"><div class="stepper"></div></div>');
    var $stepper = $stepperWrapper.find(".stepper");
    steps.forEach(function (step, i) {
        var isActive = step.number === currentStep;
        var isCompleted = step.number < currentStep;
        var stepClass = isActive ? "active" : isCompleted ? "completed" : "";
        var icon, labelContent, html;
        if (isActive) {
            icon = `<div class="step-icon bg-success">${step.number}</div>`;
            labelContent = `<div class="step-label"><p class="text-success mb-1"><i class="fa-solid ${step.icon} me-1 text-success"></i> ${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-success">${icon}${labelContent}</div>`;
        } else if (isCompleted) {
            icon = `<div class="step-icon" style="background: #006BB7;">${step.number}</div>`;
            labelContent = `<div><a href="${step.url}" class="step-label"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</a></div>`;
            html = `<div class="step ${stepClass}">${icon}${labelContent}</div>`;
        } else {
            icon = `<div class="step-icon">${step.number}</div>`;
            labelContent = `<div class="step-label-not-active"><p style="margin: 0;"><i class="fa-solid ${step.icon} me-1"></i>${step.label}</p></div>`;
            html = `<div class="step ${stepClass} text-secondary">${icon}${labelContent}</div>`;
        }
        $stepper.append(html);
    });
    $(".content-header .container-fluid .row").append($stepperWrapper);
    $("#btn-action").hide();
    $("#btn-cancel").html('<i class="fa-solid fa-ban"></i></i> Cancel');
        const $cancelButton = $("#btn-cancel");
        if ($cancelButton.length) {
            // Sisipkan tombol custom
            let $customButtons = ``;
            let status = $("#x_StatusAktivitas").val();
            switch (status) {
            case "Waiting":
                $customButtons = `
                    <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-draft">
                        <i class="fas fa-save"></i> Save
                    </button>
                `;
                break;
            case "Draft":
                $customButtons = `
                    <button type="button" class="btn btn-primary ew-btn ml-2" id="btn-draft">
                        <i class="fas fa-save"></i> Save
                    </button>
                    <button type="button" class="btn btn-success ew-btn ml-2" id="btn-completed">
                        <i class="fas fa-paper-plane"></i> Submit
                    </button>
                `
                break;
            case "Completed":
                $customButtons = `
                    <button type="button" class="btn btn-warning ew-btn ml-2" id="btn-editCompleted">
                        <i class="fas fa-edit"></i> Edit Completed
                    </button>
                `;
                break;
            case "Waiting for Api":
                $customButtons = `
                    <button type="button" class="btn btn-success ew-btn ml-2" id="btn-submitCompleted">
                        <i class="fas fa-paper-plane"></i> Submit Completed
                    </button>
                `;
                break;
            }
            $cancelButton.before($customButtons);
        }
});
</script>
