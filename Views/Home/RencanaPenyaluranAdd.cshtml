<script>
loadjs.ready("head", function() {
    // Client script
    $('#fRencanaPenyaluranadd').on('submit', function (e) {
        e.preventDefault();
        showLoading();
        setTimeout(() => {
            hideLoading();
        }, 3000);
        this.requestSubmit();
    });
    $('#x_LookupJenisPlant').change(function () {
        if ($(this).val() == 'STS') {
            $('#r_TipeProdukSTS').show();
        } else {
            $('#r_TipeProdukSTS').hide();
            $('#x_TipeProdukSTS').val('');
        }
    });
    $('#x_LookupPlant').on("change", function () {
        const $this = $(this);
        const selectedValue = $this.val();
        const selectedText = $this.find('option:selected').text();
        $('#x_IdPlant').val(selectedValue || '').trigger('change');
        $('#sv_x_IdPlant').val(selectedText || '');
        // Clear dependent selects that rely on Plant (adjust if more fields become dependent)
        $('#x_IdModa').val(null).trigger('change');
        $('#x_TipePenyaluran').val(null).trigger('change');
        $('#x_KategoriPenyaluran').val(null).trigger('change');
    });
});
</script>
