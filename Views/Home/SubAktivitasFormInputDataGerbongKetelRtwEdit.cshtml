    List<Dictionary<string, object>> resultList = new List<Dictionary<string, object>>();
    string NoReferensi = subAktivitasFormInputDataGerbongKetelRtwEdit.NoReferensi.CurrentValue?.ToString();
    string IdAktivitas = subAktivitasFormInputDataGerbongKetelRtwEdit.idAktifitas.CurrentValue?.ToString();
    string TipeProses = "", Caption = "(KL)";
    string sqlQuery = @"
        WITH GerbongSplit AS (
            SELECT
                SA.id,
                value AS DetailGerbong,
                ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS rn
            FROM subAktivitasFormInputDataGerbongKetelRtw SA
            CROSS APPLY STRING_SPLIT(SA.DetailGerbong, ';')
            WHERE SA.NoReferensi = @NoReferensi
        ),
        QuantitySplit AS (
            SELECT
                SA.id,
                value AS DetailQuantity,
                ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS rn
            FROM subAktivitasFormInputDataGerbongKetelRtw SA
            CROSS APPLY STRING_SPLIT(ISNULL(SA.DetailQuantity, '0'), ';')
            WHERE SA.NoReferensi = @NoReferensi
        )
        SELECT
            g.DetailGerbong,
            q.DetailQuantity
        FROM GerbongSplit g
        LEFT JOIN QuantitySplit q
            ON g.id = q.id
        AND g.rn = q.rn
        ORDER BY g.rn;
    ";
    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection()) {
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection)) {
            command.Parameters.AddWithValue("@NoReferensi", NoReferensi);
            using (SqlDataReader rs = command.ExecuteReader()) {
                while (rs.Read()) {
                    Dictionary<string, object> row = new Dictionary<string, object>();
                    for (int i = 0; i < rs.FieldCount; i++) {
                        row[rs.GetName(i)] = rs[i] != null? rs[i] : "";
                    }
                    resultList.Add(row);
                }
            }
        }
        sqlQuery = "SELECT TOP 1 TipeProses FROM Aktivitas WHERE IdAktivitas = @IdAktivitas";
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection)) {
            command.Parameters.AddWithValue("@IdAktivitas", IdAktivitas);
            using (SqlDataReader rs = command.ExecuteReader()) {
                if (rs.Read()) {
                    TipeProses = rs[0] != null? rs[0].ToString() : "";
                }
            }
        }
    }
} *@
