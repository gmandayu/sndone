<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("PenyimpananSample");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    (() => {
        const parentURL = ew.PATH_BASE;
        const showMsg = (m) => (ew?.alert ? ew.alert(m) : alert(m));
        const showLoadingSafe = () => typeof showLoading === "function" && showLoading();
        const hideLoadingSafe = () => typeof hideLoading === "function" && hideLoading();
        $(function () {
            let filesArr = [];
            $("#cstm_x_Foto-Name").on("click", () => $("#cstm_x_Foto").trigger("click"));
            $("#cstm_x_Foto").on("change", function (e) {
                const newFiles = Array.from(e.target.files || []);
                if (!newFiles.length) return;
                newFiles.forEach((f) => {
                    const key = `${f.name}|${f.size}|${f.lastModified}`;
                    const exists = filesArr.some((x) => `${x.name}|${x.size}|${x.lastModified}` === key);
                    if (!exists) filesArr.push(f);
                });
                $(this).val("");
                renderTable();
            });
            function renderTable() {
                const $rowWrap = $("#row-table");
                const $tbody = $("#cstm_x_Foto-Table tbody");
                const $label = $("#cstm_x_Foto-Name");
                if (!$rowWrap.length) {
                    console.warn("#row-table tidak ditemukan");
                    return;
                }
                if (!$tbody.length) {
                    console.warn("#cstm_x_Foto-Table tbody tidak ditemukan");
                    return;
                }
                const count = filesArr.length;
                $label.val(count === 0 ? "Add Images" : count === 1 ? "1 file selected" : `${count} files selected`);
                $tbody.empty();
                if (count === 0) {
                    $rowWrap.hide();
                    return;
                }
                $rowWrap.show();
                filesArr.forEach((file, index) => {
                    const sizeKB = (file.size / 1024).toFixed(1);
                    $tbody.append(`
                            <tr>
                                <td class="text-center">${index + 1}</td>
                                <td>${escapeHtml(file.name)} <small class="text-muted">(${sizeKB} KB)</small></td>
                                <td class="text-center">
                                <button class="btn btn-sm text-danger btn-delete" type="button" data-index="${index}">
                                    <i class="fa-solid fa-times"></i>
                                </button>
                                </td>
                            </tr>
                        `);
                });
            }
            $("#row-table").on("click", ".btn-delete", function () {
                const idx = Number($(this).data("index"));
                if (!Number.isInteger(idx)) return;
                filesArr.splice(idx, 1);
                renderTable();
            });
            function escapeHtml(s) {
                return String(s).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;").replaceAll("'", "&#039;");
            }
            renderTable();
            const $plant = $("#x_IdPlant");
            $plant.empty().append('<option value="">Please Select</option>');
            $.getJSON(`${parentURL}api/LookUpList/get-dropdown/plant`)
                .done((rows) => {
                    rows.forEach((r) => $plant.append(new Option(r.Label, r.Value)));
                    if (rows.length > 0) $plant.val(rows[0].Value).trigger("change");
                })
                .fail(() => showMsg("Gagal load data Plant."));
            $("#btn-submit-custom").on("click", function (e) {
                e.preventDefault();
                const formData = new FormData();
                const jenisSample = $("#x_JenisSample").val();
                const idPlant = $("#x_IdPlant").val();
                const tanggal = $("#x_Tanggal").val();
                const namaMasterSample = $("#x_NamaMasterSample").val();
                const expired = $("#x_ExpiredEst").val();
                if (!jenisSample) return showMsg("Jenis Sample wajib diisi.");
                if (!idPlant) return showMsg("Plant wajib diisi.");
                if (!tanggal) return showMsg("Tanggal wajib diisi.");
                if (!namaMasterSample) return showMsg("Nama Master Sample wajib diisi.");
                if (!expired) return showMsg("Expired Est wajib diisi.");

                ["JenisSample", "IdPlant", "NamaMasterSample", "NomorSegel", "Tanggal", "ExpiredEst"].forEach((f) => {
                    const v = $(`#x_${f}`).val();
                    if (v) formData.set(f, v);
                });
                filesArr.forEach((f) => formData.append("Foto", f));
                showLoadingSafe();
                $.ajax({
                    url: `${parentURL}api/qq/psm-add`,
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: (res) => {
                        hideLoadingSafe();
                        if(!res?.success) {
                            showMsg(res?.message || 'An error occurred while adding record')
                            return;
                        }
                        showMsg(res?.message || "Berhasil menambahkan data.");
                        window.location.href = `${parentURL}PenyimpananSampleList`;
                    },
                    error: (xhr) => showMsg(xhr.responseJSON?.message || "Gagal menyimpan data."),
                    complete: hideLoadingSafe,
                });
            });
            $("#btn-cancel-custom").on("click", function (e) {
                e.preventDefault();
                window.location.href = `${parentURL}PenyimpananSampleList`;
            });
        });
    })();
});
</script>
