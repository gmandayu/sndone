        <td data-name="NomorPenerimaan" @Html.Raw(penerimaanView.NomorPenerimaan.CellAttributes)>
<span id="el_Penerimaan_NomorPenerimaan">
<span @Html.Raw(penerimaanView.NomorPenerimaan.ViewAttributes)>
@Html.Raw(penerimaanView.NomorPenerimaan.GetViewValue())</span>
