@if (!bukuTamuList.IsExport()) {
<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("BukuTamu");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    const parent_url = ew.PATH_BASE;
    (function () {
        var originalSubmit = HTMLFormElement.prototype.submit;
        HTMLFormElement.prototype.submit = function () {
            if (this.id === 'fBukuTamusrch') {
                var regionVal = $('#filter-region').val() || 'All';
                var plantVal = $('#filter-plant').val() || 'All';
                $('#x_filterRegion', this).val(regionVal);
                $('#x_filterPlant', this).val(plantVal);
            }
            return originalSubmit.apply(this, arguments);
        };
    })();
    $(document).ready(function () {
        // Add New button
        var oldButton = $('button.btn-primary[name="btn-submit"]');
        var addButton = $('<button class="btn btn-success ms-1" id="btn-add-custom"><i class="fas fa-plus"></i> Add New</button>');
        addButton.on('click', function (e) {
            e.preventDefault();
            window.location.href = parent_url + 'BukuTamuAdd';
        });
        oldButton.parent().append(addButton);

        // Dropdown setup
        const cfg = window._bukuTamuFilterConfig;
        const regions = cfg?.regions ?? [];
        const plants = cfg?.plants ?? [];
        const $regionSelect = $('#filter-region');
        const $plantSelect = $('#filter-plant');

        // Populate regions
        regions.forEach(r => $regionSelect.append($('<option>').val(r.idRegion).text(r.namaRegion)));
        function loadPlants(regionId) {
            $plantSelect.empty().append('<option value="All"> All </option>');
            const filtered = (!regionId || regionId === 'All')
                ? plants
                : plants.filter(p => p.idRegion === regionId);
            filtered.forEach(p => $plantSelect.append($('<option>').val(p.idPlant).text(p.namaPlant)));
        }
        loadPlants('All');

        // Fungsi highlight
        function highlightMatch(text, search) {
            if (!search) return $('<span>').text(text);
            var regex = new RegExp('(' + search.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
            var $span = $('<span>');
            $span.html(
                $('<span>').text(text).html()
                    .replace(regex, '<mark style="background:#ff0;padding:0;font-weight:bold;">$1</mark>')
            );
            return $span;
        }

        // Apply Select2
        $regionSelect.select2({
            placeholder: ' All ',
            allowClear: true,
            width: '100%',
            templateResult: function (data) {
                if (!data.id) return data.text;
                var search = $('.select2-search--dropdown .select2-search__field').val() || '';
                return highlightMatch(data.text, search);
            }
        });
        $plantSelect.select2({
            placeholder: ' All ',
            allowClear: true,
            width: '100%',
            templateResult: function (data) {
                if (!data.id) return data.text;
                var search = $('.select2-search--dropdown .select2-search__field').val() || '';
                return highlightMatch(data.text, search);
            }
        });
        // Tutup dropdown lain saat salah satu dibuka
        $regionSelect.on('select2:open', function () {
            $plantSelect.select2('close');
        });
        $plantSelect.on('select2:open', function () {
            $regionSelect.select2('close');
        });

        // Tutup semua dropdown saat klik X
        $regionSelect.on('select2:clear', function () {
            $plantSelect.select2('close');
        });
        $plantSelect.on('select2:clear', function () {
            $regionSelect.select2('close');
        });

        // Region change handler — dengan validasi plant
        $regionSelect.on('change', function () {
            var val = $(this).val() || 'All';
            var currentPlant = $plantSelect.val();
            loadPlants(val);
            if (currentPlant && currentPlant !== 'All') {
                var plantExistsInRegion = $plantSelect.find('option[value="' + currentPlant + '"]').length > 0;
                if (plantExistsInRegion) {
                    $plantSelect.val(currentPlant).trigger('change');
                } else {
                    $plantSelect.val(null).trigger('change');
                }
            } else {
                $plantSelect.val(null).trigger('change');
            }
            updateResetButton();
        });
        $plantSelect.on('change', function () {
            updateResetButton();
        });
        function updateResetButton() {
            var urlParams = new URLSearchParams(window.location.search);
            var activeRegion = urlParams.get('x_filterRegion') || 'All';
            var activePlant = urlParams.get('x_filterPlant') || 'All';
            var $resetBtn = $('#btn-custom-reset');
            if (activeRegion !== 'All' || activePlant !== 'All') {
                $('.ew-show-all').hide();
                if ($resetBtn.length === 0) {
                    var $btn = $('<a id="btn-custom-reset" class="btn btn-default btn-sm" role="button" title="Show all" data-bs-placement="bottom" style="cursor:pointer"><i class="icon-reset-search ew-icon"></i></a>');
                    $('.ew-search-option .btn-group-sm').append($btn);
                    new bootstrap.Tooltip($btn[0], { placement: 'bottom' });
                }
                $('#btn-custom-reset').show();
            } else {
                $('.ew-show-all').show();
                $resetBtn.hide();
            }
        }

        // Inject filter ke export links
        function updateExportLinks() {
            var urlParams = new URLSearchParams(window.location.search);
            var regionVal = urlParams.get('x_filterRegion') || 'All';
            var plantVal = urlParams.get('x_filterPlant') || 'All';
            if (regionVal === 'All' && plantVal === 'All') return;
            $('.ew-export-link').each(function () {
                try {
                    var url = new URL($(this).attr('href'), window.location.origin);
                    url.searchParams.set('x_filterRegion', regionVal);
                    url.searchParams.set('x_filterPlant', plantVal);
                    $(this).attr('href', url.toString());
                } catch (e) { }
            });
        }

        // Restore dari URL
        const urlParams = new URLSearchParams(window.location.search);
        var savedRegion = urlParams.get('x_filterRegion') || 'All';
        var savedPlant = urlParams.get('x_filterPlant') || 'All';
        if (savedRegion !== 'All') {
            $regionSelect.val(savedRegion).trigger('change');
            loadPlants(savedRegion);
        }
        setTimeout(function () {
            if (savedPlant !== 'All') $plantSelect.val(savedPlant).trigger('change');
            if (savedRegion !== 'All' || savedPlant !== 'All') updateResetButton();
            updateExportLinks();
        }, 100);

        // Intercept semua aksi EW (sort, pagination, page size)
        $(document).on('click', '[data-ew-action="redirect"],[data-ew-action="sort"],[data-ew-action="change-page-size"]', function (e) {
            var regionVal = $regionSelect.val() || 'All';
            var plantVal = $plantSelect.val() || 'All';
            if (regionVal === 'All' && plantVal === 'All') return;
            e.preventDefault();
            e.stopImmediatePropagation();
            var targetUrl = $(this).data('url') || $(this).data('sort-url') || $(this).attr('href');
            if (!targetUrl) return;
            try {
                var u = new URL(targetUrl, window.location.origin);
                u.searchParams.set('x_filterRegion', regionVal);
                u.searchParams.set('x_filterPlant', plantVal);
                window.location.href = u.toString();
            } catch (err) { }
        });

        // Override ew.redirect sebagai fallback
        var _origRedirect = ew.redirect;
        ew.redirect = function (url) {
            try {
                var regionVal = $regionSelect.val() || 'All';
                var plantVal = $plantSelect.val() || 'All';
                if (regionVal === 'All' && plantVal === 'All') return _origRedirect.call(this, url);
                var u = new URL(url, window.location.origin);
                u.searchParams.set('x_filterRegion', regionVal);
                u.searchParams.set('x_filterPlant', plantVal);
                return _origRedirect.call(this, u.toString());
            } catch (e) { return _origRedirect.call(this, url); }
        };

        // Clear column filter
        $(document).on('click', '.ew-filter-clear', function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
            var regionVal = $regionSelect.val() || 'All';
            var plantVal = $plantSelect.val() || 'All';
            var url = new URL(window.location.href);
            Array.from(url.searchParams.keys()).forEach(function (key) {
                if (key.startsWith('x_') && key !== 'x_filterRegion' && key !== 'x_filterPlant')
                    url.searchParams.delete(key);
            });
            url.searchParams.delete('cmd');
            if (regionVal !== 'All') url.searchParams.set('x_filterRegion', regionVal);
            else url.searchParams.delete('x_filterRegion');
            if (plantVal !== 'All') url.searchParams.set('x_filterPlant', plantVal);
            else url.searchParams.delete('x_filterPlant');
            window.location.href = url.toString();
        });

        // Reset / Show all
        $(document).on('click', '#btn-custom-reset', function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
            $regionSelect.val(null).trigger('change');
            $plantSelect.val(null).trigger('change');
            window.location.href = parent_url + 'BukuTamuList?cmd=reset';
        });
    });
});
</script>
}
