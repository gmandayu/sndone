@{
    // View
    View = this;

    // Check action result
    if (penerimaanAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penerimaanAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(penerimaanAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penerimaan: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fPenerimaanadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenerimaanadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["NomorVoyage", [fields.NomorVoyage.visible && fields.NomorVoyage.required ? ew.Validators.required(fields.NomorVoyage.caption) : null], fields.NomorVoyage.isInvalid],
            ["NomorPengiriman", [fields.NomorPengiriman.visible && fields.NomorPengiriman.required ? ew.Validators.required(fields.NomorPengiriman.caption) : null], fields.NomorPengiriman.isInvalid],
            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["IdPlant", [fields.IdPlant.visible && fields.IdPlant.required ? ew.Validators.required(fields.IdPlant.caption) : null, ew.Validators.integer], fields.IdPlant.isInvalid],
            ["TipeProdukSTS", [fields.TipeProdukSTS.visible && fields.TipeProdukSTS.required ? ew.Validators.required(fields.TipeProdukSTS.caption) : null], fields.TipeProdukSTS.isInvalid],
            ["KodeProduk", [fields.KodeProduk.visible && fields.KodeProduk.required ? ew.Validators.required(fields.KodeProduk.caption) : null], fields.KodeProduk.isInvalid],
            ["ModaTransportasi", [fields.ModaTransportasi.visible && fields.ModaTransportasi.required ? ew.Validators.required(fields.ModaTransportasi.caption) : null], fields.ModaTransportasi.isInvalid],
            ["NamaKapal", [fields.NamaKapal.visible && fields.NamaKapal.required ? ew.Validators.required(fields.NamaKapal.caption) : null], fields.NamaKapal.isInvalid],
            ["Refinery", [fields.Refinery.visible && fields.Refinery.required ? ew.Validators.required(fields.Refinery.caption) : null], fields.Refinery.isInvalid],
            ["IdPenyaluran", [fields.IdPenyaluran.visible && fields.IdPenyaluran.required ? ew.Validators.required(fields.IdPenyaluran.caption) : null], fields.IdPenyaluran.isInvalid],
            ["TanggalSandar", [fields.TanggalSandar.visible && fields.TanggalSandar.required ? ew.Validators.required(fields.TanggalSandar.caption) : null, ew.Validators.datetime(fields.TanggalSandar.clientFormatPattern)], fields.TanggalSandar.isInvalid],
            ["IdDermaga", [fields.IdDermaga.visible && fields.IdDermaga.required ? ew.Validators.required(fields.IdDermaga.caption) : null], fields.IdDermaga.isInvalid],
            ["StatusProses", [fields.StatusProses.visible && fields.StatusProses.required ? ew.Validators.required(fields.StatusProses.caption) : null], fields.StatusProses.isInvalid],
            ["PersentaseProgress", [fields.PersentaseProgress.visible && fields.PersentaseProgress.required ? ew.Validators.required(fields.PersentaseProgress.caption) : null], fields.PersentaseProgress.isInvalid],
            ["IdTemplate", [fields.IdTemplate.visible && fields.IdTemplate.required ? ew.Validators.required(fields.IdTemplate.caption) : null], fields.IdTemplate.isInvalid],
            ["Catatan", [fields.Catatan.visible && fields.Catatan.required ? ew.Validators.required(fields.Catatan.caption) : null], fields.Catatan.isInvalid],
            ["DibuatOleh", [fields.DibuatOleh.visible && fields.DibuatOleh.required ? ew.Validators.required(fields.DibuatOleh.caption) : null], fields.DibuatOleh.isInvalid],
            ["TanggalDibuat", [fields.TanggalDibuat.visible && fields.TanggalDibuat.required ? ew.Validators.required(fields.TanggalDibuat.caption) : null], fields.TanggalDibuat.isInvalid],
            ["DiperbaruiOleh", [fields.DiperbaruiOleh.visible && fields.DiperbaruiOleh.required ? ew.Validators.required(fields.DiperbaruiOleh.caption) : null], fields.DiperbaruiOleh.isInvalid],
            ["TanggalDiperbarui", [fields.TanggalDiperbarui.visible && fields.TanggalDiperbarui.required ? ew.Validators.required(fields.TanggalDiperbarui.caption) : null], fields.TanggalDiperbarui.isInvalid],
            ["LookupTipeProduk", [fields.LookupTipeProduk.visible && fields.LookupTipeProduk.required ? ew.Validators.required(fields.LookupTipeProduk.caption) : null], fields.LookupTipeProduk.isInvalid],
            ["LookupJenisPlant", [fields.LookupJenisPlant.visible && fields.LookupJenisPlant.required ? ew.Validators.required(fields.LookupJenisPlant.caption) : null], fields.LookupJenisPlant.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "LookupPlant": @Html.Raw(penerimaanAdd.LookupPlant.ToClientList(penerimaanAdd)),
            "IdPlant": @Html.Raw(penerimaanAdd.IdPlant.ToClientList(penerimaanAdd)),
            "TipeProdukSTS": @Html.Raw(penerimaanAdd.TipeProdukSTS.ToClientList(penerimaanAdd)),
            "KodeProduk": @Html.Raw(penerimaanAdd.KodeProduk.ToClientList(penerimaanAdd)),
            "ModaTransportasi": @Html.Raw(penerimaanAdd.ModaTransportasi.ToClientList(penerimaanAdd)),
            "Refinery": @Html.Raw(penerimaanAdd.Refinery.ToClientList(penerimaanAdd)),
            "IdPenyaluran": @Html.Raw(penerimaanAdd.IdPenyaluran.ToClientList(penerimaanAdd)),
            "IdDermaga": @Html.Raw(penerimaanAdd.IdDermaga.ToClientList(penerimaanAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    var parent_url = ew.PATH_BASE;
    $('#fPenerimaanadd button[type=submit]').on('click', function (e) {
        e.preventDefault();
        const parent_url = ew.PATH_BASE;
        const UserLevel = "@CurrentUserLevel()";
        const idRole = '@CurrentUserInfo("Rule")?.ToString()';
        const idModa = $('#x_ModaTransportasi').val();
        const idPenyaluran = $('#x_IdPenyaluran').val();
        const lookupPlant = $('#x_LookupPlant').val();
        const idDermaga = $('#x_IdDermaga').val();
        $('#x_IdPlant').val(lookupPlant);
        if ((idModa == '1' || idModa == '2') && !idDermaga) {
        ew.alert('Dermaga tidak boleh kosong');
        return false;
        }
        if ((idModa == '4') && !idPenyaluran) { // RTW
            ew.alert('Penyaluran tidak boleh kosong');
            return false;
        }
        if ((idModa == '3') && !idPenyaluran) { // Truck
                ew.alert('Penyaluran tidak boleh kosong');
                return false;
            }
        if (UserLevel != "2" && UserLevel != "-1" && UserLevel != "4" && UserLevel != "5" && idRole != '1' && idRole != '12' && idRole != '13') {
            ew.alert('Anda tidak memiliki akses untuk menambah data Penerimaan.');
            setTimeOut(() => {
                window.location.href = parent_url+'PenerimaanList';
            }, 1000);
            return false;
        }
        const data = {
            IdPlant: $('#x_IdPlant').val(),
            KodeProduk: $('#x_KodeProduk').val(),
            ModaTransportasi: $('#x_ModaTransportasi').val(),
            NamaKapal: $('#x_NamaKapal').val(),
            TanggalSandar: $('#x_TanggalSandar').val(),
            IdDermaga: $('#x_IdDermaga').val()
        };
        showLoading();
        $.ajax({
            url: parent_url + 'api/LookUpList/CheckDuplicateReferensi',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                Referensi: 'Penerimaan',
                Data: data
            }),
            success: function (res) {
                if (res.success && !res.duplicate) {
                    $('#fPenerimaanadd').submit();
                    setTimeout(() => {
                        hideLoading();
                    }, 3000);
                } else if (res.success && res.duplicate) {
                    hideLoading();
                    ew.alert({
                        text: "Telah ditemukan ada data yang sama, apakah anda yakin ingin menambah data ini?",
                        showCancelButton: true,
                        confirmButtonText: 'Yes',
                        cancelButtonText: 'Cancel',
                    }).then((result) => {
                        if (result.isConfirmed) {
                            showLoading();
                            setTimeout(function () {
                                hideLoading();
                            }, 3000);
                            $('#fPenerimaanadd').submit();
                        } else if (result.dismiss === 'cancel') {
                            return false;
                        }
                    });
                }
            },
            error: function (err) {
                hideLoading();
                ew.alert('An error occured on the server.');
                console.error(err);
                return false;
            }
        });
    });
    $('#x_LookupJenisPlant').change(function () {
        if ($(this).val() == 'STS') {
            $('#r_TipeProdukSTS').show();
        } else {
            $('#r_TipeProdukSTS').hide();
            $('#x_TipeProdukSTS').val('');
        }
    });
    $('#x_LookupPlant').on("change", function () {
        const selectedValue = $(this).val();
        $('#x_IdPlant').val(selectedValue).trigger('change');
        let idModa = $('#x_ModaTransportasi').val();
        if (idModa && (idModa == 5 || idModa == 6)){
            fillIdPenyaluranList(selectedValue, idModa)
        } else if (idModa && (idModa == 4)){ // RTW
            fillIdPenyaluranList(selectedValue, idModa)
        } else if (idModa && (idModa == 3)){ // Truck
            fillIdPenyaluranList(selectedValue, idModa)
        } else {
            $('#r_IdPenyaluran').hide();
        }
    });
    $('#x_ModaTransportasi').on("change", function () {
        const selectedValue = $(this).val();
        let idPlant = $('#x_LookupPlant').val();
        if (idPlant && (selectedValue == 5 || selectedValue == 6)){
            fillIdPenyaluranList(idPlant, selectedValue);
            $('#r_NamaKapal').hide();
            $('#r_IdDermaga').hide();
            $('#r_NomorVoyage').hide();
            $('#x_NamaKapal').val('');
            $('#x_IdDermaga').val('');
            $('#x_NomorVoyage').val('');
            $('#elh_Penerimaan_TanggalSandar').contents().first()[0].textContent = 'Tanggal';
            $('#x_TanggalSandar').attr('placeholder', 'Tanggal');
            $('#r_Refinery').show();
        } else if (idPlant && (selectedValue == 4)){ // RTW
            fillIdPenyaluranList(idPlant, selectedValue);
            $('#r_NamaKapal').hide();
            $('#r_IdDermaga').hide();
            $('#r_NomorVoyage').hide();
            $('#r_Refinery').hide();
            $('#x_NamaKapal').val('');
            $('#x_IdDermaga').val('');
            $('#x_NomorVoyage').val('');
            $('#x_Refinery').prop("checked", false);
            $('#elh_Penerimaan_TanggalSandar').contents().first()[0].textContent = 'Tanggal';
            $('#x_TanggalSandar').attr('placeholder', 'Tanggal');
        } else if (idPlant && selectedValue == 3){ // Truck
            fillIdPenyaluranList(idPlant, selectedValue);
            $('#r_NamaKapal').hide();
            $('#r_IdDermaga').hide();
            $('#r_NomorVoyage').hide();
            $('#r_Refinery').hide();
            $('#x_NamaKapal').val('');
            $('#x_IdDermaga').val('');
            $('#x_NomorVoyage').val('');
            $('#x_Refinery').prop("checked", false);
            $('#elh_Penerimaan_TanggalSandar').contents().first()[0].textContent = 'Tanggal';
            $('#x_TanggalSandar').attr('placeholder', 'Tanggal');
        } else if (selectedValue == 4) {
            $('#r_NamaKapal').hide();
            $('#r_IdDermaga').hide();
            $('#r_NomorVoyage').hide();
            $('#r_Refinery').hide();
            $('#x_NamaKapal').val('');
            $('#x_IdDermaga').val('');
            $('#x_NomorVoyage').val('');
            $('#x_Refinery').prop("checked", false);
            $('#elh_Penerimaan_TanggalSandar').contents().first()[0].textContent = 'Tanggal';
            $('#x_TanggalSandar').attr('placeholder', 'Tanggal');
        } else {
            $('#elh_Penerimaan_TanggalSandar').contents().first()[0].textContent = 'Tanggal Sandar';
            $('#x_TanggalSandar').attr('placeholder', 'Tanggal Sandar');
            $('#r_NamaKapal').show();
            $('#r_IdDermaga').show();
            $('#r_NomorVoyage').show();
            $('#r_IdPenyaluran').hide();
            $('#r_Refinery').hide();
            $('#x_IdPenyaluran').val('');
            $('#x_Refinery').prop("checked", false);
        }
    });
    function fillIdPenyaluranList(idPlant, idModa){
        const penyaluranSelection = $("#x_IdPenyaluran");
        penyaluranSelection.empty();
        penyaluranSelection.append('<option value="">Loading...</option>');
        $.ajax({
            url: parent_url + 'api/LookUpList/get-dropdown/penyaluran-to-penerimaan',
            method: 'GET',
            dataType: 'json',
            data: {
                plantId: idPlant,
                modaId: idModa
            },
            success: function (data) {
                penyaluranSelection.empty(); 
                $.each(data, function (index, item) {
                    penyaluranSelection.append(`<option value="${item.Value}">${item.Label}</option>`);
                });
            },
            error: function (xhr, status, error) {
                console.error("Gagal ambil data dropdown:", error);
                penyaluranSelection.empty();
            },
            complete: function () {
                $('#r_IdPenyaluran').show();
            }     
        });
    }
});
</script>
