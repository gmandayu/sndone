            ["nominasi", [fields.nominasi.visible && fields.nominasi.required ? ew.Validators.required(fields.nominasi.caption) : null, ew.Validators.float], fields.nominasi.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    var nominasi = fobj.elements["x_nominasi"]?.value || "";
                    var regex = /^[0-9]*\.?[0-9]*$/;
                    if (!regex.test(nominasi)) {
                        alert("Kolom nominasi hanya boleh berisi angka dan titik desimal.");
                        return false;
                    } 
                    if (nominasi == "0"){
                        alert("Kolom tidak boleh bernilai 0.");
                        return false;
                    }
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    // Write your client script here, no need to add script tags.
    var IdProses = "@subaktivitasDataKapalEdit.idProses.CurrentValue";
    var NoReferensi = "@subaktivitasDataKapalEdit.NoReferensi.CurrentValue";
    var parent_url = ew.PATH_BASE;
    function handleCustomSubmit(status) {
        let tgltibaVal = $("#x_tgltiba").val();
        let noReferensi = $("#x_NoReferensi").val();
        let idAktivitas = $("#x_idAktifitas").val();
        const originalStatus = document.querySelector('#el_SubaktivitasDataKapal_StatusAktivitas .form-control-plaintext').textContent;

        // Validasi tanggal sandar
        $.ajax({
            url: parent_url + 'api/LookUpList/get_tanggal_tiba_sandar',
            type: 'GET',
            data: {
                NoReferensi: noReferensi,
                Menu: "Penerimaan"
            },
            beforeSend: function () {
                showLoading();
            },
            success: function (rs) {
                let tanggalSandar = new Date(rs.tanggalSandar);
                if (!tgltibaVal) {
                    hideLoading();
                    ew.alert("Tanggal tiba tidak boleh kosong");
                    return;
                }
                let tanggalTiba = new Date(tgltibaVal);
                if (tanggalTiba > tanggalSandar) {
                    hideLoading();
                    ew.alert("Tanggal tiba tidak boleh melebihi dari tanggal sandar");
                    return;
                }
                $.ajax({
                    url: parent_url + `api/LookUpList/check_valid_status_aktivitas?idAktivitas=${idAktivitas}&originalStatus=${originalStatus}`,
                    type: 'GET',
                    success: function (response) {
                        if (!response.IsValid){
                            hideLoading();
                            ew.alert(response.Message ?? "Status aktivitas telah diubah oleh pengguna lain");
                            return;
                        } else {
                            // Submit form AJAX
                            let form = $("#fSubaktivitasDataKapaledit");
                            $.ajax({
                                url: form.attr("action"),
                                type: form.attr("method"),
                                data: form.serialize(),
                                success: function (response) {
                                    updateStatus(idAktivitas, status);
                                },
                                error: function (xhr, status, error) {
                                    hideLoading();
                                    ew.alert("Gagal menyimpan data.");
                                    console.error("Form submit gagal:", error);
                                }
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        hideLoading();
                        ew.alert("Gagal menyimpan data.");
                        console.error("Form submit gagal:", error);
                    }
                });
            },
            error: function (xhr, status, error) {
                hideLoading();
                console.error("Gagal mengambil tanggal sandar:", error);
            }
        });
    }
    function updateStatus(idAktivitas, status) {
        $.ajax({
            url: parent_url + `api/LookUpList/update_status_aktivitas?idAktivitas=${idAktivitas}&statusAktivitas=${status}`,
            type: 'POST',
            success: function () {
                $.ajax({
                    url: parent_url + 'api/LookUpList/generate_etc',
                    method: 'POST',
                    data: JSON.stringify({ NoReferensi: NoReferensi }),
                    contentType: 'application/json',
                    success: function (res) {
                        setTimeout(function () {
                            if (status == "Completed" || status == "Completed Edit") {
                                window.location.href = `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`;
                            } else {
                                location.reload();
                            }
                        }, 1000);
                    },
                    error: function (err) {
                        hideLoading();
                        ew.alert('Perubahan gagal disimpan.');
                        console.error(err);
                    },
                });
            },
            error: function (xhr, status, error) {
                ew.alert("Status gagal diperbarui.");
                console.error("Update status gagal:", error);
            },
            complete: function () {
                hideLoading();
            }
        });
    }
    function reverseStatus(status, catatan) {
        showLoading();
        let idAktivitas = $("#x_idAktifitas").val();
        $.ajax({
                url: parent_url + `api/LookUpList/update_status_aktivitas-v2`,
                type: 'POST',
                data: JSON.stringify({ IdAktivitas: idAktivitas, StatusAktivitas: status, Catatan: catatan ?? null }),
                contentType: 'application/json',
                success: function () {
                    $.ajax({
                        url: parent_url + 'api/LookUpList/generate_etc',
                        method: 'POST',
                        data: JSON.stringify({ NoReferensi: NoReferensi }),
                        contentType: 'application/json',
                        success: function (res) {
                            setTimeout(function () {
                                window.location.href = `${parent_url}AktivitasList?cmd=search&x_IdProses%5B%5D=${IdProses}&search=&searchtype=`;
                            }, 1000);
                        },
                        error: function (err) {
                            hideLoading();
                            ew.alert('Perubahan gagal disimpan.');
                            console.error(err);
                        },
                    });
                },
                error: function (xhr, status, error) {
                    ew.alert("Status gagal diperbarui.");
                    console.error("Update status gagal:", error);
                },
                complete: function () {
                    hideLoading();
                }
            });
        }
    $(document).on("click", "#btn-draft", function () {
        handleCustomSubmit("Draft");
    });
    $(document).on("click", "#btn-completed", function () {
        handleCustomSubmit("Completed");
    });
    $(document).on("click", "#btn-editing", function () {
        handleCustomSubmit("Editing");
    });
    $(document).on("click", "#btn-completedEdit", function () {
        handleCustomSubmit("Completed Edit");
    });
    $(document).on("submit", "#reverseStatusEditingModalForm", function (e) {
        e.preventDefault();
        let catatanText = $("#catatanReverseStatusEditing").val();
        reverseStatus("Editing", catatanText);
    });
});
</script>
