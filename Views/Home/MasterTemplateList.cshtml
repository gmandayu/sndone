@if (!masterTemplateList.IsModal) {
<form name="fMasterTemplatesrch" id="fMasterTemplatesrch" class="ew-form ew-ext-search-form" action="@AppPath(CurrentPageName())" novalidate autocomplete="off">
<div id="fMasterTemplatesrch_search_panel" class="mb-2 mb-sm-0 @(masterTemplateList.SearchPanelClass)"><!-- .ew-search-panel -->
<script>
var currentTable = @Html.Raw(ConvertToJson(masterTemplateList.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterTemplate: currentTable } });
var currentForm;
var fMasterTemplatesrch, currentSearchForm, currentAdvancedSearchForm;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery,
        fields = currentTable.fields;

    // Form object for search
    let form = new ew.FormBuilder()
        .setId("fMasterTemplatesrch")
        .setPageId("list")
@if (masterTemplateList.UseAjaxActions) {
        <text>.setSubmitWithFetch(true)</text>
}

        // Add fields
        .setFields([
        ])
        // Validate form
        .setValidate(
            async function () {
                if (!this.validateRequired)
                    return true; // Ignore validation
                let fobj = this.getForm();

                // Validate fields
                if (!this.validateFields())
                    return false;

                // Call Form_CustomValidate event
                if (!(await this.customValidate?.(fobj) ?? true)) {
                    this.focus();
                    return false;
                }
                return true;
            }
        )

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "NamaTemplate": @Html.Raw(masterTemplateList.NamaTemplate.ToClientList(masterTemplateList)),
            "IdModa": @Html.Raw(masterTemplateList.IdModa.ToClientList(masterTemplateList)),
            "JenisProses": @Html.Raw(masterTemplateList.JenisProses.ToClientList(masterTemplateList)),
            "Keterangan": @Html.Raw(masterTemplateList.Keterangan.ToClientList(masterTemplateList)),
            "DibuatOleh": @Html.Raw(masterTemplateList.DibuatOleh.ToClientList(masterTemplateList)),
            "TanggalDibuat": @Html.Raw(masterTemplateList.TanggalDibuat.ToClientList(masterTemplateList)),
            "DiperbaruiOleh": @Html.Raw(masterTemplateList.DiperbaruiOleh.ToClientList(masterTemplateList)),
            "TanggalDiperbarui": @Html.Raw(masterTemplateList.TanggalDiperbarui.ToClientList(masterTemplateList)),
            "TipePenimbunan": @Html.Raw(masterTemplateList.TipePenimbunan.ToClientList(masterTemplateList)),
            "TipePenyaluran": @Html.Raw(masterTemplateList.TipePenyaluran.ToClientList(masterTemplateList)),
            "KategoriPenyaluran": @Html.Raw(masterTemplateList.KategoriPenyaluran.ToClientList(masterTemplateList)),
            "NamaDokumen": @Html.Raw(masterTemplateList.NamaDokumen.ToClientList(masterTemplateList)),
        })

        // Filters
        .setFilterList(@Html.Raw(masterTemplateList.GetFilterList()))
        .build();
    window[form.id] = form;
    currentSearchForm = form;
    loadjs.done(form.id);
});
</script>
