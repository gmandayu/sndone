@{
    // View
    View = this;

    // Check action result
    if (masterPipaEdit.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = masterPipaEdit.UseLayout ? "_Layout" : "";
}
@masterPipaEdit.ShowPageHeader()
@masterPipaEdit.ShowMessages()
<main class="edit">
<form name="fMasterPipaedit" id="fMasterPipaedit" class="@(masterPipaEdit.FormClassName)" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
<script>
var currentTable = @Html.Raw(ConvertToJson(masterPipaEdit.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { MasterPipa: currentTable } });
var currentPageID = ew.PAGE_ID = "edit";
var currentForm;
var fMasterPipaedit;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fMasterPipaedit")
        .setPageId("edit")

        // Add fields
        .setFields([

            ["KeteranganPipa", [fields.KeteranganPipa.visible && fields.KeteranganPipa.required ? ew.Validators.required(fields.KeteranganPipa.caption) : null], fields.KeteranganPipa.isInvalid],
            ["idPlantAsal", [fields.idPlantAsal.visible && fields.idPlantAsal.required ? ew.Validators.required(fields.idPlantAsal.caption) : null], fields.idPlantAsal.isInvalid],
            ["Flowrate", [fields.Flowrate.visible && fields.Flowrate.required ? ew.Validators.required(fields.Flowrate.caption) : null, ew.Validators.float], fields.Flowrate.isInvalid],
            ["BiayaProject", [fields.BiayaProject.visible && fields.BiayaProject.required ? ew.Validators.required(fields.BiayaProject.caption) : null, ew.Validators.float], fields.BiayaProject.isInvalid],
            ["PlantAsal", [fields.PlantAsal.visible && fields.PlantAsal.required ? ew.Validators.required(fields.PlantAsal.caption) : null], fields.PlantAsal.isInvalid],
            ["NamaPlantAsal", [fields.NamaPlantAsal.visible && fields.NamaPlantAsal.required ? ew.Validators.required(fields.NamaPlantAsal.caption) : null], fields.NamaPlantAsal.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "idPlantAsal": @Html.Raw(masterPipaEdit.idPlantAsal.ToClientList(masterPipaEdit)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Client script
    $("#x_Panjang, #x_Diameter, #x_Volume, #x_Flowrate, #x_Panjang2, #x_Diameter2, #x_Volume2, #x_Flowrate2, #x_Panjang3, #x_Diameter3, #x_Volume3, #x_Flowrate3")
        .attr('inputmode', 'numeric')
        .on('input', function () {
            let val = $(this).val();
            let isNegative = val.startsWith('-');
            val = val.replace(',', '.');
            val = val.replace(/[^0-9.]/g, '');
            const parts = val.split('.');
            if (parts.length > 2) {
                val = parts[0] + '.' + parts.slice(1).join('');
            }
            if (isNegative) {
                val = '-' + val;
            }
            $(this).val(val);
        });
});
</script>
