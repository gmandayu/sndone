<template id="tpm_SetPjsview">
<div id="ct_setPjsView">@{
    string id = setPjsView.Id.CurrentValue.ToString();
    string status = setPjsView.Status.CurrentValue.ToString();
    string idUserPjs = setPjsView.DibuatOleh.CurrentValue.ToString();
    string idUser = CurrentUserInfo("IdUser").ToString();
    bool enable = true;
    Dictionary<string, object> viewData = new Dictionary<string, object>();
    string sqlQuery = @"
        SELECT
            CONCAT(p.PosisiAwal, ' - ', mpAwal.NamaPosition) AS PosisiAwal,
            CONCAT(p.PosisiPJS, ' - ', mpPjs.NamaPosition) AS PosisiPJS,
            mpPjs.Role
        FROM SetPjs p
        JOIN MasterPosition mpAwal ON p.PosisiAwal = mpAwal.IdPosition
        JOIN MasterPosition mpPjs ON p.PosisiPJS = mpPjs.IdPosition
        WHERE p.Id = @Id;
    ";
    using (SqlConnection sqlConnection = GetConnection("Db").OpenConnection()) {
        using (SqlCommand command = new SqlCommand(sqlQuery, sqlConnection)) {
            command.Parameters.AddWithValue("@Id", id);
            using (SqlDataReader rs = command.ExecuteReader()) {
                while (rs.Read()) {
                    for (int i = 0; i < rs.FieldCount; i++) {
                        viewData[rs.GetName(i)] = rs[i] != null? rs[i] : "";
                    }
                }
            }
        }
        int posisiPjs = Convert.ToInt32(setPjsView.PosisiPJS.CurrentValue);
        int pjsRole = viewData["Role"] != null ? Convert.ToInt32(viewData["Role"]) : 0;
        int currentUserLevel = CurrentUserLevel() != null ? Convert.ToInt32(CurrentUserLevel()) : 0;
        int currentRole = CurrentUserInfo("Rule") != null ? Convert.ToInt32(CurrentUserInfo("Rule")) : 0;
        int currentUserPositionId = CurrentUserInfo("IdPosition") != null ? Convert.ToInt32(CurrentUserInfo("IdPosition")) : 0;
        switch (pjsRole)
        {
            case 15:
                if (currentUserLevel != -1)
                {
                    enable = false;
                }
                break;
            case 14:
                if (currentUserLevel != -1 && currentRole != 15)
                {
                    enable = false;
                }
                break;
            case 10:
                if (currentUserLevel != -1 && currentRole != 14)
                {
                    enable = false;
                }
                bool isSameRegion = false;
                sqlQuery = @"
                    SELECT 1
                    FROM MappingPosition mpPjs
                    INNER JOIN MappingPosition mpApprover
                        ON mpPjs.IdRegion = mpApprover.IdRegion
                    WHERE mpPjs.IdPosition = @PjsPosition
                    AND mpApprover.IdPosition = @ApproverPosition
                ";
                using (SqlCommand cmd = new SqlCommand(sqlQuery, sqlConnection))
                {
                    cmd.Parameters.Add("@PjsPosition", SqlDbType.Int).Value = posisiPjs;
                    cmd.Parameters.Add("@ApproverPosition", SqlDbType.Int).Value = currentUserPositionId;
                    var result = cmd.ExecuteScalar();
                    isSameRegion = result != null;
                }
                if (currentUserLevel != -1 && !isSameRegion)
                {
                    enable = false;
                }
                break;
            default:
                if (currentUserLevel != -1 && currentRole != 10)
                {
                    enable = false;
                }
                bool isSamePlant = false;
                sqlQuery = @"
                    SELECT 1
                    FROM MappingPosition mpPjs
                    INNER JOIN MappingPosition mpApprover
                        ON mpPjs.IdPlant = mpApprover.IdPlant
                    WHERE mpPjs.IdPosition = @PjsPosition
                    AND mpApprover.IdPosition = @ApproverPosition
                ";
                using (SqlCommand cmd = new SqlCommand(sqlQuery, sqlConnection))
                {
                    cmd.Parameters.Add("@PjsPosition", SqlDbType.Int).Value = posisiPjs;
                    cmd.Parameters.Add("@ApproverPosition", SqlDbType.Int).Value = currentUserPositionId;
                    var result = cmd.ExecuteScalar();
                    isSamePlant = result != null;
                }
                if (currentUserLevel != -1 && !isSamePlant)
                {
                    enable = false;
                }
                break;
        }
    }
}
<style>
    .stepper {
        display: flex;
        counter-reset: step;
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 8px;
    }
    .stepper::-webkit-scrollbar {
        height: 6px; /* tipis */
    }
    .stepper::-webkit-scrollbar-thumb {
        background-color: #ccc;
        border-radius: 3px;
    }
    .step {
        width: 150px;
        text-align: center;
        position: relative;
    }
    .step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 20px;
        right: -50%;
        width: 100%;
        height: 4px;
        background-color: #ccc;
        z-index: 0;
    }
    .step.completed:not(:last-child)::after {
        background-color: #3c6dbd;
    }
    .step-icon {
        width: 36px;
        height: 36px;
        line-height: 36px;
        border-radius: 50%;
        background: #ccc;
        display: inline-block;
        z-index: 1;
        position: relative;
        color: white;
        font-weight: bold;
    }
    .step.active .step-icon {
        background: #3c6dbd;
    }
    .step-label {
        margin-top: 8px;
        font-size: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        color: #333;
    }
    .step-label {
        color: #3c6dbd !important;
        text-decoration: none;
        margin: 0;
        padding: 0;
    }
    .step-label-not-active {
        color: #CCCCCC !important;
    }
    .ew-buttons {
        display: none;
    }
    .view-page-table td {
        white-space: normal !important;
        word-wrap: break-word;
    }
    .view-page-table th {
        background-color: #006BB7;
    }
    .body-table {
        background-color: #fff;
    }
    .header-table {
        background-color: #006BB7 !important;
        color: #fff !important;
    }
    .view-page-table {
        table-layout: fixed;
    }
    .btn {
        white-space: nowrap;
    }
    .file-input-wrapper {
        border: 1px solid #ced4da;
        border-radius: .375rem;
        overflow: hidden;
        transition: border-color .15s, box-shadow .15s;
    }
    .file-input-wrapper:focus-within {
        border-color: #86b7fe;
        box-shadow: 0 0 0 .25rem rgba(13,110,253,.25);
    }
    .file-input-wrapper .btn {
        border-radius: 0;
    }
    .file-input-wrapper .form-control {
        border: none;
        box-shadow: none !important;
    }
    #el_SetPjs_OrganizationLevel,
    #el_SetPjs_Region,
    #el_SetPjs_Plant,
    #el_SetPjs_LookupPosition,
    #el_SetPjs_TanggalMulai,
    #el_SetPjs_TanggalSelesai,
    #el_SetPjs_Keterangan {
        width: 100%;
    }
    .status-approved {
        background-color: #baffc9 !important;
        color: #155724;
    }
    .status-requested {
        background-color: #a3e0f7 !important;
        color: #0c5460;
    }
    .status-canceled {
        background-color: #e2e3e5 !important;
        color: #41464b;
    }
    .btn-toolbar {
        display: none;
    }
    .ag-theme-quartz .ag-header {
        background-color: #006BB7 !important;
    }
    .ag-theme-quartz .ag-header-cell-label {
        color: #ffffff !important;
    }
    .ag-theme-quartz .ag-icon-filter {
        color: #ffffff !important;
    }
    .rotate-down {
        transform: rotate(90deg);
        transition: transform 0.3s ease;
    }
    .rotate-right {
        transform: rotate(0deg);
        transition: transform 0.3s ease;
    }
</style>
