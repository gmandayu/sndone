loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenyimpananSampleadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["JenisSample", [fields.JenisSample.visible && fields.JenisSample.required ? ew.Validators.required(fields.JenisSample.caption) : null], fields.JenisSample.isInvalid],
            ["IdPlant", [fields.IdPlant.visible && fields.IdPlant.required ? ew.Validators.required(fields.IdPlant.caption) : null], fields.IdPlant.isInvalid],
            ["Tanggal", [fields.Tanggal.visible && fields.Tanggal.required ? ew.Validators.required(fields.Tanggal.caption) : null, ew.Validators.datetime(fields.Tanggal.clientFormatPattern)], fields.Tanggal.isInvalid],
            ["NamaMasterSample", [fields.NamaMasterSample.visible && fields.NamaMasterSample.required ? ew.Validators.required(fields.NamaMasterSample.caption) : null], fields.NamaMasterSample.isInvalid],
            ["NomorSegel", [fields.NomorSegel.visible && fields.NomorSegel.required ? ew.Validators.required(fields.NomorSegel.caption) : null], fields.NomorSegel.isInvalid],
            ["Foto", [fields.Foto.visible && fields.Foto.required ? ew.Validators.required(fields.Foto.caption) : null], fields.Foto.isInvalid],
            ["ExpiredEst", [fields.ExpiredEst.visible && fields.ExpiredEst.required ? ew.Validators.required(fields.ExpiredEst.caption) : null, ew.Validators.datetime(fields.ExpiredEst.clientFormatPattern)], fields.ExpiredEst.isInvalid]
        ])

        // Form_CustomValidate
        .setCustomValidate(
            function(fobj) { // DO NOT CHANGE THIS LINE!
                    // Your custom validation code here, return false if invalid.
                    return true;
                }
        )

        // Use JavaScript validation or not
        .setValidateRequired(ew.CLIENT_VALIDATE)

        // Dynamic selection lists
        .setLists({
            "JenisSample": @Html.Raw(penyimpananSampleAdd.JenisSample.ToClientList(penyimpananSampleAdd)),
            "IdPlant": @Html.Raw(penyimpananSampleAdd.IdPlant.ToClientList(penyimpananSampleAdd)),
        })
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
