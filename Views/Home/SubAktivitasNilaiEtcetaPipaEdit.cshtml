    $(document).ready(function() {
        $(".input-numeric")
            .attr('inputmode', 'numeric')
            .on('input', function () {
                let val = $(this).val();
                let isNegative = val.startsWith('-');
                val = val.replace(',', '.');
                val = val.replace(/[^0-9.]/g, '');
                const parts = val.split('.');
                if (parts.length > 2) {
                    val = parts[0] + '.' + parts.slice(1).join('');
                }
                if (isNegative) {
                    val = '-' + val;
                }
                $(this).val(val);
            });
    });
</script></div>
