}
<div class="ew-list-other-options">
@templateAktivitasList.OtherOptions.RenderBody("bottom")
</div>
</div>
}
</div><!-- /.ew-grid -->
} else { // Show other options
<div class="ew-list-other-options">
@templateAktivitasList.OtherOptions.ForEach(opt => opt.ButtonClass = "").RenderBody()
</div>
}
</div>
<div id="ew-footer-options">
    @templateAktivitasList.FooterOptions.RenderBody()
</div>
</main>
@templateAktivitasList.ShowPageFooter()
@Html.Raw(GetDebugMessage())
