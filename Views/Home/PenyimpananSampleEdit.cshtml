            ["Status", [fields.Status.visible && fields.Status.required ? ew.Validators.required(fields.Status.caption) : null], fields.Status.isInvalid],
            ["Foto", [fields.Foto.visible && fields.Foto.required ? ew.Validators.required(fields.Foto.caption) : null], fields.Foto.isInvalid],
            ["ExpiredEst", [fields.ExpiredEst.visible && fields.ExpiredEst.required ? ew.Validators.required(fields.ExpiredEst.caption) : null], fields.ExpiredEst.isInvalid],
