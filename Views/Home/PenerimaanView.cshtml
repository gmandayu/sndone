@{
    // View
    View = this;

    // Check action result
    if (penerimaanView.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = penerimaanView.UseLayout ? "_Layout" : "";
}
@if (!penerimaanView.IsExport()) {
<div class="btn-toolbar ew-toolbar">
    @penerimaanView.ExportOptions.RenderBody()
    @penerimaanView.OtherOptions.RenderBody()
</div>
}
@penerimaanView.ShowPageHeader()
@penerimaanView.ShowMessages()
<main class="view">
<form name="fPenerimaanview" id="fPenerimaanview" class="ew-form ew-view-form overlay-wrapper" action="@AppPath(CurrentPageName())" method="post" novalidate autocomplete="off">
@if (!penerimaanView.IsExport()) {
<script>
var currentTable = @Html.Raw(ConvertToJson(penerimaanView.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { Penerimaan: currentTable } });
var currentPageID = ew.PAGE_ID = "view";
var currentForm;
var fPenerimaanview;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fPenerimaanview")
        .setPageId("view")
        .build();
    window[form.id] = form;
    currentForm = form;
    loadjs.done(form.id);
});
</script>
<script>
loadjs.ready("head", function() {
    // Write your client script here, no need to add script tags.
});
</script>
}
@if (CurrentPage?.CheckToken ?? false) {
    <input type="hidden" name="@Config.TokenNameKey" value="@Config.TokenName"><!-- CSRF token name -->
    @Html.AntiForgeryToken()
}
