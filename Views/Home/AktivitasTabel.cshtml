    <div class="modal fade" id="modal-popup" tabindex="-1" aria-labelledby="modal-popupLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-centered">
            <div class="modal-content">
                <form id="form-input-modal" autocomplete="off" novalidate>
                    <div class="modal-header text-white" style="background: #3c6dbd;">
                        <h5 class="modal-title fw-bold" id="modal-popupLabel"></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (currentGuideFields != null && currentGuideFields.Count > 0)
                        {
                            var renderedGuideLabels = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                            <div class="card border-primary shadow-sm mb-3">
                                <div class="card-header bg-primary text-white py-2 px-3">
                                    <strong>Petunjuk Pengisian Data</strong>
                                </div>
                                <div class="card-body py-2 px-3 text-dark">
                                    <p class="mb-2">
                                        Harap perhatikan satuan dan ketelitian saat mengisi parameter berikut:
                                    </p>
                                    <ul class="mb-2 ps-3" style="padding-left: 0;">
                                        @foreach (var field in currentGuideFields)
                                        {

                                            Console.WriteLine("Field: " + field);
                                            var fieldLabel = GetFieldLabel(field);
                                            var fieldUnit = GetFieldUnit(field, (IdTemplateAktivitas == "388" ? "RTW" : TipeProduk));
                                            if (!renderedGuideLabels.Add(fieldLabel))
                                            {
                                                continue;
                                            }
                                            <li class="mb-1">
                                                <strong>@fieldLabel</strong>
                                                @if (!string.IsNullOrEmpty(fieldUnit))
                                                {
                                                    <span class="text-muted fw-normal"> — @fieldUnit</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                    <div class="mt-3 border-top border-light">
                                        <p class="mb-0 fst-italic small text-danger">
                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                            Gunakan tanda titik (.) sebagai pemisah desimal.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        }
                        @{
                            // helper ambil value default dari formList (kalau ada)
                            string GetFormValue(string fieldName)
                            {
                                var it = formList?.FirstOrDefault(x => x.Count > 2 && string.Equals(x[2], fieldName, StringComparison.OrdinalIgnoreCase));
                                return (it != null && it.Count > 3) ? (it[3] ?? "") : "";
                            }

                            // helper ambil label
                            string GetFormLabel(string fieldName)
                            {
                                var it = formList?.FirstOrDefault(x => x.Count > 2 && string.Equals(x[2], fieldName, StringComparison.OrdinalIgnoreCase));
                                return (it != null && it.Count > 0) ? (it[0] ?? fieldName) : fieldName;
                            }
                        }
                        @if (IdTemplateAktivitas == "388")
                        {
                            <div id="row_Produk" class="row mb-3">
                                <div class="col-2 fw-bold d-flex align-items-center">@GetFormLabel("Produk")</div>
