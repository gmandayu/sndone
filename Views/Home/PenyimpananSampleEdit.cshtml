<script>
// Field event handlers
loadjs.ready("head", function() {
    ew.addEventHandlers("PenyimpananSample");
});
</script>
<script>
loadjs.ready("load", function() {
    // Startup script
    // Write your table-specific startup script here
    // document.write("page loaded");
    (() => {
        const parentURL = ew.PATH_BASE;
        const showMessage = (msg) => (ew?.alert ? ew.alert(msg) : alert(msg));
        const showLoadingSafe = () => (typeof showLoading === "function" ? showLoading() : null);
        const hideLoadingSafe = () => (typeof hideLoading === 'function' ? hideLoading() : null);
        function getFilenamFromDisposition(disposition) {
            if (!disposition) return "download_file";
            const utf8 = disposition.match(/filename\*\s*=\s*UTF-8''([^;]+)/i);
            if (utf8?.[1]) return decodeURIComponent(utf8[1]);
            const normal = disposition.match(/filename="?([^";]+)"?/i);
            if (normal?.[1]) return decodeURIComponent(normal[1]);
            return "download_file";
        }
        function downloadBlob(blob, fileName) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = fileName || "download_file";
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        }
        const wrap = document.querySelector("#downloadFotoWrap");
        if (!wrap) return;
        const fotoText = document.querySelector("#el_PenyimpananSample_Foto")?.textContent?.trim() || "";
        console.log(fotoText);
        const id = location.pathname.split("/").pop();
        if (fotoText && !/Not Uploaded/i.test(fotoText)) {
            wrap.innerHTML = `
                    <a class="download-document btn btn-primary"
                        data-id="${id}"
                        data-field="Foto">
                        <i class="fas fa-download me-2"></i> Download
                    </a>
                `;
        } else {
            wrap.innerHTML = `<p class="mb-0">Not Uploaded</p>`;
        }
        $(document).on('click', '.download-document', function (e) {
            e.preventDefault();
            const id = $(this).data('id');
            const type = ($(this).data('type') || 'psm').toString().trim().toLowerCase();
            if(!id) return ew.alert('ID dokumen tidak ditemukan.');
            if(!type) return ew.alert('Type tidak ditemukan.');
            $.ajax({
                url: `${parentURL}api/qq/download?id=${encodeURIComponent(id)}&type=${encodeURIComponent(type)}`,
                method: 'GET',
                xhrFields: { responseType: 'blob' },
                beforeSend: showLoadingSafe,
                success: async (blob, _status, xhr) => {
                    const ct = (xhr.getResponseHeader('Content-Type') || '').toLowerCase();
                    if (ct.includes('application/json')) {
                        const obj = await blobToJson(blob);
                        return showMessage(obj.message || 'Gagal download.');
                    }
                    const cd = xhr.getResponseHeader('Content-Disposition');
                    const fileName = getFilenamFromDisposition(cd);
                    downloadBlob(blob, fileName);
                    showMessage('Download berhasil!');
                },
                error: async xhr => {
                    try {
                        const blob = xhr.response;
                        if (blob instanceof Blob) {
                            const obj = await blobToJson(blob);
                            if (obj?.message) return showMessage(obj.message);
                        }
                    } catch {}
                    console.error(`Gagal mengunduh file. (${xhr.status} ${xhr.statusText})`);
                    return showMessage('Gagal mengunduh file.');
                },
                complete: hideLoadingSafe,
            });
        });
        const handleToast = (el) => {
            const msg = el.querySelector(".toast-body")?.innerText?.trim();
            if (!msg) return;
            el.remove();
            (window.ew?.alert ?? alert)(msg);
        };
        const scan = (root = document) => root.querySelectorAll(".toast.text-bg-danger.show, .toast.text-bg-danger.fade.show").forEach(handleToast);
        scan();
        new MutationObserver((m) => m.forEach((x) => x.addedNodes.forEach((n) => n instanceof Element && scan(n)))).observe(document.body, { childList: true, subtree: true });
        const apply = () => {
            const saveBtn = document.querySelector("#btn-action");
            const cancelBtn = document.querySelector("#btn-cancel");
            if (!saveBtn || !cancelBtn) return false;
            const status = document.querySelector("#x_Status")?.value?.trim() || "";
            if (!saveBtn.dataset.iconized) {
                saveBtn.insertAdjacentHTML("afterbegin", '<i class="fas fa-save me-2"></i>');
                saveBtn.dataset.iconized = "1";
            }
            if (!cancelBtn.dataset.iconized) {
                cancelBtn.insertAdjacentHTML("afterbegin", '<i class="fas fa-ban me-2"></i>');
                cancelBtn.dataset.iconized = "1";
            }
            if (status === "Dimusnahkan") {
                saveBtn.remove();
            }
            return true;
        };
        if (apply()) return;
        const obs = new MutationObserver(() => {
            if (apply()) obs.disconnect();
        });
        obs.observe(document.body, { childList: true, subtree: true });
    })();
});
</script>
