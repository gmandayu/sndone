@{
    // View
    View = this;

    // Check action result
    if (bukuTamuAdd.ActionResult is EmptyResult) // Terminate page
        return;

    // Layout
    Layout = bukuTamuAdd.UseLayout ? "_Layout" : "";
}
<script>
var currentTable = @Html.Raw(ConvertToJson(bukuTamuAdd.ToClientVar()));
ew.deepAssign(ew.vars, { tables: { BukuTamu: currentTable } });
var currentPageID = ew.PAGE_ID = "add";
var currentForm;
var fBukuTamuadd;
loadjs.ready(["wrapper", "head"], function () {
    let $ = jQuery;
    let fields = currentTable.fields;

    // Form object
    let form = new ew.FormBuilder()
        .setId("fBukuTamuadd")
        .setPageId("add")

        // Add fields
        .setFields([

            ["LookupPlant", [fields.LookupPlant.visible && fields.LookupPlant.required ? ew.Validators.required(fields.LookupPlant.caption) : null], fields.LookupPlant.isInvalid],
            ["Plant", [fields.Plant.visible && fields.Plant.required ? ew.Validators.required(fields.Plant.caption) : null], fields.Plant.isInvalid],
            ["Tanggal", [fields.Tanggal.visible && fields.Tanggal.required ? ew.Validators.required(fields.Tanggal.caption) : null, ew.Validators.datetime(fields.Tanggal.clientFormatPattern)], fields.Tanggal.isInvalid],
            ["StatusZona", [fields.StatusZona.visible && fields.StatusZona.required ? ew.Validators.required(fields.StatusZona.caption) : null], fields.StatusZona.isInvalid],
            ["Nama", [fields.Nama.visible && fields.Nama.required ? ew.Validators.required(fields.Nama.caption) : null], fields.Nama.isInvalid],
            ["AsalPerusahaan", [fields.AsalPerusahaan.visible && fields.AsalPerusahaan.required ? ew.Validators.required(fields.AsalPerusahaan.caption) : null], fields.AsalPerusahaan.isInvalid],
            ["Jabatan", [fields.Jabatan.visible && fields.Jabatan.required ? ew.Validators.required(fields.Jabatan.caption) : null], fields.Jabatan.isInvalid],
            ["FungsiygDikunjungi", [fields.FungsiygDikunjungi.visible && fields.FungsiygDikunjungi.required ? ew.Validators.required(fields.FungsiygDikunjungi.caption) : null], fields.FungsiygDikunjungi.isInvalid],
            ["MaksudKunjungan", [fields.MaksudKunjungan.visible && fields.MaksudKunjungan.required ? ew.Validators.required(fields.MaksudKunjungan.caption) : null], fields.MaksudKunjungan.isInvalid],
            ["TandaPengenal", [fields.TandaPengenal.visible && fields.TandaPengenal.required ? ew.Validators.required(fields.TandaPengenal.caption) : null], fields.TandaPengenal.isInvalid],
            ["TandaTangan", [fields.TandaTangan.visible && fields.TandaTangan.required ? ew.Validators.required(fields.TandaTangan.caption) : null], fields.TandaTangan.isInvalid],
            ["TandaTanganDownload", [fields.TandaTanganDownload.visible && fields.TandaTanganDownload.required ? ew.Validators.required(fields.TandaTanganDownload.caption) : null], fields.TandaTanganDownload.isInvalid],
            ["Keterangan", [fields.Keterangan.visible && fields.Keterangan.required ? ew.Validators.required(fields.Keterangan.caption) : null], fields.Keterangan.isInvalid],
            ["PintuUtamaId", [fields.PintuUtamaId.visible && fields.PintuUtamaId.required ? ew.Validators.required(fields.PintuUtamaId.caption) : null, ew.Validators.integer], fields.PintuUtamaId.isInvalid],
            ["PintuUtamaInTanggal", [fields.PintuUtamaInTanggal.visible && fields.PintuUtamaInTanggal.required ? ew.Validators.required(fields.PintuUtamaInTanggal.caption) : null, ew.Validators.datetime(fields.PintuUtamaInTanggal.clientFormatPattern)], fields.PintuUtamaInTanggal.isInvalid],
            ["PintuUtamaInFoto", [fields.PintuUtamaInFoto.visible && fields.PintuUtamaInFoto.required ? ew.Validators.required(fields.PintuUtamaInFoto.caption) : null], fields.PintuUtamaInFoto.isInvalid],
