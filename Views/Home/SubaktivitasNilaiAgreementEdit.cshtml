} else {
    <button class="btn btn-default ew-btn" name="btn-cancel" id="btn-cancel" type="button" form="fSubaktivitasNilaiAgreementedit" data-href="@AppPath(subaktivitasNilaiAgreementEdit.ReturnUrl)">@Html.Raw(Language.Phrase("CancelBtn"))</button>
}
    </div><!-- /buttons offset -->
@Html.Raw(subaktivitasNilaiAgreementEdit.IsModal ? "</template>" : "</div>")<!-- /buttons .row -->
